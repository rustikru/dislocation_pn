function get_periods
return t_xx_period_table pipelined
as
    l_row               t_xx_period_row;
    l_period_cl_row     t_xx_period_closing_row;
    l_json_tmp          json;
    l_json_list         json_list;
    --
    cursor c_period_cl (p_period_id number) is
        select * 
          from table(xx_dislocation.get_period_closing(p_period_id));
begin
    for l_tmp in (
        select acct_period_id
              ,period_name
              ,period_num
              ,period_year
              ,period_start_date
              ,schedule_close_date
          from inv.org_acct_periods             
         where 1=1
           and organization_id = 81
           and period_start_date >= to_date('01.01.2018','dd.mm.yyyy')
         order by
               period_year desc
              ,period_start_date desc)
    loop
        l_row.per_id := l_tmp.acct_period_id;
        l_row.period := l_tmp.period_name;
        l_row.per_month := l_tmp.period_num;
        l_row.per_year := l_tmp.period_year;
        l_row.per_from := to_char(l_tmp.period_start_date,'dd.mm.yyyy');
        l_row.per_to := to_char(l_tmp.schedule_close_date,'dd.mm.yyyy');
        l_json_list := json_list(); 
        for l_period_c in c_period_cl(l_row.per_id)
        loop
            l_period_cl_row.operation_id := l_period_c.operation_id;
            l_period_cl_row.operation_desc := l_period_c.operation_desc;
            l_period_cl_row.status_id := l_period_c.status_id;
            l_period_cl_row.status_descr := l_period_c.status_descr;
            l_period_cl_row.last_update_by := l_period_c.last_update_by;
            l_period_cl_row.last_update_date := l_period_c.last_update_date;
            
            l_json_tmp := json();
            l_json_tmp.put('operation_id',l_period_cl_row.operation_id);
            l_json_tmp.put('operation_desc',l_period_cl_row.operation_desc);
            l_json_tmp.put('status_id',l_period_cl_row.status_id);
            l_json_tmp.put('status_descr',l_period_cl_row.status_descr);
            l_json_tmp.put('last_update_by',l_period_cl_row.last_update_by);
            l_json_tmp.put('last_update_date',l_period_cl_row.last_update_date);
            
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        l_row.period_closing := l_json_list.to_char(false); -- Прооба
        pipe row (l_row);
    end loop;
end;

function get_period_closing(p_period_id number)
return t_xx_period_closing_table pipelined
as
    l_row       t_xx_period_closing_row;
begin
    for l_close_status in (
        select po.id
              ,po.descr
              ,nvl(pc.status_id,1)      status_id
              ,(select status_descr
                  from xx_etw.xx_disl_period_status ps
                 where ps.status_id = nvl(pc.status_id,1))
                                        status_descr
              ,(select full_name
                  from xx_etw.xx_disl_users
                 where id = pc.last_update_by)
                                        last_update_by
              ,pc.last_update_date
          from xx_etw.xx_disl_period_operations po
              ,(select *
                  from xx_etw.xx_disl_period_closing    pc
                 where pc.period_id = p_period_id)
                                                pc
         where 1=1
           and po.id = pc.operation_id(+)
         order by
               po.id desc
    ) loop
        l_row.operation_id := l_close_status.id; 
        l_row.operation_desc := l_close_status.descr; 
        l_row.status_id := l_close_status.status_id; 
        l_row.status_descr := l_close_status.status_descr; 
        l_row.last_update_by := l_close_status.last_update_by; 
        l_row.last_update_date := to_char(l_close_status.last_update_date,'dd.mm.yyyy'); 
        
        pipe row (l_row);   
    end loop;
end;

function save_period_status(    
    p_period_id     number,
    p_oper_id       number,
    p_status_id     number,
    p_user_id       number
) return varchar2
as
begin
    update xx_etw.xx_disl_period_closing
       set status_id = p_status_id
          ,last_update_by = p_user_id
          ,last_update_date = sysdate
     where 1=1
       and period_id = p_period_id
       and operation_id = p_oper_id;
       
    if (sql%rowcount = 0) then
        insert into xx_etw.xx_disl_period_closing
        values (p_period_id,p_oper_id,p_status_id,p_user_id,sysdate);
    end if;
    
    commit;
    return 'done'||'$'||to_char(sysdate,'dd.mm.yyyy');   
exception
    when others then rollback; return 'fail';
end;

function check_open_period(    
    p_oper_id       number,
    p_date          varchar2
) return varchar2
as
    l_count     number;
    l_date      date;
    l_result    varchar2(10);
    l_log_id    number := xx_etw.xx_disl_log_seq.nextval();
    l_function  varchar2(240):= 'check_open_period';
begin
    log_new(l_log_id,l_function,' p_oper_id = '||p_oper_id);
    log_new(l_log_id,l_function,' p_date = '||p_date);
    l_count := regexp_count(p_date,':');      
    
    if (l_count = 1) then 
        l_date := to_date(p_date,'dd.mm.yyyy hh24:mi'); 
    else
        l_date := to_date(p_date,'dd.mm.yyyy hh24:mi:ss'); 
    end if;
    
    begin   
        select '1'
          into l_result
          from inv.org_acct_periods             oap
              ,(select *
                  from xx_etw.xx_disl_period_closing    pc
                 where 1=1
                   and nvl(pc.operation_id,p_oper_id) = p_oper_id
                   and nvl(pc.status_id,1) = 1)
                                                pc
         where 1=1
           and organization_id = 81
           and oap.period_start_date >= to_date('01.01.2018','dd.mm.yyyy')
           and trunc(l_date) between oap.period_start_date and oap.schedule_close_date 
           and oap.acct_period_id = pc.period_id(+);
    exception
        when no_data_found then l_result := '0';  
    end;
    log_new(l_log_id,l_function,' l_result = '||l_result);
    return l_result;  
exception
    when others then 
    log_new(l_log_id,l_function,' Error = '||sqlerrm);
    return '0';    
end;

-- проверка дата (в открытом периоде или нет)
function OpenPeriodCheck (p_org_id number, p_date date) return varchar
is
    l_open_flag varchar2(10);
begin
    -- [Запасы] -> Цикл закрытия периода -> Период учета запасов
    select   decode(open_flag,'Y','O' -- Открыт
                         ,'N','C' -- Закрыт
               ) as open_flag
      into   l_open_flag
      from   inv.org_acct_periods oap
     where       1 = 1
             and organization_id = p_org_id
             and oap.period_start_date >= to_date ('01.01.2018', 'dd.mm.yyyy')
             and trunc(p_date) between oap.period_start_date and oap.schedule_close_date;
    return l_open_flag;
exception
    when others then return 'C';    
end;
