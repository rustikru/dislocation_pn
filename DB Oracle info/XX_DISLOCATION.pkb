function get_railways_for_request(p_station_id number)
return t_xx_railway_for_request_table pipelined
as
    l_row                       t_xx_railway_for_request_row;
begin
    for tmp in (select  tree.id
                       ,tree.type
                       ,nm_v.name
                       ,level lvl
                  from  xx_etw.xx_disl_relations           tree
                       ,xx_etw.xx_disl_union_name_v        nm_v
                 where     1=1
                       and tree.id = nm_v.id
                       and tree.type = nm_v.type
                       and tree.type = 'railway'  
               connect by  
                       tree.parent_id = prior tree.id
                   and tree.parent_type = prior tree.type
                 start with 
                       tree.parent_id = p_station_id
                   and tree.parent_type = 'station'
                 order siblings by tree.r_order  
               )
    loop
        l_row.id := tmp.id;
        l_row.name := tmp.name;
        l_row.type := tmp.type;
        l_row.lvl := tmp.lvl;
        
        if (tmp.type = 'railway') then
            select nvl(disabled,'N')
              into l_row.disabled
              from xx_etw.xx_disl_railways
             where 1=1
               and railway_id = tmp.id        
            ;
        end if;
        
        pipe row (l_row);
    end loop;
end;
