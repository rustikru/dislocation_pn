--        l_row.cnt_skid := l_json.get_string('cnt_skid');
--        l_row.cnt_axis_1 := l_json.get_string('cnt_axis_1');
--        l_row.cnt_axis_2 := l_json.get_string('cnt_axis_2');
--        
--        l_row.created_by := p_user_id;
--        l_row.creation_date := sysdate;
--        l_row.last_updated_by := p_user_id;
--        l_row.last_update_date := sysdate;
--        l_row.deleted := 'N';

--        insert into xx_etw.xx_disl_railway_part  
--        values l_row;
--    else
--        update xx_etw.xx_disl_railway_part 
--           set railway_id = l_json.get_string('railway_id')
--              ,descr = l_json.get_string('part_id')
--              ,side = l_json.get_string('side')
--              ,cnt_skid = l_json.get_string('cnt_skid')
--              ,cnt_axis_1 = l_json.get_string('cnt_axis_1')
--              ,cnt_axis_2 = l_json.get_string('cnt_axis_2')
