function get_cars_from_shop(
    p_user_id       number,
    p_return_type   number,/*0 - возвращаем цистерны и контейнера, 1 - только платформы*/
    p_loading_subs  varchar2 default ''
    )
return t_xx_car_from_shop_table pipelined
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100) := 'get_cars_from_shop';
    --
    l_row                   t_xx_car_from_shop_row;
    l_user_div              number;
    l_user_adm              varchar2(1);
    l_loading_id            number;
    
begin
    log_new(l_log_id,l_function,'p_user_id: ' || p_user_id);
    log_new(l_log_id,l_function,'p_return_type: ' || p_return_type);
    log_new(l_log_id,l_function,'p_loading_subs: ' || p_loading_subs);
    
    l_loading_id := xx_etw.xx_dislocation.get_un_loading_type(nvl(p_loading_subs,'*'));
    log_new(l_log_id,l_function,'l_loading_id: ' || l_loading_id);
    
    -- add 28.11.2024 Нужно переписать
    /*select max(nvl(administrator,'N'))             administrator
      into l_user_adm
      from xx_disl_user_credential uc
          ,xx_disl_credential      c
     where 1=1
       and uc.user_id = p_user_id
       and uc.credential_id = c.credential_id(+)
    ;*/
    -- add 28.11.2024
    l_user_adm := get_user_cred_rights_val(p_user_id => p_user_id, p_rights_code => 'administrator');
    
    begin
        select division_id
          into l_user_div
          from xx_etw.xx_disl_user_div_hist ud
         where 1=1
           and ud.user_id = p_user_id
           and ud.end_date is null
        ;     
    exception
        when no_data_found then l_user_div:=-1;
    end;
    log_new(l_log_id,l_function,'l_user_adm: ' || l_user_adm);
    log_new(l_log_id,l_function,'l_user_div: ' || l_user_div);
    
    for l_tmp in ( 
        select si.*
        from (
        select dense_rank() over (order by si.date_post,si.date_start,si.date_end,si.date_zayavka_uvod,si.date_uvod,si.who_looked,si.who_start,si.who_end,si.who_zayavka,us.full_name) id
              ,to_char(si.date_post,'dd.mm.yyyy hh24:mi')                  date_post
              ,to_char(si.date_start,'dd.mm.yyyy hh24:mi')              date_start
              ,to_char(si.date_end,'dd.mm.yyyy hh24:mi')                date_end
              ,to_char(si.date_zayavka_uvod,'dd.mm.yyyy hh24:mi')       date_zayavka_uvod
              ,to_char(si.date_uvod,'dd.mm.yyyy hh24:mi')               date_uvod
              ,si.who_looked
              ,si.who_start
              ,si.who_end
              ,si.who_zayavka
              ,si.car_number
              ,si.cont_number
              ,si.refusal
              ,si.shop_info_id
              ,us.full_name              created_by
              ,si.accepted_weight
              ,si.define_task
              ,si.define_comment
              ,xx_etw.xx_dislocation.get_shop_not_end_flag(si.shop_info_id,null,null,p_user_id) as get_shop_not_end_flag
              ,si.un_loading_from_subs
              ,si.otgruzka_1c_id
          from (select date_post
                      ,date_start
                      ,date_end
                      ,date_zayavka_uvod
                      ,date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,si.refusal                                             refusal
                      ,r.railcar_id                                           car_number
                      ,null                                                   cont_number
                      ,si.shop_info_id                                        shop_info_id
                      ,si.accepted_weight
                      ,si.define_task
                      ,si.define_comment
                      ,si.un_loading_from_subs
                      ,si.OTGRUZKA_1C_ID
                  from xx_etw.xx_disl_shop_info_v  si
                      ,xx_etw.xx_disl_round      r
                 where 1=1
                   -- Только погрузка/разгрузка
                   and si.round_type = 'railcar'
                   and si.last_record = 'Y'
                   and xx_etw.xx_dislocation.get_railcar_type(r.round_id) = p_return_type
                   and si.round_id = r.round_id
                   and r.station_hist_id_out is null
                   and si.un_loading_from_subs = l_loading_id
                 union all 
                select date_post
                      ,date_start
                      ,date_end
                      ,date_zayavka_uvod
                      ,date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,si.refusal                                             refusal
                      ,r.railcar_id                                           car_number
                      ,null                                                   cont_number
                      ,si.shop_info_id                                        shop_info_id  
                      ,si.accepted_weight
                      ,si.define_task
                      ,si.define_comment
                      ,si.un_loading_from_subs
                      ,null OTGRUZKA_1C_ID
                  from xx_etw.xx_disl_shop_info_loading_v  si
                      ,xx_etw.xx_disl_round      r
                 where 1=1
                   -- Только погрузка/разгрузка при перемещении
                   and si.round_type = 'railcar'
                   and si.last_record = 'Y'
                  
                   and xx_etw.xx_dislocation.get_railcar_type(r.round_id) = p_return_type
                   and si.round_id = r.round_id
                   and r.station_hist_id_out is null
                   and si.UN_LOADING_FROM_SUBS = l_loading_id
                union all
                select date_post
                      ,date_start
                      ,date_end
                      ,date_zayavka_uvod
                      ,date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,si.refusal                                             refusal
                      ,r.railcar_id                                           car_number
                      ,cr.cont_number                                         cont_number
                      ,si.shop_info_id                                        shop_info_id
                      ,si.accepted_weight
                      ,si.define_task
                      ,si.define_comment
                      ,si.un_loading_from_subs
                      ,si.OTGRUZKA_1C_ID
                  from xx_etw.xx_disl_shop_info_v             si
                      ,xx_etw.xx_disl_cont_round            cr
                      ,(select *
                          from xx_etw.xx_disl_cont_history_cur
                         where 1=1
                           and place_type = 'railcar'
                       )      
                                                            chc
                      ,xx_etw.xx_disl_round                 r
                 where 1=1
                   and p_return_type = 0
                   and si.round_type = 'cont'
                   
                   and si.round_id = cr.cont_round_id
                   and cr.cont_history_out is null
                   
                   and cr.cont_round_id = chc.cont_round_id(+)
                    and si.last_record = 'Y'
                   and chc.place_id = r.round_id(+)
                   and r.station_hist_id_out is null
                   and si.UN_LOADING_FROM_SUBS = l_loading_id
               )
                                            si
              ,xx_etw.xx_disl_users         us
         where 1=1
--           and si.refusal is null
--           and (   date_post is null
--                or date_end is null
--                or date_zayavka_uvod is null
--                or date_uvod is null
--                or (    si.weight_net = si.weight_net_begin         
--                    and si.last_update_by != -1
--                    and si.created_by != -1
--                    and p_return_type = 0 -- для платформ вес груза не запоняется
--                   )  
--               )
         
           and si.created_by = us.id
                     
           and (   si.created_by = p_user_id
                or l_user_adm = 'Y'
                or (l_loading_id = 1 and si.created_by = 1)
                or (l_user_div in (1,3) and si.created_by = -1) -- add 03.03.2022 Подраздления: Метанол и КФК могут видеть записи, которые создались автоматически
                or exists(
                    select 'x'
                      from xx_etw.xx_disl_user_div_hist ud
                     where 1=1
                       and ud.user_id = si.created_by
                       and si.creation_date between nvl(ud.start_date,to_date('01.01.2016','dd.mm.yyyy')) and nvl(ud.end_date,to_date('31.12.2999','dd.mm.yyyy'))
                       and ud.division_id = l_user_div
                   )
               ))si
               where get_shop_not_end_flag = 'Y'
         order by si.date_post desc,si.date_start,si.date_end,si.date_zayavka_uvod,si.date_uvod,si.who_looked,si.who_start,si.who_end,si.who_zayavka,si.created_by,si.car_number,si.cont_number
               ) 
    loop
        --log_new(l_log_id,l_function,'l_tmp.id='||l_tmp.id||' car_number='||l_tmp.car_number);
        l_row.id := l_tmp.id;
        l_row.date_post := l_tmp.date_post;
        l_row.date_start := l_tmp.date_start;
        l_row.date_end := l_tmp.date_end;
        l_row.date_zayavka_uvod := l_tmp.date_zayavka_uvod;
        l_row.date_uvod := l_tmp.date_uvod;
        l_row.who_looked := l_tmp.who_looked;
        l_row.who_start := l_tmp.who_start;
        l_row.who_end := l_tmp.who_end;
        l_row.who_zayavka := l_tmp.who_zayavka;
        l_row.created_by := l_tmp.created_by;
        l_row.car_number := l_tmp.car_number;
        l_row.cont_number := l_tmp.cont_number;
        l_row.refusal := l_tmp.refusal;
        l_row.shop_info_id := l_tmp.shop_info_id;
        
        l_row.accepted_weight := l_tmp.accepted_weight;
        l_row.define_task := l_tmp.define_task;
        l_row.define_comment := l_tmp.define_comment;
        l_row.otgruzka_1c_id := l_tmp.otgruzka_1c_id;
        
        if (l_tmp.cont_number is null) then
            select rai.freight_name
                  ,nvl(rai.weight_net,0)
                  ,nvl(rai.weight_dep,0)
                  ,nvl(rai.weight_net,0) + nvl(rai.weight_dep,0)
              into l_row.freight_name,l_row.weight_net,l_row.weight_dep,l_row.weight_gross
              from xx_etw.xx_disl_railcar_add_info          rai
             where 1=1
               and rai.round_id = returnLastRound(l_tmp.car_number)
               and rai.last_record = 'Y'
            ;
            
            select min(weight_net)keep (dense_rank last order by add_info_id)
              into l_row.arrive_weight_net
              from xx_etw.xx_disl_railcar_add_info         info
             where 1=1
               and info.round_id = returnLastRound(l_tmp.car_number)
               and info.add_info_type = 'A'
            ;
            begin
                select nsi.car_tonnage 
                  into l_row.car_tonnage
                  from xx_etw.etw_car_nsi nsi where nsi.CAR_NUMBER = l_tmp.car_number;
            exception when others then 
                l_row.car_tonnage:='';
            end;    
        else
            begin
                select cai.freight_name
                      ,nvl(cai.weight_net,0)
                      ,nvl(cai.weight_dep,0)
                      ,nvl(cai.weight_net,0) + nvl(cai.weight_dep,0)
                  into l_row.freight_name,l_row.weight_net,l_row.weight_dep,l_row.weight_gross
                  from xx_etw.xx_disl_cont_add_info     cai
                 where 1=1                   
                   and cai.cont_round_id = return_last_cont_round(l_tmp.cont_number)
                   and cai.last_record = 'Y'   
                ;
            exception 
                when others then -- add 08.07.2024 BekmansurovRR
                    null; 
            end;
            
            begin
            
                select min(weight_net)keep (dense_rank last order by add_info_id)
                  into l_row.arrive_weight_net
                  from xx_etw.xx_disl_cont_add_info     cai
                 where 1=1
                   and cai.cont_round_id = return_last_cont_round(l_tmp.cont_number)
                   and cai.add_info_type = 'A'
                ;
            exception 
                when others then -- add 08.07.2024 BekmansurovRR
                    null; 
            end;
        end if;

        pipe row (l_row);
    end loop;    
end;

/*p_status: null - пусто, 0 - Не отражен в OEBS, 1 - Отражен в OEBS*/
/*p_type: null - пусто, cont - Контейнерная, railcar - Повагонно*/
function get_cars_from_shop_for_oebs(p_user_id number,p_freight varchar2,p_date_from varchar2,p_date_to varchar2,p_status varchar2,p_type varchar2)
return t_xx_car_from_shop_table pipelined
as
    l_row                   t_xx_car_from_shop_row;
    l_user_adm              varchar2(1); 
    
    l_date_from             date;
    l_date_to               date;
    
    l_user_div              number;
begin
    dbms_output.put_line(  'p_user_id = '||p_user_id
                           ||' p_freight = '||p_freight
                           ||' p_date_from = '||p_date_from
                           ||' p_date_to = '||p_date_to
                           ||' p_status = '||p_status
                           ||' p_type = '||p_type
                           );

    -- add 28.11.2024 Нужно переписать
    /*select max(nvl(administrator,'N'))             administrator
      into l_user_adm
      from xx_etw.xx_disl_user_credential uc
          ,xx_etw.xx_disl_credential      c
     where 1=1
       and uc.user_id = p_user_id
       and uc.credential_id = c.credential_id(+)
    ;*/
     -- add 28.11.2024
    l_user_adm := get_user_cred_rights_val(p_user_id => p_user_id, p_rights_code => 'administrator');
    
    dbms_output.put_line('l_user_adm = '||l_user_adm);
    
    begin
        select division_id
          into l_user_div
          from xx_etw.xx_disl_user_div_hist ud
         where 1=1
           and ud.user_id = p_user_id
           and ud.end_date is null
        ;     
    exception
        when no_data_found then l_user_div:=-1;
    end;
    dbms_output.put_line('l_user_div = '||l_user_div);
    
    l_date_from := to_date(p_date_from,'dd.mm.yyyy hh24:mi');
    l_date_to := to_date(p_date_to,'dd.mm.yyyy hh24:mi');
  
    for l_tmp in ( 
        select dense_rank() over (order by date_post,date_start,date_end,who_looked,who_start,who_end,si.freight_name,si.batch_no) id
              ,si.date_post
              ,si.date_start
              ,si.date_end
              ,si.date_zayavka_uvod
              ,si.date_uvod
              ,si.who_looked
              ,si.who_start
              ,si.who_end
              ,si.who_zayavka
              ,si.who_looked_add
              ,si.who_start_add
              ,si.who_end_add
              ,si.who_zayavka_add
              ,si.car_number
              ,count('x') over (partition by date_post,date_start,date_end,who_looked,who_start,who_end,si.freight_name,si.car_number)  cont_count
              ,si.cont_number
              ,si.freight_name
              ,si.weight_net
              ,si.batch_no
              ,si.refusal
              ,si.shop_info_id
              ,batch_g.product --add 20/06/2020
              ,si.round_id
              ,si.created_by
              ,si.creation_date
              ,si.last_update_by
              ,si.LAST_UPDATE_DATE
          from (select date_post                                              date_post_d
                      ,to_char(date_post,'dd.mm.yy hh24:mi')                  date_post
                      ,to_char(date_start,'dd.mm.yy hh24:mi')                 date_start
                      ,to_char(date_end,'dd.mm.yy hh24:mi')                   date_end
                      ,to_char(date_zayavka_uvod,'dd.mm.yy hh24:mi')          date_zayavka_uvod
                      ,to_char(date_uvod,'dd.mm.yy hh24:mi')                  date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,who_looked                                             who_looked_add
                      ,who_start                                              who_start_add
                      ,who_end                                                who_end_add
                      ,who_zayavka                                            who_zayavka_add
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,freight_name                                           freight_name
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,si.refusal                                             refusal
                      ,r.railcar_id                                           car_number
                      ,null                                                   cont_number
                      ,round_type                                             round_type
                      ,batch_id                                               batch_id
                      ,batch_no                                               batch_no
                      ,si.shop_info_id                                        shop_info_id 
                      ,si.round_id
                      ,si.LAST_UPDATE_DATE
                  from xx_etw.xx_disl_shop_info  si
                      --xx_etw.xx_disl_shop_info_v  si
                      ,xx_etw.xx_disl_round      r
                 where si.round_type = 'railcar'
                   and si.last_record = 'Y'
                   
                   and si.round_id = r.round_id
                   and r.station_hist_id_out is null
                 union all 
                select date_post                                              date_post_d
                      ,to_char(si.date_post,'dd.mm.yy hh24:mi')                  date_post
                      ,to_char(si.date_start,'dd.mm.yy hh24:mi')                 date_start
                      ,to_char(si.date_end,'dd.mm.yy hh24:mi')                   date_end
                      ,to_char(si.date_zayavka_uvod,'dd.mm.yy hh24:mi')          date_zayavka_uvod
                      ,to_char(si.date_uvod,'dd.mm.yy hh24:mi')                  date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,who_looked                                             who_looked_add
                      ,who_start                                              who_start_add
                      ,who_end                                                who_end_add
                      ,who_zayavka                                            who_zayavka_add
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,dcai.freight_name                                      freight_name
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,si.refusal                                             refusal
                      --,r.railcar_id                                           car_number
                      ,(select r.railcar_id
                          from xx_etw.xx_disl_cont_history ch
                              ,xx_etw.xx_disl_round        r
                         where 1=1
                           and ch.cont_round_id = cr.cont_round_id
                           and si.creation_date between ch.in_date_sys and nvl(ch.out_date_sys,sysdate) 
                           
                           and ch.place_id = r.round_id
                       )
                                                                              car_number
                      ,cr.cont_number                                         cont_number
                      ,round_type                                             round_type
                      ,batch_id                                               batch_id
                      ,batch_no                                               batch_no
                      ,si.shop_info_id                                        shop_info_id
                      ,si.round_id
                      ,si.LAST_UPDATE_DATE
                  from xx_etw.xx_disl_shop_info             si
                      ,xx_etw.xx_disl_cont_round            cr
                      ,xx_etw.xx_disl_cont_add_info         dcai              -- add 14.08.2024 BekmansurovRR
--                      ,(select *
--                          from xx_etw.xx_disl_cont_history_cur
--                         where 1=1
--                           and place_type = 'railcar'
--                       )      
--                                                            chc
--                      ,xx_etw.xx_disl_round                 r
                 where si.round_type = 'cont'
                   and si.last_record = 'Y'
                   
                   -- add 14.08.2024 BekmansurovRR
                   and dcai.cont_round_id = cr.cont_round_id
                   and dcai.last_record = 'Y'
                   
                   and si.round_id = cr.cont_round_id
                   and cr.cont_history_out is null
                   
--                   and cr.cont_round_id = chc.cont_round_id(+)
--                   
--                   and chc.place_id = r.round_id(+)
--                   and r.station_hist_id_out is null
               ) si
               , (select msib.segment1 product, gbh.BATCH_ID
                    from gme.gme_batch_header gbh, 
                         gme.gme_material_details gmd,
                         inv.mtl_system_items_b msib
                    where 1=1
                          --and gbh.BATCH_NO = '221757'
                          and gbh.BATCH_ID = gmd.BATCH_ID
                          and gmd.LINE_TYPE = '1' -- продукт
                          and msib.INVENTORY_ITEM_ID = gmd.INVENTORY_ITEM_ID
                          and msib.ORGANIZATION_ID = 362) batch_g -- add 20.06.2020
         where 1=1
           and si.date_post_d between l_date_from and l_date_to
           and si.batch_id = batch_g.batch_id (+) -- add 20.06.2020
           and lower(si.freight_name) = nvl(lower(p_freight),lower(si.freight_name))
           and (   (si.batch_id is null and p_status = 0)
                or (si.batch_id is not null and p_status = 1)
                or (p_status is null)
               )
           and si.round_type = nvl(p_type,si.round_type)
           
           and (   si.created_by = p_user_id
                or l_user_adm = 'Y'
                or exists(
                    select 'x'
                      from xx_etw.xx_disl_user_div_hist ud
                     where 1=1
                       and ud.user_id = si.created_by
                       and si.creation_date between nvl(ud.start_date,to_date('01.01.2016','dd.mm.yyyy')) and nvl(ud.end_date,to_date('31.12.2999','dd.mm.yyyy'))
                       and ud.division_id = l_user_div
                   )
               )
         order by
               date_post,date_start,date_end,who_looked,who_start,who_end,si.freight_name,si.car_number,si.cont_number) 
    loop
        
        l_row.id := l_tmp.id;
        l_row.date_post := l_tmp.date_post;
        l_row.date_start := l_tmp.date_start;
        l_row.date_end := l_tmp.date_end;
        l_row.date_zayavka_uvod := l_tmp.date_zayavka_uvod;
        l_row.date_uvod := l_tmp.date_uvod;
        l_row.who_looked := l_tmp.who_looked;
        l_row.who_start := l_tmp.who_start;
        l_row.who_end := l_tmp.who_end;
        l_row.who_zayavka := l_tmp.who_zayavka;
        l_row.who_looked_add := l_tmp.who_looked_add;
        l_row.who_start_add := l_tmp.who_start_add;
        l_row.who_end_add := l_tmp.who_end_add;
        l_row.who_zayavka_add := l_tmp.who_zayavka_add;
        l_row.car_number := l_tmp.car_number;
        l_row.cont_number := l_tmp.cont_number;
        l_row.freight_name := l_tmp.freight_name;
        l_row.weight_net := l_tmp.weight_net;
        l_row.batch_no := l_tmp.batch_no;
        l_row.refusal := l_tmp.refusal;
        l_row.shop_info_id := l_tmp.shop_info_id;
        l_row.cont_count := l_tmp.cont_count;
        l_row.product := l_tmp.product; --add 20/06/2020
        
        l_row.round_id := l_tmp.round_id; 
        l_row.creation_date := l_tmp.creation_date; 
        l_row.last_update_by := l_tmp.last_update_by;
        l_row.last_update_date := l_tmp.last_update_date;
        l_row.created_by := l_tmp.created_by;
        
        l_row.who_looked_fio := xx_etw.xx_dislocation.get_user_full_name(l_tmp.who_looked);
        l_row.who_start_fio :=xx_etw.xx_dislocation.get_user_full_name(l_tmp.who_start);
        l_row.who_end_fio :=xx_etw.xx_dislocation.get_user_full_name(l_tmp.who_end);
        l_row.who_zayavka_fio :=xx_etw.xx_dislocation.get_user_full_name(l_tmp.who_zayavka);
        begin
            select cn.car_tonnage into l_row.car_tonnage
              from xx_etw.etw_car_nsi cn
             where cn.car_number = l_tmp.car_number;
        exception 
            when others then 
                l_row.car_tonnage := 0;
        end;
        
        pipe row (l_row);
    end loop;    
end;

/*отражение выработки в oebs*/
function create_output_in_oebs(p_user_id number, p_shop_info varchar2)
return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100) := 'create_output_in_oebs';
    
    l_shop_id_mas           xx_etw.xx_disl_table_of_number  := xx_etw.xx_disl_table_of_number();
    prev_dr                 number := 0;
    
    l_freight_oebs          xx_etw.xx_disl_output_in_oebs_t.freight_oebs%type;
    
    l_result                xx_etw.xx_dislocation.t_xx_result; 
    
    l_batchs                varchar2(1000);
begin
    log_new(l_log_id,l_function,'parameters: p_user_id = ' || p_user_id || ' p_shop_info = ' || p_shop_info);
    
    l_result.done := true;
    
    insert into xx_etw.xx_disl_output_in_oebs_t
    select regexp_substr(shop_info,'[^:]+',1,1)     shop_info_id
          ,regexp_substr(shop_info,'[^:]+',1,2)     freight_oebs
      from (select regexp_substr(p_shop_info,'[^|]+',1,level) shop_info
              from dual
            connect by level <= regexp_count(p_shop_info,'[^|]+')
           ) 
    ;
    
    /*группируем погрузки на группы с одинаковыми датами*/
    /*т.к. учет ведется в разрезе вагонов/контейнеров, а выработку нужно создавать по погрузке*/
    for l_shops in ( 
        select dense_rank() over (order by date_post,date_start,date_end,who_looked,who_start,who_end) dr
              ,si.shop_info_id
          from (select to_char(date_post,'dd.mm.yyyy hh24:mi')                date_post
                      ,to_char(date_start,'dd.mm.yyyy hh24:mi')               date_start
                      ,to_char(date_end,'dd.mm.yyyy hh24:mi')                 date_end
                      ,to_char(date_zayavka_uvod,'dd.mm.yyyy hh24:mi')        date_zayavka_uvod
                      ,to_char(date_uvod,'dd.mm.yyyy hh24:mi')                date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,freight_name                                           freight_name
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,si.refusal                                             refusal
                      ,r.railcar_id                                           car_number
                      ,null                                                   cont_number
                      ,si.shop_info_id                                        shop_info_id  
                      ,si.batch_id                                            batch_id
                  from xx_etw.xx_disl_shop_info  si
                      ,xx_etw.xx_disl_round      r
                 where si.round_type = 'railcar'
                   and si.last_record = 'Y'
                   
                   and si.round_id = r.round_id
                   and r.station_hist_id_out is null
                 union all 
                select to_char(si.date_post,'dd.mm.yyyy hh24:mi')                date_post
                      ,to_char(si.date_start,'dd.mm.yyyy hh24:mi')               date_start
                      ,to_char(si.date_end,'dd.mm.yyyy hh24:mi')                 date_end
                      ,to_char(si.date_zayavka_uvod,'dd.mm.yyyy hh24:mi')        date_zayavka_uvod
                      ,to_char(si.date_uvod,'dd.mm.yyyy hh24:mi')                date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,dcai.freight_name                                      freight_name
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,si.refusal                                             refusal
                      ,r.railcar_id                                           car_number
                      ,cr.cont_number                                         cont_number
                      ,si.shop_info_id                                        shop_info_id
                      ,si.batch_id                                            batch_id
                  from xx_etw.xx_disl_shop_info             si
                      ,xx_etw.xx_disl_cont_round            cr
                      ,xx_etw.xx_disl_cont_add_info         dcai -- add 14.08.2024 
                      ,(select *
                          from xx_etw.xx_disl_cont_history_cur
                         where 1=1
                           and place_type = 'railcar'
                       )      
                                                            chc
                      ,xx_etw.xx_disl_round                 r
                 where si.round_type = 'cont'
                   and si.last_record = 'Y'
                   -- add 14.08.2024 
                   and dcai.cont_round_id = cr.cont_round_id
                   and dcai.last_record = 'Y'
                   
                   and si.round_id = cr.cont_round_id
                   and cr.cont_history_out is null
                   
                   and cr.cont_round_id = chc.cont_round_id(+)
                   
                   and chc.place_id = r.round_id(+)
                   and r.station_hist_id_out is null
               )
                                            si
         where 1=1
           and si.refusal is null
           and si.date_post is not null
           and si.date_start is not null
           and si.date_end is not null
           and si.who_looked is not null
           and si.who_start is not null
           
           
           --and si.cont_number is not null
           and ((si.freight_name in ('КФК','Формалин','Метанол') and si.cont_number is not null and si.who_end is not null) 
                    or (si.freight_name in ('Карбамид') and si.cont_number is null)
               )
           and batch_id is null
           
           and to_date(si.date_post,'dd.mm.yyyy hh24:mi') >= to_date('01.12.2017 00:00','dd.mm.yyyy hh24:mi') 
           
           and si.shop_info_id in (
                select shop_info_id
                  from xx_etw.xx_disl_output_in_oebs_t
           )
         order by
               date_post,date_start,date_end,who_looked,who_start,who_end,si.car_number,si.cont_number) 
    loop
        exit when l_result.done != true;
        
        if (prev_dr!=l_shops.dr) then
            if(l_shop_id_mas.count != 0) then
                log_new(l_log_id,l_function,'l_shop_id_mas: ');
                for i in l_shop_id_mas.first .. l_shop_id_mas.last
                loop
                    log_new(l_log_id,l_function,'l_shop_id_mas(i): ' || l_shop_id_mas(i));
                end loop;
                
                select distinct freight_oebs
                  into l_freight_oebs
                  from xx_etw.xx_disl_output_in_oebs_t
                 where 1=1
                   and shop_info_id in (
                        select column_value
                          from table(l_shop_id_mas)
                   )
                ;
                log_new(l_log_id,l_function,'l_freight_oebs: ' || l_freight_oebs);
                /*вызов ф-ции*/
                l_result := apps.xx_dislocation_helper.create_output_in_oebs(p_user_id,l_shop_id_mas,l_freight_oebs);
                if(l_result.done) then
                    l_batchs := l_batchs || l_result.descr || ' ';
                end if;       
            end if;
        
            l_shop_id_mas.delete;
            l_shop_id_mas.extend;
            l_shop_id_mas(l_shop_id_mas.last) := l_shops.shop_info_id; 
            
            prev_dr := l_shops.dr; 
        else
            l_shop_id_mas.extend;
            l_shop_id_mas(l_shop_id_mas.last) := l_shops.shop_info_id;   
        end if;    
    end loop;
    
    if (l_shop_id_mas.count != 0 and l_result.done) then
        log_new(l_log_id,l_function,'l_shop_id_mas: ');
        for i in l_shop_id_mas.first .. l_shop_id_mas.last
        loop
            log_new(l_log_id,l_function,'l_shop_id_mas(i): ' || l_shop_id_mas(i));            
        end loop;
        
        select distinct freight_oebs
          into l_freight_oebs
          from xx_etw.xx_disl_output_in_oebs_t
         where 1=1
           and shop_info_id in (
                select column_value
                  from table(l_shop_id_mas)
           )
        ;
        log_new(l_log_id,l_function,'l_freight_oebs: ' || l_freight_oebs);
        /*вызов ф-ции*/
        l_result := apps.xx_dislocation_helper.create_output_in_oebs(p_user_id,l_shop_id_mas,l_freight_oebs);
        if(l_result.done) then
            l_batchs := l_batchs || l_result.descr || ' ';
        end if;
    end if;
    
    if (l_result.done) then
        commit;
        return 'done'||'|'||l_batchs;
    else
        rollback;
        return l_result.descr;
    end if; 
exception
    when others then rollback;  return 'fail';      
end;

