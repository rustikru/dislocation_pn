function save_route(
    p_user_id           number,
    p_route_id          number,
    p_date_from         varchar2,
    p_date_to           varchar2,
    p_status            number,
    p_smena             number,
    p_station           number,
    p_station_officer   number,
    p_route_gave        number,
    p_loco              number,
    p_driver1           number,
    p_driver2           number,
    p_conductor         number,
    p_com               varchar2
    
) return varchar2 
as
    l_row_route         xx_etw.xx_disl_loco_routes%rowtype;   
    
    l_result            varchar2(4000);
    
    l_exists_route      varchar2(4000);       
begin
    begin
    select listagg(lrv.route_num,',') within group (order by lrv.route_num)
      into l_exists_route
      from xx_etw.xx_disl_loco_routes       lr
          ,xx_etw.xx_disl_loco_routes_v     lrv          
     where 1=1
       and lrv.route_id != nvl(p_route_id,-1)
       and lr.route_id = lrv.route_id
       and lr.status != 5
       and lr.loco = p_loco
       and (lr.date_from between to_date(p_date_from,'dd.mm.yyyy hh24:mi') + 1/24/60 and to_date(p_date_to,'dd.mm.yyyy hh24:mi') 
            or
            lr.date_to between to_date(p_date_from,'dd.mm.yyyy hh24:mi') + 1/24/60 and to_date(p_date_to,'dd.mm.yyyy hh24:mi'));
    exception
        when others then l_exists_route := null;
    end;
    
    if (l_exists_route is not null) then
        l_result := 'mistake'||'$'||l_exists_route;
    else
        if (p_route_id is null) then
            l_row_route.route_id := xx_etw.xx_disl_loco_routes_seq.nextval();
            l_row_route.date_from := to_date(p_date_from,'dd.mm.yyyy hh24:mi');
            l_row_route.date_to := to_date(p_date_to,'dd.mm.yyyy hh24:mi');
            l_row_route.status := p_status;
            l_row_route.smena := p_smena;
            l_row_route.station := p_station;
            l_row_route.station_officer := p_station_officer;
            l_row_route.route_gave := p_route_gave;
            l_row_route.loco := p_loco;
            l_row_route.driver1 := p_driver1;
            l_row_route.driver2 := p_driver2;
            l_row_route.conductor := p_conductor;
            l_row_route.com := p_com;
            l_row_route.created_by := p_user_id;
            l_row_route.creation_date := sysdate;
            l_row_route.last_update_by := p_user_id;
            l_row_route.last_update_date := sysdate;

            insert into xx_etw.xx_disl_loco_routes  
            values l_row_route;
            
            insert into xx_etw.xx_disl_route_status_history
            values(
                l_row_route.route_id,
                l_row_route.status,
                null,
                l_row_route.created_by,
                l_row_route.creation_date);
        else
            update xx_etw.xx_disl_loco_routes 
               set date_from = to_date(p_date_from,'dd.mm.yyyy hh24:mi')
                  ,date_to = to_date(p_date_to,'dd.mm.yyyy hh24:mi')
                  --,status = p_status
                  ,smena = p_smena
                  ,station = p_station
                  ,station_officer = p_station_officer
                  ,route_gave = p_route_gave
                  ,loco = p_loco
                  ,driver1 = p_driver1
                  ,driver2 = p_driver2
                  ,conductor = p_conductor
                  ,com = p_com
                  ,last_update_by = p_user_id
                  ,last_update_date = sysdate
             where route_id = p_route_id;
        end if;
          
        commit;
        l_result := 'done';   
    end if;

    return l_result;
exception
    when others then rollback; return 'fail';
end;

function save_route_status(
    p_user_id           number,
    p_route_id          number,
    p_status            number,
    p_status_descr      varchar2
) return varchar2 
as    
begin
    insert into xx_etw.xx_disl_route_status_history
    values(
        p_route_id,
        p_status,
        p_status_descr,
        p_user_id,
        sysdate);
    
    update xx_etw.xx_disl_loco_routes 
       set status = p_status
          ,last_update_by = p_user_id
          ,last_update_date = sysdate
     where route_id = p_route_id;
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail'; 
end;

function get_flag_route_closed(
    p_route_id          number
) return varchar2 
as 
    l_status    number;   
begin
    select status
      into l_status
      from xx_disl_loco_routes 
     where route_id = p_route_id;
    if (l_status = 3) then
        return '1';
    else
        return '0';
    end if;
end;

function get_routes(
    p_date_from     varchar2,
    p_date_to       varchar2,
    p_smena         number,
    p_station       number,
    p_loco          number
) return t_xx_route_table pipelined
as
    l_row   xx_disl_loco_routes_v%rowtype;
begin
    for c_row in (
        select lrv.*
          from xx_disl_loco_routes      lr
              ,xx_disl_loco_routes_v    lrv
         where 1=1
           and lr.route_id = lrv.route_id
           and lr.date_from between to_date(p_date_from,'dd.mm.yyyy hh24:mi') and nvl(to_date(p_date_to,'dd.mm.yyyy hh24:mi'),lr.date_from)
           and lr.smena = nvl(p_smena,lr.smena)
           and lr.station = nvl(p_station,lr.station)
           and lr.loco = nvl(p_loco,lr.loco))
    loop
        l_row.route_id := c_row.route_id;
        l_row.route_num := c_row.route_num;
        l_row.date_from := c_row.date_from;
        l_row.date_to := c_row.date_to;
        l_row.status := c_row.status;
        l_row.status_desc := c_row.status_desc;
        l_row.smena := c_row.smena;
        l_row.smena_desc := c_row.smena_desc;
        l_row.station := c_row.station;
        l_row.station_desc := c_row.station_desc;
        l_row.station_officer := c_row.station_officer;
        l_row.station_officer_desc := c_row.station_officer_desc;
        l_row.route_gave := c_row.route_gave;
        l_row.route_gave_desc := c_row.route_gave_desc;
        l_row.loco := c_row.loco;
        l_row.loco_desc := c_row.loco_desc;
        l_row.driver1 := c_row.driver1;
        l_row.driver1_desc := c_row.driver1_desc;
        l_row.driver2 := c_row.driver2;
        l_row.driver2_desc := c_row.driver2_desc;
        l_row.conductor := c_row.conductor;
        l_row.conductor_desc := c_row.conductor_desc;
        l_row.com := c_row.com;
        l_row.created_by := c_row.created_by;
        l_row.created_by_desc := c_row.created_by_desc;
        l_row.creation_date := c_row.creation_date;
        l_row.last_update_by := c_row.last_update_by;
        l_row.last_update_by_desc := c_row.last_update_by_desc;
        l_row.last_update_date := c_row.last_update_date;     
       
        pipe row (l_row);
    end loop;
end;

