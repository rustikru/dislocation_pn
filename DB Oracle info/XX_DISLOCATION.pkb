procedure update_car_add_info_from_nsi(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as
    f_out               number default apps.fnd_file.log;    
    l_str_output        varchar2(4000);
    rec_etw_car_nsi     etw_car_nsi%rowtype;
    
    l_error             varchar2(4000) := '';
    l_ip_server     varchar2(20);
    
    cursor crs_car_nsi
    is
    select rai.car_number
          ,rai.add_info_id
          ,sh.come_date
      from xx_etw.xx_disl_round                    r
          ,xx_etw.xx_disl_railcar_add_info         rai
          ,xx_etw.xx_disl_round_inv             ri
          ,xx_etw.xx_disl_station_history          sh
     where 1=1
       and length(railcar_id) = 8
     
       and r.station_hist_id_out is null
       -- add 24.06.2024 по просьбе Кулиняк Л.Я.
       and r.round_id = ri.round_id(+)
       and not exists (
            select   'не краны'
              from   xx_etw.ETW_INV_CAR eic, xx_etw.ETW_INVOICE ei
             where   eic.FRONT_END_ID = ei.FRONT_END_ID 
                     and eic.CAR_NUMBER = r.RAILCAR_ID
                     and ei.INVOICE_ID = ri.INVOICE_ID
                     and eic.CAR_TYPE_NAME = 'краны'
       )
       and r.round_id = rai.round_id
       and rai.last_record = 'Y'
       and rai.need_load_car_info = 'Y'
       and nvl(rai.update_date_nsi,sysdate - 1) + 1 <=  sysdate
       
       and r.round_id = sh.round_id
       and r.station_hist_id_in = sh.station_hist_id
       and sh.come_date is not null;
       
       
begin
    for v_car in crs_car_nsi
    loop
        rec_etw_car_nsi := xx_etw.etw_car_nsi_pkg.get_car_nsi (p_car_number => v_car.car_number, p_nsi_date => v_car.come_date);
        
        if (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'S') then
            update xx_etw.xx_disl_railcar_add_info rai
               set rai.weight_dep = nvl(rai.weight_dep,0) + case /*бывают случаи когда в накладной приходит длина равная 0, тогда нужно обновить только длину вагона(invoice_id = 594571401)*/
                                                              when rai.car_length = 0 then 0
                                                              else nvl(rec_etw_car_nsi.car_weight_dep,0)/10
                                                            end
                  ,rai.car_length = rec_etw_car_nsi.car_length
                  ,rai.need_load_car_info = 'N'
             where 1=1       
               and rai.add_info_id = v_car.add_info_id;
               
            l_str_output:=l_str_output||v_car.car_number||': обновлен'||chr(10);
        elsif (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'E') then
            update xx_etw.xx_disl_railcar_add_info rai
               set rai.update_date_nsi = sysdate
             where 1=1       
               and rai.add_info_id = v_car.add_info_id;
            
            l_error := l_error || ' ' || v_car.car_number || ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10);  
        elsif (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'U') then
            update xx_etw.xx_disl_railcar_add_info rai
               set rai.update_date_nsi = sysdate
             where 1=1       
               and rai.add_info_id = v_car.add_info_id; 
               
            l_error := l_error || ' ' || v_car.car_number || ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10);
        end if; 
        
        commit;  
    end loop;
    
    if (l_error is not null) then
        l_str_output := l_str_output || l_error;
        
        /*чтобы письма не шли с тестовых серваков*/
        select utl_inaddr.get_host_address
          into l_ip_server 
          from dual;    
        if (l_ip_server='10.0.0.40'/*m5000*/) then
            send_mail_general('Внутрення дислокация - ОШИБКА обновления НСИ вагонов!!!','Процедура завершилась с ошибкой! Обратитесь к разработчикам! '||l_error);
        end if;
    end if;   
    
    if (l_str_output is not null) then
        apps.fnd_file.put_line (f_out,l_str_output);
    end if;
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end;

procedure update_cars_nsi(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as
    f_out               number default apps.fnd_file.log;    
    l_str_output        varchar2(8000);
    rec_etw_car_nsi     etw_car_nsi%rowtype;
    
    l_error             varchar2(8000) := '';
    l_ip_server         varchar2(20);
    
    cursor crs_car_nsi
    is
    select distinct 
           rai.car_number
          ,sh.come_date
      from xx_etw.xx_disl_round                 r
          ,xx_etw.xx_disl_round_inv             ri
          ,xx_etw.xx_disl_station_history       sh
          ,(select round_id             round_id
                  ,max(add_info_id)     add_info_id
              from xx_etw.xx_disl_railcar_add_info      rai
             where 1=1
               and add_info_type = 'A'
             group by
                   round_id)
                                                rai_l
          ,xx_etw.xx_disl_railcar_add_info      rai
          ,xx_etw.etw_car_nsi                   ecn
     where 1=1
       and r.station_hist_id_out is null
       and r.foreign_car is null
       -- add 24.06.2024 по просьбе Кулиняк Л.Я.
       and r.round_id = ri.round_id(+)
       and not exists (
            select   'не краны'
              from   xx_etw.ETW_INV_CAR eic, xx_etw.ETW_INVOICE ei
             where   eic.FRONT_END_ID = ei.FRONT_END_ID 
                     and eic.CAR_NUMBER = r.RAILCAR_ID
                     and ei.INVOICE_ID = ri.INVOICE_ID
                     and eic.CAR_TYPE_NAME = 'краны'
       )
       and r.round_id = sh.round_id
       and r.station_hist_id_in = sh.station_hist_id
       and sh.in_date_fact is null
       
       and r.round_id = rai_l.round_id
       and rai_l.add_info_id = rai.add_info_id
       and ((nvl(rai.weight_net,0) = 0 and rai.owner in ('МТФ','МД'))
             or
            (nvl(rai.weight_net,0) != 0 and rai.owner in ('МТФ')))
       and r.railcar_id = ecn.car_number(+)
       
       and ecn.car_iskl_date is null
       
       and (ecn.car_number is null
            or 
            (trunc(ecn.car_next_repair) - trunc(sysdate)) < 40)
            
       and (trunc(sysdate) - trunc(nvl(ecn.xx_last_update_date,sysdate-6))) >= 5;
       
       
begin
    for v_car in crs_car_nsi
    loop
        if (xx_etw.etw_car_nsi_pkg.car_number_validate(v_car.car_number)) then     
            apps.fnd_file.put_line (f_out,'*** '||v_car.car_number);
            rec_etw_car_nsi := xx_etw.etw_car_nsi_pkg.get_car_nsi (p_car_number => v_car.car_number, p_nsi_date => sysdate/*v_car.come_date*/);
            
            apps.fnd_file.put_line (f_out,xx_etw.etw_car_nsi_pkg.get_car_nsi_status);
            apps.fnd_file.put_line (f_out,xx_etw.etw_car_nsi_pkg.get_car_nsi_message);
            
            if (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'S') then
                l_str_output:=l_str_output||v_car.car_number||': обновлен'||chr(10);
            elsif (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'E') then
                l_error := l_error || ' ' || v_car.car_number || ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10);  
            elsif (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'U') then
                l_error := l_error || ' ' || v_car.car_number || ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10);
            end if; 
            
            commit;  
        end if;
    end loop;
    
    /*чтобы письма не шли с тестовых серваков*/
    select utl_inaddr.get_host_address
      into l_ip_server 
      from dual;    
      
    if (l_error is not null) then
        l_str_output := l_str_output || l_error;
        
        if (l_ip_server='10.0.0.40'/*m5000*/) then
            send_mail_general('Внутренняя дислокация - ОШИБКА обновления НСИ вагонов с подхода!',l_error);
        end if;
    end if;   
    
    if (l_str_output is not null) then
        apps.fnd_file.put_line (f_out,l_str_output);
        if (l_ip_server='10.0.0.40'/*m5000*/) then
            send_mail_general('Внутренняя дислокация - обновления НСИ вагонов с подхода!',l_str_output);
        end if;
    end if;
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end;

procedure updateCars(p_errbuf   out nocopy varchar2,  
                     p_retcode  out nocopy varchar2,
                     p_section  in varchar2 default null)
is
    l_function      varchar2(100) := 'update_cars';
    
    f_out           number default apps.fnd_file.log;
    
    l_errbuf        varchar2(4000);
    l_retcode       varchar2(1);
    
    tmp varchar2(10);
    
    l_ip_server     varchar2(20);
begin
    /**************/
    l_retcode:=null;
    l_errbuf:=null;
    apps.fnd_file.put_line (f_out,rpad(lpad('update_railcars_add_info',45,'*'),77,'*'));
    apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
    
    if nvl(p_section,'*') = '*' then
        xx_etw.xx_dislocation.update_railcars_add_info(l_errbuf,l_retcode);
        
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));    
        /**************/
        l_retcode:=null;
        l_errbuf:=null;
        apps.fnd_file.put_line (f_out,rpad(lpad('update_cars_for_ugl',45,'*'),77,'*'));
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
        
        xx_etw.xx_dislocation.update_cars_for_ugl(l_errbuf,l_retcode);
        
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));
        /**************/
        /* убрал 11.08.2016 все осмотры ведутся уже во внутр. дислокации
        l_retcode:=null;
        l_errbuf:=null;
        apps.fnd_file.put_line (f_out,rpad(lpad('nrb_stop_update_prc',45,'*'),77,'*'));
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
        
        nrb_stop_update_prc(l_errbuf,l_retcode);
        
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));*/
        /**************/
        l_retcode:=null;
        l_errbuf:=null;
        apps.fnd_file.put_line (f_out,rpad(lpad('remove_empty_bandwagons',45,'*'),77,'*'));
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
        
        remove_empty_bandwagons(l_errbuf,l_retcode);
        
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));
        /**************/
        l_retcode:=null;
        l_errbuf:=null;
        apps.fnd_file.put_line (f_out,rpad(lpad('del_old_notification',45,'*'),77,'*'));
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
        
        del_old_notification(l_errbuf,l_retcode);
        
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line(f_out,rpad('*',77,'*'));
        /**************/
        l_retcode:=null;
        l_errbuf:=null;
        apps.fnd_file.put_line (f_out,rpad(lpad('update_car_add_info_from_nsi',45,'*'),77,'*'));
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
     
        update_car_add_info_from_nsi(l_errbuf,l_retcode);

        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));
        /**************/
        if to_char(sysdate,'hh24') = '09' then 
            l_retcode:=null;
            l_errbuf:=null;
            apps.fnd_file.put_line (f_out,rpad(lpad('update_cars_nsi',45,'*'),77,'*'));
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры обновления НСИ с подхода');
            
            update_cars_nsi(l_errbuf,l_retcode);
            
            if (l_retcode='2' or l_retcode='1') then
                p_retcode := l_retcode;
                apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
                apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
            else
                apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');   
            end if;
            apps.fnd_file.put_line(f_out,rpad('*',77,'*'));
        end if;
        /**************/
        l_retcode:=null;
        l_errbuf:=null;
        apps.fnd_file.put_line (f_out,rpad(lpad('update_railcar_status',45,'*'),77,'*'));
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
        
        update_railcar_status(l_errbuf,l_retcode);
        
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));
        /**************/
        l_retcode:=null;
        l_errbuf:=null;
        apps.fnd_file.put_line (f_out,rpad(lpad('update_shop_info',45,'*'),77,'*'));
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
            
        update_shop_info(l_errbuf,l_retcode);
            
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));    
    elsif nvl(p_section,'*') = 'UPDATE_RAILCAR_STATUS' then
        apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Запуск процедуры');
        
        update_railcar_status(l_errbuf,l_retcode);
        
        if (l_retcode='2') then
            p_retcode := l_retcode;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась с ошибкой');
            apps.fnd_file.put_line (f_out, 'Ошибка: '||l_errbuf);  
        else
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'Процедура завершилась без ошибок');        
        end if;
        apps.fnd_file.put_line (f_out,rpad('*',77,'*'));
    end if;
    /*чтобы письма не шли с тестовых серваков*/
    select utl_inaddr.get_host_address
      into l_ip_server 
      from dual;    
    
    if (p_retcode = 2 and l_ip_server='10.0.0.40'/*m5000*/) then
        send_mail_general('Внутрення дислокация - ОШИБКА!!!','Процедура завершилась с ошибкой! Обратитесь к разработчикам! Параллелная программа: "Метафракс: Обновление данных для внутренней дислокации". Идент. запроса = '||apps.fnd_global.CONC_REQUEST_ID||'Ошибка: '||l_errbuf);
    end if;
end;



function get_request_data(p_request_id number,p_type varchar2 default 'pdf')
return blob
as
    l_blob              blob;
    l_bfile             bfile;
    
    l_outfile_name varchar2(1000);
begin               
    select decode(p_type
                 ,'excel',fnpr.concurrent_program_name||'_'||fcr.request_id||'_'||'1'||'.'||fnpr.output_file_type
                 ,substr(outfile_name, instr(outfile_name,'/', -1,1)+1))
      into l_outfile_name
      from apps.fnd_concurrent_requests     fcr
          ,apps.fnd_concurrent_programs     fnpr   
     where 1=1
       and fcr.concurrent_program_id = fnpr.concurrent_program_id
       and fcr.program_application_id = fnpr.application_id
       and fcr.request_id = p_request_id;
                    
    l_bfile := bfilename('XX_DISL_CONCURRENT_PATH', l_outfile_name);
    dbms_lob.fileopen(l_bfile);
               
    dbms_lob.createtemporary (l_blob, FALSE);
                  
    dbms_lob.loadfromfile(l_blob,l_bfile,dbms_lob.getlength(l_bfile));

    dbms_lob.fileclose(l_bfile); 
                    
    return l_blob;
exception    
    when others then null;                   
end get_request_data;



function get_msg_to_users 
  return t_xx_msg_to_user_table pipelined
as
    l_row           t_xx_msg_to_user_row;
    l_ip_server     varchar2(50):='12';
begin
    
    for tmp in (
        select   TYPE,
                 TEXT,
                 CREATED_BY,
                 CREATED_DATE
          from   xx_etw.xx_disl_message_to_users
         where       1 = 1
                 and ROWNUM <= 1
                 and SYSDATE between EFFECTIVE_DATE_START and EFFECTIVE_DATE_END
                 and nvl(X_ENABLE,'N') = 'Y'
           
    )
    loop
        l_row.type := tmp.type;
        l_row.TEXT := tmp.TEXT;
        l_row.CREATED_BY := tmp.CREATED_BY;
        l_row.CREATED_DATE := tmp.CREATED_DATE;
        pipe row (l_row);
    end loop;
end;

/***************** Обработка вагонов *********************/
/*******************************************************************************
Функция возвращает список данных по вагону для формы "Обработка вагонов"
Параметры:
  * p_user_id - пользователь
  * p_params - массив данных в формет JSON
*******************************************************************************/
function get_process_of_wagons(
    p_params        varchar2)
return t_xx_process_of_wagons_table pipelined
is
    l_function          varchar2(100):='get_process_of_wagons';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_car_number        varchar2(240);
    l_item_id           number;
    l_row               t_xx_process_of_wagons_row;
    l_trx_date_begin    date;
    l_trx_date_end      date;
    ---
    l_json_par          json;
    l_json              json;
    l_json_tmp          json; 
    l_json_list         json_list;
    l_json_value        json_value;
    l_json_val          json_value;
    ---
begin
    l_json_par := xx_wms.json(p_params);
    
    -- Номер вагона
    if (l_json_par.exist('car_number')) then
        l_car_number := l_json_par.get_string('car_number'); 
    else 
        l_car_number:= null;
    end if;
    
    -- ID позиции
    if (l_json_par.exist('inventory_item_id')) then
        l_item_id := l_json_par.get_string('inventory_item_id'); 
    else 
        l_item_id:= null;
    end if;
    -- Дата начала обработки 
    if (l_json_par.exist('trx_date_begin')) then
        l_trx_date_begin := to_date(l_json_par.get_string('trx_date_begin'),'DD.MM.YYYY HH24:MI'); 
    else 
        l_trx_date_begin:= null;
    end if;
    -- Дата окончания обработки 
    if (l_json_par.exist('trx_date_end')) then
        l_trx_date_end := to_date(l_json_par.get_string('trx_date_end'),'DD.MM.YYYY HH24:MI');
    else 
        l_trx_date_end:= null;
    end if;

    
    for tmp in (
        SELECT   x.disl_hdr_id,
                 x.created_by,
                 x.created_fio,
                 x.creation_date,
                 x.last_updated_fio,
                 x.last_updated_by,
                 x.last_update_date,
                 l.trx_date_begin,
                 l.trx_date_end,
                 l.batch_id as batch_id,
                 l.batch_num as batch_num,
                 l.xx_opm_trx_hdr_id as hdr_opm_id,
                 l.disl_lines_id,
                 l.round_id,
                 l.car_number,
                 l.cont_round_id,
                 l.cont_number,
                 l.freight_name,
                 l.inventory_item_id,
                 fo.code_base
          FROM   xx_etw.xx_disl_opm_trx_header_v x,
                 xx_etw.xx_disl_opm_trx_lines l,
                 xx_etw.xx_disl_freight_oebs_v fo
         WHERE       1 = 1
                 AND x.disl_hdr_id = l.disl_hdr_id
                 AND l.inventory_item_id = fo.inventory_item_id(+)
                 and l.car_number = nvl(l_car_number,l.car_number)
                 and l.inventory_item_id = nvl(l_item_id,l.inventory_item_id)
                 and l.trx_date_begin between l_trx_date_begin and l_trx_date_end
                 
    )
    loop
        l_row.DISL_HDR_ID:= tmp.DISL_HDR_ID;
        l_row.CREATED_BY:= tmp.CREATED_BY;
        l_row.CREATED_FIO:= tmp.CREATED_FIO;
        l_row.CREATION_DATE:= tmp.CREATION_DATE;
        l_row.LAST_UPDATED_FIO:= tmp.LAST_UPDATED_FIO;
        l_row.LAST_UPDATED_BY:= tmp.LAST_UPDATED_BY;
        l_row.LAST_UPDATE_DATE:= tmp.LAST_UPDATE_DATE;
        l_row.TRX_DATE_BEGIN:= tmp.TRX_DATE_BEGIN;
        l_row.TRX_DATE_END:= tmp.TRX_DATE_END;
        l_row.BATCH_ID:= tmp.BATCH_ID;
        l_row.BATCH_NUM:= tmp.BATCH_NUM;
        l_row.HDR_OPM_ID:= tmp.HDR_OPM_ID;
        l_row.DISL_LINES_ID:= tmp.DISL_LINES_ID;
        l_row.ROUND_ID:= tmp.ROUND_ID;
        l_row.CAR_NUMBER:= tmp.CAR_NUMBER;
        l_row.CONT_ROUND_ID:= tmp.CONT_ROUND_ID;
        l_row.CONT_NUMBER:= tmp.CONT_NUMBER;
        l_row.FREIGHT_NAME:= tmp.FREIGHT_NAME;
        l_row.INVENTORY_ITEM_ID:= tmp.INVENTORY_ITEM_ID;
        l_row.CODE_BASE:= tmp.CODE_BASE;
        pipe row (l_row);
    end loop;

end;

/*******************************************************************************
Функция возвращает список данных по вагону для формы "Обработка вагонов (историческая)"
Параметры:
  * p_params - массив данных в формет JSON
*******************************************************************************/
function get_process_of_wagons_history( 
            p_params        varchar2
) return t_xx_process_of_wag_hist_table pipelined
is
    l_function          varchar2(100):='get_process_of_wagons_history';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_car_number        varchar2(240);
    l_item_id           number;
    l_row               t_xx_process_of_wag_hist_row;
    l_trx_date_begin    date;
    l_trx_date_end      date;
    ---
    l_json_par          json;
    l_json              json;
    l_json_tmp          json; 
    l_json_list         json_list;
    l_json_value        json_value;
    l_json_val          json_value;
    ---
begin
    l_json_par := xx_wms.json(p_params);
    log_new(l_log_id,l_function,'p_params = '||p_params);
    -- Номер вагона
    if (l_json_par.exist('car_number')) then
        l_car_number := l_json_par.get_string('car_number'); 
    else 
        l_car_number:= null;
    end if;
    
    -- ID позиции
    if (l_json_par.exist('inventory_item_id')) then
        l_item_id := l_json_par.get_string('inventory_item_id'); 
        if l_item_id = 0 then
            l_item_id := null; 
        end if;
    else 
        l_item_id:= null;
    end if;
    -- Дата начала обработки 
    if (l_json_par.exist('trx_date_begin')) then
        l_trx_date_begin := to_date(l_json_par.get_string('trx_date_begin'),'DD.MM.YYYY HH24:MI'); 
    else 
        l_trx_date_begin:= null;
    end if;
    -- Дата окончания обработки 
    if (l_json_par.exist('trx_date_end')) then
        l_trx_date_end := to_date(l_json_par.get_string('trx_date_end'),'DD.MM.YYYY HH24:MI');
    else 
        l_trx_date_end:= null;
    end if;
    for tmp in (
       select product, 
              lot_number, 
              to_char(min (begin_transaction_date),'DD.MM.YYYY HH24:MI') as begin_transaction_date,
              to_char(max (end_transaction_date),'DD.MM.YYYY HH24:MI') as end_transaction_date,
              abs (sum (qty_production)) as qty_production,
              abs (sum (qty_write_off)) as qty_write_off
        from (
        select   si.segment1 as product 
                ,ln.lot_number 
                ,case when mt.transaction_type_id in (44) then mt.transaction_date else null end as begin_transaction_date  -- Дата/время завершения
                ,case when mt.transaction_type_id in (32) then mt.transaction_date else null end as end_transaction_date  -- Дата/время завершения 
                ,case when mt.transaction_type_id in (44,17) then mt.transaction_quantity else 0 end as qty_production -- Кол-во выработка 
                ,case when mt.transaction_type_id in (32,341) then mt.transaction_quantity else 0 end as qty_write_off -- Кол-во списание 
                ,tt.transaction_type_name
        from inv.mtl_material_transactions mt
            ,inv.mtl_transaction_lot_numbers ln
            ,inv.mtl_system_items_b si
            ,inv.mtl_transaction_types tt
        where 1=1
            and mt.transaction_id = ln.transaction_id
            and mt.inventory_item_id = si.inventory_item_id
            and si.organization_id = 362
            and mt.transaction_type_id = tt.transaction_type_id
            AND mt.transaction_date  between l_trx_date_begin and l_trx_date_end
            and mt.transaction_type_id in (44,32, 17, 341)
            /*  44 - Завершение сборки НзП (выработка),
                32 - Прочая выдача (списание),
                17 - Возврат сборки в НзП,
                341 - Прочее поступление (сторно проч.выдачи) 
            */
            and exists (
                select 1
                  from xx_etw.xx_disl_opm_trx_header_v h,
                       xx_etw.xx_disl_opm_trx_lines l
                 where 1=1
                       and nvl(l.cont_number,l.car_number) = ln.lot_number
                       and h.disl_hdr_id = l.disl_hdr_id
                       and l.trx_date_begin between l_trx_date_begin and l_trx_date_end
                       and l.inventory_item_id = nvl(l_item_id,l.inventory_item_id)
            )
        ) x
        group by product, lot_number
                 
    )
    loop
        l_row.PRODUCT:= tmp.PRODUCT;
        l_row.LOT_NUMBER:= tmp.LOT_NUMBER;
        l_row.BEGIN_TRANSACTION_DATE:= tmp.BEGIN_TRANSACTION_DATE;
        l_row.END_TRANSACTION_DATE:= tmp.END_TRANSACTION_DATE;
        l_row.QTY_PRODUCTION:= tmp.QTY_PRODUCTION;
        l_row.QTY_WRITE_OFF:= tmp.QTY_WRITE_OFF;
        pipe row (l_row);
    end loop;
end;


/*******************************************************************************
Процедура добавляет/обновляет данные в таблице xx_disl_opm_trx_header
Параметры:
  * p_trx_header_row - запись
  * p_disl_hdr_id - Идентификатор таблицы xx_disl_opm_trx_header
*******************************************************************************/
PROCEDURE api_disl_opm_trx (
      p_trx_header_row      in out xx_etw.xx_disl_opm_trx_header%rowtype,
      p_disl_hdr_id         out nocopy number,
      p_status              out nocopy varchar2,
      p_message             out nocopy varchar2
   )
is
   l_function      varchar2(100):='api_disl_opm_trx';
   l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
   --
   v_disl_hdr_id   number;
   
begin
      if nvl(p_trx_header_row.disl_hdr_id,0) > 0
      then
         update   xx_etw.xx_disl_opm_trx_header x
            set   last_updated_by = p_trx_header_row.last_updated_by,
                  last_update_date = sysdate
          where   1 = 1 and x.disl_hdr_id = p_trx_header_row.disl_hdr_id;
          p_disl_hdr_id := p_trx_header_row.disl_hdr_id;
      else
         insert into xx_etw.xx_disl_opm_trx_header x (disl_hdr_id,
                                                      created_by,
                                                      creation_date,
                                                      last_updated_by,
                                                      last_update_date
                                                      )
                                                      
            values   (xx_etw.xx_disl_opm_trx_header_s.nextval,
                      p_trx_header_row.created_by,
                      sysdate,
                      p_trx_header_row.last_updated_by,
                      sysdate
                      )
                      
         returning   disl_hdr_id into p_disl_hdr_id;
      end if;
      p_status :='S';
exception
    when others then 
        rollback;
        p_status :='E'; p_message:=sqlerrm;
        log_new(l_log_id,l_function,'Erorr = '||p_message);
              
end;

/*******************************************************************************
Процедура добавляет/обновляет данные в таблице xx_disl_opm_trx_lines
Параметры:
  * p_trx_row - запись
  * p_status - статус обработки: S - успешно, E - ошибка
  * p_message - сообщение 
*******************************************************************************/
PROCEDURE api_disl_opm_trx_lines (
      p_trx_row             in  xx_etw.xx_disl_opm_trx_lines%rowtype,
      p_status              out nocopy varchar2,
      p_message             out nocopy varchar2
   )
is
   l_function      varchar2(100):='api_disl_opm_trx_lines';
   l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
   --
   v_disl_hdr_id   NUMBER;
   
begin
      if nvl(p_trx_row.disl_lines_id,0) > 0
      then
         update   xx_etw.xx_disl_opm_trx_lines x
            set   last_updated_by       = p_trx_row.last_updated_by,
                  last_update_date      = sysdate,
                  round_id              = p_trx_row.round_id,
                  car_number            = p_trx_row.car_number,
                  cont_round_id         = p_trx_row.cont_round_id,
                  cont_number           = p_trx_row.cont_number,
                  freight_name          = p_trx_row.freight_name,
                  inventory_item_id     = p_trx_row.inventory_item_id,
                  reason_id             = p_trx_row.reason_id,
                  trx_date_begin        = p_trx_row.trx_date_begin,
                  trx_date_end          = p_trx_row.trx_date_end
                  
          where   1 = 1 
                  and x.disl_lines_id = p_trx_row.disl_lines_id;
      else
         insert into xx_etw.xx_disl_opm_trx_lines x (disl_lines_id, 
                                                     disl_hdr_id, 
                                                     created_by,  
                                                     last_updated_by,  
                                                     round_id, 
                                                     car_number, 
                                                     cont_round_id,
                                                     cont_number, 
                                                     freight_name, 
                                                     inventory_item_id,
                                                     reason_id,
                                                     trx_date_begin,
                                                     trx_date_end
                                                     )
                                                      
            values   (xx_etw.xx_disl_opm_trx_lines_s.nextval,
                      p_trx_row.disl_hdr_id, 
                      p_trx_row.created_by, 
                      p_trx_row.last_updated_by, 
                      p_trx_row.round_id, 
                      p_trx_row.car_number, 
                      p_trx_row.cont_round_id,
                      p_trx_row.cont_number, 
                      p_trx_row.freight_name, 
                      p_trx_row.inventory_item_id,
                      p_trx_row.reason_id,
                      p_trx_row.trx_date_begin,
                      p_trx_row.trx_date_end
                      );
      end if;
      p_status :='S';
exception
    when others then 
        rollback;
        p_status :='E'; p_message:=sqlerrm;
        log_new(l_log_id,l_function,'Erorr = '||p_message);    
end;

/* Formatted on 13.09.2022 11:01:55 (QP5 v5.115.810.9015) */
FUNCTION lastMaxRoundCarID (p_railcar_id NUMBER)
   RETURN NUMBER
IS
   l_round_id   NUMBER;
BEGIN
   SELECT   MAX (round_id)
     INTO   l_round_id
     FROM   xx_etw.xx_disl_round x
    WHERE   1 = 1 AND railcar_id = p_railcar_id;

   RETURN l_round_id;
EXCEPTION
   WHEN OTHERS
   THEN
      RETURN -1;
END;

FUNCTION lastMaxRoundContID (p_cont_number VARCHAR2)
   RETURN NUMBER
IS
   l_round_id   NUMBER;
BEGIN
   SELECT   MAX (CONT_ROUND_ID)
     INTO   l_round_id
     FROM   xx_etw.xx_disl_cont_round x
    WHERE   1 = 1 AND cont_number = p_cont_number;

   RETURN l_round_id;
EXCEPTION
   WHEN OTHERS
   THEN
      RETURN -1;
END;

/*******************************************************************************
Процедура Сохраняем данные из формы "Обработка вагонов"
Параметры:
  * p_user_id - пользователь
  * p_add_data - массив данных в формет JSON
  * p_resul - результат выполнения (массив): done - успешно
                                    fail$MessageError - ошибка$текст_ошибки
*******************************************************************************/
procedure save_process_of_wagons (
    p_user_id           in  number,
    p_add_data          in  clob,
    p_result            out varchar2                         
)
is
    l_function          varchar2(100):='save_process_of_wagons';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_status            varchar2(1);
    l_message           varchar2(500);
    ---
    l_json_par          json;
    l_json              json;
    l_json_tmp          json; 
    l_json_list         json_list;
    l_json_value        json_value;
    l_json_val          json_value;
    ---
    l_disl_hdr_id       number;
    l_row_header        xx_etw.xx_disl_opm_trx_header%rowtype;
    l_row_lines         xx_etw.xx_disl_opm_trx_lines%rowtype;
    l_clob clob;
    l_trx_date_begin    date;
    l_trx_date_end      date;
    ----
    
    
begin
    log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
    l_json_par := xx_wms.json(p_add_data);
    l_row_header.disl_hdr_id := l_json_par.get_string('header_id');
    l_trx_date_begin := to_date(l_json_par.get_string('trx_date_begin'),'DD.MM.YYYY HH24:MI');
    l_trx_date_end := to_date(l_json_par.get_string('trx_date_end'),'DD.MM.YYYY HH24:MI');
    l_row_header.created_by := p_user_id;
    l_row_header.last_updated_by := p_user_id;
    
    log_new(l_log_id,l_function,'Begin disl_hdr_id='||l_row_header.disl_hdr_id
                                    ||' trx_date_begin='||to_char(l_trx_date_begin,'DD.MM.YYYY HH24:MI')
                                    ||' trx_date_end='||to_char(l_trx_date_end,'DD.MM.YYYY HH24:MI')
           
           );
   
    -- Массив строк таблицы 
    l_json_value := l_json_par.get('opm_trx_lines');
    l_json_list := json_list(l_json_value); 
    for i in 1..l_json_list.count loop
        l_json_value := l_json_list.get(i);
        l_json := json(l_json_value);
        -- Строки
        l_row_lines:=null;
        l_row_lines.created_by := p_user_id;
        l_row_lines.last_updated_by := p_user_id;
        l_row_lines.car_number := l_json.get_string('car_number');
        l_row_lines.round_id := lastMaxRoundCarID(l_row_lines.car_number);                                                                            --l_json.get_string('round_id');
        l_row_lines.cont_number := l_json.get_string('cont_number');
        l_row_lines.cont_round_id := lastMaxRoundContID(l_json.get_string('cont_number'));
        l_row_lines.freight_name := l_json.get_string('freight_name');
        l_row_lines.inventory_item_id := l_json.get_string('item_id');
        l_row_lines.trx_date_begin := l_trx_date_begin;
        l_row_lines.trx_date_end := l_trx_date_end;

        l_row_lines.disl_lines_id := case when l_json.get_string('line_id')>0 then l_json.get_string('line_id') else get_opm_trx_line_id(l_row_lines) end;

        l_row_header.disl_hdr_id :=get_opm_trx_header_id(l_row_lines.disl_lines_id);
        l_status:='';
        l_message:='';
                    -- Добавляем/Обновляем данные на заголовке
        api_disl_opm_trx (p_trx_header_row   => l_row_header,
        p_disl_hdr_id      => l_disl_hdr_id,
        p_status           => l_status,
        p_message          => l_message
        );

        if nvl(l_status,'*') = 'E' then
            p_result:= 'fail$'||l_message;
            rollback;
            return;
        end if;

        l_row_lines.disl_hdr_id := l_disl_hdr_id;
        l_status:='';
        l_message:='';

        BEGIN
           select   mtr.reason_id
             into   l_row_lines.reason_id
             from   inv.mtl_transaction_reasons mtr,
                    xx_etw.xx_disl_freight_oebs_v dfo
            where       1 = 1
                    and dfo.inventory_item_id = l_row_lines.inventory_item_id
                    and dfo.code_base = mtr.reason_name
                    and mtr.disable_date is null;
        EXCEPTION
           WHEN OTHERS
           THEN
              l_row_lines.reason_id := NULL;
        END;

        api_disl_opm_trx_lines(
            p_trx_row             => l_row_lines,
            p_status              => l_status,
            p_message             => l_message
        );

        if nvl(l_status,'*') = 'E' then
            p_result:= 'fail$'||l_message;
            rollback;
            return;
        end if;

    end loop;
    commit;
    p_result := 'done$Данные сохранены';
exception
    when others then 
        rollback;
        log_new(l_log_id,l_function,'Erorr = '||sqlerrm);
        p_result:= 'fail$'||sqlerrm;          
end;

function get_opm_trx_header_id (p_line_id number) return number
is
    p_header_id number;     
begin
        select distinct h.disl_hdr_id
          into p_header_id
          from xx_etw.xx_disl_opm_trx_header h,
               xx_etw.xx_disl_opm_trx_lines l
         where 1=1
               and h.disl_hdr_id = l.disl_hdr_id
               and l.disl_lines_id = p_line_id
         ;
        
        return p_header_id;
exception 
    when no_data_found then return 0; 
end;
function get_opm_trx_line_id (p_rec in xx_etw.xx_disl_opm_trx_lines%rowtype) return number
is
    l_function      varchar2(100):='get_opm_trx_line_id';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    l_line_id number;
begin
    if (p_rec.CONT_ROUND_ID is null or p_rec.CONT_ROUND_ID = -1) then
        select l.disl_lines_id
          into l_line_id
          from xx_etw.xx_disl_opm_trx_lines l
         where l.round_id = p_rec.round_id;
    elsif (p_rec.CONT_ROUND_ID != -1) then
        select l.disl_lines_id
          into l_line_id
          from xx_etw.xx_disl_opm_trx_lines l
         where l.round_id = p_rec.round_id
               and l.cont_round_id = p_rec.cont_round_id;
    end if;
    return l_line_id;
exception when others then 
    log_new(l_log_id,l_function,'Error='||sqlerrm||' round_id='||p_rec.round_id||' cont_round_id='||p_rec.cont_round_id);
    return 0;
end;
/*******************************************************************************
Функция возвращает список Мэппинг категорий позиций OeBS и наим.груза 
Параметры:
  * 
*******************************************************************************/
function get_disl_freight_oebs (p_add_data varchar2) return t_xx_disl_freight_oebs_table pipelined

is
    l_function      varchar2(100):='get_disl_freight_oebs';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    ---
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    --
    l_row           xx_etw.xx_disl_freight_oebs_v%rowtype;
    l_freight_name  varchar2(240);
begin
    l_json_par := xx_wms.json(p_add_data);
    l_freight_name := l_json_par.get_string('freight_name');
    
    l_row := null;
    for c_row in (
           SELECT x.*
             FROM xx_etw.xx_disl_freight_oebs_v x
            where 1=1 
           )
    loop
        l_row := null;
        l_row.INVENTORY_ITEM_ID := c_row.INVENTORY_ITEM_ID; -- ID позиции
        l_row.ITEM_NAME := c_row.ITEM_NAME; -- Код позиции
        l_row.FREIGHT_NAME := c_row.FREIGHT_NAME; -- Наименование груза
        l_row.CODE_BASE := c_row.CODE_BASE; -- Код основания
        l_row.FREIGHT_SELECTED := case when lower(trim(l_freight_name)) = lower(trim(c_row.FREIGHT_NAME)) then 1 else 0 end;
        pipe row (l_row);
    end loop;
    
end;

/*******************************************************************************
Процедура заполняет интерфейсную таблицу xx_mtf.xx_opm_trx_hdr_interface.
          В запасах создается задание.
Параметры:
  * p_user_id - пользователь
  * p_add_data - массив данных в формет JSON
  * p_result - результат выполнения (массив): done - успешно
                                    fail$MessageError - ошибка$текст_ошибки
*******************************************************************************/
procedure run_process_of_wagons (
    p_user_id           in  number,
    p_add_data          in  clob,
    p_result            out varchar2                         
)
is
    l_function          varchar2(100):='run_process_of_wagons';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_status            varchar2(1);
    l_message           varchar2(500);
    ---
    l_json_par          json;
    l_json              json;
    l_json_tmp          json; 
    l_json_list         json_list;
    l_json_value        json_value;
    l_json_val          json_value;
    ---
    l_user_id           number := 13251; /*ANONYMOUS OEBS*/
    l_disl_hdr_id       number;
    l_disl_line_id      number;
    l_count_batch       number:=0;
    l_request_id        number:=0;
    l_result            varchar2(2400):='';
    l_errbuf            varchar2(2400);
    l_retcode           varchar2(240);
    l_batch_num         varchar2(400):='';
    l_interface_msg     varchar2(1000):='';
    
    l_hdr_id            number:=0;
    l_dev_phase         varchar2(240);
    l_phase             varchar2(240);
    l_dev_status        varchar2(240);
    l_bool              boolean;
    l_disl_lines_m      varchar2(2400):='';
    l_interface_status  xx_etw.xx_disl_opm_trx_lines.lns_interface_status%type;
    l_trx_date_begin    date;
    l_trx_date_end      date;
    --
    l_done_msg  varchar2(2000); -- Успешно
    l_error_msg varchar2(2000); -- Ошибка 
    l_others_msg varchar2(2000); -- Прочая выдача
    --
    l_row_h             xx_mtf.xx_opm_trx_hdr_interface%rowtype;
    l_row_l             xx_mtf.xx_opm_trx_lns_interface%rowtype;
    l_disl_l            xx_etw.xx_disl_opm_trx_lines%rowtype;
begin

    begin
        select x.setting_value
          into l_user_id
          from xx_mtf.xx_opm_trx_settings x
         where 1=1
               and upper(x.setting_name) = upper('user_run_interface');
        exception 
            when others then l_user_id:=13251;
    end;
    
    log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
    l_json_par := xx_wms.json(p_add_data);
    
    l_trx_date_begin := to_date(l_json_par.get_string('trx_date_begin'),'DD.MM.YYYY HH24:MI');
    l_trx_date_end := to_date(l_json_par.get_string('trx_date_end'),'DD.MM.YYYY HH24:MI');
    
    l_json_value := l_json_par.get('opm_trx_lines');
    l_json_list := json_list(l_json_value); 
    
    -- Дата окончания должна быть больше даты начала
    if l_trx_date_end<=l_trx_date_begin then
        p_result:= 'fail$'||'"Дата окончания обработки" меньше "Даты начала обработки"';
        return;    
    end if;
    
    -- Дата начала обработки меньше текущей
    if l_trx_date_begin> trunc(sysdate,'MI') then
        p_result:= 'fail$'||'"Дата начала обработки" больше текущей даты';
        return;    
    end if;
    
    -- Дата окончания обработки меньше текущей
    if l_trx_date_end> trunc(sysdate,'MI') then
        p_result:= 'fail$'||'"Дата окончания обработки" больше текущей даты';
        return;    
    end if;
    
    -- Даты должны находится в одном периоде
    if trunc(l_trx_date_end,'MM') != trunc(l_trx_date_begin,'MM') then
        p_result:= 'fail$'||'Введенные даты находятся в разных периодах!';
        return;    
    end if;
    
    if (openperiodcheck (p_org_id => 362, p_date => l_trx_date_begin) != 'O') then
        p_result:= 'fail$'||'Введенная дата находится не в открытом периоде!';
        return;
    end if;
    
    -- Сохраняем/Обновляем данные 
    save_process_of_wagons(p_user_id    => p_user_id,
                           p_add_data   => p_add_data,
                           p_result     => l_result
                          );
                        
    if nvl(l_result,'*') not like 'done%' then
       p_result :=l_result;
       return;
    end if;  
    
    for i in 1..l_json_list.count loop
        l_disl_l:=null;
        l_json_value := l_json_list.get(i);
        l_json := json(l_json_value);
        l_disl_line_id := l_json.get_string('line_id');
        
        if l_disl_line_id = 0 then
           l_disl_l.round_id        :=lastMaxRoundCarID(l_json.get_string('car_number'));
           l_disl_l.cont_number     :=l_json.get_string('cont_number');
           l_disl_l.cont_round_id   :=lastMaxRoundContID(l_json.get_string('cont_number'));
           l_disl_line_id           :=get_opm_trx_line_id(l_disl_l);
        end if;
        
        l_disl_lines_m := l_disl_lines_m||l_disl_line_id||'$';
    end loop;
    
    log_new(l_log_id,l_function,'l_disl_lines_m='||l_disl_lines_m);
    
    -- Интерфейс можно запускать, если нет задания
    select count (*) into l_count_batch
      from xx_etw.xx_disl_opm_trx_lines l,
          (select regexp_substr(l_disl_lines_m,'[^$]+',1,level) line_id
             from dual
       connect by level <= regexp_count(l_disl_lines_m,'[^$]+'
           )) line
     where l.disl_lines_id = line.line_id
           and l.batch_id is not null;
    
    if l_count_batch > 0 then
        p_result:= 'fail$По выбранным данным уже создано задание!';
        return;
    end if;
    
    
    
    for c_hdr in (
             select  distinct 
                     null as hdr_id,
                     --x.disl_hdr_id,
                     362 as organization_id, -- унп
                     l.inventory_item_id as prod_item_id,
                     max(l.trx_date_begin) over (partition by l.inventory_item_id) as trx_date,
                     max(x.created_by) over (partition by l.inventory_item_id) as created_by,
                     max(x.creation_date) over (partition by l.inventory_item_id) as creation_date,
                     max(x.last_updated_by) over (partition by l.inventory_item_id) as last_updated_by,
                     max(x.last_update_date) over (partition by l.inventory_item_id) as last_update_date,
                     max(x.created_login) over (partition by l.inventory_item_id) as interface_user_name,
                     'CPRT' as page_name,
                     max(l.trx_date_end) over (partition by l.inventory_item_id) as transaction_date
              from   xx_etw.xx_disl_opm_trx_header_v x,
                     xx_etw.xx_disl_opm_trx_lines l,
                     xx_etw.xx_disl_freight_oebs_v fo,
                     (select regexp_substr(l_disl_lines_m,'[^$]+',1,level) line_id
                        from dual
                      connect by level <= regexp_count(l_disl_lines_m,'[^$]+')) line
             where       1 = 1
                     and x.disl_hdr_id = l.disl_hdr_id
                     and l.inventory_item_id = fo.inventory_item_id(+)
                     and l.disl_lines_id = line.line_id
                     and l.batch_id is null
        
        )
        loop
            l_row_h:=null;
            
            l_row_h.hdr_id              :=xx_mtf.xx_opm_trx_hdr_interface_s.nextval;
            l_row_h.organization_id     :=c_hdr.organization_id;
            l_row_h.prod_item_id        :=c_hdr.prod_item_id;
            l_row_h.trx_date            :=c_hdr.trx_date;
            l_row_h.created_by          :=case when get_user_oebs_id(c_hdr.created_by) = -1 then get_user_oebs_id(247) /*'BOYKOAD'*/ else get_user_oebs_id(c_hdr.created_by) end;
            l_row_h.creation_date       :=c_hdr.creation_date;
            l_row_h.last_updated_by     :=case when get_user_oebs_id(c_hdr.created_by) = -1 then get_user_oebs_id(247) /*'BOYKOAD'*/ else get_user_oebs_id(c_hdr.created_by) end;
            l_row_h.last_update_date    :=c_hdr.last_update_date;
            l_row_h.interface_user_name :=c_hdr.interface_user_name;
            l_row_h.page_name           :=c_hdr.page_name;
            l_row_h.transaction_date    :=c_hdr.transaction_date;
            
            -- Заполняем интерфейсную таблицу
            insert into xx_mtf.xx_opm_trx_hdr_interface values l_row_h;
            
            for c_lns in (
                 select  1 as line_type, -- 1 - продукт 
                         l.inventory_item_id as inventory_item_id, 
                         nvl(l.cont_number,l.car_number) as lot_number, 
                         1 as transaction_quantity, 
                         'ШТ' as transaction_uom, 
                         l_row_h.created_by as created_by, 
                         l.creation_date as creation_date, 
                         l_row_h.last_updated_by as last_updated_by, 
                         l_row_h.last_update_date as last_update_date, 
                         l_row_h.hdr_id as hdr_id, 
                         l_row_h.interface_user_name as interface_user_name,
                         l.disl_lines_id,
                         l.reason_id as trx_reason_id
                  from   xx_etw.xx_disl_opm_trx_lines l,
                         (select regexp_substr(l_disl_lines_m,'[^$]+',1,level) line_id
                            from dual
                          connect by level <= regexp_count(l_disl_lines_m,'[^$]+')) line
                 where   1 = 1 
                         and l.inventory_item_id = c_hdr.prod_item_id
                         and l.disl_lines_id = line.line_id
                         and l.batch_id is null
                         
            
            )
            loop
                l_row_l:=null;
                l_row_l.line_type               :=c_lns.line_type;
                l_row_l.inventory_item_id       :=c_lns.inventory_item_id;
                l_row_l.lot_number              :=c_lns.lot_number;
                l_row_l.transaction_quantity    :=c_lns.transaction_quantity;
                l_row_l.transaction_uom         :=c_lns.transaction_uom;
                l_row_l.created_by              :=c_lns.created_by;
                l_row_l.creation_date           :=c_lns.creation_date;
                l_row_l.last_updated_by         :=c_lns.last_updated_by;
                l_row_l.last_update_login       :=c_lns.last_updated_by;
                l_row_l.last_update_date        :=c_lns.last_update_date;
                l_row_l.hdr_id                  :=c_lns.hdr_id;
                l_row_l.interface_user_name     :=c_lns.interface_user_name;
                l_row_l.lns_id                  :=xx_mtf.xx_opm_trx_lns_interface_s.nextval; 
                l_row_l.trx_reason_id           :=c_lns.trx_reason_id;
                
                -- Заполняем интерфейсную таблицу
                insert into xx_mtf.xx_opm_trx_lns_interface values l_row_l; 
                
                update xx_etw.xx_disl_opm_trx_lines l
                   set xx_opm_trx_lns_id = l_row_l.lns_id
                      ,xx_opm_trx_hdr_id = c_lns.hdr_id
                 where 1=1
                       and l.disl_lines_id = c_lns.disl_lines_id;
            end loop;
             
        end loop;
        
       for c_trx in (
        -- Запускаем импорт 
        select distinct
               l.xx_opm_trx_hdr_id as hdr_id 
          into l_hdr_id
          from xx_etw.xx_disl_opm_trx_lines l,
               (select regexp_substr(l_disl_lines_m,'[^$]+',1,level) line_id
                            from dual
                          connect by level <= regexp_count(l_disl_lines_m,'[^$]+')) line
         where 1=1
               and l.disl_lines_id = line.line_id
       )       
       loop
           l_hdr_id:=c_trx.hdr_id;
           l_interface_msg:='';      
           if nvl(l_hdr_id,0) <> 0 then
                -- запускаем интерфейс
                -- Метафракс: Интерфейс УНП
                l_request_id :=apps.xx_dislocation_helper.xx_opm_interface (p_hdr_id      => l_hdr_id,
                                                                            p_batch_id    => null,
                                                                            p_message     => l_interface_msg
                                                                           );
                
                log_new(l_log_id,l_function,'l_request_id = '||l_request_id); 
                log_new(l_log_id,l_function,'l_interface_msg = '||l_interface_msg);
                
                -- Обновляем номер задания
                UPDATE   xx_etw.xx_disl_opm_trx_lines l 
                   SET   (batch_id, batch_num, lns_interface_status) =
                            (select   hdr.batch_id, hdr.batch_no, ll.trx_interface_status
                               from   gme.gme_batch_header hdr,
                                      xx_mtf.xx_opm_trx_hdr_interface h,
                                      xx_mtf.xx_opm_trx_lns_interface ll
                              where       1 = 1
                                      and h.hdr_id = l_hdr_id
                                      and h.xx_batch_id = hdr.batch_id
                                      and h.hdr_id = ll.hdr_id
                                      and l.xx_opm_trx_lns_id = ll.lns_id
                                      ),
                         request_id = l_request_id
                        ,interface_msg = l_interface_msg
                 WHERE   1 = 1 
                         AND l.xx_opm_trx_hdr_id = l_hdr_id;
                
           else
                p_result:='fail$Нет данных для импорта! l_hdr_id = '||l_hdr_id;
           end if;
       end loop;
       /*
       -- Возвращаем данные
        select   listagg (batch_num, ',') within group (order by 1) as batch_num,
                 listagg (interface_msg, ',') within group (order by 1)  as interface_msg,
                 listagg (interface_status, ',') within group (order by 1)  as interface_status
          into   l_batch_num, l_interface_msg, l_interface_status
          from   (select   distinct
                           l.interface_msg as interface_msg, 
                           batch_num as batch_num,
                           lns_interface_status as interface_status
                    from   xx_etw.xx_disl_opm_trx_lines l,
                           (select regexp_substr(l_disl_lines_m,'[^$]+',1,level) line_id
                            from dual
                          connect by level <= regexp_count(l_disl_lines_m,'[^$]+')) line
                   where   1=1
                           and l.disl_lines_id = line.line_id
                  ) x;
       log_new(l_log_id,l_function,'l_interface_msg = '||l_interface_msg);
       log_new(l_log_id,l_function,'l_batch_num = '||l_batch_num);
       log_new(l_log_id,l_function,'l_interface_status = '||l_interface_status);
       if (l_interface_msg is not null or l_batch_num is null) and nvl(l_interface_status,'*') !='S' then
            if l_batch_num is not null then
                p_result:='fail$По выбранным данным создано задание:'||l_batch_num||',но не создана прочая выдача!'
                         ||'Ошибка:'||nvl(l_interface_msg,l_interface_status)||' | RequestID = '||l_request_id;
            else 
                p_result:='fail$По выбранным данным не создалось задание в OeBS! Ошибка:'||l_interface_msg;
            end if;
       else 
            p_result:='done$! Создана партия в задании OeBS: '||'№'||l_batch_num;
       end if;
       */
       for c_cur in (
        SELECT   DISTINCT NVL (l.cont_number, l.CAR_NUMBER) AS CAR_NUMBER,
                          l.interface_msg AS interface_msg,
                          batch_num AS batch_num,
                          lns_interface_status AS interface_status,
                          request_id
          FROM   xx_etw.xx_disl_opm_trx_lines l,
                 (    SELECT   REGEXP_SUBSTR (l_disl_lines_m,
                                              '[^$]+',
                                              1,
                                              LEVEL)
                                  line_id
                        FROM   DUAL
                  CONNECT BY   LEVEL <= regexp_count (l_disl_lines_m, '[^$]+')) line
         WHERE   1 = 1 AND l.disl_lines_id = line.line_id
     )
     loop
        if c_cur.BATCH_NUM is not null then
            if nvl(c_cur.interface_status,'*') !='S' then
                l_others_msg:=l_others_msg||c_cur.BATCH_NUM||'(REQUEST_ID='||c_cur.REQUEST_ID||')';
            else 
                l_done_msg:=l_done_msg||c_cur.BATCH_NUM||',';
            end if;
        else 
             if nvl(c_cur.interface_status,'*') !='S' or c_cur.interface_msg is not null then
                l_error_msg :=l_error_msg||c_cur.CAR_NUMBER||'('||c_cur.interface_msg||'),';
             end if;
        end if; 
     end loop;
     --DBMS_OUTPUT.put_line('l_done_msg: '||l_done_msg);
     --DBMS_OUTPUT.put_line('l_error_msg: '||l_error_msg);
     --DBMS_OUTPUT.put_line('l_others_msg: '||l_others_msg);
     if l_done_msg is not null then
        p_result:='done$! Создана партия в задании OeBS: '||'№'||regexp_replace(l_done_msg, '[^[:alpha:]]$','')
                    ||case when trim(l_error_msg) is not null then ', Ошибка:'||l_error_msg end
                    ||case when trim(l_others_msg) is not null then ',Не создана прочая выдача:'||l_others_msg end
                    ;
     else
        if l_others_msg is not null then
            p_result:='done$! Создана партия в задании OeBS'||case when trim(l_others_msg) is not null then ', но не создана прочая выдача:'||l_others_msg end;
        else      
            p_result:='fail$По выбранным данным не создалось задание в OeBS! Ошибка:'||l_error_msg;
        end if;
     end if;

    commit;
    
exception
    when others then 
        rollback;
        log_new(l_log_id,l_function,'Erorr = '||sqlerrm);
        p_result:= 'fail$'||sqlerrm; 
end;

    procedure update_info_for_proc_of_wagons (p_car_number varchar2)
    is
        l_round_id number;
    begin
            
            -- Заполняем данными по вагону, который уже ушел
            if xx_dislocation.xx_is_number (p_car_number) then
                if returnLastRound(p_car_number) <> -1 then
                    return;
                else 
                    l_round_id := lastMaxRoundCarID(p_car_number);
                end if;
            else
                if return_last_cont_round(p_car_number) <> -1 then
                    return;
                else
                    l_round_id := lastMaxRoundContID(p_car_number);
                end if;
            end if;
            
            update xx_etw.xx_disl_obj_add_info_tmp 
               set round_id = l_round_id
             where 1=1
                   and round_id = -1;
                   
            update xx_etw.xx_disl_obj_add_info_tmp info_tmp
               set (status,car_type,freight_name,weight_net,weight_dep,weight_gross,owner,car_length) = 
                   (select status
                          ,car_type
                          ,freight_name
                          ,nvl(weight_net,0)
                          ,nvl(weight_dep,0)
                          ,nvl(weight_net,0)+nvl(weight_dep,0)
                          ,owner
                          ,car_length
                      from xx_etw.xx_disl_railcar_add_info         info
                     where 1=1
                       and info.round_id = info_tmp.round_id
                       
                       and info.last_record = 'Y'
                   )
             where 1=1
               and obj_type = 'railcar'
               and info_tmp.round_id = l_round_id
            ;

            update xx_etw.xx_disl_obj_add_info_tmp info_tmp
               set (status,freight_name,weight_net,weight_dep,weight_gross,owner,inv_number) = 
                   (SELECT   status,
                             freight_name,
                             NVL (weight_net, 0),
                             NVL (weight_dep, 0),
                             NVL (weight_net, 0) + NVL (weight_dep, 0),
                             owner,
                             info.inv_number
                      FROM   xx_etw.xx_disl_cont_add_info info
                     WHERE       1 = 1
                             AND info.cont_round_id = info_tmp.round_id
                             AND info.LAST_RECORD = 'Y'
                   )
             where 1=1
               and obj_type = 'cont'
               and info_tmp.round_id = l_round_id;
             update xx_etw.xx_disl_obj_add_info_tmp info_tmp
               set CONT = OBJ_NUMBER,
                   OBJ_NUMBER = (SELECT  MAX (dr.RAILCAR_ID) AS RAILCAR_ID
                          FROM   xx_etw.xx_disl_cont_history chc, xx_etw.xx_disl_round dr
                         WHERE       1 = 1
                                 AND chc.CONT_ROUND_ID = info_tmp.ROUND_ID
                                 AND chc.PLACE_ID = dr.round_id
                                 AND chc.place_type = 'railcar')
             where  obj_type = 'cont';
    end;  

/*******************************************************************************
Функция возвращает вагон/контейнер для формы "Обработка вагонов"
Параметры:
  * p_params - массив данных в формет JSON
*******************************************************************************/
function add_car_for_process_of_wagons(
     p_car_number in  varchar2
) return t_xx_process_of_wagons_table pipelined
is
    l_function      varchar2(100):='add_car_for_process_of_wagons';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_car_number    varchar2(240);
    l_item_id       number;
    l_row           t_xx_process_of_wagons_row;
    ---
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    l_json_val      json_value;
    ---
    l_round_id       number;
    l_count         number:=0;
    l_trx_line_c    xx_etw.xx_disl_opm_trx_lines%rowtype;
    l_car_type      varchar2(20);
         
begin
    
    if xx_is_number (p_car_number) then
        -- Номер вагона
       l_round_id := returnLastRound(p_car_number);
       if l_round_id = -1 then
         l_round_id := lastMaxRoundCarID(p_car_number);
       end if;
       l_car_type := 'raillcar';
    else 
         -- Номер вагона
       l_round_id := return_last_cont_round(p_car_number);
       if l_round_id = -1 then
         l_round_id := lastMaxRoundContID(p_car_number);
       end if;
       l_car_type := 'cont';
    end if;
    
    if l_round_id > 0 then
        select count(*) 
          into l_count 
          from xx_etw.xx_disl_opm_trx_lines l
         where 1=1
               and ((l.round_id = l_round_id and l_car_type = 'raillcar') 
                            or (l.cont_round_id = l_round_id and l_car_type = 'cont')
                           );
               
        if l_count>0 then
            for tmp in (
                select l.*
                      ,to_char(l.trx_date_begin,'DD.MM.YYYY HH24:MI') as trx_date_begin_text
                      ,to_char(l.trx_date_end,'DD.MM.YYYY HH24:MI') as trx_date_end_text
                  from xx_etw.xx_disl_opm_trx_header h,
                       xx_etw.xx_disl_opm_trx_lines l
                 where 1=1
                       and h.disl_hdr_id = l.disl_hdr_id
                       and ((l.round_id = l_round_id and l_car_type = 'raillcar') 
                            or (l.cont_round_id = l_round_id and l_car_type = 'cont')
                           )
            )
            loop
                l_row.BATCH_ID              := tmp.BATCH_ID;
                l_row.BATCH_NUM             := tmp.BATCH_NUM;
                l_row.DISL_LINES_ID         := tmp.DISL_LINES_ID;
                l_row.ROUND_ID              := tmp.ROUND_ID;
                l_row.CAR_NUMBER            := tmp.CAR_NUMBER;
                l_row.CONT_ROUND_ID         := tmp.CONT_ROUND_ID;
                l_row.CONT_NUMBER           := tmp.CONT_NUMBER;
                l_row.FREIGHT_NAME          := tmp.FREIGHT_NAME;
                l_row.INVENTORY_ITEM_ID     := tmp.INVENTORY_ITEM_ID;
                l_row.TRX_DATE_BEGIN_TEXT   := tmp.TRX_DATE_BEGIN_TEXT;
                l_row.TRX_DATE_END_TEXT     := tmp.TRX_DATE_END_TEXT;
                l_row.INTERFACE_STATUS      := case when tmp.batch_num is not null and tmp.lns_interface_status = 'S' then 'Y' 
                                                    when tmp.interface_msg is not null then 'Error' 
                                                    else 'N' 
                                               end;
                
                pipe row (l_row);
            end loop;
        else 
            for tmp in (
                select   0 as disl_lines_id,
                         case when OBJ_TYPE = 'cont' and tmp.id = tmp.cont_ then null
                              else tmp.id 
                         end as car_number,
                         tmp.freight_name,
                         regexp_substr (tmp.cont_,
                                        '[^|]+',
                                        1,
                                        level)
                            as cont_number
                  from   (select   x.*, replace (cont, ' ', '|') as cont_
                            from   table (xx_etw.xx_dislocation.return_child_add_info) x
                           where   cont is not null) tmp
                connect by   level <= regexp_count (tmp.cont_, '[^|]+')
                union
                select   0 as disl_lines_id,
                         tmp.id as car_number,
                         tmp.freight_name,
                         null as cont_number
                  from   (select   x.*
                            from   table (xx_etw.xx_dislocation.return_child_add_info) x
                           where   cont is null) tmp
            )
            loop
                l_row.disl_lines_id     := tmp.disl_lines_id;
                l_row.car_number        := tmp.car_number;
                l_row.cont_number       := tmp.cont_number;
                l_row.freight_name      := tmp.freight_name;
                l_row.interface_status  := 'N';
                pipe row (l_row);
            end loop;
            
            
        end if;
    end if;
    
end;
function check_carnumber_in_db (p_car_number varchar2) return varchar2
is
    l_result    varchar2(100);
    l_round_id  number;
begin
    if xx_is_number (p_car_number) then
        -- Номер вагона
       l_round_id := returnLastRound(p_car_number);
       if l_round_id = -1 then
         l_round_id := lastMaxRoundCarID(p_car_number);
       end if;
    else 
         -- Номер вагона
       l_round_id := return_last_cont_round(p_car_number);
       if l_round_id = -1 then
         l_round_id := lastMaxRoundContID(p_car_number);
       end if;
    end if;
    
    if l_round_id >0 then
        return '1';
    else 
        return '0';
    end if;
end;    
/*********************************************************/


function get_scales_type_list 
return t_xx_scales_type_list_table pipelined
as
    l_row       xx_etw.xx_disl_scales_type_v%rowtype;
begin
    for l_tmp in (select *
                    from xx_etw.xx_disl_scales_type_v
                 )
    loop
        l_row.id := l_tmp.id;
        l_row.scales_type := l_tmp.scales_type;
        pipe row (l_row);
    end loop;
    
end;
function get_define_task (p_define_task_id number) return varchar2
is
    l_define_task   varchar2(240);
begin
    
    begin
        select name into l_define_task
          from xx_etw.xx_disl_define_task_v
         where 1=1
               and ID = p_define_task_id;
    exception when others then return null;
    end;
    return l_define_task;
end;
function get_define_task_list return t_xx_id_name_table pipelined
is
    l_row       t_xx_id_name_row;
begin
    for l_tmp in (select *
                    from xx_etw.xx_disl_define_task_v
                   order by id
                 )
    loop
        l_row.id := l_tmp.id;
        l_row.name := l_tmp.name;
        pipe row (l_row);
    end loop;
end;
    function get_main_menu( 
            p_user_id           varchar2,
            p_station_id        varchar2,
            p_part_site         varchar2 default 'main'
    ) return t_xx_main_menu_table pipelined
    is
    
    l_function      varchar2(100):='get_main_menu';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_row           t_xx_main_menu_row;
    ---
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    l_json_val      json_value;
    ---
    l_station_id    number;
    l_station_name  varchar2(240);
    l_user_id       number;
    --
    l_login         varchar2(240);

    begin
        -- log_new(l_log_id,l_function,'p_user_id ='||p_user_id||' p_station_id = '||p_station_id);
        
        l_user_id:= p_user_id; l_station_id:= p_station_id;
        
        begin
            select du.login into l_login
              from xx_etw.xx_disl_users du 
             where 1=1
                   and du.ID = p_user_id;
        exception 
            when others then l_login:='';
        end;
        
        begin
            select ds.name into l_station_name
              from xx_etw.xx_disl_stations ds
             where ds.station_id = p_station_id;
        exception 
            when others then null;
        end;
        
        for l_tmp in (
            with s_user_data as (
                select   rud.* 
                  from   table (xx_dislocation.return_user_data (l_login)) rud
            )
            select * from (
            select   dm.id,
                     case when dm.menu_code = 'station' then 'Станция '||l_station_name
                          else dm.name 
                     end as menu_name,
                     dm.menu_type as menu_type,
                     dm.parent_id,
                     dm.order_n,
                     dm.paths_url,
                     case when lower(menu_code) = lower('route') 
                                and (root.route_add = 'Y' or root.route_processing = 'Y' or root.route_closing = 'Y') then 'Y'
                          when lower(menu_code) = lower('fixing_device') 
                                    and (root.fix_dev_rule = 'Y' or root.fix_dev_place = 'Y') then 'Y'
                          when lower(menu_code) = lower('control_cars') 
                                    and (root.control_cars = 'Y') then 'Y'
                          when lower(menu_code) = lower('admin') 
                                    and (root.administrator = 'Y') then 'Y'
                          else dm.visible_default
                     end as visible_menu,
                     dm.menu_code
              from   xx_etw.xx_disl_menu dm, s_user_data root
              where 1=1
                    and dm.part_site = p_part_site
            ) x
            where 1=1
            
                  and x.visible_menu = 'Y'
            order by x.parent_id, x.order_n, id
        )
        loop
            l_row.id := l_tmp.id;
            l_row.parent_id := l_tmp.parent_id;
            l_row.menu_name := l_tmp.menu_name;
            l_row.paths_url := l_tmp.paths_url;
            l_row.menu_code := l_tmp.menu_code;
            l_row.menu_type := l_tmp.menu_type;
            
            pipe row (l_row);
        end loop;
    end;
    
function xx_disl_last_railcar_info (p_round_id number, p_un_loading_from_subs number, p_info varchar2) return varchar2
is
    l_info_value varchar2(240);
begin
    
    if upper(p_info) = 'WEIGHT_DEP' then
        begin
            SELECT   weight_dep into l_info_value
              FROM   (SELECT   MAX (drai.weight_dep)
                                  KEEP (DENSE_RANK FIRST ORDER BY add_info_id)
                                  weight_dep
                        FROM   xx_etw.xx_disl_railcar_add_info drai
                       WHERE       1 = 1
                               AND drai.round_id = p_round_id
                               AND p_un_loading_from_subs != 1
                      UNION ALL
                      SELECT   MAX (drai.weight_dep)
                                  KEEP (DENSE_RANK LAST ORDER BY add_info_id)
                        FROM   xx_etw.xx_disl_railcar_add_info drai
                       WHERE       1 = 1
                               AND drai.round_id = p_round_id
                               AND p_un_loading_from_subs = 1)
             WHERE   weight_dep IS NOT NULL;
        exception when others then l_info_value:='';
        end;
    end if;
    return l_info_value;
exception 
    when others then return null;
end;


/*
    Контроль качества по продуктам
        Создание:
            1) Пробы
            2) Результатов пробы
            
*/


function get_product_for_freight (p_add_data      varchar2,
                                  p_user_id       varchar2
                                 ) return t_xx_product_table pipelined
is
    l_function      varchar2(100):='get_product_for_freight';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_row           t_xx_product_row;
    ---
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    l_json_val      json_value;
    ---
    l_freight       varchar2(240);
begin
    log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
    l_json_par := xx_wms.json(p_add_data);
    l_freight := l_json_par.get_string('freight');
    
    for item in (
        select 'ГП0098' as item_code, 'ГП0098' as item_name from dual
            where upper(l_freight) = upper('карбамид')
        union 
        select 'ГП0011' as item_code, 'ГП0011' as item_name from dual
            where upper(l_freight) = upper('метанол')
        union 
        select 'ДС5001' as item_code, 'ДС5001' as item_name from dual
            where 1=2 -- add 10.07.2024 BekmansurovRR
                  and upper(l_freight) = upper('метанол')
    )
    loop
        l_row.code := item.item_code;              -- item_code
        l_row.name := item.item_name;              -- item_name
        
        pipe row (l_row);
    end loop;
end;

function get_specid_for_product (p_product varchar2) return number
is
    l_spec_id   number;
    l_item_id   number;
begin
    
    begin
        select inventory_item_id
          into l_item_id
          from inv.mtl_system_items_b
         where 1=1
               and segment1 = p_product
               and organization_id = 362; 
    exception 
        when no_data_found then 
            l_item_id := 0;
    end;
    
    select spec_id into l_spec_id
      from apps.gmd_specifications_vl
     where 1 = 1 
           --and spec_status = 700 -- Утверждено для общего использования
           and spec_name = p_product
           and inventory_item_id = l_item_id; 
    
    return l_spec_id;
exception when others then 
    return 0;
end;

-- Функция возвращает шапку таблицы для формы "Export пробы в OeBS"
function get_sample_tbl_header (p_add_data      varchar2,
                                p_user_id       varchar2
                               ) return t_xx_sample_tbl_header_table pipelined
is
    l_function      varchar2(100):='get_sample_tbl_header';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_row           t_xx_sample_tbl_header_row;
    ---
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    l_json_val      json_value;
    ---
    l_product       varchar2(240);
    l_item_code     varchar2(240);
    l_spec_id       number;        -- Спецификация
    l_code_class    varchar2(240); -- Класс проверки
    l_user_adm      varchar2(10):='N';
    ---
    TYPE qc_test_values IS RECORD(
          test_id           apps.gmd_qc_test_values.test_id%type,
          test_value_id     apps.gmd_qc_test_values.test_value_id%type,
          value_char        apps.gmd_qc_test_values.value_char%type
    );
    
    v_qc_test_values qc_test_values;
    
    cursor c_qc_test_values (p_test_id number) is
        select gtv.test_value_id, 
               gtv.test_id, 
               gtv.value_char
          from apps.gmd_qc_test_values gtv
         where 1=1
               and gtv.test_id = p_test_id; 
    
    function get_test_code_required (p_test_code in varchar2, 
                                     p_item_code in varchar2) return varchar2
    is
        l_result varchar2(1):='N';
    begin
        
        if p_item_code in ('ГП0098') then
            if p_test_code in ('ОГП/1','ОГП/20','ОГП/8','ОГП/6','ОГП/15','ОГП/15/0','ОГП/16','ОГП/17','ОГП/13','ОГП/14','ОГП/13/1'
                               ,'АЗОТ/К','АММИАК/К','ВВВ','РАССЫП/К','ОСТАТОК6/К'
                              )
                then  return 'Y';
            end if;                             
        elsif p_item_code in ('ГП0011') then
            if p_test_code in ('ОГП/15','ОГП/16', 'ОГП/17', 'ОГП/18/1', 'ОГП/18/2', 'ОГП/18/3','ОГП/2','ОГП/4','ОГП/6','ОГП/8') then
                return 'Y';
            end if;
        end if;
        
        return l_result;
    end;                                  
begin
    log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
    l_json_par := xx_wms.json(p_add_data);
    
    l_product := l_json_par.get_string('product');
    l_item_code := l_json_par.get_string('item_code_oebs');
    -- add 28.11.2024 Нужно переписать
    /*select max(nvl(administrator,'N')) as admins
      into l_user_adm
      from xx_etw.xx_disl_user_credential uc
          ,xx_etw.xx_disl_credential      c
     where 1=1
       and uc.user_id = p_user_id
       and uc.credential_id = c.credential_id(+);*/
       
    -- add 28.11.2024
    l_user_adm := get_user_cred_rights_val(p_user_id => p_user_id, p_rights_code => 'administrator');
    
    if l_product in ('Карбамид','Метанол') then
       -- Спецификация
       l_spec_id :=xx_etw.xx_dislocation.get_specid_for_product(l_item_code);
       /* Спецификация: ГП0098,  Версия: 1  Продукт: ГП0098 */
       --l_spec_id := 5676;
                           
       -- Класс проверки
       l_code_class :='КК0041';
    else 
        l_spec_id := -1;
    end if;
    log_new(l_log_id,l_function,'l_product = '||l_product);
    log_new(l_log_id,l_function,'l_spec_id = '||l_spec_id);
    log_new(l_log_id,l_function,'l_code_class = '||l_code_class);
    
    for item in (
          select   gqt.test_id, 
                   gqt.test_code, 
                   gqt.test_desc, 
                   case when gqt.TEST_TYPE = 'V' then 'SET_VALUES' -- Список значений проверки
                        when gqt.TEST_TYPE = 'N' then 'NUMBER'
                        when gqt.TEST_TYPE in ('U','T') then 'TEXT'
                        else gqt.TEST_TYPE
                   end as data_type
                  ,gqt.min_value_num
                  ,gqt.max_value_num
                  ,case when gqt.TEST_TYPE = 'N' then to_char(gs.target_value_num,'FM999999999.999')
                        else gs.target_value_char
                   end as target_value_char
                  ,to_number(nvl(gs.attribute20,gs.seq)) sort_num
                  ,case when gqt.test_code in('ОГП/8' -- нетто , кг
                                             ,'ОГП/6' -- брутто, кг
                                             ,'ОГП/15'-- Тара, кг (пл, цс, вагона, п/в)
                                             ,'ОГП/15/0' -- Тара проверенная, кг
                                             ,'ОГП/13' -- Грузоподъемность, т
                                              ) 
                        and l_user_adm !='Y'
                        then 'Y'
                        else 'N'
                   end as disabled
                   
            from   apps.gmd_spec_tests_vl gs, 
                   apps.gmd_qc_tests_vl gqt
           where       1 = 1
                   and gs.spec_id = l_spec_id
                   and gs.test_id = gqt.test_id
                   and (gqt.test_class = l_code_class or nvl(gs.target_value_char,to_char(gs.target_value_num)) is not null)
        order by   to_number(nvl(gs.attribute20,gs.seq))
    )
    loop
        l_row.test_id := item.test_id;              -- ID
        l_row.sample_code := item.test_code;        -- Код 
        l_row.title := item.test_desc;              -- Описание 
        l_row.required_t := get_test_code_required(item.test_code, l_item_code); /*item.required_t;*/        -- Обязательное поле 
        l_row.data_type := item.data_type;          -- Тип данных
        l_row.min_value_num := item.min_value_num;  -- MIN значение
        l_row.max_value_num := item.max_value_num;  -- MAX значение
        l_row.target_value_char := item.target_value_char;  -- Контрольное значение
        l_row.disabled := item.disabled;  -- Недоступен для редактирования
        
        l_json_list := json_list(); 
        
        for l_samples_tbl in c_qc_test_values(item.test_id)
        loop
            
            
            v_qc_test_values.test_id := l_samples_tbl.test_id;
            v_qc_test_values.test_value_id := l_samples_tbl.test_value_id;
            v_qc_test_values.value_char := l_samples_tbl.value_char;
            
            l_json_tmp := json();
            l_json_tmp.put('test_id',v_qc_test_values.test_id);
            l_json_tmp.put('test_value_id',v_qc_test_values.test_value_id);
            l_json_tmp.put('value_char',v_qc_test_values.value_char);
            
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        l_row.qc_test_values := l_json_list.to_char(false); -- Прооба
        pipe row (l_row);
    end loop;
    
end;


/*
    Выводим данные на форму "Экспорт пробы"
*/

function get_sample_name_for_product (p_item_name   in varchar2, 
                                      p_lot_number  in varchar2) return varchar2
is
    l_sample_name   varchar2(80);
begin
    -- Правило создания пробы:
      -- [Цифровой код позиции готовой продукции]\[номер_партии]
    l_sample_name:= substr (p_item_name, 3)
                            ||'/'
                            ||'_' 
                            ||p_lot_number;
    return l_sample_name;
end;                                      

function get_disl_samples_info (p_add_data      varchar2,
                                p_user_id       varchar2
                               ) return t_xx_car_from_samples_table pipelined
is
    l_function      varchar2(100):='get_disl_samples_info';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_row           t_xx_car_from_samples_row;
    ---
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    l_json_val      json_value;
    --- 
    l_user_adm      varchar2(10);
    l_user_div      varchar2(10);
    l_freight       xx_disl_obj_add_info_tmp.freight_name%type;
    l_type          varchar2(240);
    l_status        varchar2(10);
    l_date_from     date;
    l_date_to       date;
    l_batch_num     varchar2(240);-- Номер задания
    l_item_code     inv.mtl_system_items_b.segment1%type;
    
    ---
    TYPE sample_def IS RECORD(
          spec_id           apps.gmd_spec_tests_vl.spec_id%type,
          test_id           apps.gmd_qc_tests_vl.test_id%type,
          test_code         apps.gmd_qc_tests_vl.test_code%type,
          freight_name      varchar2(240),
          product           varchar2(240),
          car_number        varchar2(240),
          cont_number       varchar2(240),
          lot_number        varchar2(240),
          weight_net        number,
          weight_dep        number,
          weight_gross      number,
          car_tonnage       number,
          car_axles         number,
          car_model         varchar2(240),
          car_count_zpu     inv.mtl_eam_asset_attr_values.c_attribute4%type,
          target_value_char apps.gmd_spec_tests_vl.target_value_char%type,
          weight_ud         varchar2(50),
          oebs_sample_id    number,
          disl_sample_id    number,
          oebs_sample_no    varchar2(240),
          disl_sample_no    varchar2(240),
          car_volume        varchar2(240),
          type_of_packaging varchar2(240), -- Род упаковки -- add 11.07.2024 
          method_of_weight  varchar2(240) -- Способ определения веса -- add 11.07.2024 
    );
    v_sample_def sample_def;
    l_default_value varchar2(500):='';
    l_car_overload  varchar2(1) :='N';
    ---
    -- Шапка таблицы проб
    cursor get_tbl_header (p_add_data   varchar2, 
                           p_user_id    number) is
    select x.* 
     from table (xx_etw.xx_dislocation.get_sample_tbl_header(p_add_data,p_user_id)) x;  
    
    -- Значение по-умолчанию для ОГП Результата пробы
    function default_samples_value (p_sample_def   in sample_def) return varchar2
    is
        l_default_value     varchar2(500);
        function reset_the_value (p_freight_name in varchar2, p_test_code in varchar2, p_value in varchar2) return varchar2
        is
        begin
            if upper(p_freight_name) in ('МЕТАНОЛ') then
                if p_test_code in ('ОГП/14','ОГП/11','ОГП/13','ОГП/20','ОГП/3','ОГП/4','ОГП/5') then
                    return '';
                end if;
            end if;
            
            return p_value;
        end;
    begin
        
        if upper(p_sample_def.freight_name) in ('КАРБАМИД','МЕТАНОЛ') then 
            l_default_value := case p_sample_def.test_code
                                    WHEN 'ОГП/1' then to_char(nvl(p_sample_def.type_of_packaging,p_sample_def.target_value_char)) -- Род упаковки
                                    WHEN 'ОГП/2' THEN to_char(p_sample_def.weight_ud) -- уд.вес 
                                    WHEN 'ОГП/8' THEN to_char(p_sample_def.weight_net) -- нетто , кг
                                    WHEN 'ОГП/6' THEN to_char(p_sample_def.weight_gross) -- брутто, кг
                                    WHEN 'ОГП/15' THEN to_char(p_sample_def.weight_dep) -- Тара, кг (пл, цс, вагона, п/в)
                                    WHEN 'ОГП/15/0' THEN to_char(p_sample_def.weight_dep) -- Тара проверенная, кг
                                    WHEN 'ОГП/13' THEN to_char(p_sample_def.car_tonnage)  -- Грузоподъемность, т
                                    WHEN 'ОГП/14' THEN to_char(p_sample_def.car_axles) -- Количество осей
                                    WHEN 'ОГП/17' THEN to_char(p_sample_def.car_count_zpu) -- Количество ЗПУ
                                    WHEN 'ОГП/20' THEN nvl(to_char(p_sample_def.car_model),to_char(p_sample_def.target_value_char)) -- Тип цистерны/вид контейнера
                                    WHEN 'ОГП/13/1' THEN to_char(p_sample_def.car_volume) -- Объем кузова, цистерны, куб.м
                                    WHEN 'ОГП/19' THEN to_char(nvl(p_sample_def.method_of_weight,p_sample_def.target_value_char)) --Способ определения веса
                                    ELSE to_char(p_sample_def.target_value_char)
                               end;
            
        end if;

        l_default_value := reset_the_value(p_sample_def.freight_name,p_sample_def.test_code,l_default_value);
        
        return l_default_value;
    exception 
        when others then return '';
    end;
    
    function get_samples_value (p_sample_def    in sample_def) return varchar2
    is
        l_default_value     varchar2(500);
        l_function          varchar2(100):='get_disl_samples_info';
        l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    begin
        
        if nvl(p_sample_def.oebs_sample_id,0) <> 0 then
            select nvl(gr.result_value_char,to_char(gr.result_value_num))
              into l_default_value
              from gmd.gmd_results gr
             where 1=1
                   and gr.test_id = p_sample_def.test_id
                   and gr.sample_id = p_sample_def.oebs_sample_id;
        else 
            select gr.result_value_char
              into l_default_value
              from xx_etw.xx_disl_results gr
             where 1=1
                   and gr.test_id = p_sample_def.test_id
                   and gr.sample_id = p_sample_def.disl_sample_id;
        end if;
    
        return l_default_value;
    exception 
        when others then 
            return '';
    end; 
    
    -- Вывод номера ЗПУ для вагона
    function get_car_zpu (p_car_number varchar2) return varchar2
    is 
        l_value inv.mtl_eam_asset_attr_values.c_attribute4%type;
    begin
        begin
        
            select   meaav.c_attribute4 -- количество зпу
              into   l_value
              from   inv.mtl_eam_asset_attr_values meaav,
                     apps.mtl_eam_asset_attr_groups_v meaag,
                     csi.csi_item_instances cii,
                     inv.mtl_categories_b mc
             where       1 = 1
                     and meaag.descriptive_flex_context_code = meaav.attribute_category
                     and meaag.association_id = meaav.association_id
                     and cii.instance_id = meaav.maintenance_object_id
                     and cii.instance_number = p_car_number
                     and meaav.maintenance_object_type(+) = 3
                     and cii.category_id = mc.category_id
                     and mc.segment1 = 'Вагоны'
                     and meaag.descriptive_flex_context_code = 'XXEAM_PS' -- атрибуты подвижного состава
                     and meaav.c_attribute4 is not null;                  -- количество зпу
        exception 
            when others then 
                
                return null;
        end;
        
        return l_value;
    end;
    
begin
    log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
    log_new(l_log_id,l_function,'p_user_id: ' || p_user_id);
    
    l_json_par := xx_wms.json(p_add_data);
    
    -- Дата начала  
    if (l_json_par.exist('p_date_from')) then
        l_date_from := to_date(l_json_par.get_string('p_date_from'),'DD.MM.YYYY HH24:MI'); 
    else 
        l_date_from:= null;
    end if;
    
    -- Дата окончания  
    if (l_json_par.exist('p_date_to')) then
        l_date_to := to_date(l_json_par.get_string('p_date_to'),'DD.MM.YYYY HH24:MI'); 
    else 
        l_date_to:= null;
    end if;
    
    -- Груз
    if (l_json_par.exist('product')) then
        l_freight := l_json_par.get_string('product'); 
    else 
        l_freight:= null;
    end if;
    
    -- Позиция
    if (l_json_par.exist('item_code_oebs')) then
        l_item_code := l_json_par.get_string('item_code_oebs'); 
    else 
        l_item_code:= null;
    end if;
    
    -- Вид загрузки
    if (l_json_par.exist('p_type')) then
        l_type := l_json_par.get_string('p_type'); 
    else 
        l_type:= null;
    end if;
    
    -- Номер задания
    if (l_json_par.exist('p_batch_num')) then
        l_batch_num := l_json_par.get_string('p_batch_num'); 
    else 
        l_batch_num:= null;
    end if;
    
    -- Номер задания
    if (l_json_par.exist('p_status')) then
        l_status := l_json_par.get_string('p_status'); 
    else 
        l_status:= '0';
    end if;
    
    log_new(l_log_id,l_function,'l_freight: ' || l_freight);
    log_new(l_log_id,l_function,'l_item_code: ' || l_item_code);
    log_new(l_log_id,l_function,'l_date_from: ' || to_char(l_date_to,'DD.MM.YYYY HH24:MI:SS'));
    log_new(l_log_id,l_function,'l_date_to: ' || to_char(l_date_to,'DD.MM.YYYY HH24:MI:SS'));
    log_new(l_log_id,l_function,'l_type: ' || l_type);
    log_new(l_log_id,l_function,'l_status: ' || l_status);
    log_new(l_log_id,l_function,'l_batch_num: ' || l_batch_num);
    
    -- add 28.11.2024 Нужно переписать
    /*select max(nvl(administrator,'N')) as admins
      into l_user_adm
      from xx_etw.xx_disl_user_credential uc
          ,xx_etw.xx_disl_credential      c
     where 1=1
       and uc.user_id = p_user_id
       and uc.credential_id = c.credential_id(+);*/
    
    -- add 28.11.2024
    l_user_adm := get_user_cred_rights_val(p_user_id => p_user_id, p_rights_code => 'administrator');

    begin
        select division_id
          into l_user_div
          from xx_etw.xx_disl_user_div_hist ud
         where 1=1
           and ud.user_id = p_user_id
           and ud.end_date is null
        ;     
    exception
        when no_data_found then l_user_div:=-1;
    end;
    log_new(l_log_id,l_function,'l_user_adm: ' || l_user_adm);
    log_new(l_log_id,l_function,'l_user_div: ' || l_user_div);
    
    for item in (
        
        select dense_rank() over (order by date_post,date_start,date_end,who_looked,who_start,who_end,si.freight_name,si.batch_no) id
              ,si.freight_name
              ,msib.segment1 as product
              ,si.batch_no
              ,si.date_post
              ,si.car_number
              ,si.cont_number
              ,si.batch_id
              ,si.shop_info_id
              ,mtln.lot_number
              ,si.weight_net as weight_net_tonn
              ,si.weight_net*1000 as weight_net
              ,si.weight_dep*1000 as weight_dep
              ,(si.weight_net + si.weight_dep)*1000 as weight_gross
              ,mmt.locator_id
              ,si.owner
              --,count (distinct mtln.lot_number) over (partition by si.batch_no) gr_count
              ,1 as gr_count
              ,nvl(ds.sample_no,gs.sample_no) as sample_no
              ,gs.sample_no as oebs_sample_no
              ,gs.sample_id as oebs_sample_id
              ,ds.sample_id as disl_sample_id
              ,ds.sample_no as disl_sample_no
              ,case when upper(l_freight) = 'МЕТАНОЛ' and upper(l_item_code) = 'ГП0011' then 'ТАНК-КОНТЕЙНЕР'
                    else null
               end as type_of_packaging -- add 11.07.2024
              ,case when upper(l_freight) = 'МЕТАНОЛ' and upper(l_item_code) = 'ГП0011' then 'ПО РАСЧЕТУ'
                    else null
               end as method_of_weight -- add 11.07.2024
               
          from (select date_post                                              date_post_d
                      ,to_char(date_post,'dd.mm.yy hh24:mi')                  date_post
                      ,to_char(si.date_start,'dd.mm.yy hh24:mi')                 date_start
                      ,to_char(si.date_end,'dd.mm.yy hh24:mi')                   date_end
                      ,to_char(date_zayavka_uvod,'dd.mm.yy hh24:mi')          date_zayavka_uvod
                      ,to_char(date_uvod,'dd.mm.yy hh24:mi')                  date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,who_looked                                             who_looked_add
                      ,who_start                                              who_start_add
                      ,who_end                                                who_end_add
                      ,who_zayavka                                            who_zayavka_add
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,si.freight_name                                           freight_name
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,drai.WEIGHT_DEP                                        WEIGHT_DEP
                      ,si.refusal                                             refusal
                      ,r.railcar_id                                           car_number
                      ,null                                                   cont_number
                      ,round_type                                             round_type
                      ,batch_id                                               batch_id
                      ,batch_no                                               batch_no
                      ,si.shop_info_id                                        shop_info_id
                      ,drai.OWNER                                             owner  
                  from xx_etw.xx_disl_shop_info  si
                      ,xx_etw.xx_disl_railcar_add_info drai
                      ,xx_etw.xx_disl_round      r
                 where si.round_type = 'railcar'
                   and si.last_record = 'Y'
                   and si.ROUND_ID = drai.ROUND_ID
                   and drai.last_record = 'Y'
                   and si.round_id = r.round_id
                   and r.station_hist_id_out is null
                 union all 
                select date_post                                              date_post_d
                      ,to_char(date_post,'dd.mm.yy hh24:mi')                  date_post
                      ,to_char(si.date_start,'dd.mm.yy hh24:mi')                 date_start
                      ,to_char(si.date_end,'dd.mm.yy hh24:mi')                   date_end
                      ,to_char(date_zayavka_uvod,'dd.mm.yy hh24:mi')          date_zayavka_uvod
                      ,to_char(date_uvod,'dd.mm.yy hh24:mi')                  date_uvod
                      ,who_looked_id                                          who_looked
                      ,who_start_id                                           who_start
                      ,who_end_id                                             who_end
                      ,who_zayavka_id                                         who_zayavka
                      ,who_looked                                             who_looked_add
                      ,who_start                                              who_start_add
                      ,who_end                                                who_end_add
                      ,who_zayavka                                            who_zayavka_add
                      ,si.created_by                                          created_by
                      ,si.creation_date                                       creation_date
                      ,si.last_update_by                                      last_update_by
                      ,dcai.freight_name                                           freight_name
                      ,si.weight_net                                          weight_net
                      ,si.weight_net_begin                                    weight_net_begin
                      ,case 
                            -- add 11.07.2024
                            when lower(l_freight) = lower('Метанол') 
                                    and lower(l_item_code) = lower('ГП0011')
                            then dcai.WEIGHT_DEP
                            else drai.WEIGHT_DEP                              
                       end as                                                 WEIGHT_DEP
                      ,si.refusal                                             refusal
                      ,(select r.railcar_id
                          from xx_etw.xx_disl_cont_history ch
                              ,xx_etw.xx_disl_round        r
                         where 1=1
                           and ch.cont_round_id = cr.cont_round_id
                           and si.creation_date between ch.in_date_sys and nvl(ch.out_date_sys,sysdate) 
                           
                           and ch.place_id = r.round_id
                       )
                                                                              car_number
                      ,cr.cont_number                                         cont_number
                      ,round_type                                             round_type
                      ,batch_id                                               batch_id
                      ,batch_no                                               batch_no
                      ,si.shop_info_id                                        shop_info_id
                      ,drai.OWNER                                             owner
                  from xx_etw.xx_disl_shop_info             si
                      ,xx_etw.xx_disl_cont_round            cr
                      ,xx_etw.xx_disl_railcar_add_info drai
                      ,xx_etw.xx_disl_cont_add_info dcai -- add 11.07.2024
                      ,xx_disl_cont_history ch -- add 05.12.2024
                 where si.round_type = 'cont'
                   and si.last_record = 'Y'
                   
                   --and si.ROUND_ID = drai.ROUND_ID -- rem 05.12.2024
                   -- add 05.12.2024 begin
                   and ch.place_id = drai.round_id
                   and ch.CONT_ROUND_ID = cr.cont_round_id
                   and ch.place_type = 'railcar'
                   and ch.out_date_sys is null
                   and drai.last_record = 'Y'
                   -- add 05.12.2024 end
                   
                   and si.round_id = cr.cont_round_id
                   and cr.cont_history_out is null
                   -- add 11.07.2024
                   and cr.cont_round_id = dcai.cont_round_id   
                   and dcai.last_record = 'Y'
               ) si
               left join xx_etw.xx_disl_samples ds
                    on ds.shop_info_id = si.shop_info_id 
               ,gme.gme_batch_header gbh 
               ,gme.gme_material_details gmd
               ,inv.mtl_system_items_b msib
               ,inv.mtl_material_transactions mmt 
               ,inv.mtl_transaction_lot_numbers mtln
               left join gmd.gmd_samples gs
                    on gs.lot_number = mtln.lot_number
                       and gs.organization_id = 362
         where 1=1
           and si.date_post_d between l_date_from and l_date_to
           and si.batch_id = gbh.batch_id -- add 20.06.2020
           and si.batch_id = mmt.transaction_source_id
           and mmt.transaction_id = mtln.transaction_id
           and si.batch_no = nvl (l_batch_num,si.batch_no)
           and substr(mtln.LOT_NUMBER,1,instr(mtln.LOT_NUMBER,'_',1,1)-1) = nvl(si.cont_number,si.car_number)
           and ((l_status = '0' and gs.sample_no is null 
                    --and nvl(ds.sample_id,0)  not in (6251,6252)
                 ) /*Проба не отражена в OeBS*/
                or (l_status = '1' 
                        and nvl(ds.sample_no, gs.sample_no) is not null
                        and gs.inventory_item_id = mmt.inventory_item_id
                        and (regexp_like (replace(nvl(ds.sample_no, gs.sample_no),' ',''),'^(\d{4}/)?\d{8}_\d{10}$') -- Формат шаблона для значений (0098/58306143_2303220455 или 58306143_2303220455), значение н.п 58306143_2303220455/1 - т.к это "порча пробы"
                            or regexp_like (replace(nvl(ds.sample_no, gs.sample_no),' ',''),'^\d{4}/[A-Z]{4}\d{7}_\d{10}:\d{2}$') -- add 15.07.2024
                            or regexp_like (replace(nvl(ds.sample_no, gs.sample_no),' ',''),'^\d{4}/[A-Z]{4}\d{7}_\d{10}') -- add 15.07.2024
                            )
                        
                    )  /*Проба отражена в OeBS*/
                --or (l_status = '1' and nvl(ds.sample_id,0)  in (6251,6252))
               )
           and gbh.BATCH_ID = gmd.BATCH_ID
           and gmd.LINE_TYPE = '1' -- продукт
           and msib.INVENTORY_ITEM_ID = gmd.INVENTORY_ITEM_ID
           and msib.ORGANIZATION_ID = 362
           and lower(si.freight_name) = lower(l_freight) 
           and lower(msib.segment1) = lower(l_item_code) -- add 09.07.2024 BekmansurovRR по наряду 0000057911
           
           and si.round_type = nvl(l_type,si.round_type)
           
           and (   si.created_by = p_user_id
                or l_user_adm = 'Y'
                or exists(
                    select 'x'
                      from xx_etw.xx_disl_user_div_hist ud
                     where 1=1
                       and ud.user_id = si.created_by
                       and si.creation_date between nvl(ud.start_date,to_date('01.01.2016','dd.mm.yyyy')) and nvl(ud.end_date,to_date('31.12.2999','dd.mm.yyyy'))
                       and ud.division_id = l_user_div
                   )
               )
         having sum (mmt.transaction_quantity) <> 0
            group by date_post,date_start,date_end,who_looked,who_start,who_end,si.freight_name,si.batch_no
                  ,msib.segment1 
                  ,si.car_number
                  ,si.cont_number
                  ,si.batch_id
                  ,si.shop_info_id
                  ,mtln.lot_number
                  ,si.weight_net
                  ,si.weight_dep
                  ,mmt.locator_id
                  ,si.owner
                  ,nvl(ds.sample_no,gs.sample_no)
                  ,gs.sample_no
                  ,gs.sample_id 
                  ,ds.sample_id 
                  ,ds.sample_no
         order by
               date_post,si.freight_name,si.batch_no,si.car_number,si.cont_number,nvl(ds.sample_no,gs.sample_no)
    )
    loop
        v_sample_def:= null;
        
        l_row.id := item.id;
        l_row.freight_name := item.freight_name;
        l_row.product := item.product;
        l_row.date_post := item.date_post;
        l_row.car_number := item.car_number;
        l_row.cont_number := item.cont_number;
        l_row.batch_no := item.batch_no;
        l_row.batch_id := item.batch_id;
        l_row.shop_info_id := item.shop_info_id;
        l_row.lot_number := item.lot_number;
        l_row.locator_id := item.locator_id;
        l_row.spec_id := xx_etw.xx_dislocation.get_specid_for_product(item.product);
        l_row.owner := item.owner;
        l_row.weight_net_tonn := item.weight_net_tonn;
        l_row.gr_count := item.gr_count;
        l_row.sample_no := item.sample_no;
        
        l_json_list := json_list(); 
        
        v_sample_def.freight_name:=item.freight_name;
        v_sample_def.product:=item.product;
        v_sample_def.car_number:=item.car_number;
        v_sample_def.cont_number:=item.cont_number;
        v_sample_def.lot_number:=item.lot_number;
        v_sample_def.weight_net:=item.weight_net;
        v_sample_def.weight_dep:=item.weight_dep;
        v_sample_def.weight_gross:=item.weight_gross;
        v_sample_def.type_of_packaging := item.type_of_packaging; -- add 11.07.2024
        v_sample_def.method_of_weight := item.method_of_weight; -- add 11.07.2024
        
        
        v_sample_def.oebs_sample_id:=item.oebs_sample_id;
        v_sample_def.disl_sample_id:=item.disl_sample_id;
        
        begin
            select nsi.car_tonnage, nsi.car_axles, nsi.car_model, nsi.car_volume
              into v_sample_def.car_tonnage
                  ,v_sample_def.car_axles
                  ,v_sample_def.car_model
                  ,v_sample_def.car_volume
              from xx_etw.etw_car_nsi nsi 
             where nsi.car_number = item.car_number
                   and lower(l_freight) = lower('карбамид') ;
        exception when others then 
            v_sample_def.car_tonnage:= null;
            v_sample_def.car_axles:= null;
            v_sample_def.car_volume:= null;
        end; 
        
        if  lower(l_freight) = lower('карбамид') then
            v_sample_def.car_count_zpu:=get_car_zpu(item.car_number); 
        elsif lower(l_freight) = lower('метанол') then
            v_sample_def.car_count_zpu:='3';
            v_sample_def.weight_ud:='0.796';
        end if;
        
        for l_samples_tbl in get_tbl_header(p_add_data, p_user_id)
        loop
            l_default_value :='';
            
            v_sample_def.test_id := l_samples_tbl.test_id;
            v_sample_def.test_code := l_samples_tbl.sample_code;
            v_sample_def.target_value_char := l_samples_tbl.target_value_char;
            
            l_json_tmp := json();
            l_json_tmp.put('test_id',l_samples_tbl.test_id);
            l_json_tmp.put('sample_code',l_samples_tbl.sample_code);
            l_json_tmp.put('required',l_samples_tbl.required_t);
            if l_status = '1' then
                l_default_value := get_samples_value (v_sample_def);
                l_json_tmp.put('value', l_default_value);
            else
                l_default_value := default_samples_value (v_sample_def);
                l_json_tmp.put('value', l_default_value);
                
                if (v_sample_def.test_code = 'ОГП/8') then
                    -- Перегруз вагона
                    -- Грузоподьемность - нетто,кг
                    -- if (v_sample_def.car_tonnage - (v_sample_def.weight_net/1000)<=0.15) 
                    if (v_sample_def.car_tonnage - ((v_sample_def.weight_net/1000)+0.2)<=0)
                            and lower(l_freight) = lower('карбамид') 
                    then
                        l_car_overload :='Y';
                    else 
                        l_car_overload :='N';
                    end if;
                    
                else 
                    l_car_overload :='N';
                end if;
            end if;
            l_json_tmp.put('car_overload', l_car_overload);
            
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        l_row.samples := l_json_list.to_char(false); -- Прооба
        
        pipe row (l_row);
    end loop;
end;                               
procedure export_samples_info (p_add_data       in  clob,
                               p_user_id        in  number,
                               p_result         out varchar2
                              )
is

   l_function              VARCHAR2 (100) := 'export_samples_info';
   l_log_id                NUMBER := xx_etw.xx_disl_log_seq.NEXTVAL ();
   --- PLJSON
   l_json                  xx_wms.json;
   l_json_list             xx_wms.json_list;
   l_json_value            xx_wms.json_value;
   --- samplesMS
   l_js_samplesMS_list     xx_wms.json_list;
   l_js_samplesMS          xx_wms.json_value;
   --- Импорт пробы
   xx_import_spec_tbl      xx_etw.xx_dislocation.t_import_samples_tbl;
   l_samples_rec           xx_etw.xx_disl_samples%ROWTYPE;
   lx_qc_samples_rec       gmd.gmd_samples%ROWTYPE;
   l_samples_result_rec    xx_etw.xx_disl_results%ROWTYPE;
   lx_results_tab          apps.gmd_api_pub.gmd_results_tab;
   -- Тип для результатов проверок (тестов) -----------------------
   TYPE type_import_results_table
   IS
      TABLE OF apps.gmd_results_pub.results_rec
         INDEX BY BINARY_INTEGER;

   xx_import_results_tbl   type_import_results_table;
   user_exception exception;
   ---
   im_samples_rec          gmd.gmd_samples%ROWTYPE;
   v_indx                  NUMBER := 0;
   tmp_vchar               VARCHAR2 (32767);
   l_org_r                 inv.mtl_parameters%ROWTYPE;
   l_user_name             VARCHAR2 (240) := 'ANONYMOUS OEBS';
   l_user_id               NUMBER;
   l_sample_id             NUMBER;
   l_msg_out               CLOB;
   l_freight_name          VARCHAR2 (100);
   l_status                varchar2(10);
   l_msg                   varchar2(1000);
   l_delimiter_line        VARCHAR2 (100);
   l_car_overload          VARCHAR2 (32767);
   ---- Для отправки писем -----
   l_request_id            number; 
   l_dir_report            varchar2 (50) := 'XX_DISL_CONCURRENT_PATH'; --Директория файлов
   x_filename              varchar2 (100);
   l_out_filetype          varchar2 (50);
   x_filetype              varchar2 (50);
   x_file_rep              blob;
   ----
   l_item_code             inv.mtl_system_items_b.segment1%type;
   l_item_desc             inv.mtl_system_items_b.description%type;
   l_batch_no              varchar2(50);
   x_file                  blob;
   x_file_name             varchar2(150);
   l_rpad                  INT := 40;

   CURSOR c_sample ( p_batch_id NUMBER )
   IS
        SELECT   ds.SAMPLE_ID,
                 ds.SAMPLE_NO,
                 ds.SAMPLE_DESC,
                 ds.LOT_NUMBER,
                 ds.batch_no,
                 msib.segment1 product,
                 msib.description product_desc,
                 ds.weight_net,
                 ds.SAMPLE_QTY_UOM
          FROM   xx_etw.xx_disl_samples ds, 
                 inv.mtl_system_items_b msib
         WHERE       1 = 1
                 and ds.STATUS = 'NEW'
                 AND ds.BATCH_ID = p_batch_id
                 AND msib.INVENTORY_ITEM_ID = ds.INVENTORY_ITEM_ID
                 AND msib.organization_id = 81
      ORDER BY   ds.SAMPLE_ID,
                 ds.SAMPLE_NO,
                 ds.batch_no,
                 ds.SAMPLE_DESC,
                 ds.LOT_NUMBER,
                 msib.segment1,
                 msib.description;

   CURSOR c_result (p_sample number )
   IS
      (SELECT   gqt.test_code,
                gqt.test_desc,
                dr.result_value_char AS result_value
         FROM   xx_etw.xx_disl_samples ds,
                xx_etw.xx_disl_results dr,
                apps.gmd_qc_tests_vl gqt
        WHERE       1 = 1
                and ds.STATUS = 'NEW'
                AND ds.SAMPLE_ID = p_sample
                AND dr.SAMPLE_ID = ds.SAMPLE_ID
                AND gqt.TEST_ID = dr.TEST_ID);
BEGIN
   
   DBMS_LOB.createtemporary (l_msg_out, TRUE);
   l_json_list := xx_wms.json_list (p_add_data);

   BEGIN
      SELECT   user_id
        INTO   l_user_id
        FROM   apps.fnd_user
       WHERE   user_name = l_user_name;
   EXCEPTION
      WHEN NO_DATA_FOUND
      THEN
         l_status := 'false';
         l_msg := 'Не определился USER_ID для ' || l_user_name;
         RAISE user_exception;
      WHEN OTHERS
      THEN
         l_status := 'false';
         l_msg := 'Ошибка при определении пользователя! Error = ' || SQLERRM;
         RAISE user_exception;
   END;

   tmp_vchar := 'Импорт данных по параметрам загрузки и контроля качества '  || CHR (10) || CHR (10);
   DBMS_LOB.append (l_msg_out, tmp_vchar);
   FOR i IN 1 .. l_json_list.COUNT
   LOOP
      l_samples_rec := NULL;

      SELECT   *
        INTO   l_org_r
        FROM   inv.mtl_parameters
       WHERE   organization_code = 'УНП';

      l_json_value := l_json_list.get (i);
      l_json := json (l_json_value);
      
      l_item_code:=l_json.get_string ('product');
      l_batch_no :=l_json.get_string ('batch_no');
      l_freight_name:=l_json.get_string ('freight_name');
      l_samples_rec.shop_info_id:=l_json.get_string ('shop_info_id');
      l_samples_rec.weight_net:=l_json.get_string ('weight_net_tonn');
      
      
      l_samples_rec.status := 'NEW';      -- Новая запись. Готова для создания
      l_sample_id := xx_etw.xx_disl_samples_seq.NEXTVAL;
      l_samples_rec.sample_id := l_sample_id;
      l_samples_rec.creation_date := SYSDATE;
      l_samples_rec.last_update_date := SYSDATE;
      l_samples_rec.freight_name := l_freight_name;
      l_samples_rec.CREATED_BY := p_user_id;
      l_samples_rec.LAST_UPDATED_BY := p_user_id;
      
      -- Правило создания пробы:
      -- [Цифровой код позиции готовой продукции]\[номер_партии]
      l_samples_rec.sample_no :=
            SUBSTR (l_item_code, 3)
         || '/'
         || l_json.get_string ('lot_number');
      l_samples_rec.source := 'I';                  -- Источник ['I'='Запасы']
      l_samples_rec.sample_desc :=
         l_samples_rec.sample_no || ' - загрузка данных из "Дислокация ПН"';
      l_samples_rec.organization_id := l_org_r.organization_id;
      -- Лаборатория КК [362=УНП];
      l_samples_rec.lot_number := l_json.get_string ('lot_number');
      -- Спецификация
      l_samples_rec.spec_id := l_json.get_string ('spec_id');  -- Спецификация
      l_samples_rec.batch_id := l_json.get_string ('batch_id');     -- Задание
      l_samples_rec.batch_no :=l_batch_no;
      l_samples_rec.org_code := l_json.get_string ('owner');       -- Владелец
      l_samples_rec.sample_qty_uom := 'Т';
      l_samples_rec.sample_qty := 1;
      l_samples_rec.date_drawn := SYSDATE;                    -- Даты Получено
      
      log_new(l_log_id,l_function,'l_samples_rec[spec_id]='||l_samples_rec.spec_id);
      log_new(l_log_id,l_function,'l_samples_rec[batch_id]='||l_samples_rec.batch_id);
      log_new(l_log_id,l_function,'l_samples_rec[l_batch_no]='||l_samples_rec.batch_no);
      log_new(l_log_id,l_function,'l_samples_rec[owner]='||l_samples_rec.org_code);


      -- Позиция
      BEGIN
         SELECT   inventory_item_id,
                  description
           INTO   l_samples_rec.inventory_item_id,
                  l_item_desc
           FROM   inv.mtl_system_items_b
          WHERE       1 = 1
                  AND segment1 = l_item_code
                  AND organization_id = l_samples_rec.organization_id;
      EXCEPTION
         WHEN NO_DATA_FOUND THEN
            l_status := 'false';
            l_msg :=  'Не найдена ID позиции для ' || l_json.get_string ('product');
            RAISE user_exception;
      END;

      l_js_samplesMS := l_json.get ('samplesMS');
      l_js_samplesMS_list := xx_wms.json_list (l_js_samplesMS);

      -- Массив Результат проб
      FOR j IN 1 .. l_js_samplesMS_list.COUNT
      LOOP
         l_samples_result_rec := NULL;

         l_json_value := l_js_samplesMS_list.get (j);
         l_json := json (l_json_value);

         l_samples_result_rec.sample_id := l_sample_id;
         l_samples_result_rec.result_id := xx_etw.xx_disl_results_seq.NEXTVAL;

         l_samples_result_rec.created_by := l_samples_rec.created_by;
         l_samples_result_rec.creation_date := l_samples_rec.creation_date;
         l_samples_result_rec.last_updated_by := l_samples_rec.last_updated_by;
         l_samples_result_rec.last_update_date := l_samples_rec.last_update_date;

         l_samples_result_rec.test_id := l_json.get_string ('test_id');
         l_samples_result_rec.result_value_char := l_json.get_string ('value');
         l_samples_result_rec.car_overload := l_json.get_string ('caroverload');
         
         log_new(l_log_id,l_function,'l_samples_result_rec.test_id = '||l_samples_result_rec.test_id);
         log_new(l_log_id,l_function,'l_samples_result_rec.result_value_char = '||l_samples_result_rec.result_value_char);
         log_new(l_log_id,l_function,'l_samples_result_rec.car_overload = '||l_samples_result_rec.car_overload);

         INSERT INTO xx_etw.xx_disl_results VALUES   l_samples_result_rec;
      END LOOP;

      INSERT INTO xx_etw.xx_disl_samples VALUES   l_samples_rec;
      im_samples_rec.organization_id := l_samples_rec.organization_id;
      im_samples_rec.sampler_id := l_user_id;           -- fnd_global.user_id;
      im_samples_rec.sample_type := 'I';                                 -- ??
      im_samples_rec.lab_organization_id := l_samples_rec.organization_id;
      im_samples_rec.sample_no := l_samples_rec.sample_no;            -- Проба
      im_samples_rec.sample_desc := l_samples_rec.sample_desc;
      im_samples_rec.sample_disposition := '1P';
      -- Состояние ['1P'='Отложено']
      im_samples_rec.inventory_item_id := l_samples_rec.inventory_item_id;
      -- Позиция
      im_samples_rec.source := l_samples_rec.source;
      -- Источник ['I'='Запасы']
      im_samples_rec.lot_number := l_samples_rec.lot_number;
      im_samples_rec.sample_qty := l_samples_rec.sample_qty;
      im_samples_rec.sample_qty_uom := l_samples_rec.sample_qty_uom;
      im_samples_rec.date_drawn := l_samples_rec.date_drawn;  -- Даты Получено
      
      
      
      tmp_vchar := '     Продукт: '|| l_item_code ||' '||l_item_desc||CHR(10);
      DBMS_LOB.append (l_msg_out, tmp_vchar);
      tmp_vchar := '       Проба: '|| im_samples_rec.sample_no ||CHR(10);
      DBMS_LOB.append (l_msg_out, tmp_vchar);
      tmp_vchar := '    Описание: '|| im_samples_rec.sample_desc ||CHR(10);
      DBMS_LOB.append (l_msg_out, tmp_vchar);
      tmp_vchar := 'Номер партии: '|| im_samples_rec.lot_number ||CHR(10);
      DBMS_LOB.append (l_msg_out, tmp_vchar);
      tmp_vchar := '     Задание: '|| l_batch_no ||CHR(10);
      DBMS_LOB.append (l_msg_out, tmp_vchar);
      
      log_new(l_log_id,l_function,'shop_info_id = '||l_samples_rec.shop_info_id);
      log_new(l_log_id,l_function,'sampler_id = '||im_samples_rec.sampler_id);
      log_new(l_log_id,l_function,'sample_no = '||im_samples_rec.sample_no);
      log_new(l_log_id,l_function,'sample_desc = '||im_samples_rec.sample_desc);
      log_new(l_log_id,l_function,'lab_organization_id = '||im_samples_rec.lab_organization_id);
      log_new(l_log_id,l_function,'inventory_item_id = '||im_samples_rec.inventory_item_id);
      
      log_new(l_log_id,l_function,'l_user_id = '||l_user_id);
      log_new(l_log_id,l_function,'organization_id = '||im_samples_rec.organization_id);
      log_new(l_log_id,l_function,'lab_organization_id = '||im_samples_rec.lab_organization_id);
      log_new(l_log_id,l_function,'sample_disposition = '||im_samples_rec.sample_disposition);
      log_new(l_log_id,l_function,'source = '||im_samples_rec.source);
      log_new(l_log_id,l_function,'lot_number = '||im_samples_rec.lot_number);
      log_new(l_log_id,l_function,'sample_qty = '||im_samples_rec.sample_qty);
      log_new(l_log_id,l_function,'sample_qty_uom = '||im_samples_rec.sample_qty_uom);
      log_new(l_log_id,l_function,'date_drawn = '||im_samples_rec.date_drawn);
      
      log_new(l_log_id,l_function,'Begin xx_import_gmd_samples.');
      apps.xx_dislocation_helper.xx_import_gmd_samples (p_user_login        => l_user_name,
                                                        p_samples_rec       => im_samples_rec,
                                                        p_out_samples_rec   => lx_qc_samples_rec,
                                                        p_out_results_tab   => lx_results_tab,
                                                        p_return_status     => l_status,
                                                        p_err_msg           => l_msg);
      
      
      log_new(l_log_id,l_function,'l_status = '||l_status);
      log_new(l_log_id,l_function,'l_msg = '||l_msg);
      log_new(l_log_id,l_function,'OeBS sample_id = '||lx_qc_samples_rec.sample_id);
      
      IF l_status = 'E'
      THEN
         l_status := 'false';
         l_msg := 'Во время создания пробы произошла ошибка! ' || l_msg;
         RAISE user_exception;
      END IF;
      
      log_new(l_log_id,l_function,'End xx_import_gmd_samples.');
      -- Перенесем результаты
      DECLARE
         lx_results_rec             gmd.gmd_results%ROWTYPE;
      BEGIN
         -- **********************************************************
         -- Сохраним данные LX_RESULTS_TAB для переноса результатов
         xx_import_results_tbl.delete;
         
         l_delimiter_line := '-------------------- ---------------' || CHR (10);
         DBMS_LOB.append (l_msg_out, l_delimiter_line);
         tmp_vchar := 'Проверка             Результат' ||CHR(10);
         DBMS_LOB.append (l_msg_out, tmp_vchar);
         DBMS_LOB.append (l_msg_out, l_delimiter_line);

         FOR v_cnt IN NVL (lx_results_tab.FIRST, 1) .. NVL (
                                                          lx_results_tab.LAST,
                                                          0
                                                       )
         LOOP
            xx_import_results_tbl (v_cnt).result_value := '';
            xx_import_results_tbl (v_cnt).result_id := lx_results_tab (v_cnt).result_id;
            xx_import_results_tbl (v_cnt).sample_id := lx_results_tab (v_cnt).sample_id;
            xx_import_results_tbl (v_cnt).test_id := lx_results_tab (v_cnt).test_id;

            BEGIN
               SELECT   result_value_char
                 INTO   xx_import_results_tbl (v_cnt).result_value
                 FROM   xx_etw.xx_disl_results
                WHERE       1 = 1
                        AND sample_id = l_sample_id
                        AND test_id = lx_results_tab (v_cnt).test_id;
            EXCEPTION
               WHEN OTHERS THEN
                  xx_import_results_tbl (v_cnt).result_value := '';
            END;

            BEGIN
               SELECT   test_code
                 INTO   xx_import_results_tbl (v_cnt).test_code
                 FROM   apps.gmd_qc_tests_vl gqt
                WHERE   1 = 1 
                        AND test_id = lx_results_tab (v_cnt).test_id;
            EXCEPTION
               WHEN NO_DATA_FOUND THEN
                  xx_import_results_tbl (v_cnt).test_code := NULL;
                  l_msg := (RPAD ( ' *** ОШИБКА: получения контрольного значения из спецификации ', 80, '*' ));
            END;
         END LOOP;

         lx_results_tab.delete;                         -- на всякий случай :)

         FOR v_indx IN NVL (xx_import_results_tbl.FIRST, 1) .. NVL ( xx_import_results_tbl.LAST, 0)
         LOOP
            tmp_vchar := RPAD (xx_import_results_tbl (v_indx).test_code, 20);
            tmp_vchar := tmp_vchar||xx_import_results_tbl (v_indx).result_value ||CHR(10);
            DBMS_LOB.append (l_msg_out, tmp_vchar);

            IF xx_import_results_tbl (v_indx).result_value IS NOT NULL
            THEN
               -- авто COMMIT ? после вызова gmd_results_pub.record_results - РАЗОБРАТЬСЯ !!!
               --log_new(l_log_id,l_function,'Begin record_results ['||v_indx||']');
               apps.xx_dislocation_helper.xx_import_gmd_result (
                      p_user_name            => l_user_name,
                      p_result_rec           => xx_import_results_tbl (v_indx),
                      p_return_status        => l_status,
                      p_err_msg              => l_msg
                   );

               IF l_status <> 'S'
               THEN
                  l_msg := ( RPAD (' *** ОШИБКА: ' || l_msg || ' ', 80, '*'));
                  RAISE user_exception;
               END IF;
               --log_new(l_log_id,l_function,'End record_results ['||v_indx||']');
            END IF;
         END LOOP;
         --DBMS_LOB.append (l_msg_out, l_delimiter_line);
      END;
      
      if nvl(lx_qc_samples_rec.sample_id,0) = 0 then
        l_msg := 'Ошибка! Не создалась проба (sample_id = 0) для партии '||l_samples_rec.lot_number;
        RAISE user_exception;
      else
        UPDATE  xx_etw.xx_disl_samples
          SET   oebs_sample_id = lx_qc_samples_rec.sample_id
       WHERE   1 = 1 
               AND sample_id = l_samples_rec.sample_id;
      end if;
   END LOOP;
   -- Отправляем письма 
   -- Уведомление о результатах отработки интерфейса - рассылка по эл.почте по согласованному списку для каждого продукта
   -- Продукт:  лаборатория + ответственный на произв.площадке
    DBMS_LOB.createtemporary (l_msg_out, TRUE);
       
    FOR samp IN (  SELECT   batch_id, batch_no, sum (weight_net) as weight_net,
                               substr(LOT_NUMBER,instr(LOT_NUMBER,'_',1,1)+1) as lot_number,
                               sample_qty_uom
                        FROM   xx_etw.xx_disl_samples ds
                       WHERE   1 = 1
                               and ds.STATUS = 'NEW'
                    GROUP BY   batch_id,batch_no, substr(LOT_NUMBER,instr(LOT_NUMBER,'_',1,1)+1),sample_qty_uom )
    LOOP
          l_car_overload := null;
          tmp_vchar := 'Итого по партии ['||samp.lot_number||'] :' || samp.weight_net||samp.sample_qty_uom||CHR (10);
          DBMS_LOB.append (l_msg_out, tmp_vchar);
          FOR l_samples_tbl IN c_sample (samp.batch_id)
          LOOP
             tmp_vchar := '          Продукт: ' || l_samples_tbl.product|| ' '|| l_samples_tbl.product_desc|| CHR (10);
             DBMS_LOB.append (l_msg_out, tmp_vchar);
             tmp_vchar := '            Проба: ' || l_samples_tbl.sample_no || CHR (10);
             DBMS_LOB.append (l_msg_out, tmp_vchar);
             tmp_vchar := '         Описание: ' || l_samples_tbl.sample_desc || CHR (10);
             DBMS_LOB.append (l_msg_out, tmp_vchar);
             tmp_vchar := '     Номер партии: ' || l_samples_tbl.lot_number ||' ['||to_char(l_samples_tbl.weight_net)||' '||l_samples_tbl.SAMPLE_QTY_UOM||']'||CHR (10);
             DBMS_LOB.append (l_msg_out, tmp_vchar);
             tmp_vchar := '          Задание: ' || l_samples_tbl.batch_no || CHR (10);
             DBMS_LOB.append (l_msg_out, tmp_vchar);
             l_delimiter_line :=
                '--------------------------------------- ---------------' || CHR (10);
             DBMS_LOB.append (l_msg_out, l_delimiter_line);
             tmp_vchar := RPAD('Проверка',l_rpad)||RPAD('Результат',l_rpad)|| CHR (10);
             DBMS_LOB.append (l_msg_out, tmp_vchar);
             DBMS_LOB.append (l_msg_out, l_delimiter_line);

             FOR l_result IN c_result (l_samples_tbl.sample_id)
             LOOP
                tmp_vchar :=
                   RPAD (l_result.test_code || '[' || l_result.test_desc || ']',
                         l_rpad);
                tmp_vchar := tmp_vchar || l_result.result_value || CHR (10);
                DBMS_LOB.append (l_msg_out, tmp_vchar);
             END LOOP;
             
          
          END LOOP;
          
          -- Активируем вложения 
          apps.xx_mtf_send_mail_pkg.attachments := apps.xx_mtf_send_mail_pkg.attach_list ();
          tmp_vchar := CHR (10)||CHR (10);
          DBMS_LOB.append (l_msg_out, tmp_vchar);
          begin
              SELECT LISTAGG (SUBSTR (ds.lot_number, 1, INSTR (ds.lot_number, '_', 1, 1) - 1), '; ')
                        WITHIN GROUP (ORDER BY ds.lot_number)    AS car_overload
                INTO l_car_overload
                FROM xx_etw.xx_disl_results dr, xx_etw.xx_disl_samples ds
                WHERE     dr.sample_id = ds.sample_id
                        AND NVL (dr.car_overload, 'N') = 'Y'
                        AND ds.status = 'NEW';
          exception when others then 
            l_car_overload := null;
          end;
          if trim(l_car_overload) is not null then
            l_car_overload:= '<p style="color:red;">Внимание: Перегруз!<br>Список перегруженных вагонов:'||l_car_overload||'</p>';
          end if;
          
          x_file := apps.xx_dislocation_helper.clob2blob(l_msg_out);
          x_file_name := 'report_import_'||to_char(sysdate,'DDMMYYYY_HH24MISS')||'.txt';
          
          x_file_rep := null;
            -- Запускаем отчет XX_ETW_DISL_009
          l_request_id := apps.xx_dislocation_helper.start_xx_etw_disl_009
                                                                    (P_USER_ID      => 1,
                                                                     P_FREIGHT      => l_freight_name,
                                                                     P_DATE_FROM    => to_char(trunc(sysdate-2),'YYYY/MM/DD HH24:MI:SS'),
                                                                     P_DATE_TO      => to_char(trunc(sysdate+1),'YYYY/MM/DD HH24:MI:SS'),
                                                                     P_STATUS       => null,
                                                                     P_TYPE         => null,
                                                                     P_BATCH_NO     => samp.batch_no); 
            log_new(l_log_id,l_function,'request_id[XX_ETW_DISL_009]'||l_request_id);
            apps.xx_mtf_send_mail_pkg.get_report_file (p_request_id => l_request_id,
                                                       p_dir        => l_dir_report,
                                                       l_filename   => x_filename,
                                                       l_file       => x_file_rep,
                                                       l_filetype   => l_out_filetype); --процедура возвращает файл запроса.

        for c_email in (
            select * 
              from xx_etw.xx_disl_sample_mail 
             where nvl(enable,'Y') = 'Y'
                   and product = l_freight_name
           )
        loop
          apps.xx_mtf_send_mail_pkg.attachments := apps.xx_mtf_send_mail_pkg.attach_list ();
          
          if nvl(c_email.RUN_XX_ETW_DISL_009, 'N') = 'Y' then
            x_filetype := apps.xx_mtf_send_mail_pkg.content_type (l_out_filetype);
            -- Добавляем во вложение отчет по Простоям_ПП
            apps.xx_mtf_send_mail_pkg.add_attachment (P_BLOB          => x_file_rep,
                                                      P_FILENAME      => 'Отчет_Простои_ПП.xls',
                                                      P_ATTACH_MIME   => x_filetype); 
          end if;
          -- Добавляем во вложение файл по результату работы интерфейса
          apps.xx_mtf_send_mail_pkg.add_attachment (P_BLOB          => x_file,
                                                    P_FILENAME      => x_file_name,
                                                    P_ATTACH_MIME   => 'txt'); 
          apps.xx_mtf_send_mail_pkg.send_mail (
                        p_sender         =>'noreply@metafrax.ru',               --отправитель
                        p_recipient      =>c_email.email,                       --получатель               
                        p_subject        =>'Уведомление. Дислокация ПН. Интерфейс по загрузке продукта '||l_freight_name||'. Партия:'||samp.lot_number||'/Пробы.Качество',              --Заголовок
                        p_text_msg       =>'Интерфейс по загрузке продукта '
                                                ||l_freight_name
                                                ||'. Партия:'||samp.lot_number||'/Пробы.Качество. Результат во вложении.'
                                                ||l_car_overload
                                                                               
                        );
          log_new(l_log_id,l_function,'Письмо отправлено '
                                        ||c_email.email
                                        ||'. Партия:'||samp.lot_number
                                        ||' Кол-во вложений:'||APPS.xx_mtf_send_mail_pkg.attachments.count);
        end loop;
        
        DBMS_LOB.createtemporary (l_msg_out, TRUE);
   END LOOP;

   DBMS_LOB.freetemporary (l_msg_out);
   
   UPDATE   xx_etw.xx_disl_samples
      SET   status = 'CREATED'
   WHERE   1 = 1 
           and status = 'NEW';
   
   l_status := 'done'; l_msg := 'Данные успешно созданы!';
   p_result := l_status||'$'||l_msg;
   commit;
   
EXCEPTION
   WHEN user_exception
   THEN
      ROLLBACK;
      l_status := 'false';
      log_new(l_log_id,l_function,'ОШИБКА! Все действия по документу ОТМЕНЕНЫ! p_status= '
                           || l_status
                           || ' p_msg = '
                           || l_msg);
      p_result := l_status||'$'||l_msg;                     
   WHEN OTHERS
   THEN
      ROLLBACK;
      l_status := 'false';
      l_msg := SQLERRM;
      log_new(l_log_id,l_function,'ОШИБКА! Все действия по документу ОТМЕНЕНЫ p_status= '
                           || l_status
                           || ' p_msg = '
                           || l_msg);
     p_result := l_status||'$'||l_msg;                      
END;

-- add 26.09.2023 Ввод контейнеров (вручную)
function entry_foreign_container(p_user_id      number,
                                 p_add_data     varchar2,
                                 p_date_fact    varchar2) return varchar2
is
    l_function              varchar2(100) := 'entry_foreign_container';
    l_log_id                NUMBER := xx_etw.xx_disl_log_seq.nextval ();
    -----
    l_json                  xx_wms.json;
    l_json_list             xx_wms.json_list;
    l_json_value            xx_wms.json_value;
    l_exists_cont           varchar2(2400);
    ----
    l_cont_round_row        xx_etw.xx_disl_cont_round%rowtype;   
    l_cont_history_row      xx_etw.xx_disl_cont_history%rowtype;
    l_cont_history_row_cur  xx_etw.xx_disl_cont_history_cur%rowtype;
    l_cont_add_info_row     xx_etw.xx_disl_cont_add_info%rowtype;
    l_disl_relation         xx_etw.xx_disl_relations%rowtype;
    -- Есть ли контейнер сейчас в системе/на путях/на платформе
    FUNCTION check_container_in_rawllway (p_container_number VARCHAR2)
        RETURN VARCHAR2
    IS
        l_result          VARCHAR2 (240);
        l_cont_round_id   NUMBER;
    BEGIN
        BEGIN
            SELECT cont_round_id
              INTO l_cont_round_id
              FROM xx_etw.xx_disl_cont_round
             WHERE CONT_NUMBER = p_container_number AND CONT_HISTORY_OUT IS NULL;

            IF l_cont_round_id IS NOT NULL
            THEN
                l_result := 'true';
            END IF;
        EXCEPTION
            WHEN NO_DATA_FOUND
            THEN
                l_result := NULL;
            WHEN OTHERS
            THEN
                l_result := '*';
        END;
        RETURN l_result;
    END;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id);
    log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
    log_new(l_log_id,l_function,'p_date_fact = '||p_date_fact);
    
    l_json := xx_wms.json(p_add_data);
    l_json_value := l_json.get('array_info');
    l_json_list := xx_wms.json_list(l_json_value);
    
    for i in 1..l_json_list.count loop
            l_cont_round_row := null;
            l_cont_history_row := null;
            l_cont_history_row_cur := null;
            l_cont_add_info_row := null;
            l_disl_relation := null;
            
            
            l_json_value := l_json_list.get(i);
            l_json := xx_wms.json(l_json_value); 
            
            l_cont_round_row.CONT_NUMBER := l_json.get_string('contNumber');
            
            if check_container_in_rawllway(l_cont_round_row.CONT_NUMBER) is not null then
               l_exists_cont :=l_exists_cont||l_cont_round_row.CONT_NUMBER||',';
            else
                l_cont_round_row.cont_round_id := xx_etw.xx_disl_cont_round_seq.nextval();
                l_cont_history_row.cont_history_id := xx_etw.xx_disl_cont_history_seq.nextval();
                l_cont_round_row.cont_history_in := l_cont_history_row.cont_history_id;
                l_cont_history_row.cont_round_id := l_cont_round_row.cont_round_id;
                
                begin
                    select ei.invoice_id,
                           ei.inv_number
                      into l_cont_add_info_row.invoice_id,
                           l_cont_add_info_row.inv_number
                      from xx_etw.etw_invoice ei
                     where 1=1
                           and ei.inv_number = l_json.get_string('contNumber');
                exception 
                    when others then
                        l_cont_add_info_row.INVOICE_ID :=null;
                        l_cont_add_info_row.INV_NUMBER :=null;
                end;
                
                l_cont_history_row.place_type := l_json.get_string('newPlaceType');-- на платформу / пути
                
                l_cont_history_row.place_id := case when l_cont_history_row.place_type = 'railcar' then xx_etw.xx_dislocation.returnLastRound(l_json.get_string('newPlace')) 
                                                    else l_json.get_string('newPlace')
                                               end; 
                l_cont_history_row.in_date_sys := to_date(p_date_fact,'DD.MM.YYYY HH24:MI:SS');
                l_cont_history_row.in_date_fact := to_date(p_date_fact,'DD.MM.YYYY HH24:MI:SS');
                l_cont_history_row.in_user := p_user_id;
                
                l_cont_history_row_cur.cont_round_id := l_cont_history_row.cont_round_id;
                l_cont_history_row_cur.place_id := l_cont_history_row.place_id; -- на платформу / пути
                l_cont_history_row_cur.place_type := l_cont_history_row.place_type;-- на платформу / пути
                l_cont_history_row_cur.cont_history_id_in := l_cont_history_row.cont_history_id;
                l_cont_add_info_row.add_info_id := xx_etw.xx_disl_cont_add_info_seq.nextval();
                
                l_cont_add_info_row.cont_round_id := l_cont_round_row.cont_round_id; 
                l_cont_add_info_row.cont_number := l_cont_round_row.cont_number;
                l_cont_add_info_row.owner := l_json.get_string('owner'); 
                l_cont_add_info_row.status := l_json.get_string('status');
                l_cont_add_info_row.freight_name := l_json.get_string('freightName');
                l_cont_add_info_row.weight_net := nvl(l_json.get_string('weightNet'),0)/1000;
                l_cont_add_info_row.weight_dep := nvl(l_json.get_string('weightDep'),0)/1000;
                l_cont_add_info_row.add_info_type := 'A';
                l_cont_add_info_row.last_record := 'Y';
                l_cont_add_info_row.last_update_date := sysdate;
                l_cont_add_info_row.last_update_user_id := p_user_id;
                l_cont_add_info_row.need_load_cont_info := 'N';
                l_cont_add_info_row.date_begin := to_date(p_date_fact,'DD.MM.YYYY HH24:MI:SS');
                
                if l_cont_history_row.place_type = 'area' then
                    l_disl_relation.ID := l_cont_round_row.cont_number;
                    l_disl_relation.TYPE := 'cont';
                    
                    l_disl_relation.PARENT_ID := l_cont_history_row.place_id;
                    l_disl_relation.PARENT_TYPE := l_cont_history_row.place_type;
                    l_disl_relation.FLAG_COME := 'Y';
                    
                    select nvl(max(R_ORDER),0)+1 
                      into l_disl_relation.R_ORDER
                      from xx_etw.xx_disl_relations
                     where PARENT_ID = l_cont_history_row_cur.place_id
                           and type = 'cont'
                           and FLAG_COME = 'Y';
                    
                    
                end if;
                                
                -- Добавляем данные
                insert into xx_etw.xx_disl_cont_round
                values l_cont_round_row;  
                
                insert into xx_etw.xx_disl_cont_history
                values l_cont_history_row;
                
                insert into xx_etw.xx_disl_cont_history_cur
                values l_cont_history_row_cur;
                 
                insert into xx_etw.xx_disl_cont_add_info
                values l_cont_add_info_row;  
                
                if l_cont_history_row.place_type = 'area' then
                    insert into xx_etw.xx_disl_relations 
                    values l_disl_relation;
                end if;
            end if;
                        
            log_new(l_log_id,l_function,' cont_number = '||l_cont_round_row.cont_number );
            log_new(l_log_id,l_function,' place_type = '||l_cont_history_row.place_type );
            log_new(l_log_id,l_function,' place_id = '||l_cont_history_row.place_id );
            
    end loop;
    l_exists_cont := substr(l_exists_cont,1,length(l_exists_cont)-1);
    
    log_new(l_log_id,l_function,' l_exists_cont = '||l_exists_cont );
    return 'done'||'$'||'Программа завершилась успешно!'
                      ||case when l_exists_cont is not null then 'В системе уже зарегистрированы контейнера:'||l_exists_cont 
                        end;
        
    exception when others then
        return 'fail$'||'Ошибка:'||sqlerrm;
    end;
-- add 20.12.2023 BekmansurovRR
-- Вывод доставки по последней транзакции по партии
    -- по продуктам: Метанол
function get_deliveri_name (p_car_number in varchar2 ) return varchar2
    IS
      l_deliveri_name   VARCHAR2 (240);
   BEGIN
      BEGIN
         WITH s_mmt
                AS (SELECT   DISTINCT lot_number, mmt_max.transaction_id
                      FROM   (  SELECT   mtln.lot_number,
                                         MAX(mmt.transaction_id)
                                            KEEP (DENSE_RANK LAST ORDER BY
                                                                     mmt.transaction_date,
                                                                     mmt.transaction_id NULLS LAST)
                                            transaction_id
                                  FROM   inv.mtl_material_transactions mmt,
                                         inv.mtl_system_items_b msib,
                                         inv.mtl_transaction_lot_numbers mtln,
                                         inv.mtl_item_locations mil
                                 WHERE   1 = 1
                                         AND msib.inventory_item_id =
                                               mmt.inventory_item_id
                                         AND msib.organization_id =
                                               mmt.organization_id
                                         AND msib.segment1 = 'ГП0011'
                                         AND msib.organization_id = 362 /*унп*/
                                         AND mmt.organization_id = 362 /*унп*/
                                         AND mmt.locator_id =
                                               mil.inventory_location_id
                                         AND mmt.transaction_id =
                                               mtln.transaction_id
                                         AND SUBSTR (mtln.lot_number, 1, 8) =
                                               p_car_number
                                         AND mmt.transaction_date >=
                                               TO_DATE ('01.09.2022',
                                                        'DD.MM.YYYY')
                                         AND mtln.transaction_date >=
                                               TO_DATE ('01.09.2022',
                                                        'DD.MM.YYYY')
                              GROUP BY   mtln.lot_number) mmt_max,
                             inv.mtl_material_transactions mmt
                     WHERE   1 = 1
                             AND mmt.transaction_id = mmt_max.transaction_id)
         SELECT   mmt.deliveri_name into l_deliveri_name
           FROM   (  SELECT   wdd.tracking_number, wnd.NAME deliveri_name
                       FROM   (SELECT   SUBSTR (mmt.LOT_NUMBER,
                                                1,
                                                INSTR (mmt.LOT_NUMBER,
                                                       '_',
                                                       1,
                                                       1)
                                                - 1)
                                           car_number,
                                        mmt.LOT_NUMBER,
                                        mmt.transaction_id
                                 FROM   s_mmt mmt
                                WHERE   1 = 1
                                        AND mmt.lot_number LIKE p_car_number || '%') mmt_max,
                              inv.mtl_material_transactions mmt,
                              inv.mtl_item_locations mil,
                              inv.mtl_transaction_types mtt,
                              wsh.wsh_new_deliveries wnd,
                              wsh.wsh_delivery_assignments wda,
                              wsh.wsh_delivery_details wdd
                      WHERE       1 = 1
                              AND mmt.transaction_id = mmt_max.transaction_id
                              AND mil.INVENTORY_LOCATION_ID = mmt.locator_id
                              AND mil.ORGANIZATION_ID = mmt.ORGANIZATION_ID
                              AND mtt.transaction_type_id = mmt.transaction_type_id
                              AND wdd.lot_number = mmt_max.lot_number
                              AND wda.delivery_id = wnd.delivery_id
                              AND wdd.delivery_detail_id = wda.delivery_detail_id
                              
                               
                   ORDER BY   TO_NUMBER(REGEXP_REPLACE (
                                           SUBSTR (mmt_max.lot_number,
                                                   10,
                                                   11),
                                           '[^0-9.,]'
                                        )) DESC) mmt
          WHERE   1 = 1 AND ROWNUM = 1;
      EXCEPTION
         WHEN OTHERS
         THEN
            RETURN NULL;
      END;

      RETURN l_deliveri_name;
   END;
-- add 20.12.2023 BekmansurovRR
-- Функция определяет, является ли вагон прицепной частью маршрута?
function get_car_trailer_part (
       p_car_number     IN VARCHAR2,
       p_front_end_id   IN VARCHAR2,
       p_inv_number     IN VARCHAR2
    ) RETURN VARCHAR2
IS
   l_value   VARCHAR2 (150);
BEGIN
   begin
      SELECT   DISTINCT 'СпиртМетилов_НАХОДКА_ЭКСП'
        INTO   l_value
        FROM   xx_etw.etw_invoice ei
       WHERE   ( (ei.front_end_id = p_front_end_id
                  AND p_front_end_id IS NOT NULL)
                OR (    ei.INV_NUMBER = p_inv_number
                    AND p_inv_number IS NOT NULL
                    AND p_front_end_id IS NULL))
               AND ei.inv_plan_car_count between 5 and 7 -- планируемое количество вагонов
               AND ei.inv_send_kind_id = 5      -- вид отправки ['маршрутная']
               AND ei.inv_to_station_name = 'НАХОДКА-ВОСТОЧНАЯ (ЭКСП.)'
               AND EXISTS
                     (SELECT   'груз'
                        FROM   xx_etw.etw_nsi_freight fn,
                               xx_etw.etw_inv_freight eif
                       WHERE       fn.recdatebegin(+) < SYSDATE
                               AND fn.recdateend(+) >= SYSDATE
                               AND eif.freight_code = fn.fr_code_etsng(+)
                               AND eif.front_end_id = ei.front_end_id
                               AND LOWER (fn.fr_short_name) LIKE
                                     '%спирт%метилов%');
   EXCEPTION
      WHEN OTHERS
      THEN
         l_value := '';
   END;

   RETURN l_value;
END;
-- add 20.12.2023 BekmansurovRR
function get_trailer_part_color (p_trailer_part varchar2) return varchar2
is
    l_code varchar2(50) :='';
begin
    if p_trailer_part = 'СпиртМетилов_НАХОДКА_ЭКСП' then
        select code into l_code
          from xx_etw.xx_disl_color
          where NAME = 'ORANGE';
    
    end if;
    return l_code;
    
exception when others then return '';
end; 

function get_product_name_list (p_section in varchar2 default null) return t_xx_product_list_table pipelined
is
    l_row xx_etw.xx_disl_product_name%rowtype;
begin

    for cur in (
        SELECT x.id, x.item_name
          FROM xx_etw.xx_disl_product_name x
      ORDER BY x.item_name
    )
    loop
    
        l_row.id := cur.ID;
        l_row.item_name := cur.ITEM_NAME;
        
        pipe row (l_row);
    end loop;
    
end;

function get_loadind_status_oebs_list (p_section in varchar2 default null) return t_xx_loadind_status_oebs_table pipelined
is
    l_row xx_etw.xx_disl_loadind_status_oebs%rowtype;
begin

    for cur in (
        SELECT x.id, x.status_name
          FROM xx_etw.xx_disl_loadind_status_oebs x
      ORDER BY x.status_name
    )
    loop
    
        l_row.id := cur.ID;
        l_row.status_name := cur.STATUS_NAME;
        
        pipe row (l_row);
    end loop;
    
end;

function get_loadind_type_oebs_list (p_section in varchar2 default null) 
  return t_xx_loadind_type_oebs_table pipelined
is
    l_row xx_etw.xx_disl_loadind_type_oebs%rowtype;
begin

    for cur in (
        SELECT x.type_code, x.type_name
          FROM xx_etw.xx_disl_loadind_type_oebs x
      ORDER BY x.type_name
    )
    loop
    
        l_row.type_code := cur.TYPE_CODE;
        l_row.type_name := cur.TYPE_NAME;
        
        pipe row (l_row);
    end loop;
    
end;

    function save_new_credential_new( p_user_id in number, p_add_data in varchar2) return varchar2
    is
        l_function              varchar2(100):='save_new_credential_new';
        l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
        ----
        l_json                  json;
        l_json_l                json;
        l_json_list             json_list;
        l_json_value            json_value;
        ----
        l_row_cr                xx_etw.xx_disl_credential%rowtype;
        l_row_cr_r              xx_etw.xx_disl_credential_rights%rowtype;
        ----
        l_result                varchar2(2400);
        function get_rights_id (p_righhts_val in varchar2) return number
        is
            l_value number;
        begin
            select id into l_value 
              from xx_etw.xx_disl_rights 
             where id = p_righhts_val;
            
            return l_value;
        exception when others then return null;
        end;
        function get_credential_rights_id (p_credential_id in number, p_rigth_id in number) return number
        is
            l_value number;
        begin
            select id into l_value 
              from xx_etw.xx_disl_credential_rights 
             where credential_id = p_credential_id 
                   and rigth_id = p_rigth_id;
            return l_value;
        exception 
            when no_data_found then 
                return xx_etw.xx_disl_credential_rights_seq.nextval();
        end;
    begin
        log_new (l_log_id, l_function,'p_user_id='||p_user_id);
        log_new (l_log_id, l_function,'p_add_data='||p_add_data);
        l_json := xx_wms.json(p_add_data);
        l_row_cr := null;
        l_row_cr.credential_id := l_json.get_string('credential_id'); -- ID 
        l_row_cr.credential_name := l_json.get_string('credential_name'); -- NAME
        l_json_value := l_json.get('rightsCredential');
        
        log_new (l_log_id, l_function,'l_row_cr.credential_id='||l_row_cr.credential_id);
        log_new (l_log_id, l_function,'l_row_cr.credential_name='||l_row_cr.credential_name);
        l_json_list := json_list(l_json_value); 
        
        if nvl(l_row_cr.credential_id,0) = 0 then
            l_row_cr.credential_id := xx_etw.xx_disl_credential_seq.nextval();
            insert into xx_etw.xx_disl_credential (credential_id, credential_name) 
                 values (l_row_cr.credential_id, l_row_cr.credential_name);
            
        else 
            update xx_etw.xx_disl_credential
               set credential_name = l_row_cr.credential_name
             where credential_id = l_row_cr.credential_id;
        end if;
        
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json_l := json(l_json_value); 
            l_row_cr_r := null;
            
            l_row_cr_r.credential_id :=l_row_cr.credential_id;
            l_row_cr_r.creation_date :=sysdate;
            l_row_cr_r.created_by :=p_user_id;
            l_row_cr_r.last_update_by :=p_user_id;
            l_row_cr_r.last_update_date :=sysdate;
            l_row_cr_r.RIGTH_ID :=get_rights_id(to_number(trim(replace(l_json_l.get_string('id'),'rights_',''))));
            l_row_cr_r.VAL :=l_json_l.get_string('value');
            l_row_cr_r.id := get_credential_rights_id(l_row_cr_r.credential_id , l_row_cr_r.rigth_id );
            
            log_new (l_log_id, l_function,'l_row_cr_r.ID='||l_row_cr_r.id);
            log_new (l_log_id, l_function,'l_row_cr.RIGTH_ID='||l_row_cr_r.rigth_id);
            log_new (l_log_id, l_function,'l_row_cr.VAL='||l_row_cr_r.val);
            
            merge into xx_etw.xx_disl_credential_rights r
                using dual 
                   on (r.ID = l_row_cr_r.id)
                when matched then 
                    update set
                        last_update_by = l_row_cr_r.last_update_by,
                        last_update_date = l_row_cr_r.last_update_date,
                        VAL = l_row_cr_r.VAL
                when not matched then 
                    insert (ID, CREATION_DATE, CREATED_BY, LAST_UPDATE_DATE, LAST_UPDATE_BY,CREDENTIAL_ID,RIGTH_ID,VAL)
                    values (l_row_cr_r.ID, 
                            l_row_cr_r.CREATION_DATE, 
                            l_row_cr_r.CREATED_BY, 
                            l_row_cr_r.LAST_UPDATE_DATE, 
                            l_row_cr_r.LAST_UPDATE_BY,
                            l_row_cr_r.CREDENTIAL_ID,
                            l_row_cr_r.RIGTH_ID,
                            l_row_cr_r.VAL);
        end loop;
        
        l_result:='done$'||l_row_cr.credential_id;
        log_new (l_log_id, l_function,'l_result='||l_result);
        commit;
        return l_result;
    exception     
        when others then 
            l_result := 'fail$'||sqlerrm;
            log_new (l_log_id, l_function,'Ошибка:'||l_result);
            rollback;
            return l_result;
    end;
    
    function return_user_data_new(p_login varchar2) return t_xx_user_new_table pipelined
    is
        l_function              varchar2(100):='return_user_data_new';
        l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
        ----
        l_row t_xx_user_new_row;
    begin
        for tmp in ( 
            SELECT du.id     user_id,
                   du.full_name,
                   du.password,
                   du.flag_change_pwd,
                   du.enterprise,
                   cr.rights_code,
                   nvl(cr.rigth_id,0) as rigth_id,
                   max(nvl(cr.rights_val,'N')) as rights_val
              FROM xx_etw.xx_disl_users  du,
                   (SELECT uc.USER_ID, uc.credential_id, dcr.VAL as rights_val, lower(drs.RIGHTS_CODE) as RIGHTS_CODE, drs.ID as RIGTH_ID
                      FROM xx_etw.xx_disl_user_credential uc, 
                           xx_etw.xx_disl_credential c,
                           xx_etw.xx_disl_credential_rights dcr,
                           xx_etw.xx_disl_rights drs
                          
                     WHERE 1 = 1 
                           AND uc.credential_id = c.credential_id
                           and c.credential_id = dcr.credential_id
                           and dcr.RIGTH_ID = drs.ID
                    ) cr
             WHERE     1 = 1
                   AND login = UPPER (p_login)
                   AND du.id = cr.user_id(+)
                   AND du.open = 'Y'
            group by  du.id,
                      du.full_name,
                      du.password,
                      du.flag_change_pwd,
                      du.enterprise,
                      nvl(cr.rigth_id,0),
                      cr.rights_code
        )
        loop
            l_row.user_id := tmp.user_id;
            l_row.full_name := tmp.full_name;
            l_row.password := tmp.password;
            l_row.flag_change_pwd := tmp.flag_change_pwd;
            l_row.enterprise := tmp.enterprise;
            l_row.rights_code := tmp.rights_code;
            l_row.rights_val := tmp.rights_val;
            l_row.rights_id := tmp.rigth_id;
            
            /*
            log_new(l_log_id,l_function,'return_user_data: tmp.user_id = '||tmp.user_id);
            log_new(l_log_id,l_function,'return_user_data: tmp.full_name = '||tmp.full_name);
            log_new(l_log_id,l_function,'return_user_data: tmp.password = '||tmp.password);
            log_new(l_log_id,l_function,'return_user_data: tmp.flag_change_pwd = '||tmp.flag_change_pwd);
            */
            pipe row (l_row);
        end loop;
    exception when  others then
        log_new(l_log_id,l_function,'Ошибка = '||sqlerrm);
    end;
    
     /******************************************************************/
    /*               Администратор -> Справочники                     */
    /******************************************************************/
    
    function get_list_catalog return t_list_catalog_table pipelined
    is
        l_function              varchar2(100):='get_list_catalog';
        l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
        ----            
        l_row                   xx_etw.xx_disl_mdt_objects%rowtype;
    begin
        
        for tmp in (
                 SELECT x.*
                  FROM xx_disl_mdt_objects x
            START WITH PARENT_ID = 0
            CONNECT BY PRIOR OBJECT_ID = PARENT_ID
            order by IS_FOLDER desc 
            
        )
        loop
            
            l_row.object_id := tmp.object_id;
            l_row.object_name := tmp.object_name;
            l_row.object_table_name := tmp.object_table_name;
            l_row.is_folder := tmp.is_folder;
            l_row.parent_id := tmp.parent_id;
            
            pipe row (l_row);
        end loop;
    end;
    
    function get_attribute_for_catalog (p_object_id in number) return t_list_attribute_table pipelined
    is
        l_function              varchar2(100):='get_attribute_for_catalog';
        l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
        ----            
        l_row                   xx_etw.xx_disl_mdt_object_attributes%rowtype;
    begin
        
        for tmp in (
                 SELECT x.*
                  FROM xx_disl_mdt_object_attributes x
            where 1=1
                  and x.OBJECT_ID = p_object_id
                order by ORD, attribute_id
        )
        loop
            
            l_row.object_id := tmp.object_id;
            l_row.attribute_id:= tmp.attribute_id;
            l_row.attribute_code:= tmp.attribute_code;
            l_row.attribute_name:= tmp.attribute_name;
            l_row.lookup_table_name:= tmp.lookup_table_name;
            l_row.lookup_key_column:= tmp.lookup_key_column;
            l_row.lookup_value_column:= tmp.lookup_value_column;
            l_row.lookup_filter:= tmp.lookup_filter;
            l_row.is_visible:= tmp.is_visible;
            l_row.data_type:= tmp.data_type;
            l_row.is_editable:= tmp.is_editable;
            l_row.is_display_on_list:= tmp.is_display_on_list;
            l_row.is_search:= tmp.is_search;
            l_row.alias_lookup:= tmp.alias_lookup;
            -- Если запись нельзя редактировать, то поле не обязательное 
            l_row.is_required:= case when l_row.is_editable = 0 then 0 else tmp.is_required end;
            l_row.date_format:= tmp.date_format;
            
            
            pipe row (l_row);
        end loop;
    end;
    
    -- Возвращаем данные таблицы
    function get_combined_data(p_object_id in number) return sys_refcursor
    is
        l_function              varchar2(100):='get_combined_data';
        l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
        ----
        result_cursor       sys_refcursor;
        l_sql_query         varchar2(4000);
        l_table_name        varchar2(4000);
        l_table_collumns    varchar2(4000);
        l_where             varchar2(4000):=' 1=1 ';
        l_order_by          varchar2(4000);
        ---
        l_table_source      varchar2(4000);
        l_column_b          boolean:=false;
        function get_format_value (p_column_name    in varchar2,
                                   p_data_type      in varchar2, 
                                   p_data_format    in varchar2,
                                   p_alias          in varchar2) return varchar2
        is
            l_format_value varchar2(4000);
        begin
            if p_data_type in ('DATE','DATETIME') then
                l_format_value := 'to_char('||p_column_name||','''||p_data_format||''') as '||p_alias;
            else 
                l_format_value := p_column_name;
            end if;
            return l_format_value;
        end;
    begin
        -- Определяем название таблицы
        begin
            select OBJECT_TABLE_NAME||' obj' into l_table_name from xx_disl_mdt_objects where object_id = p_object_id;
        exception 
            when others then 
                log_new(l_log_id,l_function, 'get_table_name p_object_id = '||p_object_id||' sql%error = '||sqlerrm);
        end;
        
        for tmp in (
            SELECT x.*
                   --listagg('tb_'||x.OBJECT_ID||'.'||x.ATTRIBUTE_CODE,',') within group (order by x.ATTRIBUTE_ID)   into l_table_collumns
              FROM xx_disl_mdt_object_attributes x
             where 1=1
                   and x.OBJECT_ID = p_object_id
                   and x.IS_VISIBLE = 1
                order by ORD, attribute_id
        )
        loop
            -- Список столбцов
            l_table_collumns := l_table_collumns||case when l_column_b then ','end
                                    -- Формат значения
                                    ||get_format_value(p_column_name    =>' obj.'||tmp.ATTRIBUTE_CODE, 
                                                       p_data_type      =>tmp.DATA_TYPE, 
                                                       p_data_format    =>tmp.DATE_FORMAT,
                                                       p_alias          =>tmp.ATTRIBUTE_CODE)
                                    ||chr(10);
            -- Сортировка
            if tmp.is_order_by = 1 
                and tmp.IS_DISPLAY_ON_LIST = 1 
            then
                if l_order_by is not null then
                    l_order_by:= l_order_by||',';
                end if;
                l_order_by:= l_order_by||' obj.'||tmp.ATTRIBUTE_CODE;
            end if;
            
            -- Источник у поля
            if trim(tmp.LOOKUP_TABLE_NAME) is not null then
                l_table_collumns:=l_table_collumns||','
                                    ||' '||tmp.ALIAS_LOOKUP||tmp.ATTRIBUTE_ID||'.'||tmp.LOOKUP_VALUE_COLUMN
                                           ||' as '||upper(tmp.ATTRIBUTE_CODE||'_'||tmp.LOOKUP_VALUE_COLUMN)
                                    ||chr(10);
                l_table_source:=l_table_source||', '||tmp.LOOKUP_TABLE_NAME||' '||tmp.ALIAS_LOOKUP||tmp.ATTRIBUTE_ID||chr(10);
                l_where:= l_where||'and obj.'||tmp.ATTRIBUTE_CODE||'= '||tmp.ALIAS_LOOKUP||tmp.ATTRIBUTE_ID||'.'||tmp.LOOKUP_KEY_COLUMN||'(+)'||chr(10);
            end if;
            l_column_b := true;
        end loop;
        
        
        
        l_sql_query := 'select '||l_table_collumns
                      ||' from '||l_table_name||l_table_source
                      ||' where '||l_where
                      ||' order by '||nvl(l_order_by,'1');
        
        open result_cursor for l_sql_query; 
        log_new(l_log_id,l_function, ' '||l_sql_query );
        return result_cursor;
    exception 
        when others then 
            log_new(l_log_id,l_function, 'excecute p_object_id = '||p_object_id||' sql%error = '||sqlerrm);
    end;
    
    -- Сохранение данных
    procedure prc_save_catalog (p_user_id in varchar2, p_param_data in clob, p_out_result in out varchar2)
    is
        l_function              varchar2(100):='prc_save_catalog';
        l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
        l_error_msg             varchar2(2500);
        ----
        l_json                  JSON;
        l_json_list             json_list;
        l_json_value            json_value;
        ---
        l_json_d                JSON;
        l_json_list_d           json_list;
        l_json_value_d          json_value;
        ---
        l_field_code            varchar2(150);
        l_field_value           varchar2(500);
        --- 
        l_sql                   varchar2(4000);
        l_table_main            varchar2(1000);
        l_columns_val           varchar2(4000);
        l_columns_tbl           varchar2(4000);
        l_where                 varchar2(4000);
        l_where_bol             boolean:=false;
        ---
        l_info_column    xx_etw.xx_disl_mdt_object_attributes%rowtype;
        l_mode           varchar2(50);
        l_ObjectID       number;
        user_exception   exception;
        ---
        function column_value_format (p_column_id in number, p_value in varchar2) return varchar2
        is
            l_function              varchar2(100):='column_value_format';
            l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
            ---
            l_result        varchar2(4000);
            l_column_inf    xx_etw.xx_disl_mdt_object_attributes%rowtype;
        begin
            select * into l_column_inf from xx_etw.xx_disl_mdt_object_attributes where ATTRIBUTE_ID = p_column_id;
            
            if upper(l_column_inf.DATA_TYPE) = 'TEXT' then
                l_result := ''''||p_value||'''';
            elsif upper(l_column_inf.DATA_TYPE) = 'NUMBER' and trim(l_column_inf.SEQUENCE_OBJECT) is not null then
                l_result := p_value;
            elsif upper(l_column_inf.DATA_TYPE) = 'NUMBER' then
                l_result := case when p_value is not null then 'to_number('''||p_value||''')' else 'null' end;
            elsif upper(l_column_inf.DATA_TYPE) in ('DATE','DATETIME') then
                l_result := case when p_value is not null then 'to_date('''||p_value||''','''||l_column_inf.DATE_FORMAT||''')' else 'null' end;
            else 
                l_result := p_value;
            end if;
            
            return l_result;
        exception when others then return null;
        end;
        
        function get_info_column (p_object_id in number, p_attribute_code in varchar2) return xx_etw.xx_disl_mdt_object_attributes%rowtype
        is
            l_function              varchar2(100):='get_info_column';
            l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
            ---
            l_info_column xx_etw.xx_disl_mdt_object_attributes%rowtype;
        begin
            SELECT ob_a.*
              INTO l_info_column
              FROM xx_etw.xx_disl_mdt_object_attributes ob_a
             WHERE ob_a.OBJECT_ID = p_object_id
                   AND ob_a.ATTRIBUTE_CODE = p_attribute_code;
            
            return l_info_column;
            exception when others then 
                log_new(l_log_id,l_function, ' p_object_id = '||p_object_id||' Error='||sqlerrm);
                return null;
        end; 
        function get_object_table (p_object_id in varchar2) return varchar2
        is
            l_function              varchar2(100):='get_object_table';
            l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
            ---
            l_table varchar2(50);
        begin
            begin
                select ob.OBJECT_TABLE_NAME into l_table
                  from xx_etw.xx_disl_mdt_objects ob
                  where ob.object_id = p_object_id;
                  
            exception when others then
                log_new(l_log_id,l_function, ' p_object_id = '||p_object_id||' Error='||sqlerrm);
                l_table:= '';
            end;  
            return l_table;
        end;  
    BEGIN
        log_new(l_log_id,l_function,'p_user_id=' || p_user_id);
        log_new(l_log_id,l_function,'p_param_data=' || p_param_data);
        
        IF p_param_data IS NULL OR LENGTH(p_param_data) = 0 THEN
            l_error_msg := 'Входные данные отсутствуют или пусты.';
            raise user_exception;
        END IF;
        
        l_json_list := json_list (p_param_data);
        FOR i IN 1 .. l_json_list.COUNT
        LOOP
            l_json_value := l_json_list.get (i);
            l_json := json (l_json_value);
            l_ObjectID := to_number(l_json.get_string ('ObjectID'));
            l_mode := l_json.get_string ('Mode');
            
            l_table_main:= get_object_table(p_object_id => l_ObjectID);
            
            log_new(l_log_id,l_function, ' ObjectID = ' || l_ObjectID);
            log_new(l_log_id,l_function, ' Mode = ' || l_mode);
            log_new(l_log_id,l_function, ' l_table_main = ' || l_table_main);
            if l_table_main is null then
                l_error_msg := 'Не определилась таблица для '||case l_mode when 'edit' then 'обновления' when 'new' then 'добавления' end;
                raise user_exception;
            end if;
            l_json_list_d := json_list (l_json.get ('Data'));
            FOR j IN 1 .. l_json_list_d.COUNT
            LOOP
                l_info_column := null;
                l_json_value_d := l_json_list_d.get (j);
                l_json_d := json (l_json_value_d);
                l_field_code := trim(l_json_d.get_string ('fieldID'));
                l_field_value:= trim(l_json_d.get_string ('value'));
                
                log_new(l_log_id,l_function,' Data.fieldID['|| j || '] = ' || l_field_code);
                log_new(l_log_id,l_function,' Data.value[' || j || '] = ' || l_field_value);
                
                l_info_column := get_info_column(p_object_id        => l_ObjectID,
                                                 p_attribute_code   => l_field_code);
                if l_mode = 'edit' 
                then
                    if (l_info_column.is_visible = 1 -- Видимость на форме
                        and l_info_column.is_editable = 1 -- Можно редактировать
                        ) or (l_info_column.is_primary_key = 1) -- Или это PK, т.к нужен для части Where
                    then
                        
                        if l_info_column.is_primary_key != 1 then 
                            -- Обновление записи
                            l_columns_val := l_columns_val || CASE WHEN l_columns_val IS NOT NULL THEN ',' END 
                                                           || l_field_code || ' = ' || column_value_format(l_info_column.attribute_id, l_field_value);
                        end if;
                        
                        -- Формирование условия WHERE по первичным ключам
                        IF l_info_column.is_primary_key = 1 THEN
                            l_where := l_where || CASE WHEN l_where_bol THEN ' AND ' END 
                                       || l_field_code || ' = ' || column_value_format(l_info_column.attribute_id, l_field_value);
                            l_where_bol := TRUE;
                        END IF;
                    
                    end if;
                elsif l_mode = 'new' then
                    if (l_info_column.is_visible = 1  -- Видимость на форме
                        and l_field_value is not null) -- Значение не пустое
                        or (l_info_column.is_primary_key = 1)  -- Или это PK
                    then
                        
                        -- Для PK - значение это SEQ
                        if (l_info_column.is_primary_key = 1 
                            and l_info_column.sequence_object is not null 
                           ) then
                            l_field_value := l_info_column.sequence_object;
                        end if;
                        -- Собираем столбцы
                        l_columns_tbl := l_columns_tbl || CASE WHEN l_columns_tbl IS NOT NULL THEN ',' END || l_field_code;
                        -- Собираем значения для вставки
                        l_columns_val := l_columns_val || CASE WHEN l_columns_val IS NOT NULL THEN ',' END || column_value_format(l_info_column.attribute_id, l_field_value);

                    end if;
                end if;
                
            END LOOP;
        END LOOP;
        
        if l_mode = 'edit' then 
            l_sql := 'update '||(l_table_main)
                       ||' set '||l_columns_val
                       ||' where '||l_where;
            --log_new(l_log_id,l_function,'l_sql = ' || l_sql);
            -- Выполнение запроса
            EXECUTE IMMEDIATE l_sql;
            log_new(l_log_id,l_function,'Количество записей update: ' || sql%rowcount);
        elsif l_mode = 'new' then
            l_sql := 'insert into '||(l_table_main)
                                   ||' ('||l_columns_tbl||') '
                                   ||' values('||l_columns_val||')';
                        
            --log_new(l_log_id,l_function,'l_sql = ' || l_sql);
            -- Выполнение запроса
            EXECUTE IMMEDIATE l_sql;
            log_new(l_log_id,l_function,'Количество записей insert: ' || sql%rowcount);
        end if;
        p_out_result := 'true'; 
    exception 
        when user_exception then
            rollback;
            p_out_result := l_error_msg||' Log_id='||l_log_id;
            log_new(l_log_id,l_function,'l_sql = ' || l_sql);
            log_new(l_log_id,l_function,'Error = '||p_out_result);

        when others then 
            rollback;
            p_out_result := sqlerrm||' Log_id='||l_log_id;
            log_new(l_log_id,l_function,'l_sql = ' || l_sql);
            log_new(l_log_id,l_function,'Error = '||p_out_result);
            
            
    end;
   
    -- Список значений для столбца с внешним источником
    function get_source_for_column (p_param_data in varchar2) return t_source_for_column_table pipelined
    is
        l_function          varchar2(100):='get_source_for_column';
        l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
        ---
        l_json              JSON;
        l_attribute_id      number;
        ---
        TYPE t_cursor IS REF CURSOR;
             v_cursor t_cursor;
        l_sql               varchar2(4000);
        v_field1            VARCHAR2(500);
        v_field2            VARCHAR2(500);
        l_row               t_source_for_column_row;
    begin
        --log_new(l_log_id,l_function,'p_param_data = '||p_param_data);
        l_json := xx_wms.json(p_param_data);
        l_attribute_id:= to_number(l_json.get_string('attributeID')); -- attributeID 
        
        for tmp in (
             select *
               from xx_etw.xx_disl_mdt_object_attributes ob_a
              where 1=1
                    and ob_a.attribute_id = l_attribute_id
        )
        loop
            l_sql:= 'select to_char('||tmp.LOOKUP_KEY_COLUMN||'), '||tmp.LOOKUP_VALUE_COLUMN
                  ||' from '||tmp.LOOKUP_TABLE_NAME
                  ||' '||case when trim(tmp.LOOKUP_FILTER) is not null then 'where '||tmp.LOOKUP_FILTER
                         end;
        end loop;
        --DBMS_OUTPUT.PUT_LINE ( ' '||l_sql );
        OPEN v_cursor FOR l_sql;
        -- Чтение данных из курсора
        LOOP
            FETCH v_cursor INTO v_field1, v_field2;
            EXIT WHEN v_cursor%NOTFOUND;
            l_row.id := v_field1;
            l_row.name := v_field2;
            
            pipe row (l_row);
        END LOOP;
        
        
        
    exception 
        when others then 
            log_new(l_log_id,l_function,'p_param_data = '||p_param_data);
            log_new(l_log_id,l_function,'Error = '||sqlerrm);
            
    end;
    function get_categ_freight (p_categ_name    in varchar2,
                                p_freight_name  in varchar2, 
                                p_owner         in varchar2) return varchar2
    is
        l_categ_freight_name xx_etw.xx_disl_freight_list.freight_name%type;
        l_shipping_name xx_etw.xx_disl_shipping.name%type;
    begin
        begin
            select fl_f.freight_name     as categ_freight_name,
                   ds.name               as shipping_name
              into l_categ_freight_name, l_shipping_name
              from xx_etw.xx_disl_freight_list  fl
                   left join xx_etw.xx_disl_shipping ds on fl.categ_ship = ds.id
                   left join xx_etw.xx_disl_freight_list fl_f
                       on fl.categ_freight = fl_f.id
             where 1 = 1
                   and fl.freight_name = p_freight_name;
        exception 
            when no_data_found then return '';
            when others then return '*Категория не определена*';
        end;
        
        if p_categ_name = 'categ_freight' then
            return l_categ_freight_name;
        elsif p_categ_name = 'categ_ship' then
            if p_owner = 'МД' and l_categ_freight_name = 'Карбамид' then
                return 'Сырьё';
            else
                return l_shipping_name;
            end if;
        end if;
        return '';
    end;
    /******************************************************************/
    
    procedure pr_car_round_hist_out (p_railcar_id in varchar2)
    is
        l_function          varchar2(100):='pr_car_round_hist_out';
        l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
        l_curTime           date;
        l_stationHistId     number;
    begin
        
        log_new(l_log_id,l_function,'p_railcar_id = '||p_railcar_id);
        for tmp in (
             select d.*
               from xx_etw.xx_disl_round d
             where d.round_id = xx_etw.xx_dislocation.returnLastRound(p_railcar_id)
        )
        loop
            l_curTime := sysdate;
            update xx_etw.xx_disl_station_history 
               set out_date = l_curTime
                  ,out_date_fact = l_curTime
                  ,out_user_id = -1
             where 1=1
               and round_id = tmp.round_id
               and station_id = 1
               and in_date is null
            returning station_hist_id into l_stationHistId
            ;
                
            update xx_etw.xx_disl_round
               set station_hist_id_out = l_stationHistId
             where 1=1
               and round_id = tmp.round_id
            ;
        end loop;
        commit;
    exception when others then 
        
        log_new(l_log_id,l_function,'Error = '||sqlerrm);
        null;
    end;
    
    /****************************** ***********************************/
    /*                  Итеграция с 1С "Автологистика" Метадинеа
    /****************************** ***********************************/
    
    function get_request_id (p_request_id in number) return number
    is
        l_request_id number;
    begin
        select request_id 
          into l_request_id 
          from xx_etw.xx_disl_requests
          where request_id = p_request_id;
        return l_request_id;  
        
    exception 
        when no_data_found then return -1;
    end;
    
    function get_request_status_d (p_request_id in number) return varchar2
    is
        l_status varchar2(150);
    begin
        select decode (dr.status,'O','Открыт',
                                 'D','Выполнено',
                                 'R','Выполнено с замечаниями',
                                 'F','Не выполнено',
                                 'P','В обработке', dr.status)
          into l_status 
          from xx_etw.xx_disl_requests dr
          where request_id = p_request_id;
        return l_status;  
        
    end;
	
	function get_request_status_code (p_request_id in number) return varchar2
    is
        l_status varchar2(150);
    begin
        select dr.status into l_status 
          from xx_etw.xx_disl_requests dr
          where request_id = p_request_id;
        return l_status;  
        
    end;
	
	function get_railway_id (p_railway_name in varchar2) return number
	is
		l_value number;
	begin
		select RAILWAY_ID into l_value
			from xx_etw.xx_disl_railways
		   where upper(RAILWAY_NUMBER) = upper(p_railway_name);
		return l_value;
		exception when others then return -1;
	end;
	
	function get_request_tasks_name (p_task_id number) return varchar2
	is	
		l_descr xx_etw.xx_disl_request_tasks.descr%type;
	begin
		select descr into l_descr from xx_etw.xx_disl_request_tasks where task_id = p_task_id;
		
        return l_descr;
	exception 
		when no_data_found then return null;
	end;
	
	function get_criteria_tasks_name (p_task_id number) return varchar2
	is	
		l_descr xx_etw.xx_disl_request_criteria_tasks.descr%type;
	begin
		select descr into l_descr from xx_etw.xx_disl_request_criteria_tasks where task_id = p_task_id;
		
		return l_descr;
	exception 
		when no_data_found then return null;
	end;
	
	/***************** Контроль простоев *******************************/
	function get_idle_reason_list return t_xx_idle_reasons_table
        pipelined
	is
        l_row t_xx_idle_reasons_row; 
	begin
        for cur in (
            select * from xx_disl_idle_reasons
        )
        loop
            l_row.id := cur.id;
            l_row.name := cur.name;
            
            pipe row (l_row);
        end loop;
	
	end;
    function get_idle_control_list(
        p_params        varchar2
    ) return t_xx_idle_control_table pipelined
    as
        l_row t_xx_idle_control_row;
        l_function          varchar2(100):='get_idle_control_list';
        l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
        l_cause_id          number;
        l_car_number        varchar2(50);
        l_color_id          number;
        l_date_from         varchar2(50);
        l_date_to           varchar2(50);
        l_json              json;
        l_result            varchar2(4000);
        l_is_excluded       varchar2(1);
    begin   
        l_json := xx_wms.json(p_params);
        
        l_car_number := l_json.get_string('car_number');
        if (l_json.get_string('date_from') is not null) then 
            l_date_from := l_json.get_string('date_from');
        end if;
        if (l_json.get_string('date_to') is not null) then 
            l_date_to := l_json.get_string('date_to'); 
        end if;
        if (l_json.get_string('is_excluded') is not null) then 
            l_is_excluded := l_json.get_string('is_excluded'); 
        end if;
        
        for tmp in (
            SELECT   x.CREATED_BY, 
                     to_char(x.CREATION_DATE,'DD.MM.YYYY HH24:MI:SS') CREATION_DATE,
                     x.LAST_UPDATED_BY, 
                     to_char(x.LAST_UPDATE_DATE,'DD.MM.YYYY HH24:MI:SS') LAST_UPDATE_DATE,
                     x.CAR_NUMBER, 
                     to_char(x.START_DATE,'DD.MM.YYYY') START_DATE, 
                     to_char(x.END_DATE,'DD.MM.YYYY') END_DATE, 
                     x.NOTE, 
                     x.IS_EXCLUDED,
                     du.FULL_NAME CREATED_NAME,
                     x.ID_CONTROL,
                     X.IDLE_REASONS_ID,
                     ir.NAME AS IDLE_REASONS_NAME
              FROM   XX_ETW.xx_disl_idle_control x,
                     xx_etw.xx_disl_users du,
                     xx_etw.xx_disl_idle_reasons  ir
             WHERE   1 = 1 
                     and x.IDLE_REASONS_ID = ir.id (+)
                     and x.created_by = du.id
                     and nvl(x.deleted,'N') = 'N'
                     and x.car_number = nvl(l_car_number,x.car_number)
                     and x.is_excluded = nvl(l_is_excluded,x.is_excluded)
                     --and trunc(nvl(l_date_from,sysdate)) between nvl (x.start_date, sysdate) and nvl (x.end_date, sysdate)
                     and ((to_date(l_date_from,'dd.mm.yyyy') between nvl (x.start_date, sysdate) and nvl (x.end_date, sysdate) and l_date_from is not null) or  
                            (l_date_from is null and 1=1)
                            
                         )
        ) 
        loop
            l_row.id_control := tmp.id_control;
            l_row.car_number := tmp.car_number;
            l_row.creation_date := tmp.creation_date;
            l_row.last_update_date := tmp.last_update_date;
            l_row.start_date := tmp.start_date;
            l_row.end_date := tmp.end_date;
            l_row.created_name := tmp.created_name;
            l_row.note := tmp.note;
            l_row.is_excluded := tmp.IS_EXCLUDED;
            l_row.idle_reasons_id := tmp.IDLE_REASONS_ID;
            l_row.idle_reasons_name := tmp.IDLE_REASONS_NAME;
            pipe row (l_row);
        end loop;
    end;
    function save_idle_control(
        p_user_id           number,
        p_row_id            number,
        p_add_data          varchar2    
    ) return varchar2 
    as
        l_function          varchar2(100):='save_idle_control';
        l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
        l_row           XX_ETW.XX_DISL_IDLE_CONTROL%rowtype;   
        l_json          json;
        l_date_from     date;
        l_date_to       date;
        l_car_number    varchar2(240);
        l_id_control    number;
        l_idle_reasons_id number;
        l_count         number;
        l_isExcluded    varchar2(1);
        l_msg           varchar2(240);
        l_result        varchar2(4000);
    begin   
        log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
        l_json := xx_wms.json(p_add_data);
        
        l_id_control := l_json.get_string('id_control');
        l_car_number :=l_json.get_string('car_number');   
        l_isExcluded :=l_json.get_string('is_excluded');   
        l_date_from :=to_date(l_json.get_string('start_date'),'dd.mm.yyyy');
        l_date_to :=to_date(l_json.get_string('end_date'),'dd.mm.yyyy');
        l_idle_reasons_id := l_json.get_string('idle_reasons_id');
        
        -- Проверка номера вагона
        if xx_dislocation.check_car_number(l_car_number) = 0 then 
           return 'fail$'||'.Неверный номер вагона.';
        end if;
            
        begin
        select count(*) into l_count
            from XX_ETW.XX_DISL_IDLE_CONTROL x
            where 1=1
                  and CAR_NUMBER = l_car_number
                  and nvl(x.deleted,'N') = 'N'
                  and nvl(x.is_Excluded,0) = nvl(l_isExcluded,0)
                  and ((START_DATE between l_date_from and trunc(nvl(l_date_to,sysdate))) or (trunc(nvl(END_DATE,sysdate)) between l_date_from and trunc(nvl(l_date_to,sysdate))))
                  and id_control <> nvl(l_id_control,0);
        exception when others then l_count :=0;
        end;

        if (l_count > 0) then
            return 'fail$'||'.Вагон уже зарегистрирован в данном периоде';
        end if;
        
        if (nvl(l_id_control,0) = 0) then
            l_row.id_control := xx_etw.xx_disl_idle_control_seq.nextval();
            l_row.created_by := p_user_id;
            l_row.creation_date := sysdate;
            l_row.last_updated_by := p_user_id;
            l_row.last_update_date := sysdate;
            l_row.car_number :=l_json.get_string('car_number');
            l_row.start_date :=to_date(l_json.get_string('start_date'),'dd.mm.yyyy');
            l_row.end_date :=to_date(l_json.get_string('end_date'),'dd.mm.yyyy');         
            l_row.note :=l_json.get_string('note');
            l_row.is_Excluded :=l_isExcluded;
            l_row.idle_reasons_id := l_idle_reasons_id;

            insert into XX_ETW.XX_DISL_IDLE_CONTROL  
            values l_row;
        else
            update XX_ETW.XX_DISL_IDLE_CONTROL 
               set last_updated_by = p_user_id
                  ,last_update_date = sysdate
                  ,start_date =to_date(l_json.get_string('start_date'),'dd.mm.yyyy')
                  ,end_date =to_date(l_json.get_string('end_date'),'dd.mm.yyyy')      
                  ,note =l_json.get_string('note')
                  ,is_Excluded =l_isExcluded
                  ,idle_reasons_id = l_idle_reasons_id
             where id_control = l_id_control;
        end if;
              
        commit;
        l_result := 'done$';   
        return l_result;
    exception
        when others then 
            log_new(l_log_id,l_function,'p_add_data = '||p_add_data);
            rollback; return 'fail$'||sqlerrm;
    end;
    
    function delete_idle_control(
        p_user_id           number,
        p_row_id            number,
        p_add_data          varchar2    
    ) return varchar2 
    as
        l_row           XX_ETW.XX_DISL_IDLE_CONTROL%rowtype;   
        l_json          json;
        l_date_from     date;
        l_date_to       date;
        l_car_number    varchar2(240);
        l_id_control    number;
        l_idle_reasons_id    number;
        l_count         number;
        l_msg           varchar2(240);
        l_result        varchar2(4000);
    begin   
        l_json := xx_wms.json(p_add_data);
        l_id_control := l_json.get_string('id_control');
        
        
        update XX_ETW.XX_DISL_IDLE_CONTROL 
                    set deleted = 'Y', 
                        deleted_by = p_user_id, 
                        deleted_date = sysdate
                        
         where id_control = l_id_control;
        commit;
        l_result := 'done';   
        return l_result;
    exception
        when others then rollback; return 'fail$'||sqlerrm;
    end;
    
end;
/
