function change_ins_doc_type(
    p_type_id           number,
    p_name              varchar2,
    p_descr             varchar2,
    p_storage_life      number
) return varchar2
as
begin
    update xx_etw.xx_disl_ins_doc_types
       set name = p_name,
           descr = p_descr,
           storage_life = p_storage_life
     where 1=1
       and type_id = p_type_id
    ;   
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function del_ins_doc_type(p_type_id number)
return varchar2
as
begin
    delete
      from xx_etw.xx_disl_ins_doc_types
     where 1=1
       and type_id = p_type_id
    ;
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function get_rail_services_rgd
return t_xx_rail_services_rgd_table pipelined
as
    l_row       t_xx_rail_services_rgd_row;
begin
    for l_tmp in (select rsr.id
                        ,rsr.code
                        ,rsr.category
                        ,to_char(rsr.beg_date,'dd.mm.yyyy')             beg_date
                        ,to_char(rsr.end_date,'dd.mm.yyyy')             end_date
                        ,u_cr.full_name                                 created_by
                        ,to_char(rsr.created_date,'dd.mm.yyyy')         created_date
                        ,u_up.full_name                                 last_updated_by
                        ,to_char(rsr.last_updated_date,'dd.mm.yyyy')    last_updated_date
                        ,case
                           when sysdate between nvl(rsr.beg_date,sysdate-1) and nvl(rsr.end_date,sysdate+1)
                           then 'Y'
                           else 'N'
                         end
                                                                        opened
                    from xx_etw.xx_disl_rail_services_rgd   rsr
                        ,xx_etw.xx_disl_users               u_cr
                        ,xx_etw.xx_disl_users               u_up         
                   where 1=1
                     and rsr.created_by = u_cr.id(+)
                     and rsr.last_updated_by = u_up.id(+)
                   order by 
                         code   
                 )
    loop
        l_row.id := l_tmp.id;
        l_row.code := l_tmp.code;
        l_row.category := l_tmp.category;
        l_row.beg_date := l_tmp.beg_date;
        l_row.end_date := l_tmp.end_date;
        l_row.created_by := l_tmp.created_by;
        l_row.created_date := l_tmp.created_date;
        l_row.last_updated_by := l_tmp.last_updated_by;
        l_row.last_updated_date := l_tmp.last_updated_date;
        l_row.opened := l_tmp.opened;
        
        pipe row (l_row);
    end loop;
end;

