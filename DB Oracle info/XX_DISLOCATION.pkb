procedure log_new(p_log_id number,p_log_function varchar2, p_descr varchar2)
is
pragma autonomous_transaction;
begin
    if g_debug then 
        --dbms_output.put_line(to_char(sysdate,'dd.mm.yyyy hh24:mi:ss') || ' ' || p_log_function || ': ' ||p_descr);
        insert into xx_etw.xx_disl_log_new values(p_log_id,xx_etw.xx_disl_log_order_seq.nextval,sysdate,p_log_function,p_descr);
        commit;
    end if;
end log_new;

function get_substr(p_str varchar2, p_del varchar2, p_num number)
return varchar2
as
    l_str   varchar2(4000);
begin
    l_str := regexp_substr(p_str,'[^'||p_del||']+',1,p_num);
    return case
             when l_str = '_'
               then null
             else l_str
           end;               
end;  

procedure send_mail(p_to        IN VARCHAR2,
                    p_subject   IN VARCHAR2,
                    p_html_msg  IN VARCHAR2 default null,
                    p_smtp_host IN VARCHAR2 default '172.16.0.191',
                    p_smtp_port IN NUMBER   default 25) AS
    l_mail_conn UTL_SMTP.connection;

    nls_charset varchar2(256);
    err varchar(4000);
    
    function subj_encode(subj_str varchar2) return varchar2
    -- функция для перекодировки заголовка письма в utf-8
    as
        a varchar2(1000);
        b      varchar2(24);
    result varchar2(4000);
    begin
        a := subj_str;
        while length(a) > 24
        loop b := substr(a, 1, 24);
            a := substr(a, 25);
            result := result || '=?UTF-8?B?' || utl_raw.cast_to_varchar2(utl_encode.base64_encode(utl_raw.cast_to_raw(convert(b, 'utf8')))) || '?=';
        end loop;
        if length(a) > 0 then
            result := result || '=?UTF-8?B?' || utl_raw.cast_to_varchar2(utl_encode.base64_encode(utl_raw.cast_to_raw(convert(a, 'utf8')))) || '?=';
        end if;

        return result;
    end;
    
BEGIN

    l_mail_conn := UTL_SMTP.open_connection(p_smtp_host, p_smtp_port);

    UTL_SMTP.helo(l_mail_conn, p_smtp_host);

    UTL_SMTP.mail(l_mail_conn, '<noreply@metafrax.ru>');
    UTL_SMTP.rcpt(l_mail_conn, '<'||p_to||'>');
    UTL_SMTP.open_data(l_mail_conn);

    UTL_SMTP.write_data(l_mail_conn, 'To: ' || p_to || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'From: ' || 'noreply@metafrax.ru' || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'Subject: ' || NVL(SUBJ_ENCODE(p_subject), '(no subject)') || UTL_TCP.crlf);
    --UTL_SMTP.write_data(l_mail_conn, 'Reply-To: ' || p_from || UTL_TCP.crlf);

    -- передача данных: кодировки
    SELECT VALUE INTO   nls_charset FROM   nls_database_parameters WHERE  parameter = 'NLS_CHARACTERSET';

    UTL_SMTP.write_data(l_mail_conn, 'MIME-Version: 1.0' || UTL_TCP.crlf);
    UTL_SMTP.write_data(l_mail_conn, 'Content-Type: text/plain; charset="utf-8"' || UTL_TCP.crlf);
    
    utl_smtp.write_raw_data(l_mail_conn, utl_raw.cast_to_raw(utl_tcp.crlf) || utl_raw.cast_to_raw(convert(p_html_msg,'UTF8')));   

    UTL_SMTP.close_data(l_mail_conn);
    UTL_SMTP.quit(l_mail_conn);
--exception when others then 
--    null;
END;

/* Formatted on 29.11.2024 8:38:40 (QP5 v5.404) */
function get_user_cred_rights_val (p_user_id       in number,
                                   p_rights_code   in varchar2)
    return varchar2
is
    l_value   xx_etw.xx_disl_credential_rights.val%type;
begin
    select decode(max(decode(cr.val,'Y',1,0)),1,'Y','N')     as val
      into l_value
      from xx_etw.xx_disl_users              du,
           xx_etw.xx_disl_credential         dr,
           xx_etw.xx_disl_credential_rights  cr,
           xx_etw.xx_disl_rights             c,
           xx_etw.xx_disl_user_credential    uc
     where     1 = 1
           and du.id = p_user_id
           and du.id = uc.user_id
           and uc.credential_id = dr.credential_id
           and dr.credential_id = cr.credential_id
           and cr.rigth_id = c.id
           and upper (c.rights_code) = upper (p_rights_code);
    return l_value;
exception
    when others
    then
        return 'N';
end;

function get_default_id (p_table varchar2, p_section varchar2, p_value varchar2) return varchar2
    is
        l_default varchar2(240):='N';
    begin
        begin
            if p_section is null then 
                select listagg(upper(x.section),'$') within group (order by x.id) into l_default
                  from xx_etw.xx_disl_user_default x
                 where lower(x.table_name) = lower(p_table)
                       and x.value_id =  p_value
                       and x.disable = 'N';
            else 
                select 'Y' into l_default
                  from xx_etw.xx_disl_user_default x
                 where lower(x.table_name) = lower(p_table)
                       and lower(x.section) = lower(p_section)
                       and x.value_id =  p_value
                       and x.disable = 'N';
            end if;
        exception when others then l_default:='N';
        end;
        return nvl(l_default,'none');
    end;

function get_user_oebs_id (p_user_id number) return number
is
    l_user_id number;
begin
    begin
        select   fu.user_id
          into   l_user_id
          from   apps.fnd_user fu, xx_etw.xx_disl_users du
         where   1 = 1 
                 and fu.user_name = du.login 
                 and du.id = p_user_id;
     exception 
        when others then l_user_id :=-1;
     end; 
     
     return l_user_id;
end;

function get_user_full_name (p_user_id number) return varchar2
is
    l_full_name varchar2(240);
begin
    begin
        select du.full_name 
          into l_full_name
          from xx_etw.xx_disl_users du
         where 1=1
               and du.ID = p_user_id;
    exception 
        when others then return null;
    end;
    return l_full_name;
end; 

