function get_route_actions(
    p_date_from     varchar2,
    p_date_to       varchar2,
    p_station_id    number,
    p_operation     number,
    p_exists_route  number
) return t_xx_route_action_table pipelined
as
    l_row           t_xx_route_action_row;
    
    l_date_from     date;
    l_date_to       date;
begin
    l_date_from := to_date(p_date_from,'dd.mm.yyyy hh24:mi');
    l_date_to := to_date(p_date_to,'dd.mm.yyyy hh24:mi');
    
    for l_action in (
        select *
          from (select 2                        operation_id
                      ,railway_hist_id          action_id
                      ,date_oper_fact           date_oper_custom
                      ,date_oper                date_oper
                      ,'перемещение '||prev_railway_desc||' -> '||railway_desc
                                                action_desc
                      ,round_id                 obj_round_id
                      ,railcar_id               obj_number
                      ,station_id               station_id
                      ,xx_etw.xx_dislocation.get_obj_freight(round_id,'railcar',date_oper) freight
                  from (select rhv.railway_hist_id 
                              ,r.round_id
                              ,r.railcar_id
                              ,sh.station_id
                              ,(select short_name
                                  from xx_etw.xx_disl_stations  s
                                 where s.station_id =sh.station_id)
                                                        station_desc  
                              ,rhv.prev_railway
                              ,(select railway_number
                                  from xx_etw.xx_disl_railways
                                 where railway_id = rhv.prev_railway)
                                                        prev_railway_desc
                              ,rhv.railway_id
                              ,(select railway_number
                                  from xx_etw.xx_disl_railways
                                 where railway_id = rhv.railway_id)
                                                        railway_desc
                              ,rhv.date_oper
                              ,rhv.date_oper_fact
                          from xx_etw.xx_disl_railway_history_v rhv
                              ,xx_etw.xx_disl_station_history   sh
                              ,xx_etw.xx_disl_round             r
                         where 1=1
                           and nvl(p_operation,2) = 2
                         
                           and rhv.prev_railway is not null
                           and(   date_oper between l_date_from and nvl(l_date_to,date_oper)
                               or date_oper_fact between l_date_from and nvl(l_date_to,date_oper_fact))
                               
                           and rhv.station_hist_id = sh.station_hist_id
                           
                           and sh.round_id = r.round_id)
                 union all
                select 4
                      ,pk_id                    
                      ,date_w                   
                      ,created_date              
                      ,' '                        
                      ,round_id                 
                      ,to_char(car_number_corr) 
                      ,station_id
                      ,xx_etw.xx_dislocation.get_obj_freight(round_id,'railcar',created_date) freight
                  from (select pk_id
                              ,cr.round_id
                              ,cr.car_number_corr
                              ,cr.date_w
                              ,cr.created_date
                              ,cr.type
                              ,(select station_id
                                  from xx_etw.xx_disl_station_history sh
                                 where 1=1
                                   and sh.round_id = cr.round_id
                                   and cr.date_w between sh.come_date and nvl(sh.out_date,sysdate)-1/24/60/60)
                                                station_id
                          from xx_etw.xx_disl_car_scale cr
                         where 1=1
                           and nvl(p_operation,4) = 4
                           and date_w between l_date_from and nvl(l_date_to,date_w)
                       )
                 union all
                select 3
                      ,cont_history_id
                      ,in_date_fact
                      ,in_date_sys
                      ,'перемещение '||prev_place_area||' -> '||place_area
                      ,cont_round_id
                      ,cont_number
                      ,station_id
                      ,xx_etw.xx_dislocation.get_obj_freight(cont_round_id,'cont',in_date_sys) freight
                  from (select ch.cont_history_id              
                              ,ch.in_date_fact              
                              ,ch.in_date_sys               
                              ,(select 'площадка: '||name
                                  from xx_etw.xx_disl_areas
                                 where ch_prev.place_type = 'area'
                                   and area_id = ch_prev.place_id
                                 union all
                                select 'платформа: '||railcar_id
                                  from xx_etw.xx_disl_round
                                 where ch_prev.place_type = 'railcar'
                                   and round_id = ch_prev.place_id
                               )
                                                            prev_place_area          
                              ,(select 'площадка: '||name
                                  from xx_etw.xx_disl_areas
                                 where ch.place_type = 'area'
                                   and area_id = ch.place_id
                                 union all
                                select 'платформа: '||railcar_id
                                  from xx_etw.xx_disl_round
                                 where ch.place_type = 'railcar'
                                   and round_id = ch.place_id
                               )
                                                            place_area  
                              ,ch.cont_round_id
                              ,cr.cont_number 
                              ,case
                                 when ch.place_type = 'area'
                                 then (select station_id
                                         from xx_etw.xx_disl_areas
                                        where area_id = ch.place_id)
                                 else (select station_id
                                         from xx_etw.xx_disl_station_history shh
                                        where 1=1
                                          and shh.round_id = ch.place_id
                                          and ch.in_date_fact between shh.come_date and nvl(shh.out_date,sysdate)-1/24/60/60)
                               end
                                            station_id
                          from xx_etw.xx_disl_cont_history      ch
                              ,xx_etw.xx_disl_cont_history      ch_prev
                              ,xx_etw.xx_disl_cont_round        cr
                         where 1=2
                           and nvl(p_operation,3) = 3  
                         
                           and ch.cont_round_id = ch_prev.cont_round_id(+)
                           and ch.in_date_sys = ch_prev.out_date_sys(+)
                           and ch_prev.cont_round_id is not null
                           
                           and ch.cont_round_id = cr.cont_round_id
                           
                           and(   ch.in_date_fact between l_date_from and nvl(l_date_to,ch.in_date_fact)
                               or ch.in_date_sys between l_date_from and nvl(l_date_to,ch.in_date_sys))
                       )
                 union all
                select 1
                      ,station_hist_id
                      ,out_date_fact
                      ,out_date
                      ,'локомотив '||loco1_num||decode(loco2_num,null,'',','||loco2_num)||' перемещение '||prev_station_desc||' -> '||station_desc
                      ,round_id
                      ,railcar_id
                      ,station_id
                      ,xx_etw.xx_dislocation.get_obj_freight(round_id,'railcar',out_date) freight
                  from (select sh_prev.station_hist_id           
                              ,r.round_id
                              ,r.railcar_id
                              ,(select name
                                  from xx_disl_locomotives
                                 where id = wl.loco1_num)
                                                                    loco1_num      
                              ,(select name
                                  from xx_disl_locomotives
                                 where id = wl.loco2_num)
                                                                    loco2_num 
                              ,sh_prev.station_id                   prev_station_id
                              ,(select short_name
                                  from xx_etw.xx_disl_stations  s
                                 where s.station_id =sh_prev.station_id)
                                                                    prev_station_desc 
                              ,sh.station_id                        station_id
                              ,(select short_name
                                  from xx_etw.xx_disl_stations  s
                                 where s.station_id =sh.station_id)
                                                                    station_desc 
                              ,sh_prev.out_date
                              ,sh_prev.out_date_fact
                          from xx_etw.xx_disl_station_history       sh_prev
                              ,xx_etw.xx_disl_station_history       sh
                              ,xx_etw.xx_disl_round                 r
                              ,xx_etw.xx_disl_wagon_lists           wl
                         where 1=1
                           and nvl(p_operation,1) = 1
                         
                           and(   sh_prev.out_date between l_date_from and nvl(l_date_to,sh_prev.out_date)
                               or sh_prev.out_date_fact between l_date_from and nvl(l_date_to,sh_prev.out_date_fact))
                               
                           and sh_prev.round_id = sh.round_id
                           and sh_prev.out_date = sh.come_date
                           
                           and sh_prev.round_id = r.round_id
                           
                           and sh_prev.out_wagon_list_id = wl.wagon_list_id(+)
                       )
                 union all
                select 5
                      ,shop_info_id
                      ,date_post
                      ,creation_date
                      ,decode(weight_net,0,'разгрузка','погрузка')||' '||decode(round_type,'railcar','вагона','платформы')||' '||decode(round_type,'railcar',obj_num,place)||' '||weight_net_begin||' -> '||weight_net
                      ,obj_id
                      ,obj_num
                      ,station_id
                      ,xx_etw.xx_dislocation.get_obj_freight(obj_id,round_type,creation_date) freight
                  from (select si.shop_info_id
                              ,'railcar'                            round_type
                              ,r.round_id                           obj_id
                              ,r.railcar_id                         obj_num
                              ,si.date_post
                              ,weight_net
                              ,weight_net_begin
                              ,si.creation_date
                              ,(select station_id
                                  from xx_etw.xx_disl_station_history shh
                                 where 1=1
                                   and shh.round_id = r.round_id
                                   and si.date_post between shh.come_date and nvl(shh.out_date,sysdate)-1/24/60/60)
                                                                    station_id
                              ,null                                 place
                          from xx_etw.xx_disl_shop_info     si
                              ,xx_etw.xx_disl_round         r        
                         where 1=1
                           and nvl(p_operation,5) = 5
                         
                           and(   si.date_post between l_date_from and nvl(l_date_to,si.date_post)
                               or si.creation_date between l_date_from and nvl(l_date_to,si.creation_date))
                           and si.round_type = 'railcar'          
                           and si.round_id = r.round_id
                         union all
                        select si.shop_info_id
                              ,'cont'                               round_type
                              ,r.cont_round_id
                              ,r.cont_number
                              ,si.date_post
                              ,weight_net
                              ,weight_net_begin
                              ,si.creation_date
                              ,(select distinct -- 28/10/2019 BekmansurovRR 
                              --добавил max, т.к. выводилось две строки, в одной пустой id 29.07.2021
                                       max(case
                                         when ch.place_type = 'area'
                                         then (select station_id
                                                 from xx_etw.xx_disl_areas
                                                where area_id = ch.place_id)
                                         else (select station_id
                                                 from xx_etw.xx_disl_station_history shh
                                                where 1=1
                                                  and shh.round_id = ch.place_id
                                                  and ch.in_date_fact between shh.come_date and nvl(shh.out_date,sysdate)-1/24/60/60)
                                       end)
                                  from xx_etw.xx_disl_cont_history ch
                                 where 1=1
                                   and ch.cont_round_id = r.cont_round_id
                                   and si.date_post between ch.in_date_fact and nvl(ch.out_date_fact,sysdate)-1/24/60/60)
                                            station_id
                              ,(select distinct -- 28/10/2019 BekmansurovRR
                                       case
                                         when ch.place_type = 'area'
                                         then (select name
                                                 from xx_etw.xx_disl_areas
                                                where area_id = ch.place_id)
                                         else (select railcar_id
                                                 from xx_etw.xx_disl_round shh
                                                where 1=1
                                                  and shh.round_id = ch.place_id)
                                       end
                                  from xx_etw.xx_disl_cont_history ch
                                 where 1=1
                                   and ch.cont_round_id = r.cont_round_id
                                   and si.date_post between ch.in_date_fact and nvl(ch.out_date_fact,sysdate)-1/24/60/60
                                   -- 28/10/2019 BekmansurovRR
                                   and ch.CONT_HISTORY_ID = (select max(CONT_HISTORY_ID) from xx_etw.xx_disl_cont_history ch1 
                                           where ch1.cont_round_id = r.cont_round_id 
                                                 and si.date_post between ch1.in_date_fact and nvl(ch1.out_date_fact,sysdate)-1/24/60/60
                                       )
                                 
                                 )
                                                                    place
                          from xx_etw.xx_disl_shop_info     si
                              ,xx_etw.xx_disl_cont_round         r        
                         where 1=1
                           and nvl(p_operation,5) = 5
                         
                           and(   si.date_post between l_date_from and nvl(l_date_to,si.date_post)
                               or si.creation_date between l_date_from and nvl(l_date_to,si.creation_date))
                           
                           and si.round_type = 'cont'        
                           and si.round_id = r.cont_round_id
                       )
                 union all
                select 6
                      ,shop_info_id
                      ,date_uvod
                      ,creation_date
                      ,decode(weight_net,0,'разгрузка','погрузка')||' '||decode(round_type,'railcar','вагона','платформы')||' '||decode(round_type,'railcar',obj_num,place)||' '||weight_net_begin||' -> '||weight_net
                      ,obj_id
                      ,obj_num
                      ,station_id
                      ,xx_etw.xx_dislocation.get_obj_freight(obj_id,round_type,creation_date) freight
                  from (select si.shop_info_id
                              ,'railcar'                            round_type
                              ,r.round_id                           obj_id
                              ,r.railcar_id                         obj_num
                              ,si.date_uvod
                              ,weight_net
                              ,weight_net_begin
                              ,si.creation_date
                              ,(select station_id
                                  from xx_etw.xx_disl_station_history shh
                                 where 1=1
                                   and shh.round_id = r.round_id
                                   and si.date_post between shh.come_date and nvl(shh.out_date,sysdate)-1/24/60/60)
                                                                    station_id
                              ,null                                 place
                          from xx_etw.xx_disl_shop_info     si
                              ,xx_etw.xx_disl_round         r        
                         where 1=1
                           and nvl(p_operation,6) = 6
                         
                           and(   si.date_uvod between l_date_from and nvl(l_date_to,si.date_post)
                               or si.creation_date between l_date_from and nvl(l_date_to,si.creation_date))
                           and si.round_type = 'railcar'          
                           and si.round_id = r.round_id
                         union all
                        select si.shop_info_id
                              ,'cont'                               round_type
                              ,r.cont_round_id
                              ,r.cont_number
                              ,si.date_uvod
                              ,weight_net
                              ,weight_net_begin
                              ,si.creation_date
                              ,(select distinct -- 28/10/2019 BekmansurovRR
                              --добавил max, т.к. выводилось две строки, в одной пустой id 29.07.2021
                                        max(case
                                         when ch.place_type = 'area'
                                         then (select station_id
                                                 from xx_etw.xx_disl_areas
                                                where area_id = ch.place_id)
                                         else (select station_id
                                                 from xx_etw.xx_disl_station_history shh
                                                where 1=1
                                                  and shh.round_id = ch.place_id
                                                  and ch.in_date_fact between shh.come_date and nvl(shh.out_date,sysdate)-1/24/60/60)
                                       end)
                                  from xx_etw.xx_disl_cont_history ch
                                 where 1=1
                                   and ch.cont_round_id = r.cont_round_id
                                   and si.date_post between ch.in_date_fact and nvl(ch.out_date_fact,sysdate)-1/24/60/60)
                                            station_id
                              ,(select distinct -- 28/10/2019 BekmansurovRR
                                        case
                                         when ch.place_type = 'area'
                                         then (select name
                                                 from xx_etw.xx_disl_areas
                                                where area_id = ch.place_id)
                                         else (select railcar_id
                                                 from xx_etw.xx_disl_round shh
                                                where 1=1
                                                  and shh.round_id = ch.place_id)
                                       end
                                  from xx_etw.xx_disl_cont_history ch
                                 where 1=1
                                   and ch.cont_round_id = r.cont_round_id
                                   and si.date_post between ch.in_date_fact and nvl(ch.out_date_fact,sysdate)-1/24/60/60
                                   -- 28/10/2019 BekmansurovRR
                                   and ch.CONT_HISTORY_ID = (select max(CONT_HISTORY_ID) from xx_etw.xx_disl_cont_history ch1 
                                           where ch1.cont_round_id = r.cont_round_id 
                                                 and si.date_post between ch1.in_date_fact and nvl(ch1.out_date_fact,sysdate)-1/24/60/60
                                       )
                                   )
                                                                    place
                          from xx_etw.xx_disl_shop_info     si
                              ,xx_etw.xx_disl_cont_round         r        
                         where 1=1
                           and nvl(p_operation,6) = 6
                         
                           and(   si.date_uvod between l_date_from and nvl(l_date_to,si.date_post)
                               or si.creation_date between l_date_from and nvl(l_date_to,si.creation_date))
                           
                           and si.round_type = 'cont'        
                           and si.round_id = r.cont_round_id
                       )
               )
         where 1=1
           and station_id = nvl(p_station_id,station_id)
         order by
               operation_id
              ,date_oper_custom)
    loop
        l_row := null;
        select listagg(lr.route_num,', ') within group (order by lr.route_num)
          into l_row.route_desc
          from xx_etw.xx_disl_route_links       rl
              ,xx_etw.xx_disl_loco_routes_v     lr  
         where 1=1
           and rl.route_id = lr.route_id
         
           and rl.operation_id = l_action.operation_id
           and rl.action_id = l_action.action_id;
        
        select listagg(to_char(general_date_from,'dd.mm.yyyy hh24:mi')||' - '||to_char(general_date_to,'dd.mm.yyyy hh24:mi')||' ('||to_char(date_from,'hh24:mi')||'-'||to_char(date_to,'hh24:mi')||')',', ') within group (order by general_date_from)
          into l_row.route_time
          from (select distinct
                       date_from
                      ,date_to
                      ,general_date_from
                      ,general_date_to
                  from xx_etw.xx_disl_route_links       rl 
                 where 1=1
                   and rl.operation_id = l_action.operation_id
                   and rl.action_id = l_action.action_id);
        
        if ((l_row.route_desc is null and p_exists_route = 0) or (l_row.route_desc is not null and p_exists_route = 1) or p_exists_route is null) then   
    
            l_row.operation_id := l_action.operation_id;
            
            l_row.action_id := l_action.action_id;
            l_row.date_oper_custom := to_char(l_action.date_oper_custom,'dd.mm.yyyy hh24:mi');
            l_row.date_oper := to_char(l_action.date_oper,'dd.mm.yyyy hh24:mi');
            l_row.action_desc := l_action.action_desc;
            l_row.obj_round_id := l_action.obj_round_id;
            l_row.obj_number := l_action.obj_number;  
            
            l_row.station_id := l_action.station_id;
            l_row.freight := l_action.freight;
            
            select oper_descr
              into l_row.operation_descr
              from xx_etw.xx_disl_route_operations
             where oper_id = l_row.operation_id;
             
            select short_name
              into l_row.station
              from xx_etw.xx_disl_stations
             where station_id = l_row.station_id;
            
            pipe row (l_row);
        end if;
    end loop;
end;

function get_suitable_routes(
    p_date          varchar2,
    p_enter_text    varchar2)
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row; 
    l_date      date;
begin
    l_date := to_date(p_date,'dd.mm.yyyy hh24:mi');
    for l_routes in (
        select rv.route_id
              ,rv.route_num
          from xx_etw.xx_disl_loco_routes   r
              ,xx_etw.xx_disl_loco_routes_v rv
         where 1=1
           and r.route_id = rv.route_id
         
           and (   l_date between r.date_from and r.date_to
                or r.date_from between l_date-1/24*8 and l_date+1/24*8
                or r.date_to between l_date-1/24*8 and l_date+1/24*8
                or r.date_from >= l_date)
         
           and rv.route_num like '%'||p_enter_text||'%'
           
           and rv.status not in (3,5) -- Завершен, Отменен
         order by
               r.date_from
              ,rv.loco
    ) loop
        l_row.id := l_routes.route_id;
        l_row.name := l_routes.route_num;
        
        pipe row (l_row);   
    end loop; 
end;

function save_route_links(
    p_user_id           number,
    p_actions           varchar2,
    p_routes            varchar2,
    p_date_from         varchar2,
    p_date_to           varchar2)
return varchar2
as
    l_oper_id       number;
    l_act_id        number;
    
    l_count_act     number; 
    
    l_date_from     date;
    l_date_to       date;
    l_dif_sec       number; 
    l_cur_from      date;
    l_cur_to        date;
begin
--    log_new(-1,'save_route_links','p_actions = '||p_actions||' p_routes'||p_routes);
    l_date_from := to_date(p_date_from,'dd.mm.yyyy hh24:mi');
    l_date_to := to_date(p_date_to,'dd.mm.yyyy hh24:mi');

    l_count_act := regexp_count(p_actions,'[^$]+');
    
    l_dif_sec := round((l_date_to - l_date_from)*24*60*60/l_count_act);
    l_cur_from := l_date_from;
              
    for l_act in (
        select regexp_substr(p_actions,'[^$]+',1,level) text
              ,level                                    lvl
          from dual
       connect by level <= regexp_count(p_actions,'[^$]+'))
    loop
        l_oper_id := regexp_substr(l_act.text,'[^|]+',1,1); 
        l_act_id := regexp_substr(l_act.text,'[^|]+',1,2);
        
        delete
          from xx_disl_route_links
         where 1=1
           and operation_id = l_oper_id   
           and action_id = l_act_id;
        
--        log_new(-1,'save_route_links','l_count_act = '||l_count_act||' l_act.lvl = '||l_act.lvl);
        if (l_count_act = l_act.lvl) then
            l_cur_to := l_date_to;    
        else
            l_cur_to := l_cur_from + l_dif_sec/24/60/60;
        end if; 
        
--        log_new(-1,'save_route_links','l_cur_from = '||to_char(l_cur_from,'dd.mm.yyyy hh24:mi')||' l_cur_to = '||to_char(l_cur_to,'dd.mm.yyyy hh24:mi'));
              
        for l_route in (
            select regexp_substr(p_routes,'[^$]+',1,level) route_id
              from dual
           connect by level <= regexp_count(p_routes,'[^$]+'))
        loop  
            insert into xx_disl_route_links
            values (
                l_oper_id,    
                l_act_id,
                l_route.route_id,
                l_cur_from,
                l_cur_to,
                l_date_from,
                l_date_to, 
                p_user_id,
                sysdate);
        end loop;
        l_cur_from := l_cur_to;
    end loop;
    
    commit;
    return 'done';                  
exception
    when others then rollback; return 'fail';
end;

function del_route_links(
    p_user_id           number,
    p_actions           varchar2)
return varchar2
as
    l_oper_id       number;
    l_act_id        number;
    
    l_count         number; 
begin
    for l_act in (
        select regexp_substr(p_actions,'[^$]+',1,level) text
              ,level                                    lvl
          from dual
       connect by level <= regexp_count(p_actions,'[^$]+'))
    loop
        l_oper_id := regexp_substr(l_act.text,'[^|]+',1,1); 
        l_act_id := regexp_substr(l_act.text,'[^|]+',1,2);
        
        select count('x')
          into l_count
          from xx_etw.xx_disl_route_links   rl
              ,xx_etw.xx_disl_loco_routes   lr
         where 1=1
           and rl.operation_id = l_oper_id   
           and rl.action_id = l_act_id
           and rl.route_id = lr.route_id
           and lr.status = 3;
        
        if (l_count != 0) then
            rollback;
            return 'fail';
        end if;
        
        delete
          from xx_disl_route_links
         where 1=1
           and operation_id = l_oper_id   
           and action_id = l_act_id;
    end loop;
    
    commit;
    return 'done';     
exception
    when others then rollback; return 'fail';
end;


function get_other_actions(
    p_date_from     varchar2,
    p_date_to       varchar2,
    p_station_id    number,
    p_operation     number,
    p_route         number,
    p_action_id     number
) return t_xx_route_action_table pipelined
as
    l_row           t_xx_route_action_row;
    
    l_date_from     date;
    l_date_to       date;
begin
--    log_new(-1,'get_other_actions','p_date_from = '||p_date_from||' p_date_to = '||p_date_to||' p_station_id = '||p_station_id||' p_operation = '||p_operation||' p_route = '||p_route);

    l_date_from := to_date(p_date_from,'dd.mm.yyyy hh24:mi');
    l_date_to := to_date(p_date_to,'dd.mm.yyyy hh24:mi');
    
    for l_action in (
        select operation_id                 operation_id
              ,roa.action_id                action_id
              ,roa.general_date_from        date_oper_custom
              ,roa.created_date             date_oper
              ,roa.descr                    action_desc
              ,roa.round_id                 obj_round_id
              ,roa.car_number               obj_number
              ,roa.station_id               station_id
              ,xx_etw.xx_dislocation.get_obj_freight(roa.round_id,'railcar',roa.created_date) freight
              
              ,roa.general_date_from
              ,roa.general_date_to
              ,roa.date_from
              ,roa.date_to
          from xx_etw.xx_disl_route_other_actions   roa
         where 1=1
           and (   roa.action_id = p_action_id
                or
                  (    roa.general_date_from between l_date_from and nvl(l_date_to,general_date_from)
                   and nvl(roa.station_id,-1) = coalesce(p_station_id,roa.station_id,-1)
                   and roa.operation_id = nvl(p_operation,roa.operation_id)
                   
                   and exists (
                        select 'x'
                          from xx_etw.xx_disl_route_other_act_link  roal
                         where 1=1
                           and roa.action_id = roal.action_id
                           and roal.route_id = nvl(p_route,roal.route_id))
                  )
               )
         order by
               roa.general_date_from)
    loop 
        l_row := null;
        select listagg(lr.route_num,', ') within group (order by lr.route_num)
          into l_row.route_desc
          from xx_etw.xx_disl_route_other_act_link  roal 
              ,xx_etw.xx_disl_loco_routes_v         lr 
         where 1=1
           and roal.route_id = lr.route_id
           and roal.action_id = l_action.action_id;
        
        for l_route in (
            select lr.route_id
                  ,lr.route_num
                  ,rownum       rn
              from xx_etw.xx_disl_route_other_act_link  roal 
                  ,xx_etw.xx_disl_loco_routes_v         lr 
             where 1=1
               and roal.route_id = lr.route_id
               and roal.action_id = l_action.action_id)
        loop
            if (l_route.rn = 1) then
                l_row.route1_id := l_route.route_id;
                l_row.route1_desc := l_route.route_num;
            else
                l_row.route2_id := l_route.route_id;
                l_row.route2_desc := l_route.route_num;
            end if;
        end loop;
        
        l_row.route_time := to_char(l_action.general_date_from,'dd.mm.yyyy hh24:mi')||' - '||to_char(l_action.general_date_to,'dd.mm.yyyy hh24:mi')||' ('||to_char(l_action.date_from,'hh24:mi')||'-'||to_char(l_action.date_to,'hh24:mi')||')';
            
        l_row.action_id := l_action.action_id;
        l_row.date_oper_custom := to_char(l_action.date_oper_custom,'dd.mm.yyyy hh24:mi');
        l_row.date_oper := to_char(l_action.date_oper,'dd.mm.yyyy hh24:mi');
        l_row.action_desc := l_action.action_desc;
        l_row.obj_round_id := l_action.obj_round_id;
        l_row.obj_number := l_action.obj_number;  
            
        l_row.station_id := l_action.station_id;
        l_row.freight := l_action.freight;
        l_row.operation_id := l_action.operation_id;
        
        l_row.date_from := to_char(l_action.date_from,'dd.mm.yyyy hh24:mi');
        l_row.date_to := to_char(l_action.date_to,'dd.mm.yyyy hh24:mi');
        l_row.general_date_from := to_char(l_action.general_date_from,'dd.mm.yyyy hh24:mi');
        l_row.general_date_to := to_char(l_action.general_date_to,'dd.mm.yyyy hh24:mi');
            
        select oper_descr
          into l_row.operation_descr
          from xx_etw.xx_disl_other_route_operations
         where oper_id = l_row.operation_id;
             
        begin      
            select short_name
              into l_row.station
              from xx_etw.xx_disl_stations
             where station_id = l_row.station_id;
        exception
            when others then l_row.station := '';
        end;
              
        pipe row (l_row);
    end loop;
end;

function save_other_actions(
    p_user_id           number,
    p_action_id         number,
    p_date_from         varchar2,
    p_date_to           varchar2,
    p_routes            varchar2,
    p_station           number,
    p_oper              number,
    p_operation_descr        number,
    p_descr             varchar2,
    p_cars              varchar2)
return varchar2
as   
    l_count_cars     number;
    l_date_from     date;
    l_date_to       date;
    l_dif_sec       number; 
    l_cur_from      date;
    l_cur_to        date;
    l_act_id        number;
    l_round_id      number;
    l_result        varchar2(4000);
begin
    l_date_from := to_date(p_date_from,'dd.mm.yyyy hh24:mi');
    l_date_to := to_date(p_date_to,'dd.mm.yyyy hh24:mi');

    l_count_cars := regexp_count(p_cars,'[^$]+');
    
    l_dif_sec := round((l_date_to - l_date_from)*24*60*60/l_count_cars);
    l_cur_from := l_date_from;
  
    if (p_action_id is not null) then
        update xx_disl_route_other_actions
           set general_date_from = l_date_from
              ,general_date_to = l_date_to
              ,date_from = l_date_from
              ,date_to = l_date_to
              ,station_id = p_station
              ,operation_id = p_oper
              ,operation_descr_id = p_operation_descr
              ,descr = substr(p_descr,1,200) -- upd 20.04.2020
         where 1=1
           and action_id = p_action_id;   
        
        delete
          from xx_etw.xx_disl_route_other_act_link
         where action_id = p_action_id;
            
        for l_routes in (
            select regexp_substr(p_routes,'[^$]+',1,level) r_id
              from dual
           connect by level <= regexp_count(p_routes,'[^$]+'))
        loop  
            insert into xx_etw.xx_disl_route_other_act_link
            values(
                p_action_id,
                l_routes.r_id);
        end loop; 
    else 
        for l_cars in (
            select regexp_substr(p_cars,'[^$]+',1,level) car_num
                  ,level                                    lvl
              from dual
           connect by level <= regexp_count(p_cars,'[^$]+'))
        loop
            if (l_count_cars = l_cars.lvl) then
                l_cur_to := l_date_to;    
            else
                l_cur_to := l_cur_from + l_dif_sec/24/60/60;
            end if; 
            
            l_act_id := xx_etw.xx_disl_route_other_act_seq.nextval();
            l_round_id := returnLastRound(l_cars.car_num);
                  
            insert into xx_etw.xx_disl_route_other_actions
            values (
                l_act_id,
                l_cars.car_num,
                l_round_id,
                l_cur_from,
                l_cur_to,
                l_date_from,
                l_date_to,
                p_station,
                p_oper,
                p_descr,
                p_user_id,
                sysdate,
                substr(p_operation_descr,1,200)  -- upd 20.04.2020
                );
            
            for l_routes in (
                select regexp_substr(p_routes,'[^$]+',1,level) r_id
                  from dual
               connect by level <= regexp_count(p_routes,'[^$]+'))
            loop  
                insert into xx_etw.xx_disl_route_other_act_link
                values(
                    l_act_id,
                    l_routes.r_id);
            end loop;
            l_cur_from := l_cur_to;
            
            l_result := l_result||','||l_act_id;
        end loop;
    end if;
    
    commit;
    return 'done'||'$'||l_result;                  
exception
    when others then rollback; return 'fail';
end;

function del_other_actions(
    p_user_id           number,
    p_actions           varchar2)
return varchar2
as
    l_oper_id       number;
    l_act_id        number;
    l_count         number;
begin
    for l_act in (
        select regexp_substr(p_actions,'[^$]+',1,level) act_id
              ,level                                    lvl
          from dual
       connect by level <= regexp_count(p_actions,'[^$]+'))
    loop
        select count('x')
          into l_count
          from xx_etw.xx_disl_route_other_act_link  roal
              ,xx_etw.xx_disl_loco_routes           lr
         where action_id = l_act.act_id
           and roal.route_id = lr.route_id
           and lr.status = 3;
        
        if (l_count != 0) then
            rollback;
            return 'fail';
        end if;
        
        delete
          from xx_etw.xx_disl_route_other_actions
         where action_id = l_act.act_id;
         
        delete
          from xx_etw.xx_disl_route_other_act_link
         where action_id = l_act.act_id;
    end loop;

    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function num_to_str(p_num number)
return varchar2
as
begin
    return replace(to_char(p_num),',','.');    
end;

function min_to_hour(p_min number)
return varchar2
as
begin
    if (p_min is null) then
        return '';
    else
        return trunc(p_min/60,0)||' ч. '||mod(p_min,60)||' мин.';
    end if;
end;


/*p_oper_type 1 - маневровые, 2 - грузовые*/
function get_route_work_time(p_route_id number,p_oper_type number)
return number
as  
    l_time              number;
    l_other_time        number;
begin
    select sum((rl.date_to - rl.date_from)*24*60)
      into l_time
      from xx_etw.xx_disl_route_links   rl
     where 1=1
       and rl.route_id = p_route_id
       and rl.operation_id in (
           select oper_id
             from xx_etw.xx_disl_route_operations
            where oper_type = p_oper_type);
            
    select sum((roa.date_to - roa.date_from)*24*60)
      into l_other_time
      from xx_etw.xx_disl_route_other_actions   roa
          ,xx_etw.xx_disl_route_other_act_link  roal
     where 1=1
       and roa.action_id = roal.action_id
       and route_id = p_route_id
       and roa.operation_id in (
           select oper_id
             from xx_etw.xx_disl_other_route_operations
            where oper_type = p_oper_type);
            
    return round(nvl(l_time,0)+nvl(l_other_time,0),0);
end;

function get_routes_totals(
    p_date_from     varchar2,
    p_date_to       varchar2,
    p_smena         number,
    p_station       number,
    p_loco          number
) return t_xx_route_total_table pipelined
as
    l_row                   t_xx_route_total_row;
    l_consumption_fact      number;
    l_consumption_fact_kg   number;
    l_shunting_work         number;
    l_freight_work          number;
    l_consumption_norm      number;
    l_consumption_plus      number;
    l_consumption_minus     number;
    l_total_work            number;
begin    
    for c_row in (
        select lrv.*
              ,fuel_in
              ,fuel_out
              ,waiting
              ,waiting_hot
              ,waiting_cold
              ,excess_work
              ,to_char(lrt.last_update_date,'dd.mm.yyyy hh24:mi') total_last_update_date
              ,lr.date_from         date_from_d  
              ,refill 
              ,fuel_in_who 
              ,refill_who
              ,fuel_out_who
          from xx_etw.xx_disl_loco_routes      lr
              ,xx_etw.xx_disl_loco_routes_v    lrv
              ,xx_etw.xx_disl_loco_route_total lrt
         where 1=1
           and lr.route_id = lrv.route_id
           and lr.route_id = lrt.route_id(+)
           
           and lr.date_from between to_date(p_date_from,'dd.mm.yyyy hh24:mi') and nvl(to_date(p_date_to,'dd.mm.yyyy hh24:mi'),lr.date_from)
           and lr.smena = nvl(p_smena,lr.smena)
           and lr.station = nvl(p_station,lr.station)
           and lr.loco = nvl(p_loco,lr.loco)
         order by
               lr.date_from)
    loop
        l_consumption_fact := null;
        l_consumption_fact_kg := null;   
        l_shunting_work := null;         
        l_freight_work := null;          
        l_consumption_norm := null;      
        l_consumption_plus := null;      
        l_consumption_minus := null;     
    
        l_consumption_fact := c_row.fuel_in - c_row.fuel_out;
        
        if (to_char(c_row.date_from_d,'mm') = '04' or to_char(c_row.date_from_d,'mm') = '05' or to_char(c_row.date_from_d,'mm') = '06' or to_char(c_row.date_from_d,'mm') = '07' or to_char(c_row.date_from_d,'mm') = '08' or to_char(c_row.date_from_d,'mm') = '09') then
            l_consumption_fact_kg := l_consumption_fact * 0.833;
        else
            l_consumption_fact_kg := l_consumption_fact * 0.825;
        end if;
        
        l_shunting_work := get_route_work_time(c_row.route_id,1);
        l_freight_work := get_route_work_time(c_row.route_id,2);
        l_consumption_norm := round((nvl(c_row.waiting*11,0)+nvl(c_row.waiting_hot*11,0)+nvl(l_shunting_work*22,0)+nvl(l_freight_work*38,0))/60,0);
        
        if (l_consumption_fact_kg - l_consumption_norm > 0) then
            l_consumption_minus := l_consumption_fact_kg - l_consumption_norm;
        else
            l_consumption_plus := l_consumption_norm - l_consumption_fact_kg;
        end if;
        
        l_total_work := nvl(c_row.waiting,0) + nvl(c_row.waiting_hot,0) + nvl(c_row.waiting_cold,0) + nvl(l_shunting_work,0) + nvl(l_freight_work,0);
    
        l_row.route_id := c_row.route_id;
        l_row.route_num := c_row.route_num;
        l_row.status := c_row.status;
        l_row.status_desc := c_row.status_desc;
        l_row.last_update_date := c_row.last_update_date; 
        l_row.total_last_update_date := c_row.total_last_update_date;   
        l_row.fuel_in := num_to_str(c_row.fuel_in);
        l_row.fuel_out := num_to_str(c_row.fuel_out);
        l_row.consumption_fact := num_to_str(l_consumption_fact);
        l_row.consumption_fact_kg := num_to_str(trunc(l_consumption_fact_kg));
        l_row.consumption_norm := num_to_str(l_consumption_norm);
        l_row.consumption_plus := num_to_str(l_consumption_plus);
        l_row.consumption_minus := num_to_str(l_consumption_minus);
        l_row.waiting := num_to_str(c_row.waiting);
        l_row.waiting_hr := min_to_hour(c_row.waiting);
        l_row.waiting_hot := num_to_str(c_row.waiting_hot);
        l_row.waiting_hot_hr := min_to_hour(c_row.waiting_hot);
        l_row.waiting_cold := num_to_str(c_row.waiting_cold);
        l_row.waiting_cold_hr := min_to_hour(c_row.waiting_cold);
        l_row.shunting_work := num_to_str(l_shunting_work);
        l_row.shunting_work_hr := min_to_hour(l_shunting_work);
        l_row.freight_work := num_to_str(l_freight_work);
        l_row.freight_work_hr := min_to_hour(l_freight_work);
        l_row.total_work := num_to_str(l_total_work);
        l_row.total_work_hr := min_to_hour(l_total_work);
        l_row.excess_work := num_to_str(c_row.excess_work);
        l_row.excess_work_hr := min_to_hour(c_row.excess_work);
        l_row.refill := num_to_str(c_row.refill);
        l_row.fuel_in_who := c_row.fuel_in_who;
        l_row.refill_who := c_row.refill_who;
        l_row.fuel_out_who := c_row.fuel_out_who;

        pipe row (l_row);
    end loop;
end;


function get_route_operation_details(
    p_route_id    number
) return t_xx_route_operation_table pipelined
as
    l_row   t_xx_route_operation_row;
begin
    for l_route_opers in (
        select *
          from (select distinct
                       rl.general_date_from
                      ,rl.general_date_to
                      ,(rl.general_date_to - rl.general_date_from) * 24 * 60 diff_time 
                      ,ro.oper_descr
                      ,decode(ro.oper_type
                             ,1,'Маневровый'
                             ,'Грузовой')
                                                oper_type
                  from xx_etw.xx_disl_route_links          rl
                      ,xx_etw.xx_disl_route_operations     ro
                 where 1=1
                   and route_id = p_route_id
                   
                   and rl.operation_id = ro.oper_id 
                 union all
                select distinct
                       roa.general_date_from
                      ,roa.general_date_to
                      ,(roa.general_date_to - roa.general_date_from) * 24 * 60 diff 
                      ,oro.oper_descr
                      ,decode(oro.oper_type
                             ,1,'Маневровый'
                             ,'Грузовой')
                                                oper_type
                  from xx_etw.xx_disl_route_other_act_link     roal
                      ,xx_etw.xx_disl_route_other_actions      roa
                      ,xx_etw.xx_disl_other_route_operations   oro
                 where 1=1
                   and roal.route_id = p_route_id
                   
                   and roal.action_id = roa.action_id
                   and roa.operation_id = oro.oper_id 
               )
         order by
               general_date_from)
    loop
        l_row.general_date_from := to_char(l_route_opers.general_date_from,'dd.mm.yyyy hh24:mi');
        l_row.general_date_to := to_char(l_route_opers.general_date_to,'dd.mm.yyyy hh24:mi');
        l_row.diff_time := round(l_route_opers.diff_time);
        l_row.oper_descr := l_route_opers.oper_descr;
        l_row.oper_type := l_route_opers.oper_type;
        
        pipe row (l_row);
    end loop;
end;


function save_route_add(
    p_user_id           number,
    p_route_id          number,
    p_fuel_in           varchar2,
    p_fuel_out          varchar2,
    p_waiting           number,
    p_waiting_hot       number,
    p_waiting_cold      number,
    p_excess_work       number,
    p_refill            varchar2,
    p_fuel_in_who       varchar2,
    p_refill_who        varchar2,
    p_fuel_out_who      varchar2
) return varchar2 
as  
begin
    update xx_etw.xx_disl_loco_route_total 
       set fuel_in = replace(p_fuel_in,'.',',')
          ,fuel_out = replace(p_fuel_out,'.',',')
          ,waiting = replace(p_waiting,'.',',')
          ,waiting_hot = replace(p_waiting_hot,'.',',')
          ,waiting_cold = replace(p_waiting_cold,'.',',')
          ,excess_work = replace(p_excess_work,'.',',')
          ,last_update_by = p_user_id
          ,last_update_date = sysdate
          ,refill = replace(p_refill,'.',',')
          ,fuel_in_who = p_fuel_in_who
          ,refill_who = p_refill_who
          ,fuel_out_who = p_fuel_out_who
     where route_id = p_route_id;
    if (sql%rowcount = 0)then
        insert into xx_etw.xx_disl_loco_route_total
        values(
            p_route_id,
            replace(p_fuel_in,'.',','),
            replace(p_fuel_out,'.',','),
            replace(p_waiting,'.',','),
            replace(p_waiting_hot,'.',','),
            replace(p_waiting_cold,'.',','),
            replace(p_excess_work,'.',','),
            p_user_id,
            sysdate,
            replace(p_refill,'.',','),
            p_fuel_in_who,
            p_refill_who,
            p_fuel_out_who);
    end if;
          
    commit; 

    return 'done';
exception
    when others then rollback; return 'fail';
end;


/*beg***************  Расходные нормы ГСМ  ******************/
function get_fuel_loco
return t_fuel_loco_table pipelined
as
    l_row   xx_etw.xx_disl_loco_add_from_oebs_v%rowtype;
begin
    for c_row in (
        select *
          from xx_etw.xx_disl_loco_add_from_oebs_v
         order by
               par_instance_id)
    loop
        l_row.instance_id := c_row.instance_id;
        l_row.instance_number := c_row.instance_number;       
        l_row.category := c_row.category;
        l_row.par_instance_id := c_row.par_instance_id; 
        l_row.par_instance_number := c_row.par_instance_number;
        l_row.department_code := c_row.department_code;
        
        pipe row (l_row);
    end loop;
end;

function get_fuel_standart_spr
return t_fuel_standart_spr_table pipelined
as
    l_row   xx_etw.xx_disl_fuel_standart_spr%rowtype;
begin
    for c_row in (
        select *
          from xx_etw.xx_disl_fuel_standart_spr
          where trunc(sysdate) between START_DATE and nvl(end_date,trunc(sysdate))
         )
    loop
        l_row.spr_type := c_row.spr_type;
        l_row.elem_id := c_row.elem_id;       
        l_row.elem_descr := c_row.elem_descr;
        l_row.elem_add_info := c_row.elem_add_info; 
        pipe row (l_row);
    end loop;
end;

function save_fuel_standart(
    p_user_id           number,
    p_row_id            number,
    p_add_data          varchar2    
) return varchar2 
as
    l_row           xx_etw.xx_disl_fuel_standart%rowtype;   
    l_json          json;
    
    l_result        varchar2(4000);
begin   
    l_json := xx_wms.json(p_add_data);
 
    if (p_row_id is null) then
        l_row.row_id := xx_etw.xx_disl_fuel_standart_seq.nextval();
        l_row.base_type := l_json.get_string('base_type');
        l_row.base_num := l_json.get_string('base_num');
        l_row.base_date := to_date(l_json.get_string('base_date'),'dd.mm.yyyy');
        l_row.date_to := to_date(l_json.get_string('date_to'),'dd.mm.yyyy');
        l_row.base_descr := l_json.get_string('base_descr');
        l_row.instance_id := l_json.get_string('loco');
        l_row.season := l_json.get_string('season');
        l_row.cons_rate_type := l_json.get_string('cons_rate_type');
        l_row.fuel_type := l_json.get_string('fuel_type');
        l_row.conversion_factor := to_number(l_json.get_string('conversion_factor'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''');
        l_row.freight_work := to_number(l_json.get_string('freight_work'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''');
        l_row.shunting_work := to_number(l_json.get_string('shunting_work'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''');
        l_row.hot_simple := to_number(l_json.get_string('hot_simple'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''');
        l_row.under_repair := to_number(l_json.get_string('under_repair'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''');
        l_row.rounding := to_number(l_json.get_string('rounding'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''');
        l_row.other := to_number(l_json.get_string('other'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''');
        l_row.contr_date_from := to_date(l_json.get_string('contr_date_from'),'dd.mm.yyyy');
        l_row.contr_date_to := to_date(l_json.get_string('contr_date_to'),'dd.mm.yyyy');
        l_row.term := l_json.get_string('term');
        l_row.doc := l_json.get_string('doc');
        l_row.comm := l_json.get_string('comm');
        l_row.created_by := p_user_id;
        l_row.creation_date := sysdate;
        l_row.last_update_by := p_user_id;
        l_row.last_update_date := sysdate;

        insert into xx_etw.xx_disl_fuel_standart  
        values l_row;
    else
        update xx_etw.xx_disl_fuel_standart 
           set base_type = l_json.get_string('base_type')
              ,base_num = l_json.get_string('base_num')
              ,base_date = to_date(l_json.get_string('base_date'),'dd.mm.yyyy')
              ,date_to = to_date(l_json.get_string('date_to'),'dd.mm.yyyy')
              ,base_descr = l_json.get_string('base_descr')
              ,instance_id = l_json.get_string('loco')
              ,season = l_json.get_string('season')
              ,cons_rate_type = l_json.get_string('cons_rate_type')
              ,fuel_type = l_json.get_string('fuel_type')
              ,conversion_factor = to_number(l_json.get_string('conversion_factor'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''')
              ,freight_work = to_number(l_json.get_string('freight_work'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''')
              ,shunting_work = to_number(l_json.get_string('shunting_work'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''')
              ,hot_simple = to_number(l_json.get_string('hot_simple'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''')
              ,under_repair = to_number(l_json.get_string('under_repair'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''')
              ,rounding = to_number(l_json.get_string('rounding'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''')
              ,other = to_number(l_json.get_string('other'),'99999999D999','NLS_NUMERIC_CHARACTERS = ''. ''')
              ,contr_date_from = to_date(l_json.get_string('contr_date_from'),'dd.mm.yyyy')
              ,contr_date_to = to_date(l_json.get_string('contr_date_to'),'dd.mm.yyyy')
              ,term = l_json.get_string('term')
              ,doc = l_json.get_string('doc')
              ,comm = l_json.get_string('comm')
              ,last_update_by = p_user_id
              ,last_update_date = sysdate
         where row_id = p_row_id;
    end if;
          
    commit;
    l_result := 'done';   

    return l_result;
exception
    when others then rollback; return 'fail';
end;

function get_fuel_standart(
    p_params        varchar2
) return t_xx_fuel_standart_table pipelined
as
    l_row   xx_etw.xx_disl_fuel_standart_v%rowtype;
    l_json  json;
    
    l_date  date;
begin
    l_json := xx_wms.json(p_params);
    
    l_date := to_date(l_json.get_string('date'),'dd.mm.yyyy');

    for c_row in (
        select fsv.*
          from xx_etw.xx_disl_fuel_standart      fs
              ,xx_etw.xx_disl_fuel_standart_v    fsv
         where 1=1
           and rownum <= 50
         
           and fs.row_id = fsv.row_id
           and fs.base_type = nvl(l_json.get_string('base_type'),fs.base_type) 
           and fs.base_num = nvl(l_json.get_string('base_num'),fs.base_num)
           and nvl(l_date,fs.contr_date_from) between fs.contr_date_from and nvl(fs.contr_date_to,sysdate)
           
           and fs.instance_id = nvl(l_json.get_string('loco'),fs.instance_id)
           and fs.instance_id in (
                select instance_id
                  from xx_etw.xx_disl_loco_add_from_oebs_v
                 where par_instance_id = nvl(l_json.get_string('loco_par_inst'),par_instance_id)))
    loop
        l_row.row_id := c_row.row_id;
        l_row.base_type := c_row.base_type;
        l_row.base_type_descr := c_row.base_type_descr;
        l_row.base_num := c_row.base_num;
        l_row.base_date := c_row.base_date;
        l_row.date_to := c_row.date_to;
        l_row.base_descr := c_row.base_descr;
        l_row.instance_id := c_row.instance_id;
        l_row.instance_descr := c_row.instance_descr;
        l_row.season := c_row.season;
        l_row.season_descr := c_row.season_descr;
        l_row.cons_rate_type := c_row.cons_rate_type;
        l_row.cons_rate_type_descr := c_row.cons_rate_type_descr;
        l_row.fuel_type := c_row.fuel_type;
        l_row.fuel_type_descr := c_row.fuel_type_descr;
        l_row.conversion_factor := c_row.conversion_factor;
        l_row.freight_work := c_row.freight_work;
        l_row.shunting_work := c_row.shunting_work;
        l_row.hot_simple := c_row.hot_simple;
        l_row.under_repair := c_row.under_repair;
        l_row.rounding := c_row.rounding;
        l_row.other := c_row.other;
        l_row.contr_date_from := c_row.contr_date_from;
        l_row.contr_date_to := c_row.contr_date_to;
        l_row.term := c_row.term;
        l_row.doc := c_row.doc;
        l_row.comm := c_row.comm;

        l_row.created_by := c_row.created_by;
        l_row.created_by_desc := c_row.created_by_desc;
        l_row.creation_date := c_row.creation_date;
        l_row.last_update_by := c_row.last_update_by;
        l_row.last_update_by_desc := c_row.last_update_by_desc;
        l_row.last_update_date := c_row.last_update_date;     
       
        pipe row (l_row);
    end loop;
end;

/*end***************  Расходные нормы ГСМ  ******************/

function get_cars_passport(
    p_user_id   number,
    p_cars      varchar2)
return t_xx_car_passport_table pipelined
as
    l_row       t_xx_car_passport_row;     
begin
    for l_cars_info in (
        select cars.car_number                  car_number
              ,rai.status                       status
              ,to_char(ecn.car_next_repair,'dd.mm.yyyy')              car_last_repair
              ,ecn.car_norma                    car_norma
              ,ecn.car_type_name                car_type_name
              ,ecn.car_model                    car_model
              ,ecn.car_year                     car_year
              ,ecn.car_axles                    car_axles
              ,ecn.car_owner_country_name       car_owner_country_name
              ,ecn.car_owner_type_name          car_owner_type_name
              ,ecn.car_owner_okpo               car_owner_okpo
              ,ecn.car_owner_name               car_owner_name
              ,ecn.car_tonnage                  car_tonnage
              ,ecn.car_weight_dep               car_weight_dep
              ,ecn.car_volume                   car_volume
              ,ecn.car_arendator_okpo           car_arendator_okpo
              ,ecn.car_arendator_name           car_arendator_name
              ,to_char(ecn.car_end_arenda_date,'dd.mm.yyyy')          car_end_arenda_date
              ,ecn.car_length                   car_length
              ,to_char(ecn.car_nsi_date,'dd.mm.yyyy')                 car_nsi_date
              ,to_char(ecn.xx_last_update_date,'dd.mm.yyyy')          xx_last_update_date
              ,(select description||' - '||user_name
                  from apps.fnd_user
                 where 1=1
                   and user_id = ecn.xx_last_updated_by)
                                                xx_last_updated_by
              ,(select to_char(max(DATA_OPERACII),'dd.mm.yyyy')
                  from --ctm_dislocation_cars -- rem 19.04.2020
                       xx_etw.dislocation_cars -- add 19.04.2020
                 where 1=1
                   and car_number = ecn.car_number
                   and end_stationcode = dest_stationcode
                   and dest_stationcode = 76820)
                                                ugl_date
              ,to_char(ecn.car_iskl_date,'dd.mm.yyyy')                gvc_date
              ,ecn.text_teleg                   text_teleg
          from (select regexp_substr(p_cars,'[^|]+',1,level) car_number
                  from dual
               connect by level <= regexp_count(p_cars,'[^|]+'))
                                cars
              ,etw_car_nsi      ecn
              ,(select round_id
                      ,status
                  from xx_disl_railcar_add_info
                 where last_record = 'Y')
                                rai
         where 1=1
           and cars.car_number = ecn.car_number(+)
           and xx_dislocation.returnLastRound(cars.car_number) = rai.round_id(+))
    loop
        l_row := null;
        
        l_row.car_number := l_cars_info.car_number;
        l_row.status := l_cars_info.status;
        l_row.car_last_repair := l_cars_info.car_last_repair;
        l_row.car_norma := l_cars_info.car_norma;
        l_row.car_type_name := l_cars_info.car_type_name;
        l_row.car_model := l_cars_info.car_model;
        l_row.car_year := l_cars_info.car_year;
        l_row.car_axles := l_cars_info.car_axles;
        l_row.car_owner_country_name := l_cars_info.car_owner_country_name;
        l_row.car_owner_type_name := l_cars_info.car_owner_type_name;
        l_row.car_owner_okpo := l_cars_info.car_owner_okpo;
        l_row.car_owner_name := l_cars_info.car_owner_name;
        l_row.car_tonnage := l_cars_info.car_tonnage;
        l_row.car_weight_dep := l_cars_info.car_weight_dep;
        l_row.car_volume := l_cars_info.car_volume;
        l_row.car_arendator_okpo := l_cars_info.car_arendator_okpo;
        l_row.car_arendator_name := l_cars_info.car_arendator_name;
        l_row.car_end_arenda_date := l_cars_info.car_end_arenda_date;
        l_row.car_length := l_cars_info.car_length;
        l_row.car_nsi_date := l_cars_info.car_nsi_date;
        l_row.xx_last_update_date := l_cars_info.xx_last_update_date;
        l_row.xx_last_updated_by := l_cars_info.xx_last_updated_by;
        l_row.ugl_date := l_cars_info.ugl_date;
        l_row.gvc_date := l_cars_info.gvc_date;
        l_row.text_teleg := l_cars_info.text_teleg;
        
        pipe row(l_row);
    end loop;
end;

function get_fixing_side(
    p_user_id       number)
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row;     
begin
    for l_part in (
        select side_id
              ,descr
          from xx_etw.xx_disl_fixing_side)
    loop
        l_row := null;
        
        l_row.id := l_part.side_id;
        l_row.name := l_part.descr;
        
        pipe row(l_row);
    end loop;
end;

function get_railway_part(
    p_user_id       number,
    p_railway_id    number)
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row;     
begin
    for l_part in (
        select part_id
              ,descr
          from xx_etw.xx_disl_railway_part
         where 1=1
           and railway_id = p_railway_id
           and deleted = 'N')
    loop
        l_row := null;
        
        l_row.id := l_part.part_id;
        l_row.name := l_part.descr;
        
        pipe row(l_row);
    end loop;
end;

function save_railway_part(
    p_user_id           number,
    p_part_id           number,
    p_add_data          varchar2    
) return varchar2 
as
    l_row           xx_etw.xx_disl_railway_part%rowtype;   
    l_json          json;
    
    l_result        varchar2(4000);
begin   
    l_json := xx_wms.json(p_add_data);
 
    if (p_part_id is null) then
        l_row.part_id := xx_etw.xx_disl_railway_part_seq.nextval();
        l_row.railway_id := l_json.get_string('railway_id');
        l_row.descr := l_json.get_string('descr');
        l_row.created_by := p_user_id;
        l_row.creation_date := sysdate;
        l_row.last_updated_by := p_user_id;
        l_row.last_update_date := sysdate;
        l_row.deleted := 'N';

        insert into xx_etw.xx_disl_railway_part  
        values l_row;
    else
        update xx_etw.xx_disl_railway_part 
           set railway_id = l_json.get_string('railway_id')
              ,descr = l_json.get_string('descr')
              ,last_updated_by = p_user_id
              ,last_update_date = sysdate
         where part_id = p_part_id;
    end if;
          
    commit;
    l_result := 'done';   

    return l_result;
exception
    when others then rollback; return 'fail';
end;

function get_fixing_device_rule(
    p_user_id       number,
    p_params        varchar2)
return t_xx_fixing_device_rule_table pipelined
as
    l_row       t_xx_fixing_device_rule_row;  
    l_json      json;
    l_part_id   number;   
begin
    l_json := xx_wms.json(p_params);
    
    l_part_id := to_number(l_json.get_string('part_id'));

    for l_part in (
        select fdr.railway_id       railway_id
              ,r.railway_number
             ||case 
                 when r.add_info is not null
                 then ' ('||r.add_info ||')'
                 else ''
               end     
                                    railway_number
              ,fdr.part_id          part_id
              ,rp.descr             part_descr
              ,fdr.rule_id
              ,fdr.side
              ,fs.descr             side_descr
              ,fdr.cnt_skid
              ,fdr.cnt_axis_1
              ,fdr.cnt_axis_2
              ,fdr.descr
              ,fdr.last_update_date
          from xx_etw.xx_disl_fixing_device_rule        fdr
              ,xx_etw.xx_disl_railways                  r
              ,xx_etw.xx_disl_railway_part              rp
              ,xx_etw.xx_disl_fixing_side               fs
         where fdr.deleted = 'N'
           and fdr.part_id = nvl(l_part_id,fdr.part_id)
           and fdr.railway_id = r.railway_id
           and fdr.part_id = rp.part_id
           and fdr.deleted = 'N'
           and fdr.side = fs.side_id
         order by
               fdr.railway_id
              ,fdr.part_id
              ,fdr.rule_id)
    loop
        l_row := null;
        
        l_row.railway_id := l_part.railway_id;
        l_row.railway_number := l_part.railway_number;
        l_row.part_id := l_part.part_id;
        l_row.part_descr := l_part.part_descr;
        l_row.rule_id := l_part.rule_id;
        l_row.side := l_part.side;
        l_row.side_descr := l_part.side_descr;
        l_row.cnt_skid := l_part.cnt_skid;
        l_row.cnt_axis_1 := l_part.cnt_axis_1;
        l_row.cnt_axis_2 := l_part.cnt_axis_2;
        l_row.descr := l_part.descr;
        l_row.last_update_date := to_char(l_part.last_update_date,'dd.mm.yyyy hh24:mi:ss');
        
        pipe row(l_row);
    end loop;
end;

function save_fixing_device_rule(
    p_user_id           number,
    p_add_data          varchar2    
) return varchar2 
as
    l_error         exception;
    l_row           xx_etw.xx_disl_fixing_device_rule%rowtype;   
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_railway_id    number;
    l_part_id       number;
    
    l_result        varchar2(4000);
begin   
    l_json := xx_wms.json(p_add_data);
    
    l_railway_id := l_json.get_string('railway_id');
    l_part_id := l_json.get_string('part_id');
    
    if (l_railway_id is null or l_part_id is null) then
        raise l_error; 
    end if;  
    
    l_json_value := l_json.get('rule_mas');
    l_json_list := json_list(l_json_value);  
    
    for i in 1..l_json_list.count loop
        l_json_value := l_json_list.get(i);
