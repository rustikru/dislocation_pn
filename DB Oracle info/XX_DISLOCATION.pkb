function delete_credential(
     p_credential_id number
)
return varchar2
as
begin
    delete
      from xx_disl_credential 
     where 1=1
       and credential_id = p_credential_id
    ;
    
    delete
      from xx_disl_user_credential 
     where 1=1
       and credential_id = p_credential_id
    ;
    
    -- add 28.11.2024
    delete
      from xx_disl_credential_rights 
     where 1=1
       and credential_id = p_credential_id
    ;
    
    commit;
    
    return 'done';
exception
    when others then rollback; return 'fail';    
end;

function get_users_id (p_login in varchar2) return number
is
	l_login_id number;
begin
	select id into l_login_id
		from xx_disl_users 
		where trim(upper(LOGIN)) = trim(upper(p_login));
		return l_login_id;
	exception when others then return -1;
end;

function get_users
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for tmp in (select u.id
                      ,u.full_name
                  from xx_disl_users                u
                 where 1=1
                   and id >0
                 order by
                       u.full_name
               )
    loop
        l_row.id := tmp.id;   
        l_row.name := tmp.full_name;
        
        pipe row (l_row);
    end loop;
end;

function get_open_users
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for tmp in (select u.id
                      ,u.full_name
                  from xx_disl_users                u
                 where 1=1
                   and open = 'Y'
                   and id not in (1,2,3,109)
                 order by
                       u.full_name
               )
    loop
        l_row.id := tmp.id;   
        l_row.name := tmp.full_name;
        
        pipe row (l_row);
    end loop;
end;

function get_user_descr(p_user_id   number)
return t_xx_user_descr_table pipelined
as
    l_row t_xx_user_descr_row;
begin
    select u.login
          ,u.full_name
          ,u.flag_change_pwd
          ,nvl(u.enterprise,0)          enterprise
          ,division_id
          ,u.open
          ,u.phone_num
      into l_row.login
          ,l_row.full_name
          ,l_row.flag_change_pwd
          ,l_row.enterprise
          ,l_row.division_id
          ,l_row.open
          ,l_row.phone_num
      from xx_disl_users                u
     where 1=1
       and id = p_user_id; 
    
    begin
        select listagg(us.station_id,'|') within group (order by us.station_id)
          into l_row.user_stations
          from xx_disl_user_stations       us
         where 1=1
           and us.user_id = p_user_id;
    exception
        when no_data_found then l_row.user_stations := '';
    end;
    
    begin
        select us.station_id
          into l_row.user_default_station
          from xx_disl_user_stations       us
         where 1=1
           and us.user_id = p_user_id
           and nvl(us.def_station,'N') = 'Y';
    exception
        when no_data_found then l_row.user_default_station := '';
    end;
    
    begin
        select listagg(uc.credential_id,'|') within group (order by uc.credential_id)
          into l_row.user_credentials
          from xx_disl_user_credential       uc
         where 1=1
           and uc.user_id = p_user_id;
    exception
        when no_data_found then l_row.user_credentials := '';
    end;
    
    pipe row (l_row);
end;

function add_user(p_login varchar2,p_full_name varchar2,p_enterprise number,p_division number,p_change_pwd varchar2,p_open varchar2,p_phone_num varchar2,p_default_station number,p_stations varchar2,p_credentials varchar2)
return number
as
    l_function      varchar2(100):='add_user';
    l_log_id        number;

    l_user_id       number;
begin
    l_log_id := xx_etw.xx_disl_log_seq.nextval();  
    log_new(l_log_id,l_function,'parameters: p_login = '||p_login||
                                           ' p_full_name = '||p_full_name||
                                           ' p_enterprise = '||p_enterprise||
                                           ' p_division = '||p_division||
                                           ' p_change_pwd = '||p_change_pwd||
                                           ' p_open = '||p_open||
                                           ' p_phone_num = '||p_phone_num||
                                           ' p_default_station = '||p_default_station||
                                           ' p_stations = '||p_stations||
                                           ' p_credentials = '||p_credentials
           );
    
    insert into xx_disl_users(
      id
     ,login
     ,password
     ,full_name
     ,flag_change_pwd
     ,enterprise
     ,division_id
     ,open
     ,phone_num
    )
    values (
      xx_disl_users_seq.nextval
     ,upper(p_login)
     ,md5('1')
     ,p_full_name
     ,p_change_pwd
     ,p_enterprise
     ,p_division
     ,p_open
     ,p_phone_num
    )
    returning id into l_user_id
    ;
    
    insert into xx_disl_user_stations
    select l_user_id
          ,station_id
          ,'N'
      from (select regexp_substr(p_stations,'[^|]+',1,level) station_id
              from dual
           connect by level <= regexp_count(p_stations,'[^|]+')
           )
    ;
    
    update xx_disl_user_stations
       set def_station = 'Y'
     where 1=1
       and user_id = l_user_id
       and station_id = p_default_station
    ;
    
    insert into xx_disl_user_credential
    select l_user_id
          ,credential_id
      from (select regexp_substr(p_credentials,'[^|]+',1,level) credential_id
              from dual
           connect by level <= regexp_count(p_credentials,'[^|]+')
           )
    ;
    
    if (p_division is not null) then
        insert into xx_disl_user_div_hist
        values(l_user_id,p_division,sysdate,null)
        ;   
    end if;
    
    commit;
  
    return l_user_id;
exception
    when others then rollback; return 0;
end;

function change_user(p_user_id number,p_login varchar2,p_full_name varchar2,p_enterprise number,p_division number,p_change_pwd varchar2,p_open varchar2,p_phone_num varchar2,p_default_station number,p_stations varchar2,p_credentials varchar2)
return varchar2
as
    l_function              varchar2(100):='change_user';
    l_log_id                number;
    l_cur_division_id       number;
begin
    l_log_id := xx_etw.xx_disl_log_seq.nextval();  
    log_new(l_log_id,l_function,'parameters: p_user_id = '||p_user_id||
                                           ' p_login = '||p_login||
                                           ' p_full_name = '||p_full_name||
                                           ' p_enterprise = '||p_enterprise||
                                           ' p_division = '||p_division||
                                           ' p_change_pwd = '||p_change_pwd||
                                           ' p_open = '||p_open||
                                           ' p_phone_num = '||p_phone_num||
                                           ' p_default_station = '||p_default_station||
                                           ' p_stations = '||p_stations||
                                           ' p_credentials = '||p_credentials
           );
    
    update xx_disl_users
       set login = p_login
          ,full_name = p_full_name
          ,flag_change_pwd = p_change_pwd
          ,enterprise = p_enterprise
          ,division_id = p_division
          ,open = p_open
          ,phone_num = p_phone_num
     where 1=1
       and id = p_user_id
    ;

    if (p_change_pwd = 'Y') then
        update xx_disl_users
           set password = xx_dislocation.md5('1')
         where 1=1
           and id = p_user_id
        ;
    end if;

    delete 
      from xx_disl_user_stations
     where 1=1
       and user_id = p_user_id
    ;
    
    insert into xx_disl_user_stations
    select p_user_id
          ,station_id
          ,'N'
      from (select regexp_substr(p_stations,'[^|]+',1,level) station_id
              from dual
           connect by level <= regexp_count(p_stations,'[^|]+')
           )
    ;
    
    update xx_disl_user_stations
       set def_station = 'Y'
     where 1=1
       and user_id = p_user_id
       and station_id = p_default_station
    ;
    
    delete 
      from xx_disl_user_credential
     where 1=1
       and user_id = p_user_id
    ;
    
    insert into xx_disl_user_credential
    select p_user_id
          ,credential_id
      from (select regexp_substr(p_credentials,'[^|]+',1,level) credential_id
              from dual
           connect by level <= regexp_count(p_credentials,'[^|]+')
           )
    ;
    
    begin
        select division_id
          into l_cur_division_id
          from xx_disl_user_div_hist
         where 1=1
           and user_id = p_user_id
           and sysdate between start_date and nvl(end_date,to_date('31.12.2999','dd.mm.yyyy'))
        ;
    exception
        when no_data_found then l_cur_division_id := 0;
    end;
    
    if (l_cur_division_id!=nvl(p_division,0)) then
        update xx_disl_user_div_hist
           set end_date = sysdate
         where 1=1 
           and user_id = p_user_id
           and sysdate between start_date and nvl(end_date,to_date('31.12.2999','dd.mm.yyyy'))
        ;
        
        if p_division is not null then
            insert into xx_disl_user_div_hist
            values(p_user_id,p_division,sysdate,null)
            ;
        end if;  
    end if;
    
    commit;
        
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function return_child(p_parent_id number,p_parent_type varchar2,p_flagCome varchar2)
return t_xx_tree_table pipelined
as
    l_row               t_xx_tree_row;
    l_parent_id         number;
    l_parent_type       varchar2(100);
    l_flagCome          varchar2(1);
    l_addForName        varchar2(100) := '';
    l_addForNameId      varchar2(100);
    l_countRailcars     number;
    l_fromStation       varchar(100);
    l_needFillFreight   varchar2(1);
begin
    l_parent_id := p_parent_id;
    l_parent_type := p_parent_type;
    l_flagCome := p_flagCome; 
    
    for tmp in (select ds.id           id
                      ,ds.r_order||' '||nm_v.name     name
                      ,ds.type         type
                  from xx_disl_relations ds
                      ,xx_disl_union_name_v nm_v
                 where 1=1
                   and ds.parent_id = l_parent_id
                   and ds.parent_type = l_parent_type
                   and ds.id = nm_v.id
                   and ds.type = nm_v.type
                   and ds.flag_come = l_flagCome
                 order by ds.r_order
               )
    loop
        if (l_flagCome = 'N') then
            begin
                if (tmp.type = 'railcar') then
                    l_addForNameId := tmp.id;
                else
                    begin
                        select id
                          into l_addForNameId
                          from xx_disl_relations
                         where 1=1
                           and parent_id = tmp.id
                           and parent_type = tmp.type
                           and flag_come = l_flagCome
                           and rownum <= 1
                        ;
                    exception
                        when others then l_addForNameId := '-1';
                    end;    
                end if;
                
                select s.short_name
                  into l_fromStation
                  from xx_disl_station_history      last_sh
                      ,xx_disl_station_history      prev_sh
                      ,xx_disl_stations             s
                 where 1=1                   
                   and last_sh.round_id = returnLastRound(l_addForNameId)
                   and last_sh.in_date is null
                   
                   and last_sh.round_id = prev_sh.round_id
                   and last_sh.come_date = prev_sh.out_date
                   
                   and prev_sh.station_id = s.station_id 
                ;
            exception
                when no_data_found then 
                    if (l_parent_id=1 and l_parent_type='station') then
                        l_fromStation := 'п/п';
                    else
                        l_fromStation := 'Угл';
                    end if;
            end;
        else
            select count(1)
              into l_countRailcars
              from xx_disl_relations ds
             where 1=1
               and ds.type = 'railcar'
           connect by 
                   prior id = parent_id 
               and prior type = parent_type
               and prior flag_come = flag_come   
             start with 
                   parent_id = tmp.id
               and parent_type = tmp.type
               and flag_come = l_flagCome
            ;
            if (tmp.type = 'railcar' or tmp.type = 'bandwagon') then
                l_countRailcars := 0;
            end if;
        end if;
        
        l_needFillFreight:='N';
        
        /*
        if (tmp.type='railcar') then
            begin
                select 'N'
                  into l_needFillFreight
                  from xx_disl_round_freight
                 where 1=1
                   and round_id = returnLastRound(tmp.id)
                   and rownum <= 1
                ;
            exception
                when no_data_found then l_needFillFreight := 'Y';
            end; 
        end if;
        */
        
        l_row.id := tmp.id;
        l_row.name := tmp.name;
        l_row.type := tmp.type;
        l_row.count_railcars := l_countRailcars;
        l_row.from_station := l_fromStation;
        l_row.need_fill_attr := l_needFillFreight;
        pipe row (l_row);
    end loop;
end;

function get_tree_station(p_station_id varchar2,p_flag_come varchar2,p_user_id number default -1)
return t_xx_tree_table pipelined
as
    l_function              varchar2(100):='get_tree_station: ';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_row                   t_xx_tree_row;
    --
    l_railways              xx_etw.xx_disl_railways%rowtype;
    l_weight_net            number:=0;
    --
    l_addForName            varchar2(100) := '';
    l_addForNameId          varchar2(100);
    l_count_railcars        number;
    l_from_station          xx_disl_stations.short_name%type;
    l_from_station_id       xx_disl_stations.station_id%type;
    l_need_fill_attr        varchar2(1);
    l_notification          number;
    l_disabled              varchar2(1);
    l_like_railway          varchar2(1);
    l_not_info_from_shop    varchar2(1);
    l_output_defective_cars varchar2(1);
    l_user_adm              varchar2(20);
begin
    --log_new(l_log_id,l_function,'p_station_id='||p_station_id||',p_flag_come='||p_flag_come);
    
    -- add 28.11.2024 Нужно переписать
    /*select max(nvl(administrator,'N'))             administrator
      into l_user_adm
      from xx_etw.xx_disl_user_credential uc
          ,xx_etw.xx_disl_credential      c
     where 1=1
       and uc.user_id = p_user_id
       and uc.credential_id = c.credential_id(+);
    */
    -- add 28.11.2024
    l_user_adm := get_user_cred_rights_val(p_user_id => p_user_id, p_rights_code => 'administrator');
    
    for row_loop in (select tree.id
                           ,tree.type
                           ,tree.parent_id 
                           ,tree.parent_type
                           ,tree.r_order
                           ,un_n.name     name
                       from (select id
                                   ,type
                                   ,parent_id
                                   ,parent_type
                                   ,r_order
                               from xx_etw.xx_disl_relations
                              where 1=1
                                and flag_come = p_flag_come
                            )
                                                        tree
                           ,xx_etw.xx_disl_union_name_v        un_n
                      where 1=1
                        and tree.id = un_n.id
                        and tree.type = un_n.type
                    connect by prior tree.id = tree.parent_id and prior tree.type = tree.parent_type
                      start with tree.parent_id = p_station_id and tree.parent_type = 'station'
                      order siblings by r_order
                      
    )
    loop
        l_railways := null;      
        if (p_flag_come = 'N') then
            
            /* beg определяем предыдущую станцию вагона/группы вагонов */
            begin
                if (row_loop.type = 'railcar') then
                    l_addForNameId := row_loop.id;
                else
                    begin
                        select id
                          into l_addForNameId
                          from xx_etw.xx_disl_relations
                         where 1=1
                           and parent_id = row_loop.id
                           and parent_type = row_loop.type
                           and flag_come = p_flag_come
                           and rownum <= 1
                        ;
                    exception
                        when others then l_addForNameId := '-1';
                    end;    
                end if;
                
                select s.short_name
                      ,s.station_id
                  into l_from_station
                      ,l_from_station_id
                  from xx_etw.xx_disl_station_history      last_sh
                      ,xx_etw.xx_disl_station_history      prev_sh
                      ,xx_etw.xx_disl_stations             s
                 where 1=1                   
                   and last_sh.round_id = returnLastRound(l_addForNameId)
                   and last_sh.in_date is null
                       
                   and last_sh.round_id = prev_sh.round_id
                   and last_sh.come_date = prev_sh.out_date
                       
                   and prev_sh.station_id = s.station_id 
                ;
            exception
                when no_data_found then 
                    if (row_loop.id < 0 and row_loop.type = 'bandwagon') then
                            l_from_station := null;
                            l_from_station_id := null;  
                    elsif (row_loop.parent_id=1 and row_loop.parent_type='station') then
                        l_from_station := 'п/п';
                        l_from_station_id := -1; 
                    else
                        l_notification :=null;
                        begin
                            select notification_id
                              into l_notification 
                              from xx_etw.xx_disl_round
                             where 1=1
                               and round_id = returnLastRound(l_addForNameId)
                            ;
                        exception
                            when others then l_notification :=null; 
                        end;
                        l_from_station := case 
                                            when l_notification is null 
                                            then 'Угл'
                                            else 'Псп'
                                          end;
                        l_from_station_id := 1;
                    end if;
            end;
            /* end определяем предыдущую станцию вагона/группы вагонов */
        else 
            /* beg определяем кол-во вагонов на путях */
            if (row_loop.type = 'railway') then
                select count('x')
                  into l_count_railcars
                  from xx_etw.xx_disl_relations ds
                 where 1=1
                   and ds.type = 'railcar'
               connect by 
                       prior id = parent_id 
                   and prior type = parent_type
                   and prior flag_come = flag_come   
                 start with 
                       parent_id = row_loop.id
                   and parent_type = row_loop.type
                   and flag_come = p_flag_come
                ;
            elsif (row_loop.type in ('point','area')) then
                select count('x')
                  into l_count_railcars
                  from xx_etw.xx_disl_relations ds
                 where 1=1
                   and parent_id = row_loop.id
                   and parent_type = row_loop.type
                   and flag_come = p_flag_come
                ;    
            else /*row_loop.type = 'railcar' or row_loop.type = 'bandwagon' */
                l_count_railcars := 0;
            end if; 
            /* end определяем кол-во вагонов на путях */
        end if;
        
        /* beg опряделяем нужно ли заполнять атрибуты по вагону (груз/тип) */
        l_need_fill_attr:='N';
        if (row_loop.type='railcar') then
            begin
                select 'Y'
                  into l_need_fill_attr
                  from xx_etw.xx_disl_railcar_add_info
                 where 1=1
                   and round_id = xx_etw.xx_dislocation.returnLastRound(row_loop.id)
                   and add_info_type = 'A'
                   and last_record = 'Y'
                   and (freight_name is null
                        or
                        car_type is null)  
                ;
            exception
                when no_data_found then l_need_fill_attr := 'N';
            end; 
        end if;
        /* end опряделяем нужно ли заполнять атрибуты по вагону (груз/тип) */
        
        /* beg опряделяем есть ли уведомление по вагону */
        if (row_loop.type='railcar') then
            begin
                select decode(notification_id,null,'N','Y')
                  into l_row.notification
                  from xx_etw.xx_disl_round
                 where 1=1
                   and round_id = xx_etw.xx_dislocation.returnLastRound(row_loop.id)
                   and station_hist_id_out is null;
            -- 12/05/2020 BekmansurovRR добавил exception, т.к когда возникает ошибка, часть вагонов пропадает и не все отражаются в "дереве"       
            exception when others then l_row.notification := to_char(null);
            end;
        else
            l_row.notification := 'Y';
        end if;
        /* end опряделяем есть ли уведомление по вагону */
        
        /* beg правильность номмера вагона*/
        if (row_loop.type='railcar' ) then
            l_row.true_number := case 
                                   when xx_etw.etw_car_nsi_pkg.car_number_validate(row_loop.id) = true
                                     then 'Y'
                                   else 'N'
                                 end;
        else
            l_row.true_number := 'Y'; 
        end if;
        /* end */
        /**/
        if (row_loop.type='railcar' ) then
            begin
                select distinct 'Y'
                               ,cc.code||':'||cc.DESCRIPTION||'. Комм:'||x.note
                                ||', '||du.FULL_NAME||'('||to_char(x.START_DATE,'DD.MM.YYYY')||' - '||to_char(x.END_DATE,'DD.MM.YYYY')||')'
                               ,cl.code
                               ,'K'
                       into l_row.car_type_control,
                            l_row.car_control_note,
                            l_row.car_control_color,
                            l_row.car_control_kw
                  from XX_ETW.xx_disl_car_control x,
                       xx_etw.xx_disl_color cl,
                       xx_etw.xx_disl_code_cause cc,
                       xx_etw.xx_disl_users du
                where 1=1
                       and x.CAR_NUMBER = row_loop.name
                       and x.created_by = du.ID
                       and x.ID_COLOR = cl.id(+)
                       and x.id_cause = cc.id(+)
                       and nvl(x.deleted,'N') = 'N'
                       and trunc(sysdate) between nvl(x.START_DATE,sysdate) and nvl(x.END_DATE,sysdate)
                       ; 
            exception when others then 
                l_row.car_type_control := 'N';
                l_row.car_control_note :='';
                l_row.car_control_color :='';
                l_row.car_control_kw:='';
            end; 
            
            -- add 20.12.2023 Контроль по прицепной части вагона
            begin
                select 'Y'
                      ,'Контроль:'||'Прицепная часть:'||' '||cc.car_trailer_part
                      ,cc.color
                      ,'К'
                 into l_row.car_type_control,
                      l_row.car_control_note,
                      l_row.car_control_color,
                      l_row.car_control_kw
                 from (SELECT   car_trailer_part, xx_etw.xx_dislocation.get_trailer_part_color(car_trailer_part) as color 
                          FROM   (SELECT   DISTINCT
                                           xx_etw.xx_dislocation.get_car_trailer_part (
                                              info.car_number,
                                              NULL,
                                              info_inv.inv_number
                                           )
                                              car_trailer_part
                                    FROM   xx_disl_railcar_add_info info,
                                           xx_disl_railcar_add_info_inv info_inv
                                   WHERE   1 = 1 AND info.add_info_id = info_inv.add_info_id
                                           AND info.round_id =
                                                 xx_etw.xx_dislocation.returnLastRound (row_loop.name)
                                           AND info.LAST_RECORD = 'Y') x
                         WHERE   ROWNUM = 1 AND car_trailer_part IS NOT NULL) cc;
            exception when others then 
                null;
            end;
            
            
            -- add 15.03.2024 BekmansurovRR
            begin
                select 'Y'
                      ,'ПВПП:Подготовка вагона под погрузку:'
                      ,cc.color
                      ,'П'
                 into l_row.car_type_control,
                      l_row.car_control_note,
                      l_row.car_control_color,
                      l_row.car_control_kw
                  FROM   xx_etw.xx_disl_railcar_add_info info
                        ,(select CODE as color from xx_etw.xx_disl_color x where x.NAME = 'LIGHT_BLUE') cc
                 WHERE       1 = 1
                         AND info.round_id = xx_etw.xx_dislocation.returnLastRound (row_loop.name)
                         and info.status like '%Требует подготовки%'
                         AND info.LAST_RECORD = 'Y';
            exception when others then null;
            end;         
        else 
            l_row.car_type_control := 'N';
            l_row.car_control_note :='';
            l_row.car_control_note :='';
            l_row.car_control_color :='';
            l_row.car_control_kw :='';
        end if;
               
        if (row_loop.type='railway') then
            select nvl(disabled,'N')
              into l_disabled
              from xx_etw.xx_disl_railways
             where 1=1
               and railway_id = row_loop.id
            ;
        else
            l_disabled:='N'; 
        end if;
        
        /* beg устанавляваем отметку любимого пути (пути с такой отметкой раскрываются при обновлении дерева) */
        if (row_loop.type='railway' or row_loop.type='area') then
            begin
                select 'Y'
                  into l_like_railway
                  from xx_etw.xx_disl_user_like_railways
                 where 1=1
                   and obj_id = row_loop.id
                   and obj_type = row_loop.type
                   and user_id = p_user_id
                ;
            exception
                when others then l_like_railway := 'N';
            end;
        else
            l_like_railway:='N'; 
        end if;
        /* end */
        
        /* beg отметка о том что нет информации о погрузке/разгрузке */
        if (row_loop.type='railcar' ) then
            begin
                select 'Y'
                  into l_not_info_from_shop
                  from xx_etw.xx_disl_railcar_add_info
                 where 1=1
                   and round_id = returnLastRound(row_loop.id)
                   and last_record = 'Y'
                   and add_info_type = 'T'
                ;
            exception
                when others then l_not_info_from_shop := 'N';
            end;
            
            -- add 26/12/2022 BekmansurovRR
            -- Погрузка/Разгрузка при перемещении(АКМ)
            l_weight_net :=0;
            if 1=2 then
                begin  
                    select  'Y', x.railway_number, xx_etw.xx_dislocation.get_send_weight_net(returnLastRound(row_loop.id))
                      into  l_row.movement_un_loading,
                            l_railways.railway_number,
                            l_weight_net
                      from   xx_etw.xx_disl_railways x
                     where   1 = 1
                             and row_loop.parent_id = x.railway_id
                             and lower (railway_number) like lower ('%карбамид%');
                
                if nvl(l_weight_net,0) = 0 
                        and (lower(l_railways.railway_number) like lower('2_%Карбамид%') 
                                or lower(l_railways.railway_number) like lower('3_%Карбамид%')) 
                then
                    l_row.movement_un_loading:='Y';
                elsif nvl(l_weight_net,0) != 0 and (lower(l_railways.railway_number) like lower('11_%Карбамид%')) then
                    l_row.movement_un_loading:='Y';
                else 
                    l_row.movement_un_loading:='N';
                end if;
                
                exception 
                    when others then l_row.movement_un_loading:='N'; l_railways:= null; l_weight_net :=0;
                end;
            end if;
            l_row.movement_un_loading:='Y';
            
            -- Для админа на любых путях перемещение АКМ
            if nvl(l_user_adm,'N') ='Y' then   
                l_row.movement_un_loading:='Y';
            end if;
        else
            l_not_info_from_shop:='N'; 
            l_row.movement_un_loading:='N';
            l_weight_net :=0;
        end if;
        
        
        l_not_info_from_shop := 'N';
        /* end */
        
        l_row.notification_gu := to_char(null);
        if (p_station_id = 2 and p_flag_come = 'Y' and row_loop.type='railcar' ) then
            begin
                select 'п/у '||to_char(ng.not_time,'dd.mm hh24:mi')
                  into l_row.notification_gu
                  from xx_etw.xx_disl_car_notif_gu     cng
                      ,xx_etw.xx_disl_notifications_gu ng
                 where 1=1
                   and cng.round_id = returnLastRound(row_loop.id)
                   and last_record = 'Y'
                   and cng.notification_id = ng.notification_id
                ;
            exception
                when others then l_row.notification_gu := to_char(null);
            end;
        end if;
        l_row.count_fix_dev_even := 0;
        l_row.count_fix_dev_odd := 0;
        if (row_loop.type='railway') then
            begin
                select xx_etw.xx_dislocation.get_count_fix_dev (row_loop.id,'EVEN'),
                       xx_etw.xx_dislocation.get_count_fix_dev (row_loop.id,'ODD')
                       into l_row.count_fix_dev_even,l_row.count_fix_dev_odd
                  from dual;
            exception
                when others then 
                    l_row.count_fix_dev_even := 0;
                    l_row.count_fix_dev_odd := 0;
            end;
            
        end if;
        if (row_loop.type in ('railway')) then
            begin
                select   'Y' into l_output_defective_cars
                  from   xx_etw.xx_disl_railways x
                 where   1 = 1
                         and (lower (x.purpose) like '%разоб%'
                              or lower (x.purpose) like '%разб%')
                         and x.railway_id = row_loop.id ;
            exception
                when others then 
                    l_output_defective_cars :='N';
            end;
            
        else 
            l_output_defective_cars:='N';
        end if;
        
        l_row.id := row_loop.id;
        l_row.type := row_loop.type;
        l_row.parent_id := row_loop.parent_id;
        l_row.parent_type := row_loop.parent_type;
        l_row.r_order := row_loop.r_order;
        l_row.name := row_loop.name;
        
        l_row.count_railcars := l_count_railcars;
        l_row.from_station := l_from_station;
        l_row.from_station_id := l_from_station_id;
        l_row.need_fill_attr := l_need_fill_attr;
        l_row.disabled := l_disabled;   
        l_row.like_railway := l_like_railway;
        l_row.not_info_from_shop := l_not_info_from_shop;
        l_row.output_defective_cars := nvl(l_output_defective_cars,'N');
             
        pipe row (l_row);
    end loop;         
end; 
 
 
function change_order(p_id varchar2, p_type varchar2, p_action varchar2)
return varchar2
as
    l_parent_id number;
    l_parent_type varchar2(15);
    l_order number;
    l_max_order number;  
begin
    /*определяем текущего родителя*/
    select  parent_id
           ,parent_type
           ,r_order
      into  l_parent_id
           ,l_parent_type
           ,l_order
      from xx_disl_relations
     where 1=1
           and id = p_id
           and type = p_type
           and flag_come = 'Y'
    ;
    /*находим макс порядок*/
    select max(r_order)
      into l_max_order
      from xx_disl_relations
     where 1=1
           and parent_id = l_parent_id
           and parent_type = l_parent_type
           and flag_come = 'Y'
    ;
    if (p_action = 'up' and l_order!=1) then
        update xx_disl_relations
           set r_order = r_order + 1
         where 1=1
               and parent_id = l_parent_id
               and parent_type = l_parent_type
               and r_order = l_order - 1
               and flag_come = 'Y'
        ;
        update xx_disl_relations
           set r_order = r_order - 1
         where 1=1
               and id = p_id
               and type = p_type
               and flag_come = 'Y'
        ;
        commit;
    elsif (p_action = 'down' and l_order != l_max_order) then
        update xx_disl_relations
           set r_order = r_order - 1
         where 1=1
               and parent_id = l_parent_id
               and parent_type = l_parent_type
               and r_order = l_order + 1
               and flag_come = 'Y'
        ;
        update xx_disl_relations
           set r_order = r_order + 1
         where 1=1
               and id = p_id
               and type = p_type
               and flag_come = 'Y'
        ;
        commit;
    end if;
    return 'done'; 
exception
    when others then return 'fail'; 
end;     

function change_order_for_railway(p_id number,p_type varchar2, p_action varchar2)
return varchar2
as
    l_function              varchar2(100):='change_order_for_railway:';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_parent_id             varchar2(100);
    l_parent_type           varchar2(100);
    l_order                 number;
    l_max_order             number; 
    l_adjacent_elem_order   varchar2(100);
begin
    log_new(l_log_id,l_function,' p_id = '||p_id||' p_type = '||p_type||' p_action = '||p_action);
    /*определяем текущего родителя*/
    select  parent_id
           ,parent_type
           ,r_order
      into  l_parent_id
           ,l_parent_type
           ,l_order
      from xx_disl_relations
     where 1=1
           and id = p_id
           and type = p_type
           and flag_come = 'Y'
    ;
    log_new(l_log_id,l_function,' l_parent_id = '||l_parent_id||' l_parent_type = '||l_parent_type||' l_order = '||l_order);
    
    /*находим макс порядок*/
    select max(r_order)
      into l_max_order
      from xx_disl_relations
     where 1=1
           and parent_id = l_parent_id
           and parent_type = l_parent_type
           and flag_come = 'Y'
    ;
    log_new(l_log_id,l_function,' l_max_order = '||l_max_order);
    
    if (p_action = 'up' and l_order!=1) then
        select max(r_order)
          into l_adjacent_elem_order
          from xx_disl_relations
         where 1=1
               and parent_id = l_parent_id
               and parent_type = l_parent_type
               and flag_come = 'Y'
               and type in ('railway','point')
               and r_order < l_order
        ;
        log_new(l_log_id,l_function,' l_adjacent_elem_order = '||l_adjacent_elem_order);
        
        update xx_disl_relations
           set r_order = l_order
         where 1=1
               and parent_id = l_parent_id
               and parent_type = l_parent_type
               and r_order = l_adjacent_elem_order
               and flag_come = 'Y'
        ;
        log_new(l_log_id,l_function,' update xx_disl_relations. кол-во'||sql%rowcount);
        
        update xx_disl_relations
           set r_order = l_adjacent_elem_order
         where 1=1
               and id = p_id
               and type = p_type
               and flag_come = 'Y'
        ;
        log_new(l_log_id,l_function,' update xx_disl_relations. кол-во'||sql%rowcount);
    elsif (p_action = 'down' and l_order != l_max_order) then
        select min(r_order)
          into l_adjacent_elem_order
          from xx_disl_relations
         where 1=1
               and parent_id = l_parent_id
               and parent_type = l_parent_type
               and flag_come = 'Y'
               and type in ('railway','point')
               and r_order > l_order
        ;
        log_new(l_log_id,l_function,' l_adjacent_elem_order = '||l_adjacent_elem_order);
        
        update xx_disl_relations
           set r_order = l_order
         where 1=1
               and parent_id = l_parent_id
               and parent_type = l_parent_type
               and r_order = l_adjacent_elem_order
               and flag_come = 'Y'
        ;
        log_new(l_log_id,l_function,' update xx_disl_relations. кол-во'||sql%rowcount);
        
        update xx_disl_relations
           set r_order = l_adjacent_elem_order
         where 1=1
               and id = p_id
               and type = p_type
               and flag_come = 'Y'
        ;
        log_new(l_log_id,l_function,' update xx_disl_relations. кол-во'||sql%rowcount);
    end if;
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';   
end;

function get_all_station_child(p_station_id number)
return t_xx_tree_table pipelined
as
    l_row                       t_xx_tree_row;
    l_railway_id                number;
    l_cars_count                number;
    l_cars_length               number;
    l_max_cars_count            number;
    l_max_cars_length           number;
    l_dif_cars_count            number;
    l_dif_cars_length           number;
begin
    for tmp in (with tree as (select *
                                from xx_disl_relations
                               where 1=1
                                     and type in ('railway','point')
                                     and flag_come = 'Y'
                             )
                select  tree.id
                       ,tree.type
                       ,nm_v.name
                       ,level lvl
                  from  tree
                       ,xx_disl_union_name_v        nm_v
                 where     1=1
                       and tree.id = nm_v.id
                       and tree.type = nm_v.type  
               connect by  
                       tree.parent_id = prior tree.id
                   and tree.parent_type = prior tree.type
                 start with 
                       tree.parent_id = p_station_id
                   and tree.parent_type = 'station'
                 order siblings by tree.r_order  
               )
    loop
        if (tmp.type = 'railway') then
            select nvl(disabled,'N')
              into l_row.disabled
              from xx_disl_railways
             where 1=1
               and railway_id = tmp.id        
            ;
        end if;
        
        if (tmp.type = 'railway') then
            l_railway_id := tmp.id;
        else
            /*определим путь на котором стоит элемент*/
            with in_station as (select *
                                  from xx_disl_relations
                                 where 1=1
                                       and flag_come = 'Y'                     
                               )
            select min(id) keep (dense_rank first order by level)
              into l_railway_id
              from in_station
             where 1=1
               and type = 'railway'
           connect by prior parent_id = id and prior parent_type = type
             start with id = tmp.id and type = tmp.type
            ;
        end if;    
        
        --dbms_output.put_line('tmp.id = '||tmp.id||' tmp.type = '||tmp.type||' l_railway_id = '||l_railway_id);
        begin
            with in_station as (select *
                                  from xx_disl_relations
                                 where 1=1
                                       and flag_come = 'Y'                     
                               )
            select count('x')
                  ,sum(nvl(rai.car_length,0))
              into l_cars_count
                  ,l_cars_length
              from (select id
                      from in_station
                     where 1=1
                       and type = 'railcar'  
                   connect by 
                           prior id = parent_id 
                       and prior type = parent_type
                     start with 
                           parent_id = l_railway_id
                       and parent_type = 'railway'
                   )
                                                    cars
                   ,xx_disl_round                   r 
                   ,xx_disl_railcar_add_info        rai  
             where 1=1
               and r.railcar_id = cars.id
               and r.station_hist_id_out is null
               
               and r.round_id = rai.round_id 
               and rai.last_record = 'Y'
            ;
        exception
            when others
            then l_cars_count:=0; l_cars_length:=0;
        end;
        
        begin
            select max(column_value) max_count
              into l_max_cars_count
              from xx_disl_railways     r
                  ,table(cast(multiset(select to_number(regexp_substr(nvl(r.capacity,'not condition'), '[^_]+', 1, level)) 
                                       from dual 
                                     connect by level <= regexp_count(nvl(r.capacity,'not condition'), '[^_]+')
                                      ) as xx_disl_table_of_number
                             )
                        )
             where 1=1
               and railway_id = l_railway_id
            ;
        exception
            when others then l_max_cars_count:=0;
        end;
        
        
        begin
            select nvl(length_useful,0)
              into l_max_cars_length
              from xx_disl_railways     r
             where 1=1
               and railway_id = l_railway_id
            ;
        exception
            when others then l_max_cars_length:=0;
        end;
        
        l_dif_cars_count := case
                              when nvl(l_max_cars_count,0) = 0 or l_cars_count > l_max_cars_count
                              then 0
                              else l_max_cars_count - l_cars_count
                            end;
                            
        l_dif_cars_length := case
                               when nvl(l_max_cars_length,0) = 0 or l_cars_length > l_max_cars_length
                               then 0
                               else l_max_cars_length - l_cars_length
                             end;                  
        
        l_row.id := tmp.id;
        l_row.name := tmp.name;
        l_row.type := tmp.type;
        l_row.lvl := tmp.lvl;
        l_row.count_railcars := l_dif_cars_count;
        l_row.free_length := l_dif_cars_length;
        pipe row (l_row);
    end loop;
end;

function move_inside_station(p_user_id number,p_car varchar2, p_new_parent_id number,p_new_parent_type varchar2,p_operation_date varchar2,p_comment varchar2)
return varchar2
as
    l_function              varchar2(100) := 'move_inside_station';
    l_log_id                number:= xx_etw.xx_disl_log_seq.nextval();
    l_cur_parent_id         number;
    l_cur_parent_type       varchar2(10);
    l_cur_order             varchar2(10);
    l_max_order             number;
    l_cur_railway_id        number;
    l_new_railway_id        number;
    l_cur_date              date;
    l_operation_date        date;
    l_station_hist_id       number;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_car = '||p_car
                             ||' p_new_parent_id = '||p_new_parent_id
                             ||' p_new_parent_type = '||p_new_parent_type
                             ||' p_operation_date = '||p_operation_date
                             ||' p_comment = '||p_comment);       

    /*определим путь на котором стоит элемент*/
    with in_station as (select *
                          from xx_disl_relations
                         where 1=1
                               and flag_come = 'Y'                     
                       )
    select min(id) keep (dense_rank first order by level)
      into l_cur_railway_id
      from in_station
     where 1=1
       and type = 'railway'
   connect by prior parent_id = id and prior parent_type = type
     start with id = p_car and type = 'railcar'
    ;
        
    /*определим путь на котором стоят новые предки*/
    with in_station as (select *
                          from xx_disl_relations
                         where 1=1
                               and flag_come = 'Y'                     
                       )
    select min(id) keep (dense_rank first order by level)
      into l_new_railway_id
      from in_station
     where 1=1
       and type = 'railway'
   connect by prior parent_id = id and prior parent_type = type
     start with id = to_char(p_new_parent_id) and type = p_new_parent_type
    ;
            
    -- определим текущего родителя и порядок
    select  parent_Id
           ,parent_Type
           ,r_order
      into  l_cur_parent_id
           ,l_cur_parent_type
           ,l_cur_order
      from xx_disl_relations
     where 1=1
           and id = p_car
           and type = 'railcar'
           and flag_come = 'Y'
    ;
            
    if (l_cur_parent_id=p_new_parent_id and l_cur_parent_type=p_new_parent_type) then
        return 'fail';
    end if;
        
    -- изменим порядок потомков текущего родителя
    update xx_disl_relations
       set r_order = r_order - 1
     where 1=1
           and parent_id = l_cur_parent_id
           and parent_type = l_cur_parent_type
           and r_order > l_cur_order
           and flag_come = 'Y'
    ;
        
    -- определим макс. порядок среди потомков нового родителя
    l_max_order := returnMaxOrder(p_new_parent_id,p_new_parent_type,'Y');
            
    -- поместим элемент под нового родителя в конец очереди
    update xx_disl_relations
       set parent_id = p_new_parent_id
          ,parent_type = p_new_parent_type
          ,r_order = l_max_order+1
     where 1=1
       and id = p_car
       and type = 'railcar'
       and flag_come = 'Y'
    ;
        
    if (l_cur_railway_id!=l_new_railway_id) then
        l_cur_date := sysdate;
                
        begin
            l_operation_date := to_date(p_operation_date,'dd.mm.yyyy hh24:mi');
        exception
            when others then l_operation_date := l_cur_date;
        end;   
            
        select sh.station_hist_id
          into l_station_hist_id
          from xx_disl_station_history      sh
         where 1=1
           and sh.round_id = returnLastRound(p_car)
           and sh.out_date is null
        ;

        update xx_disl_railway_history
           set last_record = 'N'
         where 1=1
           and last_record = 'Y'
           and station_hist_id = l_station_hist_id
        ;
            
        insert into xx_disl_railway_history(
            railway_hist_id
           ,station_hist_id
           ,railway_id
           ,date_oper
           ,date_oper_fact
           ,user_id
           ,comment_oper
           ,last_record)
        values (xx_disl_railway_history_seq.nextval
               ,l_station_hist_id
               ,l_new_railway_id
               ,l_cur_date
               ,l_operation_date
               ,p_user_id
               ,p_comment
               ,'Y'
               )
        ;
    end if;
        
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function move_inside_station_few_child(p_user_id number,p_cars varchar2, p_parent_id number,p_parent_type varchar2,p_operation_date varchar2,p_comment varchar2)
return varchar2
as
    l_function  varchar2(100) := 'move_inside_station_few_child:';
    l_log_id    number := xx_etw.xx_disl_log_seq.nextval();
    l_done      boolean := true;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id||' p_cars = '||p_cars||' p_parent_id = '||p_parent_id ||' p_parent_type = '||p_parent_type||' p_operation_date = '||p_operation_date||' p_comment = '||p_comment);    
    
    for tmp in (select regexp_substr(p_cars,'[^$]+',1,level) text
                  from dual
               connect by level <= regexp_count(p_cars,'[^$]+')
               )
    loop
        log_new(l_log_id,l_function,' move_inside_station('||regexp_substr(tmp.text,'[^|]+',1,1)||','||p_parent_id||','||p_parent_type||')');    
        if (move_inside_station(p_user_id,regexp_substr(tmp.text,'[^|]+',1,1),p_parent_id,p_parent_type,p_operation_date,p_comment)!='done') then
            l_done := false;
                
            log_new(l_log_id,l_function,'move_inside_station: l_done = N');    
        end if; 
    end loop;
        
    if l_done then
        commit;
        return 'done';
    else
        return 'fail';
    end if;
exception
    when others then return 'fail';
end;
 
function addBandwagon(p_name varchar2, p_parentId number, p_parentType varchar2)
return number
as
    l_bandwagonId            number;
    l_maxOrder      number;
begin
    begin
        insert into xx_disl_bandwagon
        values (xx_disl_bandwagon_seq.nextval,p_name)
        returning bandwagon_id into l_bandwagonId
        ;    
        
        l_maxOrder := xx_dislocation.returnMaxOrder(p_parentId,p_parentType,'Y')+1;
        insert into xx_disl_relations 
        values (l_bandwagonId,'bandwagon',p_parentId,p_parentType,l_maxOrder,'Y')
        ;
        
        commit;
        
        return l_bandwagonId;
    exception
      when others then return 0;
    end;
end;

function deleteBandwagon(p_id number, p_type varchar2)
return varchar2
as
    l_count number;
begin
    begin
        deleteFromRelations(p_id,p_type,'Y');         
        commit;
        return 'done';
    exception
      when others then return 'fail';
    end;
end;

function get_obj_owner ( p_obj_id    number, 
                         p_obj_type  varchar2) 
return varchar2
is
    l_owner     varchar2(10);
begin
    if (p_obj_type = 'cont') then
       select owner  into l_owner
         from xx_etw.xx_disl_cont_add_info
        where cont_round_id = p_obj_id
              and last_record = 'Y';
    else
       select owner  into l_owner
         from xx_etw.xx_disl_railcar_add_info
        where round_id = p_obj_id
              and last_record = 'Y';
    end if;
    
    return l_owner; 
exception when others then return '';
end; 

function get_obj_freight(
    p_obj_id    number,
    p_obj_type  varchar2,
    p_date      date)
return varchar2
as
    l_freight       varchar2(100);
    l_cont_freight  varchar2(100);
begin
    if (p_obj_type = 'cont') then
        select freight_name
          into l_freight
          from xx_etw.xx_disl_cont_add_info
         where 1=1
           and cont_round_id = p_obj_id
           and p_date between date_begin and nvl(date_end-1/24/60/60,sysdate);
    else
        select freight_name
          into l_freight
          from xx_etw.xx_disl_railcar_add_info         info
         where 1=1
           and info.round_id = p_obj_id
           and p_date between date_begin and nvl(date_end - 1/24/60/60,sysdate);
     
        for l_cont in (
            select cr.cont_number               cont_number
                  ,cai.freight_name             freight_name
                  ,cai.weight_net               weight_net
                  ,cai.weight_dep               weight_dep
--                  ,type_brak                    type_brak
              from xx_etw.xx_disl_cont_history      chc
                  ,xx_etw.xx_disl_cont_round        cr
                  ,xx_etw.xx_disl_cont_add_info     cai
--                  ,xx_etw.xx_disl_nrb_stop_add_v    d_nrb_stop
             where 1=1
               and chc.place_id = p_obj_id
               and chc.place_type = 'railcar'
               and p_date between in_date_sys and nvl(out_date_sys - 1/24/60/60,sysdate)
               
               and chc.cont_round_id = cr.cont_round_id
                   
               and cr.cont_round_id = cai.cont_round_id
               and p_date between cai.date_begin and nvl(cai.date_end - 1/24/60/60,sysdate)
                   
--               and cr.cont_number = d_nrb_stop.obj_number(+)
        ) loop
            if (l_cont_freight is null) then
                l_cont_freight := l_cont.freight_name;
            elsif (instr(l_cont_freight,l_cont.freight_name) = 0) then
                l_cont_freight := l_cont_freight||' '||l_cont.freight_name; 
            end if;  
        end loop; 
        
        if (l_cont_freight is not null) then
            l_freight := l_cont_freight;
        end if;
    end if;
    return l_freight;    
exception
    when others then return '';  
end;

function get_car_add_info_with_conts(p_round_id number,p_date date)
return number
as
--    l_freight_name          varchar2(1000);
    l_row           t_xx_child_row_add_info;  
begin
    select nvl(weight_net,0)
--           freight_name
--          ,nvl(weight_net,0)
--          ,nvl(weight_dep,0)
      into l_row.weight_net
--           l_row.freight_name
--          ,l_row.weight_net
--          ,l_row.weight_dep
      from xx_etw.xx_disl_railcar_add_info         info
     where 1=1
       and info.round_id = p_round_id
       and p_date between date_begin and nvl(date_end - 1/24/60/60,sysdate);
    dbms_output.put_line('l_row.weight_net: '||l_row.weight_net);    
 
    for l_cont in (
        select cr.cont_number               cont_number
              ,cai.freight_name             freight_name
              ,cai.weight_net               weight_net
              ,cai.weight_dep               weight_dep
              ,type_brak                    type_brak
          from xx_etw.xx_disl_cont_history      chc
              ,xx_etw.xx_disl_cont_round        cr
              ,xx_etw.xx_disl_cont_add_info     cai
              ,xx_etw.xx_disl_nrb_stop_add_v    d_nrb_stop
         where 1=1
           and chc.place_id = p_round_id
           and chc.place_type = 'railcar'
           and p_date between in_date_sys and nvl(out_date_sys - 1/24/60/60,sysdate)
           
           and chc.cont_round_id = cr.cont_round_id
               
           and cr.cont_round_id = cai.cont_round_id
           and p_date between cai.date_begin and nvl(cai.date_end - 1/24/60/60,sysdate)
               
           and cr.cont_number = d_nrb_stop.obj_number(+)
    ) loop
        dbms_output.put_line('nvl(l_cont.weight_net,0): '||nvl(l_cont.weight_net,0));
    
--        l_row.cont := l_row.cont || l_cont.cont_number || ' '; 
        l_row.weight_net := l_row.weight_net + nvl(l_cont.weight_net,0);  
--        l_row.weight_dep := l_row.weight_dep + nvl(l_cont.weight_dep,0);
--        l_row.cont_with_ins := l_row.cont_with_ins || l_cont.cont_number ||
--                            case 
--                              when l_cont.type_brak is null
--                                then ''
--                              else ' ' || '('||l_cont.type_brak||')'
--                            end
--                            || ' ';  
--        if (instr(l_freight_name,l_cont.freight_name) = 0 or l_freight_name is null) then
--            l_freight_name := l_freight_name||' '||l_cont.freight_name;  
--        end if;  
    end loop; 
    
--    if (l_freight_name is not null) then
--        l_row.freight_name := l_freight_name;  
--    end  if;
    
    return l_row.weight_net;
exception
    when too_many_rows then return -1;
end;

function get_arrive_weight_net(p_round_id number)
return number
as
    l_date      date;
begin
    select max(date_begin)
      into l_date
      from xx_etw.xx_disl_railcar_add_info         info 
     where 1=1
       and round_id = p_round_id
       and add_info_type = 'A';
    
    return get_car_add_info_with_conts(p_round_id,l_date);
end;

function get_send_weight_net(p_round_id number)
return number
as
    l_date          date;
    l_weight_net    number;
begin
    dbms_output.put_line('p_round_id: '||p_round_id); 
    begin
        select max(date_begin)
          into l_date
          from xx_etw.xx_disl_railcar_add_info         info 
         where 1=1
           and round_id = p_round_id
           and add_info_type in ('S');
    exception
        when others then l_date := null;
    end;
    dbms_output.put_line('l_date: '||l_date);
    
    if (l_date is null) then  
        select weight_net
          into l_weight_net
          from xx_etw.xx_disl_shop_info
         where 1=1
           and round_id = p_round_id
           and last_record = 'Y';
    else
        l_weight_net := get_car_add_info_with_conts(p_round_id,l_date);
    end if;
    dbms_output.put_line('l_weight_net: '||l_weight_net);
    
    return l_weight_net;
end;

/*возвращает информацию о весе вагона и контейнерах если они есть*/
function get_car_add_info_with_conts(p_round_id number) 
return t_xx_child_row_add_info
as   
    l_freight_name          varchar2(1000);
    l_row                   t_xx_child_row_add_info;
begin
    select freight_name
          ,nvl(weight_net,0)
          ,nvl(weight_dep,0)
      into l_row.freight_name
          ,l_row.weight_net
          ,l_row.weight_dep
      from xx_etw.xx_disl_railcar_add_info         info
     where 1=1
       and info.round_id = p_round_id
       and info.last_record = 'Y'
    ;
    
    for l_cont in (
        select cr.cont_number               cont_number
              ,cai.freight_name             freight_name
              ,cai.weight_net               weight_net
              ,cai.weight_dep               weight_dep
              ,type_brak                    type_brak
          from xx_etw.xx_disl_cont_history_cur  chc
              ,xx_etw.xx_disl_cont_round        cr
              ,xx_etw.xx_disl_cont_add_info     cai
              ,xx_etw.xx_disl_nrb_stop_add_v    d_nrb_stop
         where 1=1
           and chc.place_id = p_round_id
           and chc.place_type = 'railcar'
           
           and chc.cont_round_id = cr.cont_round_id
               
           and cr.cont_round_id = cai.cont_round_id
           and cai.last_record = 'Y'
               
           and cr.cont_number = d_nrb_stop.obj_number(+)
    ) loop
        l_row.cont := l_row.cont || l_cont.cont_number || ' '; 
        l_row.weight_net := l_row.weight_net + nvl(l_cont.weight_net,0);  
        l_row.weight_dep := l_row.weight_dep + nvl(l_cont.weight_dep,0);
        l_row.cont_with_ins := l_row.cont_with_ins || l_cont.cont_number ||
                            case 
                              when l_cont.type_brak is null
                                then ''
                              else ' ' || '('||l_cont.type_brak||')'
                            end
                            || ' ';  
        if (instr(l_freight_name,l_cont.freight_name) = 0 or l_freight_name is null) then
            l_freight_name := l_freight_name||' '||l_cont.freight_name;  
        end if;  
    end loop; 
    
    if (l_freight_name is not null) then
        l_row.freight_name := l_freight_name;  
    end  if;
    
    return (l_row);
end;

function return_child_add_info
return t_xx_child_table_add_info pipelined
as
    l_function              varchar2(100) := 'return_child_add_info: ';
    l_row                   t_xx_child_row_add_info;
    function get_loading_fnc (p_car_number varchar2, p_weight_net number) return varchar2
    is
        l_movement_un_loading   varchar2(1):='N';
    begin
        begin
            SELECT   'Y' into l_movement_un_loading
              FROM   xx_etw.xx_disl_relations ds
             WHERE   1 = 1 AND ds.TYPE = 'railcar' AND ds.id = p_car_number
                     /*AND EXISTS
                           (SELECT   *
                              FROM   xx_etw.xx_disl_railways x
                             WHERE       1 = 1
                                     AND ds.parent_id = x.railway_id
                                     AND LOWER (railway_number) LIKE LOWER ('%карбамид%'))*/
                                     ;
        exception when others then l_movement_un_loading:='N';
        end;
        
        if nvl(l_movement_un_loading,'N') !='N' then
            if nvl(p_weight_net,0) != 0 then
                return 'UN_LOAD';
            else 
                return 'LOAD';
            end if;
        else 
            return 'N';
        end if;
        
        return 'N';
    end;
begin   
    --DBMS_LOCK.Sleep(5); 
    for car_info in (select *
                       from xx_etw.xx_disl_obj_add_info_tmp
                    )
    loop
        l_row.id:=car_info.obj_number;
        l_row.obj_type:=car_info.obj_type;
        l_row.foreign_car:=car_info.foreign_car;
        l_row.inv_number:=car_info.inv_number;
        l_row.status:=car_info.status;
        l_row.state:=car_info.state;
        l_row.car_type:=car_info.car_type;
        l_row.freight_name:=car_info.freight_name;
        l_row.weight_net:=car_info.weight_net;
        l_row.weight_dep:=car_info.weight_dep;
        l_row.weight_gross:=car_info.weight_gross;
        l_row.cont:=car_info.cont;
        
        if (car_info.cont is null or car_info.cont = '') then
            l_row.cont_count:= 0;
        else
            select regexp_count(car_info.cont,'[^ ]+')
              into l_row.cont_count
              from dual
            ;
        end if;
        l_row.owner:=car_info.owner;
        l_row.date_arrive:=car_info.date_arrive;
        l_row.date_last_oper:=car_info.date_last_oper;
        l_row.date_loading:=car_info.date_loading;
        l_row.car_length:=car_info.car_length;
        l_row.arrive_weight_net:=car_info.arrive_weight_net;
        l_row.cont_with_ins:=car_info.cont_with_ins;
        l_row.scale_weight_dep:=car_info.scale_weight_dep;
        l_row.scale_weight_gross:=car_info.scale_weight_gross;
        l_row.scale_weight_dep_add:=car_info.scale_weight_dep_add;
        l_row.scale_weight_gross_add:=car_info.scale_weight_gross_add;
        l_row.scale_weight_gross_add:=car_info.scale_weight_gross_add;
        l_row.can_create_return_invoice:=car_info.can_create_return_invoice;
        l_row.railcar_type:=car_info.railcar_type;
        l_row.round_id:=car_info.round_id;
        
        l_row.scale_type_id:=car_info.scale_type_id;
        
        l_row.un_loading_subs:= get_loading_fnc(l_row.id,l_row.weight_net); -- add 27/12/2022
        l_row.INV_FROM_UGL:= car_info.INV_FROM_UGL; -- add 27/12/2022
        l_row.COND_LENGTH_TRAIN:= car_info.COND_LENGTH_TRAIN; -- add 26.09.2024 По наряду 0000064852 "Условная длина поезда"
        
        pipe row (l_row);    
    end loop; 
end;

function return_child_add_info_for_gu
return t_xx_child_table_add_info_gu pipelined
as
    l_function              varchar2(100) := 't_xx_child_table_add_info_gu: ';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_row                   t_xx_child_row_add_info_gu;
begin   
    for car_info in (
        select *
          from xx_etw.xx_disl_obj_add_info_tmp)
    loop
        l_row := null;    
    
        l_row.id:=car_info.obj_number;
        l_row.obj_type:=car_info.obj_type;
        l_row.freight_name:=car_info.freight_name;
        l_row.weight_net:=car_info.weight_net;
        l_row.weight_dep:=car_info.weight_dep;
        l_row.weight_gross:=car_info.weight_gross;
        l_row.cont:=car_info.cont;
        l_row.car_length:=car_info.car_length;
        l_row.cond_length_train:= car_info.cond_length_train; -- add 26.09.2024 По наряду 0000064852 "Условная длина поезда"
        
        select listagg(econt.cont_number,'|') within group (order by econt.cont_number)
          into l_row.cont_from_inv
          from xx_etw.etw_inv_cont      econt
              --,xx_etw.etw_inv_cont_csl  eiconc
         where 1=1
           --and econt.front_end_id = eiconc.front_end_id (+) 
           --and econt.cont_line = eiconc.cont_line(+)
                              
           and econt.front_end_id in (
                select inv.front_end_id
                  from xx_etw.xx_disl_railcar_add_info      rai
                      ,xx_etw.xx_disl_railcar_add_info_inv  raii
                      ,xx_etw.etw_invoice                   inv
                 where 1=1
                   and rai.round_id = car_info.round_id
                   and rai.last_record = 'Y'
                   and rai.add_info_type in ('T','S')
                   and rai.add_info_id = raii.add_info_id
                   and raii.invoice_id = inv.invoice_id
           );
           
        select listagg('_'||'#'||eicc.seal_type_name||'#'||eicc.seal_marks,'|') within group (order by eicc.seal_type_name,eicc.seal_marks)
          into l_row.csl
          from xx_etw.etw_inv_car         ecar
              ,xx_etw.etw_inv_car_csl     eicc
         where 1=1
           and ecar.car_order = eicc.car_order 
           and ecar.front_end_id = eicc.front_end_id
           and ecar.CAR_NUMBER = car_info.obj_number       
           and ecar.front_end_id in (
                select inv.front_end_id
                  from xx_etw.xx_disl_railcar_add_info      rai
                      ,xx_etw.xx_disl_railcar_add_info_inv  raii
                      ,xx_etw.etw_invoice                   inv
                 where 1=1
                   and rai.round_id = car_info.round_id
                   and rai.last_record = 'Y'
                   and rai.add_info_type in ('T','S')
                   and rai.add_info_id = raii.add_info_id
                   and raii.invoice_id = inv.invoice_id
           );
           
        if (l_row.csl is null) then
            select listagg(econt.cont_number||'#'||eiconc.seal_type_name||'#'||eiconc.seal_marks,'|') within group (order by econt.cont_number,eiconc.seal_type_name,eiconc.seal_marks)
              into l_row.csl
              from xx_etw.etw_inv_cont      econt
                  ,xx_etw.etw_inv_cont_csl  eiconc
             where 1=1
               and econt.front_end_id = eiconc.front_end_id (+) 
               and econt.cont_line = eiconc.cont_line(+)
                             
               and econt.front_end_id in (
                    select inv.front_end_id
                      from xx_etw.xx_disl_railcar_add_info      rai
                          ,xx_etw.xx_disl_railcar_add_info_inv  raii
                          ,xx_etw.etw_invoice                   inv
                     where 1=1
                       and rai.round_id = car_info.round_id
                       and rai.last_record = 'Y'
                       and rai.add_info_type in ('T','S')
                       and rai.add_info_id = raii.add_info_id
                       and raii.invoice_id = inv.invoice_id
               );
        end if;     
        
        pipe row (l_row);    
    end loop; 
end;

procedure add_cars_for_add_info_tbl(p_id varchar2,p_type varchar2,p_station_id number)
as
    l_function              varchar2(100) := 'populate_add_info_table_with_cars: ';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
begin
    log_new(l_log_id,l_function,'parameter: p_id = ' || p_id || ' p_type = ' || p_type);
    
    insert into xx_etw.xx_disl_obj_add_info_tmp(obj_number,obj_type)
    select ds.id               
          ,ds.type
      from (select *
              from xx_disl_relations
           connect by 
                   prior id = parent_id 
               and prior type = parent_type
               and prior flag_come = flag_come
             start with 
                   parent_id = p_station_id
               and parent_type = 'station'
           ) 
               
                            ds
     where 1=1
       and ds.type in ('railcar','cont')
   connect by 
           prior ds.id = ds.parent_id 
       and prior ds.type = ds.parent_type
       and prior ds.flag_come = ds.flag_come   
     start with 
           ds.id = p_id
       and ds.type = p_type
     order by level,ds.r_order
    ;
end;

procedure add_car_for_add_info_tbl(p_car_number varchar2)
as
begin
    insert into xx_etw.xx_disl_obj_add_info_tmp(obj_number,obj_type)
    values (p_car_number,'railcar')
    ;
end;

procedure add_cont_for_add_info_tbl(p_cont_number varchar2)
as
begin
    insert into xx_etw.xx_disl_obj_add_info_tmp(obj_number,obj_type)
    values (p_cont_number,'cont')
    ;
end;

procedure add_cars_for_add_info_tbl(p_car_numbers varchar2)
as
begin
    for l_cars in (select regexp_substr(p_car_numbers,'[^|]+',1,level) text
                     from dual
                  connect by level <= regexp_count(p_car_numbers,'[^|]+')
                  )
    loop
        insert into xx_etw.xx_disl_obj_add_info_tmp(obj_number,obj_type)
        values (l_cars.text,'railcar')
        ;
    end loop;               
end;


procedure add_cars_for_add_info_tbl_r(p_car_numbers varchar2)
as
begin
    for l_cars in (
        select regexp_substr(p_car_numbers,'[^|]+',1,level) car
          from dual
       connect by level <= regexp_count(p_car_numbers,'[^|]+'))
    loop
        insert into xx_etw.xx_disl_obj_add_info_tmp(obj_number,obj_type,round_id)
        values (regexp_substr(l_cars.car,'[^#]+',1,1),'railcar',regexp_substr(l_cars.car,'[^#]+',1,2));
    end loop;               
end;

procedure return_child_add_info_bef(
    p_info_type number default 0 /*если 0 - возвращает полную информацию, если 1 - только для уведомления ГУ()*/
) as
    l_function              varchar2(100) := 'return_child_add_info_bef: ';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    
    l_conts_with_ins        varchar2(500);
    
    l_conts                 varchar2(1000);
    l_cont_weight_net       number;
    l_cont_weight_dep       number;
    
    l_car_add_info          t_xx_child_row_add_info;
begin
    update xx_etw.xx_disl_obj_add_info_tmp info_tmp
       set round_id = case
                        when obj_type = 'railcar' 
                          then returnLastRound(info_tmp.obj_number)
                        when obj_type = 'cont'
                          then return_last_cont_round(info_tmp.obj_number)
                      end
     where round_id is null;
    
    update xx_etw.xx_disl_obj_add_info_tmp info_tmp
       set (date_arrive,foreign_car) = 
           (select to_char(date_arrive,'dd.mm.yyyy hh24:mi')
                  ,nvl(foreign_car,'N')
              from xx_disl_round
             where 1=1
               and round_id = info_tmp.round_id
           )
     where 1=1
       and obj_type = 'railcar'
    ;
    
    update xx_etw.xx_disl_obj_add_info_tmp info_tmp
       set inv_number = 
           (select replace(regexp_replace(listagg(info_inv.inv_number, ',') 
                                          within group (order by info_inv.inv_number)
                                         ,'((^|,)[^,]+)(,\1)+', '\1'
                                         ),',',' ') 
                                                            inv_number
              from xx_disl_railcar_add_info         info
                  ,xx_disl_railcar_add_info_inv     info_inv
             where 1=1
               and info.add_info_id = info_inv.add_info_id
               
               and info.round_id = info_tmp.round_id
               and info.last_record = 'Y'
           )
     where 1=1
       and obj_type = 'railcar'
    ;
    
    update xx_etw.xx_disl_obj_add_info_tmp info_tmp
       set (inv_number,INV_FROM_UGL) = 
               (select replace(info_tmp.inv_number||'('||replace(regexp_replace(listagg(ei.invoice_state, ',') 
                                              within group (order by ei.invoice_state)
                                             ,'((^|,)[^,]+)(,\1)+', '\1'
                                             ),',',' ')||')','()','')
                                                                inv_number, max(case when ei.INV_FROM_STATION_CODE = '768207' then 1 else 0 end)
                  from xx_disl_railcar_add_info         info
                      ,xx_disl_railcar_add_info_inv     info_inv
                      ,xx_etw.etw_invoice               ei
                 where 1=1
                   and info.round_id = info_tmp.round_id
                   and info.last_record = 'Y' 
                 
                   and info.add_info_id = info_inv.add_info_id
                   
                   and info_inv.invoice_id = ei.invoice_id
                   -- add 31.08.2023 
                   and exists (select 'x'
                                 from xx_disl_station_history sh
                                where 1=1
                                  and sh.round_id = info_tmp.round_id
                                  and sh.out_date is null
                                  and (sh.station_id = 1 
                                        or ei.INV_FROM_STATION_CODE = '768207' -- УГЛЕУРАЛЬСКАЯ -- add 31.08.2023 
                                      )
                          )
                 --  group by ei.INV_FROM_STATION_CODE
               )
     where 1=1
       and info_tmp.inv_number is not null
       and info_tmp.obj_type = 'railcar'
       -- rem 31.08.2023 
       /*and exists (select 'x'
                     from xx_disl_station_history sh
                    where 1=1
                      and sh.round_id = info_tmp.round_id
                      and sh.out_date is null
                      and sh.station_id in (1) 
                      )*/;
    
    update xx_etw.xx_disl_obj_add_info_tmp info_tmp
       set (status,car_type,freight_name,weight_net,weight_dep,weight_gross,owner,car_length,scale_type_id) = 
           (select status
                  ,car_type
                  ,freight_name
                  ,nvl(weight_net,0)
                  ,nvl(weight_dep,0)
                  ,nvl(weight_net,0)+nvl(weight_dep,0)
                  ,owner
                  ,car_length
                  ,scales_type_id
              from xx_etw.xx_disl_railcar_add_info         info
             where 1=1
               and info.round_id = info_tmp.round_id
               and info.last_record = 'Y'
           )
     where 1=1
       and obj_type = 'railcar'
    ;

    update xx_etw.xx_disl_obj_add_info_tmp info_tmp
       set (status,freight_name,weight_net,weight_dep,weight_gross,owner,inv_number) = 
           (select status
                  ,freight_name
                  ,nvl(weight_net,0)
                  ,nvl(weight_dep,0)
                  ,nvl(weight_net,0)+nvl(weight_dep,0)
                  ,owner
                  ,info.inv_number
              from xx_etw.xx_disl_cont_add_info         info
             where 1=1
               and info.cont_round_id = info_tmp.round_id
               and info.last_record = 'Y'
           )
     where 1=1
       and obj_type = 'cont'
    ;
  
    if (p_info_type = 0) then  
        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set (status) = (select status || ' ('||to_char(car_next_repair - round(sysdate))||')' as status
                               
                           from xx_etw.etw_car_nsi
                          where 1=1
                            and car_number = info_tmp.obj_number
                        )
         where 1=1
           and obj_type = 'railcar'
           and exists (
               select 'x'
                 from xx_etw.etw_car_nsi
                where 1=1
                  and car_number = info_tmp.obj_number
           )
        ;

        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set date_last_oper = (select to_char(coalesce(rh.date_oper,sh.in_date,sh.come_date),'dd.mm.yyyy hh24:mi') 
                                   from xx_disl_station_history sh
                                       ,(select station_hist_id
                                               ,max(date_oper)  date_oper
                                           from xx_disl_railway_history
                                          where 1=1
                                          group by
                                                station_hist_id      
                                        ) 
                                                                rh
                                  where 1=1
                                    and sh.round_id = info_tmp.round_id
                                    and sh.out_date is null
                                    
                                    and sh.station_hist_id = rh.station_hist_id(+)
                                )
              ,railcar_type = xx_etw.xx_dislocation.get_railcar_type(info_tmp.round_id)
              ,cond_length_train = round(nvl((select cnsi.car_length from xx_etw.etw_car_nsi cnsi where 1=1 and cnsi.car_number = info_tmp.obj_number),14)/14,2) -- add 26.09.2024 По наряду 0000064852 "Условная длина поезда" 
         where 1=1
           and obj_type = 'railcar'
        ;
        
        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set date_last_oper = (select to_char(ch.in_date_sys,'dd.mm.yyyy hh24:mi') 
                                   from xx_etw.xx_disl_cont_history ch
                                  where 1=1
                                    and ch.cont_round_id = info_tmp.round_id
                                    and ch.out_date_sys is null
                                )
         where 1=1
           and obj_type = 'cont'
        ;
        
        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set arrive_weight_net = xx_dislocation.get_car_arrive_weight_net(info_tmp.round_id)
         where 1=1
           and obj_type = 'railcar'
        ;
        begin
            update xx_etw.xx_disl_obj_add_info_tmp info_tmp
               set date_loading = (select to_char(max(si.date_end),'dd.mm.yyyy hh24:mi')
                                     from xx_disl_shop_info si         
                                    where 1=1
                                      and si.round_id = info_tmp.round_id
                                      and si.round_type = info_tmp.obj_type
                                      and si.refusal is null
                                      and si.last_record = 'Y' 
                                  )
            ;
        exception 
            when others then null;
        end;
        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set scale_weight_dep = (select max(cs.weight_cor) keep (dense_rank last order by cs.date_w)
                                     from xx_etw.xx_disl_car_scale  cs
                                    where 1=1
                                      and cs.round_id = info_tmp.round_id
                                      and info_tmp.weight_dep between cs.weight_cor-5 and cs.weight_cor+5
                                  )
              ,scale_weight_gross = 
                                  (select max(cs.weight_cor) keep (dense_rank last order by cs.date_w)
                                     from xx_etw.xx_disl_car_scale  cs
                                    where 1=1
                                      and cs.round_id = info_tmp.round_id
                                      and info_tmp.weight_dep not between cs.weight_cor-5 and cs.weight_cor+5
                                  )
         where 1=1
           and obj_type = 'railcar'
        ;
        
        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set scale_weight_dep = (select max(cs.weight_cor) keep (dense_rank last order by cs.date_w)
                                     from xx_etw.xx_disl_car_scale  cs
                                    where 1=1
                                      and cs.car_number = info_tmp.obj_number
                                      and info_tmp.weight_dep between cs.weight_cor-5 and cs.weight_cor+5
                                  )
              ,scale_weight_dep_add = 'Y'                    
         where 1=1
           and scale_weight_dep is null
           and obj_type = 'railcar'
        ;
        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set scale_weight_gross = 
                                  (select max(cs.weight_cor) keep (dense_rank last order by cs.date_w)
                                     from xx_etw.xx_disl_car_scale  cs
                                    where 1=1
                                      and cs.car_number = info_tmp.obj_number
                                      and info_tmp.weight_dep not between cs.weight_cor-5 and cs.weight_cor+5
                                  )
              ,scale_weight_gross_add = 'Y'                   
         where 1=1
           and scale_weight_gross is null
           and obj_type = 'railcar'
        ;
    end if;   
    
    update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set cond_length_train = round(nvl((select cnsi.car_length from xx_etw.etw_car_nsi cnsi where 1=1 and cnsi.car_number = info_tmp.obj_number),14)/14,2) -- add 26.09.2024 По наряду 0000064852 "Условная длина поезда" 
         where 1=1
           and obj_type = 'railcar';
    
    for l_round in (
        select *
          from xx_etw.xx_disl_obj_add_info_tmp
         where 1=1
           and obj_type = 'railcar' 
    ) loop
        l_car_add_info := get_car_add_info_with_conts(l_round.round_id);
        DBMS_OUTPUT.put_line('l_round.round_id='||l_round.round_id||' l_car_add_info.weight_net='||l_car_add_info.weight_net||' l_car_add_info.weight_dep='||l_car_add_info.weight_dep);
        update xx_etw.xx_disl_obj_add_info_tmp
           set freight_name = l_car_add_info.freight_name
              ,cont = l_car_add_info.cont
              ,weight_net = l_car_add_info.weight_net
              ,weight_dep = l_car_add_info.weight_dep
              ,weight_gross = l_car_add_info.weight_net + l_car_add_info.weight_dep
              ,cont_with_ins = l_car_add_info.cont_with_ins
              ,date_loading = (
                 select replace(regexp_replace(listagg(to_char(si.date_end,'dd.mm.yyyy hh24:mi'), ',') 
                                               within group (order by to_char(si.date_end,'dd.mm.yyyy hh24:mi'))
                                              ,'((^|,)[^,]+)(,\1)+', '\1'
                                              ),',',' ')
                   from xx_etw.xx_disl_cont_history_cur     chc
                       ,xx_etw.xx_disl_shop_info            si 
                  where 1=1
                    and chc.place_id = l_round.round_id
                    and chc.place_type = 'railcar'
                    
                    and si.round_id = chc.cont_round_id
                    and si.round_type = 'cont'
                    and si.refusal is null
                    and si.last_record = 'Y' 
              )
         where 1=1
           and round_id = l_round.round_id
           and l_car_add_info.cont is not null
        ;
    end loop;
   
    if (p_info_type = 0) then 
        update xx_etw.xx_disl_obj_add_info_tmp 
           set can_create_return_invoice = 'Y'
         where 1=1
           --and arrive_weight_net != 0
           and trim(lower(freight_name)) in ('ацет-д',
                                             'ацетальдегид',
                                             'капрол-м',
                                             'капролактам',
                                             'едкий натр',
                                             'диоксид',
                                             'кислота мурав',
                                             'мур. к-та',
                                             'сажа белая'-- add 16.02.2022 BekmansurovRR
                                             );
         
        update xx_etw.xx_disl_obj_add_info_tmp info_tmp
           set state = case
                         when weight_net > 0
                           then 'гр.'
                         else 'пор.'
                       end
         where 1=1
        ;
    end if;
end;

procedure add_objects_for_car_cont_tbl(p_obj_numbers varchar2)
as
begin
    for l_objects in (
        select regexp_substr(p_obj_numbers,'[^|]+',1,level) obj
          from dual
       connect by level <= regexp_count(p_obj_numbers,'[^|]+')) 
    loop
        if (regexp_substr(l_objects.obj,'[^$]+',1,2) = 'railcar') then
            insert into xx_etw.xx_disl_car_cont_add_info_tmp(car_number)
            values (regexp_substr(l_objects.obj,'[^$]+',1,1))
            ;   
        else
            insert into xx_etw.xx_disl_car_cont_add_info_tmp(cont_number)
            values (regexp_substr(l_objects.obj,'[^$]+',1,1))
            ;
        end if;
    end loop;               
end;

function get_shop_not_end_flag(
    p_shop_info_id  number,
    p_round_id      number,
    p_round_type    varchar2,
    p_user_id       number default null
    )
return varchar2
as
    l_row       xx_etw.xx_disl_shop_info%rowtype;
    l_row_b     xx_etw.xx_disl_shop_info%rowtype;
    l_user_div  number :=-1;
    l_user_akm  varchar(10) :='N';
begin

    begin
        SELECT   DECODE (COUNT ( * ), 0, 'N', 'Y')
          into   l_user_akm
          FROM   xx_etw.xx_disl_user_credential uc, xx_etw.xx_disl_credential c
         WHERE       1 = 1
                 AND uc.user_id = p_user_id
                 AND uc.CREDENTIAL_ID = 38
                 AND uc.credential_id = c.credential_id(+);
       
        select division_id
          into l_user_div
          from xx_etw.xx_disl_user_div_hist ud
         where 1=1
           and ud.user_id = p_user_id
           and ud.end_date is null
        ;     
    exception
        when no_data_found then l_user_div:=-1;
    end;
    
    --return 'N'; -- временно 11.04.202
    if (p_shop_info_id is null) then
        begin  
            select *
              into l_row
              from xx_etw.xx_disl_shop_info si  
             where 1=1
               --and si.last_record = 'Y' -- rem 19/01/2023 BekmansurovRR
               and si.round_id = p_round_id
               and si.round_type = p_round_type
               and si.shop_info_id in (select max(si_1.SHOP_INFO_ID)
                                         from xx_etw.xx_disl_shop_info si_1 
                                        where 1=1 
                                              --and si_1.last_record = 'Y' -- rem 19/01/2023 BekmansurovRR
                                              and si_1.round_id = p_round_id
                                              and si_1.round_type = p_round_type
                                              and si_1.un_loading_from_subs !=1 -- исключаем операции "Погрузка/Разгрузка при перемещении АКМ" 
                                       )
               ;
        exception
            when no_data_found then return 'N';
        end;
    else
        
        select *
          into l_row
          from xx_etw.xx_disl_shop_info
         where shop_info_id = p_shop_info_id
               -- and un_loading_from_subs !=1 -- исключаем операции "Погрузка/Разгрузка при перемещении АКМ" 
               ;  
    end if;
     
    if (l_row.refusal is null and (   l_row.date_post is null 
                                   or l_row.date_start is null 
                                   or l_row.date_end is null 
                                   or l_row.date_zayavka_uvod is null 
                                   or l_row.date_uvod is null 
                                   or (    l_row.weight_net = l_row.weight_net_begin 
                                       and l_row.last_update_by != -1 
                                       and l_row.created_by != -1 
                                       and (l_row.round_type = 'cont' or xx_etw.xx_dislocation.get_railcar_type(l_row.round_id)=0)))) then
        
        
        -- add 25.11.2024 
        -- По письму: давай включим дату увода для пользователей АКМ ALL ? заполнение даты увода (!ранее у нас исторические данные закрывались по наличию даты заявки?)
            -- Если можно открыть с 01.11.2024 по дате создания записей 
        if l_row.CREATION_DATE >= to_date('20.11.2024','DD.MM.YYYY') then
            -- add 19/01/2023 BekmansurovRR
            -- Если дата Увода отсутствует, проверь 2 шаг...дб дата создания заявки и дата завершения загрузки
            if l_row.date_uvod is not null  
                    and l_row.date_zayavka_uvod is not null -- rem 25.11.2024 
                    and l_row.date_end is not null
                    and (l_user_div in (16) -- АКМ_All 
                            or l_user_akm = 'Y' -- Метафракс: Мастер смены (АКМ)
                        )
            then   
                return 'N';
            else 
                return 'Y';
            end if;
        
        else
            -- add 19/01/2023 BekmansurovRR
            -- Если дата Увода отсутствует, проверь 2 шаг...дб дата создания заявки и дата завершения загрузки
            if l_row.date_uvod is null  
                    and l_row.date_zayavka_uvod is not null 
                    and l_row.date_end is not null
                    and (l_user_div in (16) -- АКМ_All 
                            or l_user_akm = 'Y' -- Метафракс: Мастер смены (АКМ)
                        )
            then   
                return 'N';
            else 
                return 'Y';
            end if;
        end if;
        
        
    else
        return 'N';
    end if;  
end;

procedure populate_car_cont_tbl(p_only_cars number default 0,p_user_id number default null)
as
begin
    for l_cars in (
        select car_number
          from xx_etw.xx_disl_car_cont_add_info_tmp
         where 1=1
           and ((xx_etw.xx_dislocation.get_railcar_type(returnLastRound(car_number)) != 1 and p_only_cars = 1) or p_only_cars = 0)
           and car_number is not null
    ) loop
        for l_conts in (
            select cont_number
                  ,row_number() over(order by cont_number)  rn
              from table(get_car_containers(l_cars.car_number))
        ) loop
            if (l_conts.rn = 1) then
                update xx_etw.xx_disl_car_cont_add_info_tmp
                   set cont_number = l_conts.cont_number
                 where 1=1
                   and car_number = l_cars.car_number
                   and cont_number is null
                ;
            else
                insert into xx_etw.xx_disl_car_cont_add_info_tmp(car_number,cont_number)
                values(l_cars.car_number,l_conts.cont_number)
                ;
            end if;      
        end loop; 
    end loop;
    
    update xx_etw.xx_disl_car_cont_add_info_tmp
       set cont_round_id = return_last_cont_round(cont_number)
     where 1=1
       and cont_number is not null;
    
    update xx_etw.xx_disl_car_cont_add_info_tmp
       set round_id = returnLastRound(car_number)
     where 1=1
       and car_number is not null  
       and cont_number is null;
    
    update xx_etw.xx_disl_car_cont_add_info_tmp     cait
       set (freight_name,weight_net,weight_dep) = 
           (select freight_name,nvl(weight_net,0),nvl(weight_dep,0)
              from xx_etw.xx_disl_cont_add_info
             where 1=1
               and cont_round_id = cait.cont_round_id   
               and last_record = 'Y'
           )
     where 1=1
       and cont_round_id is not null;
    
    update xx_etw.xx_disl_car_cont_add_info_tmp     cait
       set (freight_name,weight_net,weight_dep) = 
           (select freight_name,nvl(weight_net,0),nvl(weight_dep,0)
              from xx_etw.xx_disl_railcar_add_info
             where 1=1
               and round_id = cait.round_id   
               and last_record = 'Y'
           )
     where 1=1
       and round_id is not null;
    
    update xx_etw.xx_disl_car_cont_add_info_tmp
       set weight_gross = weight_net + weight_dep; 
    
    update xx_etw.xx_disl_car_cont_add_info_tmp cait
       set exists_post = xx_etw.xx_dislocation.get_shop_not_end_flag(null
                                                                    ,decode(cont_number,null,round_id,cont_round_id)
                                                                    ,decode(cont_number,null,'railcar','cont')
                                                                    --,null
                                                                    ,p_user_id
                                                                    );
    
    update xx_etw.xx_disl_car_cont_add_info_tmp cait
       set car_tonnage = (select nsi.car_tonnage from xx_etw.etw_car_nsi nsi where nsi.CAR_NUMBER = cait.CAR_NUMBER); 
    begin
        update xx_etw.xx_disl_car_cont_add_info_tmp  cait
           set (refusal_akm,accepted_weight) = 
               (select to_char(x.DATE_END,'DD.MM.YYYY HH24:MI')||case when du.FULL_NAME is not null then ' - '||du.FULL_NAME end, 
                       nvl(x.accepted_weight,0)
                  from xx_etw.xx_disl_shop_info x, xx_etw.xx_disl_users du
                 where 1=1
                   and x.round_id = cait.round_id   
                   and x.last_record = 'Y'
                   and x.WHO_END_ID = du.ID(+)
               )
         where 1=1
           and round_id is not null;
    exception 
        when others then null;
    end;
    

--                         nvl((select case
--                                       when si.refusal is null and (si.date_post is null or si.date_start is null or si.date_end is null or si.date_zayavka_uvod is null or si.date_uvod is null 
--                                                                    or (si.weight_net = si.weight_net_begin and si.last_update_by != -1 and si.created_by != -1))
--                                         then 'Y'
--                                       else 'N'
--                                     end
--                                from xx_etw.xx_disl_shop_info si    
--                               where 1=1
--                                 and si.last_record = 'Y'
--                                 
--                                 and (   (si.round_id = cait.round_id and si.round_type = 'railcar')
--                                      or
--                                         (si.round_id = cait.cont_round_id and si.round_type = 'cont')
--                                     )
--                             ),'N')
--    ;  
end;

function get_car_cont_add_info
return t_xx_car_cont_add_info_table pipelined
as
    l_row   t_xx_car_cont_add_info_row;
begin   
    for obj_info in (  select  CAR_NUMBER,
                               ROUND_ID,
                               CONT_NUMBER,
                               CONT_ROUND_ID,
                               FREIGHT_NAME,
                               nvl(WEIGHT_NET,0) as WEIGHT_NET,
                               nvl(WEIGHT_DEP,0) as WEIGHT_DEP,
                               nvl(WEIGHT_GROSS,0) as WEIGHT_GROSS,
                               REFUSAL,
                               ARRIVE_WEIGHT_NET,
                               EXISTS_POST,
                               CAR_TONNAGE,
                               REFUSAL_AKM,
                               ACCEPTED_WEIGHT
                        from   xx_etw.xx_disl_car_cont_add_info_tmp
                    order by   car_number, cont_number
                    )
    loop
        l_row.car_number:=obj_info.car_number;
        l_row.cont_number:=obj_info.cont_number;
        
        l_row.freight_name:=obj_info.freight_name;
        l_row.weight_net:=obj_info.weight_net;
        l_row.weight_dep:=obj_info.weight_dep;
        l_row.weight_gross:=obj_info.weight_gross;  
        l_row.exists_post:=obj_info.exists_post;   
        l_row.car_tonnage:=obj_info.car_tonnage;   
        l_row.refusal_akm:=obj_info.refusal_akm;
        l_row.accepted_weight:=obj_info.accepted_weight;      
        pipe row (l_row);    
    end loop; 
end;

procedure fill_railcar_date_arrive(p_round_id number)
as
    l_function      varchar2(50) := 'fill_railcar_info_date_arrive: ';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    l_add_info_id   number;
begin
    log_new(l_log_id,l_function,'p_round_id='||p_round_id);
         
    update xx_etw.xx_disl_round  
       set date_arrive = (select max(ei.inv_date_arrive)          date_arrive
                            from xx_etw.etw_invoice               ei
                           where 1=1                     
                             and ei.invoice_id in (select invoice_id
                                                     from xx_etw.xx_disl_round_inv
                                                    where 1=1
                                                      and round_id = p_round_id
                                                  )
                         ) 
     where 1=1
       and round_id = p_round_id
    ;
    log_new(l_log_id,l_function,'update xx_disl_round. rowcount = '||sql%rowcount);
end;

procedure update_cont_status(p_add_info_id number default null)
as  
    l_status        varchar2(1000);
    l_cont_number   xx_etw.xx_disl_cont_add_info.cont_number%type;
begin
    select cont_number
      into l_cont_number
      from xx_etw.xx_disl_cont_add_info
     where 1=1
       and add_info_id = p_add_info_id
    ;
    
    begin
        select type_brak
          into l_status
          from xx_etw.xx_disl_nrb_stop_add_v    d_nrb_stop_add  
         where 1=1
           and d_nrb_stop_add.obj_number = l_cont_number
        ;
    exception
        when no_data_found then l_status := 'Годен';   
    end;
    
    update xx_etw.xx_disl_cont_add_info
       set status = l_status
     where 1=1
       and add_info_id = p_add_info_id
       and nvl(status,'x') != l_status
    ;
end;

procedure update_railcar_status(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2,p_add_info_id number default null)
as
    l_status        varchar2(1000);
begin
    for l_info in (select add_info_id
                         ,car_number
                     from xx_etw.xx_disl_round                  r
                         ,xx_etw.xx_disl_railcar_add_info       rai
                    where 1=1
                      and r.station_hist_id_out is null
                      and r.round_id = rai.round_id
                      
                      and rai.add_info_id = nvl(p_add_info_id,rai.add_info_id)
                      and rai.last_record = 'Y'
                  )
    loop
        begin
            with s_nerab as (
                -- add 14.03.2024 BekmansurovRR
                SELECT   cii.INSTANCE_NUMBER AS car_num
                     FROM   (SELECT   wr.*,
                                      TRIM(TRANSLATE (wr.description,
                                                      'Z' || CHR (13) || CHR (10),
                                                      'Z  '))
                                         description1,
                                      TO_DATE (character3, 'YYYY/MM/DD HH24:MI:SS')
                                         date_inspection,
                                      qr.character5 responsible_inspection
                               FROM   wip.wip_eam_work_requests wr,
                                      csi.csi_item_instances cii,
                                      qa.qa_results qr
                              WHERE       1 = 1
                                      AND wr.maintenance_object_id = cii.instance_id
                                      AND wr.attribute1 = qr.plan_id(+)
                                      AND wr.attribute2 = qr.occurrence(+)
                                      AND wr.ATTRIBUTE3 IS NULL
                             UNION ALL
                             SELECT   wr.*,
                                      TRIM(TRANSLATE (wr.description,
                                                      'Z' || CHR (13) || CHR (10),
                                                      'Z  '))
                                         description1,
                                      CREATED_DATE date_inspection,
                                      INSPECTION_PERSON responsible_inspection
                               FROM   xx_etw.XX_DISL_INSPECTIONS DI,
                                      wip.wip_eam_work_requests wr
                              WHERE       Di.INSPECTION_ID = wr.ATTRIBUTE4(+)
                                      AND wr.ATTRIBUTE3(+) = 'Дислокация'
                                      AND wr.attribute1 IS NULL
                                      AND (DI.CREATED_REQUEST_STATUS = 'S')) wr,
                            csi.csi_item_instances cii,
                            APPS.MFG_LOOKUPS wr_s
                    WHERE   1 = 1
                            AND wr.description LIKE '%ПВПП%Подготовка вагона под погрузку%'
                            AND wr.maintenance_object_id = cii.instance_id(+)
                            AND wr_s.MEANING NOT IN
                                     ('В заказе на выполнение работ',
                                      'Завершено',
                                      'Отменено',
                                      'Отклонено')
                            --AND wr.work_request_status_id = 3
                            AND wr.WORK_REQUEST_STATUS_ID = wr_s.LOOKUP_CODE
                            AND wr_s.LOOKUP_TYPE = 'WIP_EAM_WORK_REQ_STATUS'
                            AND wr_s.ENABLED_FLAG = 'Y'
            )
            select distinct 
                   case
                     when d_everyday_racing.car_iskl_date is not null
                     then 'Исключен'
                     when exists (select * from s_nerab s_n where s_n.car_num = car.car_number) then
                           case when nrb_prk.car_number is not null              -- Нерабочий парк: Если есть ваон
                                then 'Нерабочий парк/Требует подготовки'
                                else 'Требует подготовки'
                           end
                     
                     when nrb_prk.car_number is not null              -- Нерабочий парк: Если есть ваон
                     then 'Нерабочий парк'
                     when d_everyday_racing.car_next_repair - sysdate <= 33
                     then 'Подходит срок ремонта'
                     when race_ost between 1501 and 9999
                      and nvl(d_everyday_racing.car_sign,'0') != 3
                     then 'Запрет погрузки на экспорт по пробегу'
                     when race_ost <= 1500
                      and nvl(d_everyday_racing.car_sign,'0') != 3
                     then 'Запрет погрузки по пробегу'
--                     when d_nrb_stop.type_brak is not null
--                     then d_nrb_stop.type_brak
                     when d_nrb_stop_add.type_brak is not null
                     then d_nrb_stop_add.type_brak
                     else 'Годен'
                   end
                                 status
              into l_status
              from (select l_info.car_number  car_number
                      from dual 
                   )         
                                                    car                      
                  ,(select pr.car_number                                    car_number
                          ,pr.car_iskl_date                                 car_iskl_date
                          ,nvl(pr.car_sign,'0')                             car_sign
                          ,pr.car_race                                      car_race
                          ,pr.car_next_repair                               car_next_repair
                          ,(g.ost_probeg + g.obh_probeg)-pr.car_race        race_ost
                          ,(g.ost_probeg + g.obh_probeg)                    race_all
                          ,case
                             when (g.ost_probeg + g.obh_probeg)-pr.car_race between 1501 and 9999
                              and nvl(pr.car_sign,'0') != 3
                             then 'Запрет погрузки на экспорт по пробегу'
                             when (g.ost_probeg + g.obh_probeg)-pr.car_race <= 1500
                              and nvl(pr.car_sign,'0') != 3
                             then 'Запрет погрузки по пробегу'
                           end
                                                                            status 
                     from (select gvc.num_vag
                                 ,gvc.ost_probeg
                                 ,gvc.obh_probeg
                             from (select max(date_rem) mdtrem
                                         ,max(date_opr) mdtopr
                                         ,gvc1.num_vag 
                                     from xx_mtf.xxeam_gvc              gvc1
                                    group by gvc1.num_vag
                                  )
                                                        md_v
                                 ,xx_mtf.xxeam_gvc     gvc
                            where 1=1
                              and gvc.date_rem = md_v.mdtrem
                              and gvc.date_opr = md_v.mdtopr
                              and gvc.num_vag = md_v.num_vag
                          ) 
                                         g
                     right outer join xx_etw.etw_car_nsi pr 
                        on g.num_vag = pr.car_number
                   )
                                                    d_everyday_racing
                  ,(select cii.instance_number car_number
                      from wip.wip_eam_work_requests  wr
                          ,csi.csi_item_instances     cii
                    where 1=1
                      and wr.maintenance_object_id = cii.instance_id
                      and wr.work_request_status_id in (3)
                      AND wr.description not like '%ПВПП%Подготовка вагона под погрузку%'
                    group by
                          cii.instance_number
                   )
                                                    nrb_prk
--                  ,xx_etw.xx_disl_nrb_stop          d_nrb_stop
                  ,xx_etw.xx_disl_nrb_stop_add_v    d_nrb_stop_add                 
             where 1=1
               and car.car_number = d_everyday_racing.car_number(+)
               and car.car_number = nrb_prk.car_number(+)
--               and car.car_number = d_nrb_stop.car_number(+)
               and car.car_number = d_nrb_stop_add.obj_number(+)
            ;
        exception
            when others then l_status:='Годен';
        end;

        update xx_etw.xx_disl_railcar_add_info info
           set status = l_status
         where 1=1
           and info.add_info_id = l_info.add_info_id
           and nvl(status,'x') != l_status
        ;               
    end loop;
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end update_railcar_status;

function get_local_freight_name(p_freight_name in varchar2) 
return varchar2
is
begin --иден7тификаторы путей
    case upper(trim(p_freight_name)) 
    when upper('смолы карбамидф') then return 'КФК';
    when upper('спирт метилов') then return 'Метанол';
    when upper('уротропин вод') then return 'Уротропин';
    when upper('формалин') then return 'Формалин';
    when upper('фенол расплав') then return 'Фенол';
    when upper('фенол твер') then return 'Фенол';
    when upper('натр гидрокс р') then return 'Едкий натр';
    when upper('ацетальдегид') then return 'Ацет-д';
    when upper('пентаэритрит') then return 'Пентаэритрит';
    when upper('натрия формиат') then return 'Формиат натрия';
    when upper('смолы фенолоф р') then return 'ФФС';
    when upper('меламин') then return 'Меламин';
    when upper('щебень пр') then return 'Щебень';
    when upper('оксиды пр') then return 'Диоксид';
    when upper('капролактам') then return 'Капрол-м';
    else return upper(p_freight_name);
    end case;    
end; 
/*p_add_info_type: 'A'-инф-ция с накладных прибытия, 'S'-инф-ция с накладных отправки*/
procedure fill_railcar_add_info(p_round_id number,p_add_info_type varchar2)
as
    l_function          varchar2(50) := 'fill_railcar_add_info';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    
    l_add_info_id       number;
    
    l_old_add_info_id   number;
    l_old_add_info_type varchar2(1);
    
    l_freight           varchar2(200);
    l_type              varchar2(200);
    l_car_number        varchar2(20);
    l_count_send_inv    number;
    
    l_date_arrive       date;
    
    l_errbuf            varchar2(4000);
    l_retcode           varchar2(1);
    
    l_add_info_type     varchar2(1);
    
    in_oebs             number;
    
    l_pre_old_id        number;
    
    l_cont_table        xx_etw.xx_disl_table_of_varchar := xx_disl_table_of_varchar();
    l_car_model					varchar2(240);
    l_cont_count                number;
    l_cont_round_id             number;
    l_place_id                  number;
    l_place_type                varchar2(100);
    l_cont_history_id           number;
    l_cont_order                number;
    l_cont_add_info_id          number;
    l_cont_add_info_type        xx_etw.xx_disl_cont_add_info.add_info_type%type;
    l_old_cont_add_info_id      number;
    l_old_cont_add_info_type    xx_etw.xx_disl_cont_add_info.add_info_type%type;
    l_max_order                 number;
    
    l_sysdate                   date := sysdate;
    
    l_weight_net                number;
    l_invoice_id                number;
    l_owner                     varchar2(100);
    l_need_cont_out             boolean := true;
    
    l_count number;
    l_max_add_info_id number;
    l_round_id number;
begin
    log_new(l_log_id,l_function,'p_round_id = '||p_round_id||' p_add_info_type = '||p_add_info_type);
    
    l_add_info_id := xx_etw.xx_disl_railcar_add_info_seq.nextval();  
    log_new(l_log_id,l_function,'l_add_info_id = '||l_add_info_id);
    
    
    begin
    
    select round_id, max(add_info_id) add_info_id, count(*)
    into l_round_id, l_max_add_info_id, l_count
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and round_id =  p_round_id
           and last_record = 'Y'
          group by round_id;
    
    if l_count > 1 then
    
    update xx_etw.xx_disl_railcar_add_info
    set last_record = 'N'
    where round_id =  p_round_id
    and add_info_id <> l_max_add_info_id;
    
    end if;
    
    
    
        select add_info_id
              ,add_info_type
          into l_old_add_info_id
              ,l_old_add_info_type
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and round_id = p_round_id
           and last_record = 'Y'
        ;
    exception
        when no_data_found then l_old_add_info_id:=null; l_old_add_info_type:=null;
    end;
    log_new(l_log_id,l_function,'l_old_add_info_id = '||l_old_add_info_id||' l_old_add_info_type = '||l_old_add_info_type);
        
    if (l_old_add_info_id is not null) then    
        update xx_etw.xx_disl_railcar_add_info
           set last_record = 'N'
              ,date_end = l_sysdate
         where 1=1
           and add_info_id = l_old_add_info_id
        ;
        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info(last_record). sql%rowcount = '||sql%rowcount);   
    end if;
    
    insert into xx_etw.xx_disl_railcar_add_info(add_info_id,round_id,car_number,date_begin)
    select l_add_info_id
          ,round_id
          ,railcar_id
          ,l_sysdate
      from xx_etw.xx_disl_round
     where 1=1
       and round_id = p_round_id
    ;
    log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info(add_info_id,round_id,car_number). sql%rowcount = '||sql%rowcount);
    
    select car_number
      into l_car_number 
      from xx_etw.xx_disl_railcar_add_info
     where 1=1
       and add_info_id = l_add_info_id
    ;
    log_new(l_log_id,l_function,'l_car_number='||l_car_number);
    
    if (p_add_info_type='A') then
        if (l_old_add_info_id is not null) then
            delete
              from xx_etw.xx_disl_round_inv
             where 1=1
               and round_id = p_round_id
            ;
            
            insert into  xx_etw.xx_disl_round_inv(round_id,invoice_id)
            select p_round_id
                  ,ei.invoice_id
              from xx_etw.etw_invoice              ei
                  ,xx_etw.etw_inv_car              ecar
                  ,(select front_end_id
                          ,spc_custom_text 
                      from xx_etw.etw_inv_spc 
                     where spc_transp_clause_id = 975 
                        or (    spc_transp_clause_id = 993 
                            and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                           )
                   ) 
                                                   eis
                  ,xx_etw.xx_disl_inv_car          disl_car
             where  1=1
                   and ei.front_end_id = ecar.front_end_id(+)
                   and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                   
                   and ei.front_end_id = eis.front_end_id(+)
                   and ei.invoice_id = disl_car.invoice_id(+)
                                   
                   and coalesce(ecar.car_number
                               ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                               ,disl_car.car_number
                               ,'Нет отметки'
                               ) = l_car_number

                   --------------------------------------
                   and ei.invoice_state in ('Груз принят к перевозке',/*'Приемосдатчиком принято','Готов комплект документов','Согласование уведомления',*/'В пути')
                   and lower(ei.inv_to_station_name) = 'углеуральская'
                                   
                   and ei.inv_date_create >= add_months(sysdate,-6)
             group by
                   p_round_id
                  ,ei.invoice_id
            ;
        end if; 
     
        insert into xx_etw.xx_disl_railcar_add_info_inv(add_info_id,invoice_id)
        select l_add_info_id
              ,invoice_id
          from xx_etw.xx_disl_round_inv
         where 1=1
           and round_id = p_round_id
        ;
        log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info_inv(add_info_id,invoice_id). sql%rowcount = '||sql%rowcount);
    elsif (p_add_info_type='S') then
        select ei_arrive.inv_date_arrive
          into l_date_arrive
          from xx_etw.etw_invoice               ei_arrive
         where 1=1
           and ei_arrive.invoice_id = (
               select max(invoice_id)
                 from xx_etw.xx_disl_round_inv
                where 1=1
                  and round_id = p_round_id
           )
        ;    

        insert into xx_etw.xx_disl_railcar_add_info_inv(add_info_id,invoice_id)
        select l_add_info_id
              ,decode(ei.invoice_id,1492965355,1494543483,ei.invoice_id)
          from xx_etw.etw_invoice               ei
              ,xx_etw.etw_inv_car               ecar
              ,(select  front_end_id
                       ,spc_custom_text 
                  from xx_etw.etw_inv_spc 
                 where    spc_transp_clause_id = 975 
                    or (    spc_transp_clause_id = 993 
                        and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                       )
               ) 
                                                eis
         where 1=1
           and ei.invoice_id not in (610042293,636927248,648761882) /*не верно введенная накладная, позже той по которой прибыл вагон*/
           and coalesce( ecar.car_number
                        ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                        ,'Нет отметки'
                       ) = l_car_number
           and (   coalesce(ei.inv_fact_date_to_load,ei.inv_date_ready,l_date_arrive-1) > l_date_arrive
                or
                   (    ei.inv_date_create > l_date_arrive 
                    and ei.invoice_state_id = 31 /*Приемосдатчиком принято*/ 
                    and ei.inv_to_country_code != '643'/*Россия*/
                    and exists (
                        select 'x'
                          from xx_etw.xx_disl_shop_info
                         where 1=1
                           and round_id = p_round_id
                           and date_end is not null
                        )
                   )
               )
           
           and ei.front_end_id = ecar.front_end_id(+)
           and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
           
           and ei.front_end_id = eis.front_end_id(+)
           
           and ei.inv_date_create > to_date ('01.09.2014', 'dd.mm.rrrr')
           and ei.inv_recip_name <> 'ОАО "Метафракс"'
           and lower(ei.inv_from_station_name) = 'углеуральская'
           and ei.inv_number is not null
           and ei.invoice_state_id not in (89,1,440) /*Испорчен, Заготовка, Отказ в согласовании*/
        ;
        l_count_send_inv := sql%rowcount;      
        log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info_inv(add_info_id,invoice_id). l_count_send_inv = '||l_count_send_inv);
    end if;
    
    select count('x')
      into l_cont_count
      from xx_etw.etw_invoice               ei
          ,xx_etw.etw_inv_car               eicar
          ,xx_etw.etw_inv_cont              eicont
     where 1=1           
       and ei.front_end_id = eicar.front_end_id(+)
       and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                   
       and nvl(eicar.car_number,l_car_number) = l_car_number
                                       
       and ei.front_end_id = eicont.front_end_id
       and (   nvl(eicar.car_order,eicont.cont_car_order) = nvl(eicont.cont_car_order,eicar.car_order)
            or (eicar.car_order is null and eicont.cont_car_order is null)
           )
                  
       and ei.invoice_id in (select invoice_id
                               from xx_etw.xx_disl_railcar_add_info_inv
                              where 1=1
                                and add_info_id = l_add_info_id
                            )
    ;
    
    /*Вводим новый тип 'T': когда информация с накладной отправки появилась, но нет информации с цехов(погрузка/разгрузка) => тогда информация совмещается: всё берется с накладной, кроме инфjрмации о весе груза(остается предыдущая)*/
    /*Случай: создали накладную на отправку(вагон по ней пустой), а на самом деле вагон стоит не разгруженный в цехе*/
    l_add_info_type := case
                         when p_add_info_type = 'S' and (l_old_add_info_type='M' or l_old_add_info_type='T' or l_cont_count > 0/*если есть контейнера, то T ставим для контейнера*/) 
                           then 'S'
                         when p_add_info_type = 'S' and l_old_add_info_type='A'
                           then 'T'
                         when p_add_info_type = 'A'
                           then 'A'
                         else
                           p_add_info_type 
                       end;
    log_new(l_log_id,l_function,'l_add_info_type = '||l_add_info_type);

    /*делаем проверку на кол-во накладных на отправку. Случай: была накладная на отправку - попала в add_info, потом ее испортили -> запустилась процедура и никакие данные не отобразились*/
    if (p_add_info_type='S' and l_count_send_inv=0) then
    
        /*проверяем что предыдущая информация была с накладной на отправку*/
        if (l_old_add_info_type = 'T' or l_old_add_info_type = 'S') then
            begin
                select max(add_info_id)
                  into l_pre_old_id
                  from xx_etw.xx_disl_railcar_add_info
                 where 1=1
                   and round_id = p_round_id
                   and add_info_id < l_old_add_info_id
                ;
            exception
                when no_data_found then l_pre_old_id:=null;
            end;
        else
            l_pre_old_id := l_old_add_info_id;   
        end if;
        log_new(l_log_id,l_function,'l_pre_old_id='||l_pre_old_id);    
    
        update xx_etw.xx_disl_railcar_add_info
           set last_record = 'Y'
              ,date_end = null
         where 1=1
           and add_info_id = l_pre_old_id
        ;
        log_new(l_log_id,l_function,'update xx_etw.xx_disl_railcar_add_info. Кол-во = '||sql%rowcount); 
        
        delete 
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and add_info_id in (l_add_info_id,l_old_add_info_id)
           and nvl(add_info_type,'S') in ('T','S')
        ;
        log_new(l_log_id,l_function,'delete from xx_etw.xx_disl_railcar_add_info. Кол-во = '||sql%rowcount); 
    else
        update xx_etw.xx_disl_railcar_add_info_inv  info
           set inv_number = (select distinct ei.inv_number                           
                               from xx_etw.etw_invoice  ei
                              where 1=1                         
                                and ei.invoice_id = info.invoice_id
                            )
         where 1=1
           and info.add_info_id = l_add_info_id
        ;
        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info_inv(inv_number). sql%rowcount = '||sql%rowcount); 

        update xx_etw.xx_disl_railcar_add_info  info
           set (weight_net,weight_dep,owner) = 
               (select sum(case
                             when l_cont_count != 0
                               then 0
                             else eicar.car_weight_net
                           end
                          /1000)
                                                                                                weight_net
                      ,sum(case
                             when nvl(eicar.car_weight_dep_real,0) != 0
                               then eicar.car_weight_dep_real
                             when nvl(eicar.car_weight_dep,0) != 0
                               then eicar.car_weight_dep
                             else 0
                           end
                           /10)
                                                                                                weight_dep
                      ,regexp_replace(listagg(decode(decode(lower(ei.inv_to_station_name)
                                                           ,'углеуральская',ei.inv_recip_id
                                                           ,ei.inv_sender_id
                                                           )
                                                    ,33888,'МТФ'
                                                    ,295879,'МД'
                                                    ,substr(ei.inv_recip_name,1,3)
                                                    )
                                             , ',') 
                                      within group (order by ei.inv_recip_id)
                                     ,'([^,]+)(,\1)+', '\1'
                                     )                        
                                                                                                owner
                  from xx_etw.etw_invoice               ei
                      ,xx_etw.etw_inv_car               eicar
                 where 1=1           
                   and ei.front_end_id = eicar.front_end_id(+)
                   and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                   
                   and nvl(eicar.car_number,info.car_number) = info.car_number             
                  
                   and ei.invoice_id in (select invoice_id
                                           from xx_etw.xx_disl_railcar_add_info_inv
                                          where 1=1
                                            and add_info_id = l_add_info_id
                                        )
               ) 
         where 1=1
           and info.add_info_id = l_add_info_id
        ;
        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info(weight_net,weight_dep,cont,owner). sql%rowcount = '||sql%rowcount);
        
        update xx_etw.xx_disl_railcar_add_info  info
           set info.weight_dep = (
               select weight_dep
                 from xx_etw.xx_disl_railcar_add_info
                where 1=1
                  and add_info_id = l_old_add_info_id
           )
         where 1=1
           and info.add_info_id = l_add_info_id
           and info.weight_dep = 0
        ; 
        
        if (l_add_info_type = 'T') then
            update xx_etw.xx_disl_railcar_add_info  info
               set weight_net = (select t.weight_net
                                   from xx_etw.xx_disl_railcar_add_info     t
                                  where 1=1
                                    and t.add_info_id = l_old_add_info_id
                                )
             where 1=1
               and info.add_info_id = l_add_info_id
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_railcar_add_info(weight_net). sql%rowcount = '||sql%rowcount);      
        end if;
        
        dbms_output.put_line('l_add_info_id = '||l_add_info_id);
        update xx_etw.xx_disl_railcar_add_info  info
           set car_length = 
               (select max(eicar.car_length)
                  from xx_etw.etw_invoice               ei
                      ,xx_etw.etw_inv_car               eicar
                 where 1=1           
                   and ei.front_end_id = eicar.front_end_id(+)
                   and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                   
                   and nvl(eicar.car_number,info.car_number) = info.car_number
              
                   and ei.invoice_id in (select invoice_id
                                           from xx_etw.xx_disl_railcar_add_info_inv
                                          where 1=1
                                            and add_info_id = l_add_info_id
                                        )
               ) 
         where 1=1
           and info.add_info_id = l_add_info_id
        ;
        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info(car_length,need_load_car_info). sql%rowcount = '||sql%rowcount);
        update xx_etw.xx_disl_railcar_add_info  info 
           set need_load_car_info =    case
                                         when nvl(car_length,0) = 0
                                         then 'Y'
                                         else 'N'
                                       end
         where 1=1
           and info.add_info_id = l_add_info_id;
        
        
        /*убрал 28.09.17 после перехода на контейнера
        update xx_etw.xx_disl_railcar_add_info  info
           set state = decode(weight_net,0,'пор.','гр.')
         where 1=1
           and info.add_info_id = l_add_info_id
        ;
        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info(state). sql%rowcount = '||sql%rowcount);*/
       
        update_railcar_status(l_errbuf,l_retcode,l_add_info_id);
        
        if (p_add_info_type='A') then
            for railcar in (select r.railcar_id     car_id
                                  ,ri.invoice_id    inv_id
                              from xx_etw.xx_disl_round        r
                                  ,xx_etw.xx_disl_round_inv    ri
                             where 1=1
                               and r.round_id = ri.round_id
                               and r.round_id = p_round_id
                           )
            loop
                for carInfo in (
                    select DECODE (
                           DECODE (eicont.front_end_id,
                                   null, eicar.car_weight_net,
                                   eicont.cont_weight_net),
                           0, 'порожний',
                           'груженый')                                   state,
                       enwt.short_name                                   TYPE,
                       enf.fr_short_name                                 freight_name,
                       enf.fr_code_etsng                                 code_etsng,
                       NVL (eicar.car_owner_id, eicont.cont_owner_id)    owner_id,
                       eicont.cont_number                                cont_number,
                       -- add 18.02.2025 BekmansurovRR по наряду 0000078268
                       eicar.car_type_name                               as car_type_name, -- Род вагона по НСИ
                       ei.inv_recip_id                                   as inv_recip_id, -- Грузополучатель
                       ei.inv_recip_name                                 as inv_recip_name -- Грузополучатель (Наименование)
                  from xx_etw.etw_invoice       ei,
                       xx_etw.etw_inv_car       eicar,
                       (select front_end_id, spc_custom_text
                          from xx_etw.etw_inv_spc
                         where    spc_transp_clause_id = 975
                               or (    spc_transp_clause_id = 993
                                   and UPPER (spc_custom_text) like '%ПЛАТФОРМА%')) eis,
                       xx_etw.etw_inv_cont      eicont,
                       xx_etw.etw_inv_freight   eif,
                       xx_etw.etw_nsi_freight   enf,
                       xx_etw.xx_disl_inv_car   disl_car,
                       xx_etw.etw_nsi_wag_type  enwt
                 where     1 = 1
                       and ei.invoice_id = railcar.inv_id
                       and ei.front_end_id = eicar.front_end_id(+)
                       and NVL (eicar.car_sign, 0) != 1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                       and ei.front_end_id = eis.front_end_id(+)
                       and ei.front_end_id = eicont.front_end_id(+)
                       and ei.front_end_id = eif.front_end_id(+)
                       and eif.freight_code = enf.fr_code_etsng(+)
                       and ei.invoice_id = disl_car.invoice_id(+)
                       and eicar.car_type_id = enwt.wag_type_id(+)
                       and NVL (recdateend, TO_DATE ('01.01.2900', 'dd.mm.yyyy')) >= SYSDATE
                       and COALESCE (eicar.car_number,
                                     REGEXP_REPLACE (eis.spc_custom_text, '[^[[:digit:]]]*'),
                                     disl_car.car_number,
                                     'Нет отметки') = railcar.car_id 
                               )
                loop
                    
                    log_new(l_log_id,l_function,'railcar.car_id = '||railcar.car_id);
                    log_new(l_log_id,l_function,'railcar.inv_id = '||railcar.inv_id);
                    log_new(l_log_id,l_function,'carInfo.state = '||carInfo.state);
                    log_new(l_log_id,l_function,'carInfo.type = '||carInfo.type);
                    log_new(l_log_id,l_function,'carInfo.freight_name = '||carInfo.freight_name);
                    log_new(l_log_id,l_function,'carInfo.code_etsng = '||carInfo.code_etsng);
                    log_new(l_log_id,l_function,'carInfo.owner_id = '||carInfo.owner_id);
                    log_new(l_log_id,l_function,'carInfo.car_type_name = '||carInfo.car_type_name);
                    log_new(l_log_id,l_function,'carInfo.inv_recip_name = '||carInfo.inv_recip_name);

                    l_freight := '$';
                    l_type := '$';
                    
                    begin
                        select count('x')
                          into in_oebs 
                          from xx_etw.bi_msib_v
                         where 1=1
                           and segment1 =railcar.car_id
                        ;
                    exception
                        when no_data_found then in_oebs:=0;
                    end;
                    
                    if (carInfo.state != 'порожний') then
                        l_type:=getCarType(carInfo.code_etsng,carInfo.cont_number,carInfo.type);
                        l_freight:=getCarFreight(carInfo.code_etsng,carInfo.cont_number,carInfo.freight_name);
                        log_new(l_log_id,l_function,'l_type = '||l_type);
                        log_new(l_log_id,l_function,'l_freight = '||l_freight);
                    elsif (carInfo.owner_id = 33888 /*ОАО "Метафракс"*/ or carInfo.owner_id = 171231/*ООО "РАЙФФАЙЗЕН-ЛИЗИНГ"*/ or in_oebs>0) then
                        begin
                            select decode(regexp_substr(ship_code,'[^ ]+',1,1)
                                         ,'Цистерны','ЦС'
                                         ,'Минераловозы','МВ'
                                         ,'Крытый','КР'
                                         ,'Платформа','ПЛ'
                                         ,'Полувагоны','ПВ'
                                         ,regexp_substr(ship_code,'[^ ]+',1,1)
                                         )
                                  ,regexp_substr(ship_code,'[^ ]+',1,2)
                              into l_type
                                  ,l_freight 
                              from xx_etw.bi_msib_v
                             where 1=1
                               and segment1 =railcar.car_id
                            ;
                        exception
                            when no_data_found then l_type:= null; l_freight:=null;
                        end;
                        log_new(l_log_id,l_function,'xx_etw.bi_msib_v: l_freight = '||l_freight);
                        
                        if (l_freight = 'СМАМД') then
--                            select max(ei.invoice_id)
--                              into l_invoice_id
--                              from xx_etw.etw_invoice               ei
--                                  ,xx_etw.etw_inv_car               ecar
--                                  ,(select  front_end_id
--                                           ,spc_custom_text 
--                                      from xx_etw.etw_inv_spc 
--                                     where    spc_transp_clause_id = 975 
--                                        or (    spc_transp_clause_id = 993 
--                                            and upper(spc_custom_text) like '%ПЛАТФОРМА%'
--                                           )
--                                   ) 
--                                                                    eis
--                             where 1=1
--                               and coalesce( ecar.car_number
--                                            ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
--                                            ,'Нет отметки'
--                                           ) = l_car_number
--                               
--                               and ei.front_end_id = ecar.front_end_id(+)
--                               and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
--                               
--                               and ei.front_end_id = eis.front_end_id(+)
--                               
--                               and ei.inv_date_create > to_date ('01.09.2014', 'dd.mm.rrrr')
--                               and ei.inv_recip_name <> 'ОАО "Метафракс"'
--                               and lower(ei.inv_from_station_name) = 'углеуральская'
--                               and ei.inv_number is not null
--                               and ei.invoice_state_id not in (89,1) /*Испорчен, Заготовка*/
--                            ;
--                            
--                            select xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name)
--                              into l_freight_name
--                              from xx_etw.etw_invoice               ei
--                                  ,xx_etw.etw_inv_freight           eif
--                                  ,xx_etw.etw_nsi_freight           enf
--                             where 1=1           
--                               and ei.invoice_id = l_invoice_id

--                               and ei.front_end_id = eif.front_end_id(+)
--                                                                              
--                               and eif.freight_code = enf.fr_code_etsng(+)
--                               and nvl(recdateend,to_date('01.01.2900','dd.mm.yyyy')) >= sysdate
--                            ;
                            select min(freight_name) keep (dense_rank last order by add_info_id)
                              into l_freight
                              from xx_etw.xx_disl_railcar_add_info
                             where 1=1
                               and car_number = l_car_number
                               and freight_name != 'СМАМД'
                            ;
                            log_new(l_log_id,l_function,'xx_etw.xx_disl_railcar_add_info: l_freight = '||l_freight);
                            
                            if (instr(l_freight,'(н)')!=0) then
                                l_freight := substr(l_freight,1,length(l_freight)-3);
                            end if;
                            log_new(l_log_id,l_function,'(н): l_freight = '||l_freight);
                            
                            l_freight := xx_etw.xx_dislocation.get_local_freight_name(l_freight);
                            log_new(l_log_id,l_function,'get_local_freight_name: l_freight = '||l_freight);
                            
                            update xx_etw.xx_disl_railcar_add_info
                               set freight_name = 
                                               case
                                                 when l_freight = 'КФК' and carInfo.owner_id != 33888
                                                 then 'КФС'
                                                 else l_freight
                                               end
                                                        
                             where 1=1
                               and add_info_id = l_add_info_id
                            ;
                        end if;
                        
                        log_new(l_log_id,l_function,'l_type = '||l_type);
                        log_new(l_log_id,l_function,'l_freight = '||l_freight);
                    else 
                        l_type := case carInfo.code_etsng
                                    when '421034'
                                      then 'КР'
                                    when '391464'
                                      then 'ПЛ с КЦ'
                                    when '391498'
                                      then 'ПЛ с УК'
                                    when '421104'
                                      then 'ПЛ'
                                    when '423025'
                                      then 'ВПВ'
                                    when '421208'
                                      then carInfo.type
                                    else '$'
                                  end;
                        l_freight := case carInfo.code_etsng
                                       when '421034'
                                         then 'под погрузку'
                                       when '391498'
                                         then 'под погрузку'
                                       when '421104'
                                         then 'под погрузку'
                                       when '421208'
                                         then 'под погрузку'
                                       when '423025'
                                         then 'на весы'
                                       else '$'
                                     end;
                        if (carInfo.code_etsng='391464') then
                            select min(enf.fr_short_name) keep (dense_rank last order by ei.invoice_id) freight_name
                              into l_freight
                              from xx_etw.etw_invoice               ei
                                  ,xx_etw.etw_inv_cont              eicont
                                  ,xx_etw.etw_inv_freight           eif
                                  ,xx_etw.etw_nsi_freight           enf                                          
                             where 1=1
                               and ei.front_end_id = eicont.front_end_id(+)
                               and ei.front_end_id = eif.front_end_id(+)
                               and eif.freight_code = enf.fr_code_etsng(+)
                               and ei.inv_number is not null
                               and enf.fr_code_etsng != 391464
                               and ei.invoice_state_id not in (89,117) /*Испорчен,Сторнирован по назначению*/                      
                               and eicont.cont_number = carInfo.cont_number                     
                               and nvl(enf.recdateend,to_date('01.01.2900','dd.mm.yyyy')) >= sysdate
                            ;  
                        end if;
                        log_new(l_log_id,l_function,'l_type = '||l_type);             
                        log_new(l_log_id,l_function,'l_freight = '||l_freight);
                    end if;
					-- add 25.02.2026 по наряду 0000110299
                    begin
                        l_car_model := null;
                        select car_nsi.car_model into l_car_model
                          from xx_etw.xx_disl_railcar_add_info drai, xx_etw.etw_car_nsi car_nsi
                         where 1 = 1 
                               and car_nsi.car_number = railcar.car_id
                               and car_nsi.CAR_ISKL_DATE is null;
                        log_new(l_log_id,l_function,'l_car_model = '||l_car_model);
                        
                        if (nvl(l_car_model,'*') in ('12-1303-01', '12-132', '12-132-03')) then
                            l_type :='ПВ';
                        end if;
                    exception 
                        when no_data_found then null;
                        when others then 
                            log_new(l_log_id,l_function,'Модель вагона. '||'car_number='||railcar.car_id||' Ошибка:'||sqlerrm);
                    end;
                    
                    -- add 18.02.2025 BekmansurovRR по наряду 0000078268
                    -- Идентификация минераловозов. Разовая сделка
                    log_new(l_log_id,l_function,'before: Разовая сделка:l_type = '||l_type);
                    log_new(l_log_id,l_function,'before: Разовая сделка:carInfo.car_type_name = '||carInfo.car_type_name);
                    log_new(l_log_id,l_function,'before: Разовая сделка:carInfo.inv_recip_name = '||carInfo.inv_recip_name);
                    log_new(l_log_id,l_function,'before: Разовая сделка:carInfo.inv_recip_id = '||carInfo.inv_recip_id);
                    if lower(trim(l_freight)) = 'под погрузку' 
                        -- Род вагона по НСИ
                        and (lower(carInfo.car_type_name) like 'ваг%для%минерал%удобрен%' 
                                or lower(carInfo.car_type_name) like 'цс%для%метанола%'
                                or lower(carInfo.car_type_name) like 'кр.хоппера для зерна%' 
                            ) 
                        and (carInfo.inv_recip_name like '%Метафракс%Кемикалс%'
                                or carInfo.inv_recip_id = 33888 -- Акционерное общество "Метафракс Кемикалс"
                            )
                    then
                        -- 
                        begin
                            select case when lower(carInfo.car_type_name) like 'ваг%для%минерал%удобрен%' 
                                                or lower(carInfo.car_type_name) like 'кр.хоппера для зерна%'  
                                            then 'Карбамид Р'
                                        when lower(carInfo.car_type_name) like 'цс%для%метанола%'
                                            then 'Метанол Р'
                                   end, 
                                   -- Тип
                                   case when lower(carInfo.car_type_name) like 'ваг%для%минерал%удобрен%' 
                                                or lower(carInfo.car_type_name) like 'кр.хоппера для зерна%'  
                                            then 'МВ'
                                        when lower(carInfo.car_type_name) like 'цс%для%метанола%'
                                            then 'ЦС'
                                   end
                              into l_freight, l_type
                              from DUAL
                             -- те которые не на слежении/не наши
                             where not exists
                                       (select *
                                          from xx_etw.xx_track_list
                                         where car_number = l_car_number);
                        exception 
                            when others then 
                                log_new(l_log_id,l_function,'Разовая сделка Ошибка:'||sqlerrm);
                                null;
                        end;
                        log_new(l_log_id,l_function,'process: Идентификация минераловозов. Разовая сделка: l_freight='||l_freight||' l_type='||l_type);
                    end if;
                    
                    
                    if (l_type != '$') then
                        update xx_etw.xx_disl_railcar_add_info
                           set car_type = l_type
                         where 1=1
                           and add_info_id = l_add_info_id
                        ;
                        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info(car_type)='||l_type||'. sql%rowcount = '||sql%rowcount);
                    end if;
                    
                    if (l_freight != '$') then    
                        update xx_etw.xx_disl_railcar_add_info
                           set freight_name = l_freight
                         where 1=1
                           and add_info_id = l_add_info_id
                        ;
                        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info(freight_name)='||l_freight||'. sql%rowcount = '||sql%rowcount);
                    end if;
                end loop;                    
            end loop;
        elsif (p_add_info_type='S') then
            update xx_etw.xx_disl_railcar_add_info info
               set freight_name = case
                                    when nvl(info.weight_net,0) = 0
                                      then 
                                        (select freight_name
                                           from xx_etw.xx_disl_railcar_add_info
                                          where 1=1
                                            and add_info_id = l_old_add_info_id
                                        )
                                    else
                                        (select replace(regexp_replace(listagg(xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name), ',') 
                                                                     within group (order by xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name))
                                                                    ,'([^,]+)(,\1)+', '\1'
                                                                    ),',',' ')
                                                                                                                       freight_name
                                         from xx_etw.etw_invoice               ei
                                             ,xx_etw.etw_inv_freight           eif
                                             ,xx_etw.etw_nsi_freight           enf
                                             ,xx_etw.etw_inv_car               eicar
                                        where 1=1
                                          and ei.front_end_id = eif.front_end_id(+)
                                                          
                                          and eif.freight_code = enf.fr_code_etsng(+)
                                          and nvl(recdateend,to_date('01.01.2900','dd.mm.yyyy')) >= sysdate
                                                          
                                          and ei.front_end_id = eicar.front_end_id(+)
                                          and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                                          
                                          and nvl(eicar.car_number,info.car_number) = info.car_number
                                     
                                          and ei.invoice_id in (select invoice_id
                                                                  from xx_etw.xx_disl_railcar_add_info_inv inv
                                                                 where 1=1
                                                                   and inv.add_info_id=info.add_info_id
                                                               )
                                      )   
                                  end
                  ,car_type = (select car_type
                                 from xx_etw.xx_disl_railcar_add_info
                                where 1=1
                                  and add_info_id = l_old_add_info_id
                              )
             where 1=1
               and add_info_id = l_add_info_id  
            ;
            
            log_new(l_log_id,l_function,'update xx_disl_railcar_add_info(freight_name,car_type). sql%rowcount = '||sql%rowcount);
        end if;
        
        if (l_add_info_type = 'T') then
            update xx_etw.xx_disl_railcar_add_info  info
               set freight_name = (select t.freight_name
                                     from xx_etw.xx_disl_railcar_add_info     t
                                    where 1=1
                                      and t.add_info_id = l_old_add_info_id
                                  )
             where 1=1
               and info.add_info_id = l_add_info_id
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_railcar_add_info(freight_name). sql%rowcount = '||sql%rowcount);      
        end if;
        
        update xx_etw.xx_disl_railcar_add_info
           set add_info_type = l_add_info_type
              ,last_update_date = l_sysdate
              ,last_update_user_id = -1
              ,date_begin = l_sysdate
         where 1=1
           and add_info_id = l_add_info_id;
        
        log_new(l_log_id,l_function,'update xx_etw.xx_disl_railcar_add_info(add_info_type). add_info_type= '||l_add_info_type||' add_info_id='||l_add_info_id);  
        
    end if;
    
    /*обработаем контейнера*/
    for l_cont_info in (    
        select eicont.cont_number                               cont_number
              ,nvl(eicont.cont_weight_net,0)/1000               cont_weight_net
              ,nvl(eicont.cont_weight_dep,0)/1000               cont_weight_dep
              ,ei.invoice_id                                    invoice_id
              ,ei.inv_number                                    inv_number
              ,count('x') over()                                cont_count
          from xx_etw.etw_invoice               ei
              ,xx_etw.etw_inv_car               eicar
              ,xx_etw.etw_inv_cont              eicont
         where 1=1           
           and ei.front_end_id = eicar.front_end_id(+)
           and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                   
           and nvl(eicar.car_number,l_car_number) = l_car_number
                                       
           and ei.front_end_id = eicont.front_end_id
           and (   nvl(eicar.car_order,eicont.cont_car_order) = nvl(eicont.cont_car_order,eicar.car_order)
                or (eicar.car_order is null and eicont.cont_car_order is null)
               )
                  
           and ei.invoice_id in (select invoice_id
                                   from xx_etw.xx_disl_railcar_add_info_inv
                                  where 1=1
                                    and add_info_id = l_add_info_id
                                )
    ) 
    loop
        log_new(l_log_id,l_function,'l_cont_info.cont_number = '||l_cont_info.cont_number||' l_cont_info.cont_number = '||l_cont_info.cont_count);
        
        /*не обрабатываем контейнера если на одной платформе один контейнер*/
        /*бывают случаи когда накладная на отправку по одной накладной оформляется позже чем другая - нужно ждать оформления всез накладный*/
        if (l_cont_info.cont_count < 2 and p_add_info_type = 'S') then
            log_new(l_log_id,l_function,'exit from loop');
            l_need_cont_out := false;
            exit;
        end if;
    
        l_cont_table.extend;
        l_cont_table(l_cont_table.last):=l_cont_info.cont_number;
        
        begin
            select cr.cont_round_id
                  ,ch.place_id
                  ,ch.place_type
                  ,ch.cont_history_id
              into l_cont_round_id
                  ,l_place_id
                  ,l_place_type
                  ,l_cont_history_id
              from xx_etw.xx_disl_cont_round            cr
                  ,xx_etw.xx_disl_cont_history          ch
             where 1=1
               and cont_number = l_cont_info.cont_number
               and cont_history_out is null
               
               and cr.cont_round_id = ch.cont_round_id 
               and ch.out_date_sys is null
            ;
        exception
            when no_data_found then l_cont_round_id := null; 
        end;
        log_new(l_log_id,l_function,'l_cont_round_id = '||l_cont_round_id||' l_place_id = '||l_place_id||' l_place_type = '||l_place_type||' l_cont_history_id = '||l_cont_history_id);
        
        if (l_cont_round_id is null) then
            l_cont_round_id := xx_etw.xx_disl_cont_round_seq.nextval();
            l_cont_history_id := xx_etw.xx_disl_cont_history_seq.nextval();
                 
            insert into xx_etw.xx_disl_cont_round
            values(
                l_cont_round_id,
                l_cont_info.cont_number,
                l_cont_history_id,
                null,
                l_cont_info.invoice_id
            );
                
            insert into xx_etw.xx_disl_cont_history
            values(
                l_cont_history_id,
                l_cont_round_id,
                p_round_id,
                'railcar',
                sysdate,
                sysdate,
                -1,
                null,
                null,
                null,
                null  
            );
                
            insert into xx_etw.xx_disl_cont_history_cur
            values(
                l_cont_round_id,
                p_round_id,
                'railcar',
                l_cont_history_id
            );
        elsif (l_place_type != 'railcar' or (l_place_type = 'railcar' and l_place_id != p_round_id)) then             
            update xx_etw.xx_disl_cont_history
               set out_date_sys = sysdate
                  ,out_date_fact = sysdate
                  ,out_user = -1
             where 1=1
               and cont_history_id = l_cont_history_id
            ;
            
            l_cont_history_id := xx_etw.xx_disl_cont_history_seq.nextval();
            insert into xx_etw.xx_disl_cont_history
            values(
                l_cont_history_id,
                l_cont_round_id,
                p_round_id,
                'railcar',
                sysdate,
                sysdate,
                -1,
                null,
                null,
                null,
                null  
            );
            
            update xx_etw.xx_disl_cont_history_cur
               set place_id = p_round_id
                  ,place_type = 'railcar'
                  ,cont_history_id_in = l_cont_history_id
             where 1=1
               and cont_round_id = l_cont_round_id
            ;
            
            if (l_place_type = 'area') then
                select r_order
                  into l_cont_order       
                  from xx_etw.xx_disl_relations
                 where 1=1
                   and id = l_cont_info.cont_number
                   and type = 'cont'
                   and flag_come = 'Y'
                ;
            
                update xx_etw.xx_disl_relations
                   set r_order = r_order - 1
                 where 1=1
                   and parent_id = l_place_id
                   and parent_type = l_place_type
                   and flag_come = 'Y'
                   and r_order > l_cont_order
                ;
                
                delete 
                  from xx_etw.xx_disl_relations
                 where 1=1
                   and id = l_cont_info.cont_number
                   and type = 'cont'
                   and flag_come = 'Y'
                ;
            end if;        
        end if;
        
        l_cont_add_info_id := xx_etw.xx_disl_cont_add_info_seq.nextval();
        
        begin
            select add_info_id
                  ,add_info_type
              into l_old_cont_add_info_id
                  ,l_old_cont_add_info_type
              from xx_etw.xx_disl_cont_add_info
             where 1=1
               and cont_round_id = l_cont_round_id
               and last_record = 'Y'
            ;
        exception
            when no_data_found then l_old_cont_add_info_id := null; l_old_cont_add_info_type := null;
        end;
        
        log_new(l_log_id,l_function,'l_old_cont_add_info_id = '||l_old_cont_add_info_id||' l_old_cont_add_info_type = '||l_old_cont_add_info_type);
        
        l_cont_add_info_type := case
                                 when p_add_info_type = 'S' and (l_old_cont_add_info_type='M' or l_old_cont_add_info_type='T') 
                                   then 'S'
                                 when p_add_info_type = 'S' and l_old_cont_add_info_type='A'
                                   then 'T'
                                 when p_add_info_type = 'A'
                                   then 'A'
                                 else
                                   p_add_info_type 
                               end;
        log_new(l_log_id,l_function,'l_cont_add_info_type = '||l_cont_add_info_type);
        
        insert into xx_etw.xx_disl_cont_add_info
        values(
            l_cont_add_info_id,
            l_cont_round_id,
            l_cont_info.cont_number,
            null,
            null,
            l_cont_info.cont_weight_net,
            l_cont_info.cont_weight_dep,
            null,
            l_cont_add_info_type,
            'Y',
            sysdate,
            -1,
            'N',
            l_cont_info.invoice_id,
            l_cont_info.inv_number,
            l_sysdate,
            null    
        ); 
        
        update xx_etw.xx_disl_cont_add_info
           set owner = (
               select owner
                 from xx_etw.xx_disl_railcar_add_info
                where 1=1
                  and add_info_id = l_add_info_id
              )
         where 1=1
           and add_info_id = l_cont_add_info_id
        returning owner into l_owner
        ;

        if (p_add_info_type = 'A') then
            if (nvl(l_cont_info.cont_weight_net,0) = 0) then

                log_new(l_log_id,l_function,'l_cont_info.cont_number  = '||l_cont_info.cont_number );
                select min(xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name)) keep (dense_rank last order by ei.invoice_id) freight_name
                  into l_freight
                  from xx_etw.etw_invoice               ei
                      ,xx_etw.etw_inv_cont              eicont
                      ,xx_etw.etw_inv_freight           eif
                      ,xx_etw.etw_nsi_freight           enf                                          
                 where 1=1
                   and ei.front_end_id = eicont.front_end_id(+)
                   and ei.front_end_id = eif.front_end_id(+)
                   and eif.freight_code = enf.fr_code_etsng(+)
                   and ei.inv_number is not null
                   and enf.fr_code_etsng not in (391464,391498)
                   and ei.invoice_state_id not in (89,117) /*Испорчен,Сторнирован по назначению*/                      
                   and eicont.cont_number = l_cont_info.cont_number                  
                   and nvl(enf.recdateend,to_date('01.01.2900','dd.mm.yyyy')) >= sysdate
                ;

                if (l_freight is null) then
                    l_freight := 'под погрузку';
                elsif (l_freight = 'КФК') then
                    l_freight := case when l_owner='МД' then 'КФС' else l_freight end;        
                elsif (l_freight = 'Уротропин' or l_freight = 'Пентаэритрит' or l_freight = 'Формиат натрия' or l_freight = 'ФСС') then
                    l_freight := 'под погрузку';  
                else
                    null;
                end if;
            else
                log_new(l_log_id,l_function,'l_cont_info.invoice_id='||l_cont_info.invoice_id );
                select replace(regexp_replace(listagg(xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name), ',') 
                                              within group (order by xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name))
                                             ,'([^,]+)(,\1)+', '\1'
                                             ),',',' ')
                  into l_freight                                                                                 
                  from xx_etw.etw_invoice               ei
                      ,xx_etw.etw_inv_freight           eif
                      ,xx_etw.etw_nsi_freight           enf
                 where 1=1
                   and ei.front_end_id = eif.front_end_id(+)
                                                              
                   and eif.freight_code = enf.fr_code_etsng(+)
                   and nvl(recdateend,to_date('01.01.2900','dd.mm.yyyy')) >= sysdate
                    
                   and ei.invoice_id = l_cont_info.invoice_id
                ;
            end if;
        elsif (p_add_info_type = 'S') then
            if (nvl(l_cont_info.cont_weight_net,0) = 0) then                
                if (l_old_cont_add_info_id is not null) then    
                    select freight_name
                      into l_freight
                      from xx_etw.xx_disl_cont_add_info
                     where 1=1
                       and add_info_id = l_old_cont_add_info_id;  
                else
                    l_freight := null;
                end if;  
                
                /*02.11.2017 пока для контейнеров не всегда есть запись с накладной по прибытию xx_disl_cont_add_info, поэтому берем из накладных напрямую*/
                if (l_freight is null) then
                    select max(ei.invoice_id)
                      into l_invoice_id
                      from xx_etw.etw_invoice               ei
                          ,xx_etw.etw_inv_car               eicar
                          ,xx_etw.etw_inv_cont              eicont
                     where 1=1           
                       and ei.front_end_id = eicar.front_end_id(+)
                       and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                               
                                                   
                       and ei.front_end_id = eicont.front_end_id
                       and (   nvl(eicar.car_order,eicont.cont_car_order) = nvl(eicont.cont_car_order,eicar.car_order)
                            or (eicar.car_order is null and eicont.cont_car_order is null)
                           )
                           
                       and eicont.cont_number = l_cont_info.cont_number
                       
                       and lower(ei.inv_to_station_name) = 'углеуральская'
                       
                       and ei.invoice_state_id not in (89,1) /*Испорчен, Заготовка*/
                    ; 
                    
                    log_new(l_log_id,l_function,'l_invoice_id = '||l_invoice_id);
                    
                    if (l_invoice_id is not null) then
                        select xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name)
                          into l_freight
                          from xx_etw.etw_invoice               ei
                              ,xx_etw.etw_inv_freight           eif
                              ,xx_etw.etw_nsi_freight           enf
                         where 1=1           
                           and ei.invoice_id = l_invoice_id

                           and ei.front_end_id = eif.front_end_id(+)
                                                                          
                           and eif.freight_code = enf.fr_code_etsng(+)
                           and nvl(recdateend,to_date('01.01.2900','dd.mm.yyyy')) >= sysdate;
                    else
                        l_freight := null;
                    end if;
                end if;
            else
                select replace(regexp_replace(listagg(xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name), ',') 
                                              within group (order by xx_etw.xx_dislocation.get_local_freight_name(enf.fr_short_name))
                                             ,'([^,]+)(,\1)+', '\1'
                                             ),',',' ')
                  into l_freight                                                                                 
                  from xx_etw.etw_invoice               ei
                      ,xx_etw.etw_inv_freight           eif
                      ,xx_etw.etw_nsi_freight           enf
                 where 1=1
                   and ei.front_end_id = eif.front_end_id(+)
                                                              
                   and eif.freight_code = enf.fr_code_etsng(+)
                   and nvl(recdateend,to_date('01.01.2900','dd.mm.yyyy')) >= sysdate
                    
                   and ei.invoice_id = l_cont_info.invoice_id
                ;        
            end if; 
        end if;
        
        update xx_etw.xx_disl_cont_add_info
           set freight_name = l_freight
         where 1=1
           and add_info_id = l_cont_add_info_id
        ;
        
        update xx_etw.xx_disl_cont_add_info
           set last_record = 'N'
              ,date_end = l_sysdate
         where 1=1
           and add_info_id = l_old_cont_add_info_id
        ; 
        
        update_cont_status(l_cont_add_info_id);
    end loop;
    
    if (l_need_cont_out) then
        for l_cont_out in (
            select cr.cont_round_id                 cont_round_id
                  ,cr.cont_number                   cont_number 
                  ,ch.cont_history_id               cont_history_id
              from xx_etw.xx_disl_cont_round        cr
                  ,xx_etw.xx_disl_cont_history      ch
             where 1=1
               and cr.cont_number not in ( 
                   select *
                     from table(l_cont_table)
               )
               
               and cr.cont_round_id = ch.cont_round_id
               and ch.place_type = 'railcar'
               and ch.place_id = p_round_id
               and ch.out_date_sys is null
        ) loop
            if (p_add_info_type = 'A') then
                delete 
                  from xx_etw.xx_disl_cont_round
                 where 1=1
                   and cont_round_id = l_cont_out.cont_round_id 
                ;  
            elsif (p_add_info_type = 'S') then
                update xx_etw.xx_disl_cont_history
                   set out_date_sys = sysdate
                      ,out_date_fact = sysdate
                      ,out_user = -1
                 where 1=1
                   and cont_history_id = l_cont_out.cont_history_id
                ;
                
                l_cont_history_id := xx_etw.xx_disl_cont_history_seq.nextval();
                insert into xx_etw.xx_disl_cont_history
                values(
                    l_cont_history_id,
                    l_cont_out.cont_round_id,
                    -1,
                    'area',
                    sysdate,
                    sysdate,
                    -1,
                    null,
                    null,
                    null,
                    null  
                );
                    
                update xx_etw.xx_disl_cont_history_cur
                   set place_id = -1
                      ,place_type = 'area'
                      ,cont_history_id_in = l_cont_history_id
                 where 1=1
                   and cont_round_id = l_cont_out.cont_round_id
                ;
                
                l_max_order := returnMaxOrder(-1,'area','Y');
                insert into xx_etw.xx_disl_relations
                values(
                    l_cont_out.cont_number,
                    'cont',
                    -1,
                    'area',
                    l_max_order+1,
                    'Y'     
                );    
            end if;
        end loop; 
    end if;
end;

function change_railcar_add_info(p_user_id number,p_car_number varchar2,p_car_type varchar2, p_freight_name varchar2,p_weight_dep varchar2,p_owner varchar2)
return varchar2
as
    l_function              varchar2(50) := 'change_railcar_add_info';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    
    l_add_info_id_new       number;
    l_add_info_id_old       number;
    l_add_info_type_old     varchar2(1);
    l_weight_dep            number;
    l_date_loading          date;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id||' '
                              ||'p_car_number = '||p_car_number||' '
                              ||'p_car_type = '||p_car_type||' '
                              ||'p_freight_name = '||p_freight_name||' '
                              ||'p_weight_dep = '||p_weight_dep||' '
                              ||'p_owner = '||p_owner);
    
    l_weight_dep := to_number(nvl(p_weight_dep,'0'),'999999999999999D999999999999999','NLS_NUMERIC_CHARACTERS = ''. '''); 
    log_new(l_log_id,l_function,'l_weight_dep = '||l_weight_dep);
    
        
    select add_info_id
          ,add_info_type
      into l_add_info_id_old
          ,l_add_info_type_old
      from xx_disl_railcar_add_info info
     where 1=1
       and info.round_id = returnLastRound(p_car_number)
       and info.last_record = 'Y'
    ;
    log_new(l_log_id,l_function,'l_add_info_id_old = '||l_add_info_id_old||' '||'l_add_info_type_old = '||l_add_info_type_old);
       
    if (l_add_info_type_old='A' or l_add_info_type_old='M') then
        l_add_info_id_new := xx_disl_railcar_add_info_seq.nextval();
        insert into xx_disl_railcar_add_info(
             add_info_id
            ,round_id
            ,car_number
            ,status
            ,car_type
            ,freight_name
            ,weight_net
            ,weight_dep
            ,cont
            ,owner
            ,add_info_type
            ,last_record
            ,last_update_date
            ,last_update_user_id
            ,car_length
            ,need_load_car_info
            ,date_begin
        )
        select l_add_info_id_new
              ,old_info.round_id
              ,old_info.car_number
              ,old_info.status
              ,p_car_type
              ,p_freight_name
              ,old_info.weight_net
              ,l_weight_dep
              ,old_info.cont
              ,p_owner
              ,'M'
              ,'Y'
              ,sysdate
              ,p_user_id
              ,old_info.car_length
              ,old_info.need_load_car_info
              ,sysdate
          from xx_disl_railcar_add_info old_info
         where 1=1
           and add_info_id = l_add_info_id_old
        ;
        log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info Кол-во='||sql%rowcount);
            
        update xx_disl_railcar_add_info 
           set last_record = 'N'
              ,date_end = sysdate
         where 1=1
           and add_info_id = l_add_info_id_old
        ;
        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info Кол-во='||sql%rowcount);
            
        commit;
        return 'done';
--    elsif (l_add_info_type_old='M') then
--        update xx_disl_railcar_add_info 
--           set car_type = p_car_type
--              ,freight_name = p_freight_name
--              ,weight_dep = l_weight_dep
--              ,owner = p_owner
--              ,last_update_date = sysdate
--              ,last_update_user_id = p_user_id
--         where 1=1
--           and add_info_id = l_add_info_id_old
--        ;
--        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info Кол-во='||sql%rowcount);
--            
--        commit;
--        return 'done';
    else
        return 'cant change';   
    end if;
exception
    when others then rollback; return 'fail';
end;

function change_cont_add_info(
    p_user_id       number,
    p_cont_number   varchar2, 
    p_freight_name  varchar2,
    p_weight_dep    varchar2,
    p_owner         varchar2)
return varchar2
as
    l_function              varchar2(50) := 'change_cont_add_info';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    
    l_add_info_id_new       number;
    l_add_info_id_old       number;
    l_add_info_type_old     varchar2(1);
    l_weight_dep            number;
    l_date_loading          date;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id||' '
                              ||'p_cont_number = '||p_cont_number||' '
                              ||'p_freight_name = '||p_freight_name||' '
                              ||'p_weight_dep = '||p_weight_dep||' '
                              ||'p_owner = '||p_owner);
    
    l_weight_dep := to_number(nvl(p_weight_dep,'0'),'999999999999999D999999999999999','NLS_NUMERIC_CHARACTERS = ''. '''); 
    log_new(l_log_id,l_function,'l_weight_dep = '||l_weight_dep);
    
        
    select add_info_id
          ,add_info_type
      into l_add_info_id_old
          ,l_add_info_type_old
      from xx_disl_cont_add_info info
     where 1=1
       and info.cont_round_id = return_last_cont_round(p_cont_number)
       and info.last_record = 'Y';
    log_new(l_log_id,l_function,'l_add_info_id_old = '||l_add_info_id_old||' '||'l_add_info_type_old = '||l_add_info_type_old);
       
    if (l_add_info_type_old='A' or l_add_info_type_old='M') then
        l_add_info_id_new := xx_disl_cont_add_info_seq.nextval();
        
        insert into xx_disl_cont_add_info
        select l_add_info_id_new
              ,old_info.cont_round_id
              ,old_info.cont_number
              ,old_info.status
              ,p_freight_name
              ,old_info.weight_net
              ,l_weight_dep
              ,p_owner
              ,'M'
              ,'Y'
              ,sysdate
              ,p_user_id
              ,old_info.need_load_cont_info
              ,null
              ,null
              ,sysdate
              ,null
          from xx_disl_cont_add_info old_info
         where 1=1
           and add_info_id = l_add_info_id_old;
        log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info Кол-во='||sql%rowcount);
            
        update xx_disl_cont_add_info 
           set last_record = 'N'
              ,date_end = sysdate
         where 1=1
           and add_info_id = l_add_info_id_old;
        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info Кол-во='||sql%rowcount);
            
        commit;
        return 'done';
--    elsif (l_add_info_type_old='M') then
--        update xx_disl_railcar_add_info 
--           set car_type = p_car_type
--              ,freight_name = p_freight_name
--              ,weight_dep = l_weight_dep
--              ,owner = p_owner
--              ,last_update_date = sysdate
--              ,last_update_user_id = p_user_id
--         where 1=1
--           and add_info_id = l_add_info_id_old
--        ;
--        log_new(l_log_id,l_function,'update xx_disl_railcar_add_info Кол-во='||sql%rowcount);
--            
--        commit;
--        return 'done';
    else
        return 'cant change';   
    end if;
exception
    when others then rollback; return 'fail';
end;

procedure update_railcars_add_info(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as
    l_count number;
    l_function              varchar2(50) := 'update_railcars_add_info';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
begin
    dbms_output.put_line('1 '||to_char(sysdate,'dd.mm.yyyy hh24:mi:ss'));
    for l_tmp in (
        select r.round_id         round_id
              ,r.railcar_id       railcar_id 
              ,max(invoice_id)    invoice_id
          from xx_etw.xx_disl_round      r
              ,xx_etw.xx_disl_round_inv  ri
              ,xx_etw.xx_disl_station_history sh
         where 1=1
           and r.round_id = ri.round_id
           and r.station_hist_id_out is null
                     
           and invoice_id is not null
                     
           and r.station_hist_id_in = sh.station_hist_id
           and sh.in_date is not null
         group by 
               r.round_id
              ,r.railcar_id)
    loop
        select count('x')   
          into l_count
          from (select etw.invoice_id
                      ,disl.invoice_id
                  from (
                        select /*+ INDEX(ei ETW_INVOICE_N13) */
                               ei.invoice_id
                          from xx_etw.etw_invoice               ei
                              ,xx_etw.etw_inv_car               ecar
                              ,(select  front_end_id
                                      ,spc_custom_text 
                                  from xx_etw.etw_inv_spc 
                                 where    spc_transp_clause_id = 975 
                                    or (    spc_transp_clause_id = 993 
                                        and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                                       )
                               ) 
                                                                eis
                              ,xx_etw.etw_invoice               ei_arrive
                         where 1=1
                           and l_tmp.invoice_id = ei_arrive.invoice_id
                         
                           and ei.invoice_id not in (610042293,636927248,648761882,659079932) /*не верно введенная накладная, позже той по которой прибыл вагон*/
                           and coalesce( ecar.car_number
                                        ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                        ,'Нет отметки'
                                       ) = l_tmp.railcar_id
                           /**** change KuchukbaevRF 24.10.2018 разбил условие на два юниона для ускорения****/
                           and (    coalesce(ei.inv_fact_date_to_load,ei.inv_date_ready,ei_arrive.inv_date_arrive-1) > ei_arrive.inv_date_arrive
--                                or
--                                    (    ei.inv_date_create > ei_arrive.inv_date_arrive 
--                                     and ei.invoice_state_id = 31 /*Приемосдатчиком принято*/ 
--                                     and ei.inv_to_country_code != '643'/*Россия*/
--                                     and exists (
--                                         select 'x'
--                                           from xx_etw.xx_disl_shop_info
--                                          where 1=1
--                                            and round_id = l_tmp.round_id
--                                            and date_end is not null
--                                         )
--                                    )
                               )
                                                 
                           and ei.front_end_id = ecar.front_end_id(+)
                           and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                           
                           and ei.front_end_id = eis.front_end_id(+)
                                                 
                           and ei.inv_date_create > to_date ('01.01.2018', 'dd.mm.rrrr')
                           and ei.inv_recip_name <> 'ОАО "Метафракс"'
                           and lower(ei.inv_from_station_name) = 'углеуральская'
                           and ei.inv_number is not null
                           and ei.invoice_state_id not in (89,1,440) /*Испорчен, Заготовка, Отказ в согласовании*/
                           
                           and ei.inv_date_create >= add_months(sysdate,-6)
                     union all
                        select /*+ INDEX(ei ETW_INVOICE_N13) */
                               ei.invoice_id
                          from xx_etw.etw_invoice               ei
                              ,xx_etw.etw_inv_car               ecar
                              ,(select  front_end_id
                                      ,spc_custom_text 
                                  from xx_etw.etw_inv_spc 
                                 where    spc_transp_clause_id = 975 
                                    or (    spc_transp_clause_id = 993 
                                        and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                                       )
                               ) 
                                                                eis
                              ,xx_etw.etw_invoice               ei_arrive
                         where 1=1
                           and l_tmp.invoice_id = ei_arrive.invoice_id
                         
                           and ei.invoice_id not in (610042293,636927248,648761882,659079932) /*не верно введенная накладная, позже той по которой прибыл вагон*/
                           and coalesce( ecar.car_number
                                        ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                        ,'Нет отметки'
                                       ) = l_tmp.railcar_id
                           and (    
--                                    coalesce(ei.inv_fact_date_to_load,ei.inv_date_ready,ei_arrive.inv_date_arrive-1) > ei_arrive.inv_date_arrive
--                                or
                                    (    ei.inv_date_create > ei_arrive.inv_date_arrive 
                                     and ei.invoice_state_id = 31 /*Приемосдатчиком принято*/ 
                                     and ei.inv_to_country_code != '643'/*Россия*/
                                     and exists (
                                         select 'x'
                                           from xx_etw.xx_disl_shop_info
                                          where 1=1
                                            and round_id = l_tmp.round_id
                                            and date_end is not null
                                         )
                                    )
                               )
                                                 
                           and ei.front_end_id = ecar.front_end_id(+)
                           and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                           
                           and ei.front_end_id = eis.front_end_id(+)
                                                 
                           and ei.inv_date_create > to_date ('01.01.2018', 'dd.mm.rrrr')
                           and ei.inv_recip_name <> 'ОАО "Метафракс"'
                           and lower(ei.inv_from_station_name) = 'углеуральская'
                           and ei.inv_number is not null
                           and ei.invoice_state_id not in (89,1,440) /*Испорчен, Заготовка, Отказ в согласовании*/
                           and ei.inv_date_create >= add_months(sysdate,-6)
                       )
                            etw
                       full join
                       (select aiv.invoice_id
                          from xx_etw.xx_disl_railcar_add_info        ai
                              ,xx_etw.xx_disl_railcar_add_info_inv    aiv
                         where 1=1
                           and ai.round_id = l_tmp.round_id
                           and add_info_type in ('S','T')
                           and ai.last_record = 'Y'
                           and ai.add_info_id = aiv.add_info_id
                       )
                            disl
                       on etw.invoice_id = disl.invoice_id
                 where 1=1
                   and (   (etw.invoice_id is not null and disl.invoice_id is null)
                        or (etw.invoice_id is null and disl.invoice_id is not null)
                       )
               ) 
        ;
        if (l_count!=0) then
            dbms_output.put_line('****1 '||to_char(sysdate,'dd.mm.yyyy hh24:mi:ss'));
            log_new(l_log_id,l_function,'fill_railcar_add_info: p_round_id = '||l_tmp.round_id||' S');
            
            fill_railcar_add_info(l_tmp.round_id,'S'); 
            dbms_output.put_line('****1 '||to_char(sysdate,'dd.mm.yyyy hh24:mi:ss'));
            commit;
        end if;  
    end loop;
    dbms_output.put_line('2 '||to_char(sysdate,'dd.mm.yyyy hh24:mi:ss'));
    /*Случай: вагон отправили к нам по одним накладным, в процессе езды накладные изменили => ловим такие случаи и изменяем данные*/
    for l_tmp in (select r.round_id         round_id
                        ,r.railcar_id       railcar_id 
                    from xx_etw.xx_disl_round               r
                        ,xx_etw.xx_disl_station_history     sh
                        ,xx_etw.xx_disl_railcar_add_info    rai
                   where 1=1
                     and r.station_hist_id_out is null
                     
                     and r.station_hist_id_in = sh.station_hist_id
                     and sh.in_date is null
                     
                     and r.round_id = rai.round_id
                     and rai.last_record = 'Y'
                     and rai.add_info_type = 'A'    
                     order by  r.round_id                
                 )
    loop
        select count('x')   
          into l_count
          from (select etw.invoice_id
                      ,disl.invoice_id
                  from (select ei.*
                              ,count('x') over()      cnt
                          from xx_etw.etw_invoice              ei
                              ,xx_etw.etw_inv_car              ecar
                              ,(select front_end_id
                                      ,spc_custom_text 
                                  from xx_etw.etw_inv_spc 
                                 where spc_transp_clause_id = 975 
                                    or (    spc_transp_clause_id = 993 
                                        and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                                       )
                               ) 
                                                               eis
                              ,xx_etw.xx_disl_inv_car          disl_car
                         where  1=1
                               and ei.front_end_id = ecar.front_end_id(+)
                               and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                               
                               and ei.front_end_id = eis.front_end_id(+)
                               and ei.invoice_id = disl_car.invoice_id(+)
                                   
                               and coalesce(ecar.car_number
                                           ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                           ,disl_car.car_number
                                           ,'Нет отметки'
                                           ) = l_tmp.railcar_id 

                               --------------------------------------
                               and ei.invoice_state in ('Груз принят к перевозке',/*'Приемосдатчиком принято','Готов комплект документов','Согласование уведомления',*/'В пути')
                               and lower(ei.inv_to_station_name) = 'углеуральская'
                                   
                               and ei.inv_date_create >= add_months(sysdate,-6)
                       )
                            etw
                       full join
                       (select ri.invoice_id
                          from xx_etw.xx_disl_round_inv         ri
                         where 1=1
                           and ri.round_id = l_tmp.round_id
                       )
                            disl
                       on etw.invoice_id = disl.invoice_id
                 where 1=1
                   and (   (etw.invoice_id is not null and disl.invoice_id is null)
                        or (etw.invoice_id is null and etw.cnt != 0 and disl.invoice_id is not null)
                       )
               ) 
        ;
        if (l_count!=0) then
            log_new(l_log_id,l_function,'fill_railcar_add_info: p_round_id = '||l_tmp.round_id||' A');
            fill_railcar_add_info(l_tmp.round_id,'A');
            commit;
        end if;  
    end loop;                  
    dbms_output.put_line('3 '||to_char(sysdate,'dd.mm.yyyy hh24:mi:ss'));
exception 
  when others then 
    rollback;
    p_retcode:='2';
    p_errbuf:=sqlerrm;
end; 

-- add 28.11.2024 не используется, переписал на return_user_data_new
function return_user_data(p_login varchar2)
return t_xx_user_table pipelined
as
    l_row   t_xx_user_row;
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval();
    l_function                  varchar2(100):='return_user_data';
begin
    for tmp in (select  du.id                               user_id
                       ,du.full_name
                       ,du.password
                       ,du.flag_change_pwd
                       ,du.enterprise
                       ,nvl(cr.administrator,'N')           administrator
                       ,nvl(moving_inside_railway,'N')      moving_inside_railway
                       ,nvl(moving_inside_shop,'N')         moving_inside_shop
                       ,nvl(moving_inside_station,'N')      moving_inside_station
                       ,nvl(moving_between_station,'N')     moving_between_station
                       ,nvl(change_attribute,'N')           change_attribute
                       ,nvl(change_weight,'N')              change_weight
                       ,nvl(enter_inspection,'N')           enter_inspection
                       ,nvl(enter_inspection_add,'N')       enter_inspection_add
                       ,nvl(enter_dev_inspection,'N')       enter_dev_inspection
                       ,nvl(register_notification,'N')      register_notification
                       ,nvl(entry_foreign_car,'N')          entry_foreign_car
                       ,nvl(receive_to_station,'N')         receive_to_station
                       ,nvl(work_with_groups,'N')           work_with_groups
                       ,nvl(out_from_ugl,'N')               out_from_ugl
                       ,nvl(add_attribute,'N')              add_attribute
                       ,nvl(create_request,'N')             create_request
                       ,nvl(change_request,'N')             change_request
                       ,nvl(view_request,'N')               view_request
                       ,nvl(complete_request,'N')           complete_request
                       ,nvl(del_ins_doc,'N')                del_ins_doc
                       ,nvl(return_from_psp,'N')            return_from_psp
                       ,nvl(autocreate_request_v,'N')       autocreate_request_v
                       ,nvl(autocreate_request_o,'N')       autocreate_request_o
                       ,nvl(autocreate_request_t,'N')       autocreate_request_t
                       ,nvl(weigh_import,'N')               weigh_import
                       ,nvl(weigh_import_corr,'N')          weigh_import_corr
                       ,nvl(weigh_delete,'N')               weigh_delete
                       ,nvl(export_shop_info,'N')           export_shop_info
                       ,nvl(create_invoice_out,'N')         create_invoice_out
                       ,nvl(send_invoice_to_etran,'N')      send_invoice_to_etran
                       ,nvl(register_notification_gu,'N')   register_notification_gu
                       ,nvl(route_add,'N')                  route_add
                       ,nvl(route_processing,'N')           route_processing
                       ,nvl(route_closing,'N')              route_closing
                       ,nvl(output_defective_cars,'N')      output_defective_cars
                       ,nvl(export_notification_gu,'N')     export_notification_gu
                       ,nvl(fix_dev_rule,'N')               fix_dev_rule
                       ,nvl(fix_dev_place,'N')              fix_dev_place
                       ,nvl(fix_dev_add,'N')                fix_dev_add
                       ,nvl(fix_dev_undock,'N')             fix_dev_undock
                       ,nvl(fix_dev_update,'N')             fix_dev_update
                       ,nvl(shift_update,'N')               shift_update
                       ,nvl(control_cars,'N')               control_cars
                       
                       ,nvl(weighing_dispatcher,'N')        weighing_dispatcher-- Диспетчер взвешивания
                       ,nvl(process_of_wagons,'N')          process_of_wagons-- Обработка вагонов
                       ,nvl(update_of_nsi,'N')              update_of_nsi-- Обновление НСИ вагонов
                       ,nvl(scale_type_1831_manual,'N')     scale_type_1831_manual-- Ручное взвешивание АКМ
                       ,nvl(export_samples,'N')             export_samples-- Создание проб в OeBS
                       ,nvl(entry_foreign_cont,'N')         entry_foreign_cont-- Ручной ввод контейнеров
                       
                       
                  from  xx_disl_users       du
                       ,(select user_id
                               ,max(nvl(administrator,'N'))             administrator
                               ,max(nvl(moving_inside_railway,'N'))     moving_inside_railway
                               ,max(nvl(moving_inside_shop,'N'))        moving_inside_shop
                               ,max(nvl(moving_inside_station,'N'))     moving_inside_station
                               ,max(nvl(moving_between_station,'N'))    moving_between_station
                               ,max(nvl(change_attribute,'N'))          change_attribute
                               ,max(nvl(change_weight,'N'))             change_weight
                               ,max(nvl(enter_inspection,'N'))          enter_inspection
                               ,max(nvl(enter_dev_inspection,'N'))      enter_dev_inspection
                               ,max(nvl(enter_inspection_add,'N'))      enter_inspection_add
                               ,max(nvl(register_notification,'N'))     register_notification
                               ,max(nvl(entry_foreign_car,'N'))         entry_foreign_car
                               ,max(nvl(receive_to_station,'N'))        receive_to_station
                               ,max(nvl(work_with_groups,'N'))          work_with_groups
                               ,max(nvl(out_from_ugl,'N'))              out_from_ugl
                               ,max(nvl(add_attribute,'N'))             add_attribute
                               ,max(nvl(create_request,'N'))            create_request
                               ,max(nvl(change_request,'N'))            change_request
                               ,max(nvl(view_request,'N'))              view_request
                               ,max(nvl(complete_request,'N'))          complete_request
                               ,max(nvl(del_ins_doc,'N'))               del_ins_doc
                               ,max(nvl(return_from_psp,'N'))           return_from_psp
                               ,max(nvl(autocreate_request_v,'N'))      autocreate_request_v
                               ,max(nvl(autocreate_request_o,'N'))      autocreate_request_o
                               ,max(nvl(autocreate_request_t,'N'))      autocreate_request_t
                               ,max(nvl(weigh_import,'N'))              weigh_import
                               ,max(nvl(weigh_import_corr,'N'))         weigh_import_corr
                               ,max(nvl(weigh_delete,'N'))              weigh_delete
                               ,max(nvl(export_shop_info,'N'))          export_shop_info
                               ,max(nvl(create_invoice_out,'N'))        create_invoice_out
                               ,max(nvl(send_invoice_to_etran,'N'))     send_invoice_to_etran
                               ,max(nvl(register_notification_gu,'N'))  register_notification_gu
                               ,max(nvl(route_add,'N'))                 route_add
                               ,max(nvl(route_processing,'N'))          route_processing
                               ,max(nvl(route_closing,'N'))             route_closing
                               ,max(nvl(output_defective_cars,'N'))     output_defective_cars
                               ,max(nvl(export_notification_gu,'N'))    export_notification_gu
                               ,max(nvl(fix_dev_rule,'N'))              fix_dev_rule
                               ,max(nvl(fix_dev_place,'N'))             fix_dev_place
                               ,max(nvl(fix_dev_add,'N'))               fix_dev_add
                               ,max(nvl(fix_dev_undock,'N'))            fix_dev_undock
                               ,max(nvl(fix_dev_update,'N'))            fix_dev_update
                               ,max(nvl(shift_update,'N'))              shift_update
                               ,max(nvl(control_cars,'N'))              control_cars
                               ,max(nvl(weighing_dispatcher,'N'))       weighing_dispatcher-- Диспетчер взвешивания
                               ,max(nvl(process_of_wagons,'N'))         process_of_wagons-- Обработка вагонов
                               ,max(nvl(update_of_nsi,'N'))             update_of_nsi-- Обновление НСИ вагонов
                               ,max(nvl(scale_type_1831_manual,'N'))    scale_type_1831_manual-- Ручное взвешивание с весов корп.1831 (карбамид)
                               ,max(nvl(export_samples,'N'))            export_samples-- Создание проб в OeBS
                               ,max(nvl(entry_foreign_cont,'N'))        entry_foreign_cont-- Ручной ввод контейнеров
                               
                               
                           from xx_disl_user_credential uc
                               ,xx_disl_credential      c
                          where 1=1
                            and uc.credential_id = c.credential_id
                          group by
                                user_id
                        )
                                            cr
                 where     1 = 1
                       and login = upper(p_login)
                       and du.id = cr.user_id(+)
                       and du.open = 'Y'
                       
               )
    loop
        l_row.user_id := tmp.user_id;
        l_row.full_name := tmp.full_name;
        l_row.password := tmp.password;
        l_row.flag_change_pwd := tmp.flag_change_pwd;
        l_row.enterprise := tmp.enterprise;
        l_row.administrator := tmp.administrator;
        
        l_row.moving_inside_railway := tmp.moving_inside_railway;
        l_row.moving_inside_shop := tmp.moving_inside_shop;
        l_row.moving_inside_station := tmp.moving_inside_station;
        l_row.moving_between_station := tmp.moving_between_station;
        l_row.change_attribute := tmp.change_attribute;
        l_row.change_weight := tmp.change_weight;
        l_row.enter_inspection := tmp.enter_inspection;
        l_row.enter_dev_inspection := tmp.enter_dev_inspection;
        l_row.enter_inspection_add := tmp.enter_inspection_add;
        l_row.register_notification := tmp.register_notification;
        l_row.entry_foreign_car := tmp.entry_foreign_car;
        l_row.receive_to_station := tmp.receive_to_station;
        l_row.work_with_groups := tmp.work_with_groups;
        l_row.out_from_ugl := tmp.out_from_ugl;
        l_row.add_attribute := tmp.add_attribute;
        l_row.create_request := tmp.create_request;
        l_row.change_request := tmp.change_request;
        l_row.view_request := tmp.view_request;
        l_row.complete_request := tmp.complete_request;
        l_row.del_ins_doc := tmp.del_ins_doc;
        l_row.return_from_psp := tmp.return_from_psp;
        l_row.autocreate_request_v := tmp.autocreate_request_v;
        l_row.autocreate_request_o := tmp.autocreate_request_o;
        l_row.autocreate_request_t := tmp.autocreate_request_t;
        l_row.weigh_import := tmp.weigh_import;
        l_row.weigh_import_corr := tmp.weigh_import_corr;
        l_row.weigh_delete := tmp.weigh_delete;
        l_row.export_shop_info := tmp.export_shop_info;
        l_row.create_invoice_out := tmp.create_invoice_out;
        l_row.send_invoice_to_etran := tmp.send_invoice_to_etran;
        l_row.register_notification_gu := tmp.register_notification_gu;
        
        l_row.route_add := tmp.route_add;
        l_row.route_processing := tmp.route_processing;
        l_row.route_closing := tmp.route_closing;
        
        l_row.output_defective_cars := tmp.output_defective_cars;
        l_row.export_notification_gu := tmp.export_notification_gu;
        l_row.fix_dev_rule := tmp.fix_dev_rule;
        l_row.fix_dev_place := tmp.fix_dev_place;
        
        l_row.fix_dev_add := tmp.fix_dev_add;
        l_row.fix_dev_undock := tmp.fix_dev_undock;
        l_row.fix_dev_update := tmp.fix_dev_update;
        l_row.shift_update := tmp.shift_update;
        l_row.control_cars := tmp.control_cars;
        l_row.weighing_dispatcher := tmp.weighing_dispatcher;
        l_row.process_of_wagons := tmp.process_of_wagons;
        
        l_row.update_of_nsi := tmp.update_of_nsi;
        l_row.scale_type_1831_manual := tmp.scale_type_1831_manual;
        l_row.export_samples := tmp.export_samples;
        l_row.entry_foreign_cont := tmp.entry_foreign_cont;
        
        
        
        log_new(l_log_id,l_function,'return_user_data: tmp.user_id = '||tmp.user_id);
        log_new(l_log_id,l_function,'return_user_data: tmp.full_name = '||tmp.full_name);
        log_new(l_log_id,l_function,'return_user_data: tmp.password = '||tmp.password);
        log_new(l_log_id,l_function,'return_user_data: tmp.flag_change_pwd = '||tmp.flag_change_pwd);
        pipe row (l_row);
    end loop;
end;

function receive_into_station(
    p_user_id           number,
    p_car               varchar2, 
    p_new_parent_id     number,
    p_new_parent_type   varchar2,
    p_before_elem_id    number,
    p_before_elem_type  varchar2,
    p_dateFact          varchar2,
    p_comment           varchar2,
    p_wagon_list_id       number)
return varchar2
as
    l_function                  varchar2(100) := 'receive_into_station';
    l_curDate                   date;
    l_dateFact                  date;
    l_old_stat_hist_id          number := -1;
    l_new_stat_hist_id          number := -1;
    l_is_vodorazdel             varchar2(1) := 'N';
    l_railway_id                number;
    l_old_parent_id             varchar2(200);
    l_old_parent_type           varchar2(200);
    l_old_order                 number;
    l_order                     number;
    l_before_elem_order         number;
    l_new_parent_max_order      number;
    
    l_log_id                    number;
begin
    l_log_id := xx_disl_log_seq.nextval();
    
    log_new(l_log_id,l_function,'parameters: p_car = '||p_car||' p_new_parent_id = '||p_new_parent_id||' p_new_parent_type = '||p_new_parent_type||
                                ' p_before_elem_id = '||p_before_elem_id||' p_before_elem_type = '||p_before_elem_type||' p_wagon_list_id = '||p_wagon_list_id);
 
    /*порядок последнего элемента нового родителя*/
    l_new_parent_max_order:=returnMaxOrder(p_new_parent_id,p_new_parent_type,'Y');
    log_new(l_log_id,l_function,'l_new_parent_max_order = '||l_new_parent_max_order);
        
    /*порядок элемента после которого надо вставить элементы*/
    if (p_before_elem_id is null or p_before_elem_type is null) then
        l_before_elem_order:=null;   
    else
        select r_order
          into l_before_elem_order
          from xx_disl_relations
         where 1=1
           and id = p_before_elem_id
           and type = p_before_elem_type
           and parent_id = p_new_parent_id
           and parent_type = p_new_parent_type
           and flag_come = 'Y'
        ;
    end if;
    log_new(l_log_id,l_function,'l_before_elem_order = '||l_before_elem_order);
        
    /*ищем среди предков элемента станцию Водораздельную (id = 2)*/        
    begin       
        with notStation as (select *
                              from xx_disl_relations
                             where 1=1
                                   and flag_come = 'Y'                     
                           )
        select 'Y'
          into l_is_vodorazdel
          from notStation
         where 1=1
           and parent_id = '2' 
           and parent_type = 'station'
        connect by prior parent_id = id and prior parent_type = type
         start with id = to_char(p_new_parent_id) and type = p_new_parent_type
        ;
    exception
        when no_data_found then l_is_vodorazdel := 'N'; 
    end;
    log_new(l_log_id,l_function,'l_isVodorazdel = '||l_is_vodorazdel); 
        
    /*находим старого родителя и порядок в нем*/
    select parent_id
          ,parent_type
          ,r_order
      into l_old_parent_id
          ,l_old_parent_type
          ,l_old_order
      from xx_disl_relations
     where 1=1
       and id = p_car
       and type = 'railcar'
       and flag_come = 'N'
    ;
    log_new(l_log_id,l_function,'l_old_parent_id = '||l_old_parent_id||' l_old_parent_type = '||l_old_parent_type||' l_old_order = '||l_old_order);
        
    /*изменяем порядок среди элементов старого родителя*/ 
    update xx_disl_relations
       set r_order = r_order - 1
     where 1=1
       and parent_id = l_old_parent_id
       and parent_type = l_old_parent_type
       and flag_come = 'N'
       and r_order > l_old_order
    ;
    log_new(l_log_id,l_function,'update xx_disl_relations: '||sql%rowcount||' строк');
        
    /*если вагоны прибыли на Водораздельную с Углеуральской то они числятся как на подходе на Водораздельную так и стоящими на Углеуральской*/
    /*когда принимаем на Водораздельную то с Углеуральской надо удалить*/
    /*с мая 2016 этот код будет падать с ошибкой, т.к. вагоны с уведомлениями уже не числятся на Углях*/
    begin
        select parent_id
              ,parent_type
              ,r_order
          into l_old_parent_id
              ,l_old_parent_type
              ,l_old_order
          from xx_disl_relations
         where 1=1
           and id = p_car
           and type = 'railcar'
           and flag_come = 'Y'
        ;
        log_new(l_log_id,l_function,'l_old_parent_id = '||l_old_parent_id||' l_old_parent_type = '||l_old_parent_type||' l_old_order = '||l_old_order);
        
        /*изменяем порядок*/ 
        update xx_disl_relations
           set r_order = r_order - 1
         where 1=1
           and parent_id = l_old_parent_id
           and parent_type = l_old_parent_type
           and flag_come = 'Y'
           and r_order > l_old_order
        ;
        log_new(l_log_id,l_function,'update xx_disl_relations: '||sql%rowcount||' строк');
            
        delete 
          from xx_disl_relations
         where 1=1
           and id = p_car
           and type = 'railcar'
           and flag_come = 'Y'
        ;
        log_new(l_log_id,l_function,'delete xx_disl_relations: '||sql%rowcount||' строк');
    exception
        when others then null;
    end; 
    /*end для вагонов прибывших с Углеуральской*/
            
    /*находим порядок в новом родителе*/          
    if (l_before_elem_order is null) then 
        l_order:=l_new_parent_max_order+1;
    else
        l_order:=l_before_elem_order;
    end if;
    log_new(l_log_id,l_function,'l_order = '||l_order);
        
    /*изменяем порядок элементов в новом родителе*/        
    update xx_disl_relations
       set r_order = r_order + 1 
     where 1=1
       and parent_id = p_new_parent_id
       and parent_type = p_new_parent_type
       and r_order >= l_order
       and flag_come = 'Y'
    ;
    log_new(l_log_id,l_function,'update xx_disl_relations: '||sql%rowcount||' строк');
        
    /*ставим вагон на станцию под нового родителя*/       
    update xx_disl_relations
       set parent_id = p_new_parent_id
          ,parent_type = p_new_parent_type
          ,r_order = l_order
          ,flag_come = 'Y'
     where 1=1
       and id = p_car
       and type = 'railcar'
       and flag_come = 'N'
    ;                         
    log_new(l_log_id,l_function,'update xx_disl_relations: '||sql%rowcount||' строк');
                
    l_curDate := sysdate;
                
    begin
        l_dateFact := to_date(p_dateFact,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_dateFact := l_curDate;
    end;    
            
    /*Если принимаем на Водораздельную, то надо создать убытие из Углеуральской и создать запись отправки на Водораздельную*/
    /*т.к. на Углеуральской никто отправлять вагоны не будет*/
    /*эта логика работает частично после апреля 2017*/
    /*сейчас после операции "Возврат на ПСП" отправление создается*/
    if (l_is_vodorazdel = 'Y') then
        l_old_stat_hist_id := -1;
                    
        update xx_disl_station_history
           set out_date = l_curDate
              ,out_date_fact = l_dateFact
              ,out_user_id = p_user_id
              ,out_wagon_list_id = p_wagon_list_id 
         where 1=1
               and round_id = returnLastRound(p_car)
               and out_date is null
               and in_date is not null
               and station_id = 1
        returning station_hist_id into l_old_stat_hist_id 
        ;
        log_new(l_log_id,l_function,'обновили out_date для Углеуральской. Кол-во = ' || sql%rowcount || ' l_old_stat_hist_id = ' || l_old_stat_hist_id);      
              
        /*если update сделан значит вагон пришел c Углеуральской*/
        if (l_old_stat_hist_id!=-1) then 
            insert into xx_disl_station_history( station_hist_id
                                                ,round_id
                                                ,station_id
                                                ,come_date
                                                ,come_date_fact
                                                ,come_user_id
                                               )
            values( xx_disl_station_history_seq.nextval
                   ,returnLastRound(p_car)
                   ,2
                   ,l_curDate
                   ,l_dateFact
                   ,p_user_id
                  )
            ;
            log_new(l_log_id,l_function,'создали отправление на Водораздельную. Кол-во = ' || sql%rowcount);                      
        end if;
        
        /*для тех случаев когда вагон пришел повторно с ПСП*/
        update xx_disl_station_history
           set out_wagon_list_id = p_wagon_list_id 
         where 1=1
           and p_wagon_list_id is not null
           and station_hist_id = (
               select sh_prev.station_hist_id
                 from xx_disl_station_history   sh_cur
                     ,xx_disl_station_history   sh_prev
                where 1=1
                  and sh_cur.round_id = returnLastRound(p_car)
                  and sh_cur.station_id = 2
                  and sh_cur.in_date is null
                  and sh_cur.round_id = sh_prev.round_id
                  and sh_cur.come_date = sh_prev.out_date
           )
        ;             
    end if;
                
    update xx_disl_station_history
       set in_date = l_curDate
          ,in_date_fact = l_dateFact
          ,in_user_id = p_user_id
          ,in_comment = p_comment
     where 1=1
       and round_id = returnLastRound(p_car)
       and in_date is null
    returning station_hist_id into l_new_stat_hist_id
    ;
    log_new(l_log_id,l_function,'обновили дату прибытия на станцию. Кол-во = ' || sql%rowcount);        
                
    begin
        /*ищем среди предков элемента путь*/
        with notStation as (select *
                              from xx_disl_relations
                             where 1=1
                               and flag_come = 'Y'                     
                           )
       select id into l_railway_id
        from(
       select id
         from notStation
         where 1=1
           and type = 'railway'
        connect by prior parent_id = id and prior parent_type = type
         start with id = to_char(p_new_parent_id) and type = p_new_parent_type
         )
         where id = to_char(p_new_parent_id) -- add 19.05.2026 
        ;
    exception
        when no_data_found then l_railway_id := -1; 
    end;
    log_new(l_log_id,l_function,'l_railway_id = ' || l_railway_id);               
        
    if (l_railway_id!=-1) then        
        insert into xx_disl_railway_history(
            railway_hist_id
           ,station_hist_id
           ,railway_id,date_oper
           ,date_oper_fact
           ,user_id
           ,last_record)
        values (
            xx_disl_railway_history_seq.nextval
           ,l_new_stat_hist_id
           ,l_railway_id
           ,l_curDate
           ,l_dateFact
           ,p_user_id
           ,'Y')
        ;
        log_new(l_log_id,l_function,'Обновили историю по станциям. Кол-во = ' || sql%rowcount);
    end if;       
            
    return 'done';
exception
    when others then rollback; log_new(l_log_id,l_function,' Ошибка = '||sqlerrm); return 'fail';
end;

function receive_into_station_few_child(
    p_user_id           number,
    p_cars              varchar2, 
    p_new_parent_id     number,
    p_new_parent_type   varchar2, 
    p_bef_aft           varchar2, 
    p_after_elem_id     number,
    p_after_elem_type   varchar2,
    p_operation_date    varchar2,
    p_comment           varchar2,
    p_send_date         varchar2,
    p_train_num         varchar2,
    p_loco1_num         number,
    p_loco1_driver1     number,
    p_loco1_driver2     number,
    p_loco1_conductor   number,
    p_loco2_num         number,
    p_loco2_driver1     number,
    p_loco2_driver2     number,
    p_loco2_conductor   number
)
return varchar2
as
    l_function                      varchar2(100) := 'receive_into_station_few_child';
    l_log_id                        number;
    l_done                          boolean := true;
    l_new_parent_max_order          number;
    l_after_elem_order              number;
    l_before_elem_id                number; 
    l_before_elem_type              varchar2(200);

    l_send_date                     date;
    l_wagon_list_id                 number;
begin   
    l_log_id := xx_disl_log_seq.nextval();
    
    log_new(l_log_id,l_function,'parameters: p_cars = '|| p_cars||' p_new_parent_id = '||p_new_parent_id||' p_new_parent_type = '||p_new_parent_type||' p_bef_aft = '||p_bef_aft||
                                ' p_after_elem_id = '||p_after_elem_id||' p_after_elem_type = '||p_after_elem_type||' p_operation_date = '||p_operation_date||' p_comment = '||p_comment); 
    
    begin
        l_send_date := to_date(p_send_date,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_send_date := null;
    end;
        
    if (p_train_num is not null) then
        l_wagon_list_id:=xx_disl_wagon_lists_seq.nextval();
           
        insert into xx_disl_wagon_lists
        values(l_wagon_list_id
              ,1
              ,2
              ,l_send_date
              ,null
              ,null
              ,p_train_num
              ,p_loco1_num
              ,p_loco1_driver1
              ,p_loco1_driver2
              ,p_loco1_conductor
              ,p_loco2_num
              ,p_loco2_driver1
              ,p_loco2_driver2
              ,p_loco2_conductor
              ,p_user_id
              ,sysdate
              )
        ;
        log_new(l_log_id,l_function,'l_wagon_list_id = '||l_wagon_list_id);
    end if;
    
    /*порядок последнего элемента нового родителя*/
    l_new_parent_max_order:=returnMaxOrder(p_new_parent_id,p_new_parent_type,'Y');
    log_new(l_log_id,l_function,'l_new_parent_max_order = '||l_new_parent_max_order);
       
    if (p_after_elem_id is null or p_after_elem_type is null) then
        l_before_elem_id:=null;  
        l_before_elem_type:=null;
        log_new(l_log_id,l_function,'l_before_elem_id = null; l_before_elem_type = null');
    else
        select r_order
          into l_after_elem_order
          from xx_disl_relations
         where 1=1
           and id = p_after_elem_id
           and type = p_after_elem_type
           and parent_id = p_new_parent_id
           and parent_type = p_new_parent_type
           and flag_come = 'Y'
        ;
        log_new(l_log_id,l_function,'l_after_elem_order = '||l_after_elem_order);    
        
        if (p_bef_aft='after') then 
            if l_after_elem_order=l_new_parent_max_order then
                l_before_elem_id:=null;  
                l_before_elem_type:=null;
                log_new(l_log_id,l_function,'l_before_elem_id = null; l_before_elem_type = null'); 
            else
                select id,type
                  into l_before_elem_id,l_before_elem_type
                  from xx_disl_relations
                 where 1=1
                   and parent_id = p_new_parent_id
                   and parent_type = p_new_parent_type
                   and r_order = l_after_elem_order+1
                   and flag_come = 'Y'
                ;
                log_new(l_log_id,l_function,'l_before_elem_id = '||l_before_elem_id||' l_before_elem_type = '||l_before_elem_type); 
            end if;
        else
            select id,type
              into l_before_elem_id,l_before_elem_type
              from xx_disl_relations
             where 1=1
               and parent_id = p_new_parent_id
               and parent_type = p_new_parent_type
               and r_order = l_after_elem_order
               and flag_come = 'Y'
            ;
            log_new(l_log_id,l_function,'l_before_elem_id = '||l_before_elem_id||' l_before_elem_type = '||l_before_elem_type);
        end if;
    end if; 
    
    for tmp in (select regexp_substr(p_cars,'[^|]+',1,level) car_number
                  from dual
               connect by level <= regexp_count(p_cars,'[^|]+')
               )
    loop
        log_new(l_log_id,l_function,'call receive_into_station('||p_user_id||','
                                                                ||tmp.car_number||','
                                                                ||p_new_parent_id||','
                                                                ||p_new_parent_type||','
                                                                ||l_before_elem_id||','
                                                                ||l_before_elem_type||','
                                                                ||p_operation_date||','
                                                                ||p_comment||','
                                                                ||l_wagon_list_id
                                                                );  
        
        if (receive_into_station(p_user_id,tmp.car_number,p_new_parent_id,p_new_parent_type,l_before_elem_id,l_before_elem_type,p_operation_date,p_comment,l_wagon_list_id)!='done') then
            l_done := false;
            log_new(l_log_id,l_function,'l_done=N');
        end if; 
    end loop;
        
    if l_done then
        commit;
        log_new(l_log_id,l_function,'done');
        return 'done';
    else
        rollback;
        return 'fail';
    end if;
exception
    when others then rollback; return 'fail';
end;

function get_coming_cars(p_station_id number)
return t_xx_car_numbers pipelined
as
    l_row xx_disl_round.railcar_id%type;
begin
    for l_tmp in (with tree as (select rel.id
                                  from (select *
                                          from xx_disl_relations
                                         where 1=1
                                           and flag_come = 'N'
                                       )
                                                             rel
                                 where 1=1
                                   and type = 'railcar'
                                connect by prior id = parent_id and prior type = parent_type
                                 start with parent_id = p_station_id and parent_type = 'station'
                               )
                  select tree.id
                    from tree
                        ,xx_disl_round                r
                        ,xx_disl_station_history      sh
                   where 1=1
                     and tree.id = r.railcar_id
                     and station_hist_id_out is null
                     
                     and r.round_id = sh.round_id
                     and sh.out_date is null
                     
                     and (   (p_station_id != 2)
                          or
                             (    p_station_id = 2
                              and (   r.notification_id is not null
                                   or r.station_hist_id_in != sh.station_hist_id   
                                  )
                             )
                         )
                   order by
                         tree.id
                 )
    loop
        l_row := l_tmp.id;
        pipe row (l_row);
    end loop;
end;

function getNextStations(p_stationId number)
return t_xx_station_table pipelined
as
    l_row t_xx_station_row;
begin
    for tmp in (select  st.station_id
                       ,st.name 
                  from  xx_disl_next_station    ns
                       ,xx_disl_stations        st
                 where 1=1
                       and ns.next_station_id = st.station_id
                       and ns.station_id = p_stationId
               )
    loop
        l_row.id := tmp.station_id;
        l_row.name := tmp.name;

        pipe row (l_row);
    end loop;
end;

function send_to_station(p_user_id number,p_car_id varchar2,p_dest_station_id number,p_wagon_list_id number,p_send_date date,p_reason varchar2)
return varchar2
as
    l_function              varchar2(100):='send_to_station';
    l_log_id                number := xx_disl_log_seq.nextval();
    
    l_max_order             number;
    l_cur_time              date;
    l_parent_id             varchar2(100);
    l_parent_type           varchar2(100);
    l_order                 number;
    
    l_new_parent_id         number;
    l_new_parent_type       varchar2(100);
    
    l_train_num             varchar2(10);
    l_bandwagon_name        varchar2(100);
    l_bandwagon_id          number;
    
    l_parent_bandwagon_id   number;
    l_car_owner             varchar2(100);
    
begin   
    
    log_new(l_log_id,l_function,'parameters: p_user_id = '|| p_user_id
                                         ||' p_car_id = '||p_car_id
                                         ||' p_dest_station_id = '||p_dest_station_id
                                         ||' p_wagon_list_id = '||p_wagon_list_id
                                         ||' p_send_date = '||p_send_date
                                         ||' p_reason = '||p_reason); 
 
    begin
        select train_num
          into l_train_num
          from xx_disl_wagon_lists
         where 1=1
           and wagon_list_id = p_wagon_list_id
        ;
    exception
        when others then l_train_num := null;  
    end;
    
    log_new(l_log_id,l_function,'l_train_num = '||l_train_num);

    if (p_dest_station_id = 1) then
        begin
            select owner
              into l_car_owner
              from xx_disl_railcar_add_info
             where 1=1
               and round_id = returnlastround(p_car_id)
               and last_record = 'Y'
            ;
        exception
            when others then l_car_owner := ''; 
        end;
        log_new(l_log_id,l_function,'l_car_owner = '||l_car_owner);
        
            
        l_parent_bandwagon_id := case 
                                   when l_car_owner = 'МТФ'
                                     then -2
                                   when l_car_owner = 'МД'
                                     then -3
                                   else -4
                                 end;
        log_new(l_log_id,l_function,'l_parent_bandwagon_id = '||l_parent_bandwagon_id);
        
        if (l_train_num is not null or p_send_date is not null) then
            l_bandwagon_name := case
                                  when l_train_num is null
                                    then to_char(p_send_date,'dd.mm.yyyy')
                                  else l_train_num||' '||to_char(p_send_date,'dd.mm.yyyy')
                                end;  
            log_new(l_log_id,l_function,'l_bandwagon_name = '||l_bandwagon_name);
                                     
            begin
                select rel.id
                  into l_bandwagon_id
                  from xx_disl_relations        rel
                      ,xx_disl_bandwagon        b
                 where 1=1
                   and rel.parent_id = l_parent_bandwagon_id
                   and rel.parent_type = 'bandwagon'
                   and rel.flag_come = 'N'
                   and rel.type = 'bandwagon'
                   
                   and rel.id = b.bandwagon_id
                   and b.name = l_bandwagon_name
                ; 
            exception
                when others then l_bandwagon_id := null;
            end;
            log_new(l_log_id,l_function,'l_bandwagon_id = '||l_bandwagon_id);     
            
            if (l_bandwagon_id is null) then 
                insert into xx_disl_bandwagon
                values (xx_disl_bandwagon_seq.nextval,l_bandwagon_name)
                returning bandwagon_id into l_bandwagon_id
                ;
                log_new(l_log_id,l_function,'insert into xx_disl_bandwagon. rowcount = '||sql%rowcount||' l_bandwagon_id = '||l_bandwagon_id);
                
                l_order := returnMaxOrder(l_parent_bandwagon_id,'bandwagon','N')+1;
                log_new(l_log_id,l_function,'l_order = '||l_order);
                    
                insert into xx_disl_relations
                values ( l_bandwagon_id
                        ,'bandwagon'
                        ,l_parent_bandwagon_id
                        ,'bandwagon'
                        ,l_order
                        ,'N'
                       )
                ;
                log_new(l_log_id,l_function,'insert into xx_disl_relations. rowcount = '||sql%rowcount);
            end if;
        end if;
        
        if (l_bandwagon_id is not null) then
            l_new_parent_id := l_bandwagon_id;           
            l_new_parent_type := 'bandwagon';           
        else
            l_new_parent_id := l_parent_bandwagon_id;           
            l_new_parent_type := 'bandwagon';   
        end if; 
        log_new(l_log_id,l_function,'l_new_parent_id = '||l_new_parent_id||' l_new_parent_type = '||l_new_parent_type);  
    else 
        if (l_train_num is not null or p_send_date is not null) then  
            l_bandwagon_name := case
                                  when l_train_num is null
                                    then to_char(p_send_date,'dd.mm.yyyy')
                                  else l_train_num||' '||to_char(p_send_date,'dd.mm.yyyy')
                                end;
            log_new(l_log_id,l_function,'l_bandwagon_name = '||l_bandwagon_name);
            
            begin
                select rel.id
                  into l_bandwagon_id
                  from xx_disl_relations        rel
                      ,xx_disl_bandwagon        b
                 where 1=1
                   and rel.parent_id = p_dest_station_id 
                   and rel.parent_type = 'station'
                   and rel.flag_come = 'N'
                   and rel.type = 'bandwagon'
                   
                   and rel.id = b.bandwagon_id
                   and b.name = l_bandwagon_name
                ; 
            exception
                when others then l_bandwagon_id := null;
            end;  
            log_new(l_log_id,l_function,'l_bandwagon_id = '||l_bandwagon_id);
            
            if (l_bandwagon_id is null) then 
                insert into xx_disl_bandwagon
                values (xx_disl_bandwagon_seq.nextval,l_bandwagon_name)
                returning bandwagon_id into l_bandwagon_id
                ;
                log_new(l_log_id,l_function,'insert into xx_disl_bandwagon. rowcount = '||sql%rowcount||' l_bandwagon_id = '||l_bandwagon_id);
                
                l_order := returnMaxOrder(p_dest_station_id,'station','N')+1;
                log_new(l_log_id,l_function,'l_order = '||l_order);
                    
                insert into xx_disl_relations
                values ( l_bandwagon_id
                        ,'bandwagon'
                        ,p_dest_station_id
                        ,'station'
                        ,l_order
                        ,'N'
                       )
                ;
                log_new(l_log_id,l_function,'insert into xx_disl_relations. rowcount = '||sql%rowcount);
            end if;   
        end if;
        
        if (l_bandwagon_id is not null) then
            l_new_parent_id := l_bandwagon_id;           
            l_new_parent_type := 'bandwagon';           
        else
            l_new_parent_id := p_dest_station_id;           
            l_new_parent_type := 'station';   
        end if;
        log_new(l_log_id,l_function,'l_new_parent_id = '||l_new_parent_id||' l_new_parent_type = '||l_new_parent_type);  
    end if;
    

 
    select parent_id
          ,parent_type
          ,r_order
      into l_parent_id
          ,l_parent_type
          ,l_order
      from xx_disl_relations
     where 1=1
       and id = p_car_id
       and type = 'railcar'
       and flag_come = 'Y'
    ;
    /*изменяем порядок*/
    update xx_disl_relations
       set r_order = r_order - 1
     where 1=1
       and parent_id = l_parent_id
       and parent_type = l_parent_type
       and flag_come = 'Y'
       and r_order > l_order
    ;
   /*изменяем родителя для выбранного элемента на нового*/
    l_order := returnMaxOrder(l_new_parent_id,l_new_parent_type,'N')+1;
    update xx_disl_relations
       set parent_id = l_new_parent_id
          ,parent_type = l_new_parent_type
          ,r_order = l_order
          ,flag_come = 'N'
     where 1=1
       and id = p_car_id
       and type = 'railcar'
       and flag_come = 'Y'
    ;
                
    /*устанавливаем для вагонов время отправки со старой станции и время отправки на новую станцию*/
    l_cur_time := sysdate;
                
    update xx_disl_station_history
       set out_date = l_cur_time
          ,out_date_fact = p_send_date
          ,out_user_id = p_user_id
          ,out_comment = p_reason
          ,out_wagon_list_id = p_wagon_list_id  
     where 1=1
       and round_id = returnLastRound(p_car_id)
       and out_date is null
    ;
                
    insert into xx_disl_station_history(station_hist_id,round_id,station_id,come_date,come_date_fact,come_user_id,come_comment)
    values (xx_disl_station_history_seq.nextval,returnLastRound(p_car_id),p_dest_station_id,l_cur_time,p_send_date,p_user_id,p_reason)
    ;
   
    return 'done';
exception
    when others then 
    log_new(l_log_id,l_function, 'Error = '||sqlerrm);
    return 'fail';
end;

function send_to_station_few_cars(
     p_user_id          number
    ,p_cars             varchar2
    ,p_send_stat_id     number
    ,p_dest_stat_id     number
    ,p_send_date        varchar2
    ,p_arrival_date     varchar2
    ,p_reason           varchar2
    ,p_train_num        varchar2
    ,p_loco1_num        number
    ,p_loco1_driver1    number
    ,p_loco1_driver2    number
    ,p_loco1_conductor  number
    ,p_loco2_num        number
    ,p_loco2_driver1    number
    ,p_loco2_driver2    number
    ,p_loco2_conductor  number
    ,p_save_name        varchar2 default null
)
return varchar2
as
    l_function                  varchar2(100):='send_to_station_few_cars:';
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval();
    l_wagon_list_id             number;
    l_bandwagon_id              number;
    l_send_date                 date;
    l_arrival_date              date;
    l_new_parent_id             varchar2(100);
    l_new_parent_type           varchar2(100);
    l_order                     number;
    l_done                      boolean := true;
    
    l_exc_dest_stat_is_null     exception;
begin
    log_new(l_log_id,l_function,' p_user_id='||p_user_id||' p_cars='||p_cars||' p_send_stat_id='||p_send_stat_id||' p_dest_stat_id='||p_dest_stat_id||' p_send_date='||p_send_date||' p_arrival_date='||p_arrival_date||' p_reason='||p_reason||' p_train_num='||p_train_num
       ||' p_loco1_num='||p_loco1_num||' p_loco1_driver1='||p_loco1_driver1||' p_loco1_driver2='||p_loco1_driver2||' p_loco1_conductor='||p_loco1_conductor
       ||' p_loco2_num='||p_loco2_num||' p_loco2_driver1='||p_loco2_driver1||' p_loco2_driver2='||p_loco2_driver2||' p_loco2_conductor='||p_loco2_conductor
       ); 
    
    if (p_dest_stat_id is null) then
        raise l_exc_dest_stat_is_null;
    end if;
              
    begin
        l_send_date := to_date(p_send_date,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_send_date := null;
    end;
            
    begin
        l_arrival_date := to_date(p_arrival_date,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_arrival_date := null;
    end;
        
    if (p_train_num is not null) then
        l_wagon_list_id:=xx_disl_wagon_lists_seq.nextval();
           
        insert into xx_disl_wagon_lists
        values(l_wagon_list_id
              ,p_send_stat_id
              ,p_dest_stat_id
              ,l_send_date
              ,l_arrival_date
              ,p_reason
              ,p_train_num
              ,p_loco1_num
              ,p_loco1_driver1
              ,p_loco1_driver2
              ,p_loco1_conductor
              ,p_loco2_num
              ,p_loco2_driver1
              ,p_loco2_driver2
              ,p_loco2_conductor
              ,p_user_id
              ,sysdate
              )
        ;
    end if;
        
    for tmp in (select regexp_substr(p_cars,'[^$]+',1,level) text
                  from dual
               connect by level <= regexp_count(p_cars,'[^$]+')
               )
    loop
        log_new(l_log_id,l_function,' send_to_station('||p_user_id||','||regexp_substr(tmp.text,'[^|]+',1,1)||','||p_dest_stat_id||','||l_wagon_list_id||','||to_char(l_send_date,'dd.mm.yyyy hh24:mi')||','||p_reason||')');    
            
        if (send_to_station(p_user_id,regexp_substr(tmp.text,'[^|]+',1,1),p_dest_stat_id,l_wagon_list_id,l_send_date,p_reason)!='done') then
            l_done := false;
                
            log_new(l_log_id,l_function,' l_done = N');    
        end if; 
    end loop; 
    
    delete 
      from send_to_station_form_save    sfs
     where 1=1
       and sfs.name = p_save_name  
    ;
    
    if l_done then
        commit;
        return 'done';
    else
        return 'fail';
    end if;
exception
    when others then return 'fail';
end;

function save_send_to_station_form(
     p_user_id          number
    ,p_name             varchar2
    ,p_sending_time     varchar2
    ,p_arrival_time     varchar2
    ,p_reason           varchar2
    ,p_train_num        varchar2
    ,p_loco1_num        number
    ,p_loco1_driver1    number
    ,p_loco1_driver2    number
    ,p_loco1_conductor  number
    ,p_loco2_num        number
    ,p_loco2_driver1    number
    ,p_loco2_driver2    number
    ,p_loco2_conductor  number
    ,p_cars             varchar2
)
return varchar2
as
    l_function              varchar2(100) := 'save_send_to_station_form';
    l_log_id                number := xx_disl_log_seq.nextval();
begin
    log_new(l_log_id,l_function,'parameters: p_user_id = '|| p_user_id
                                         ||' p_name = '||p_name
                                         ||' p_sending_time = '||p_sending_time
                                         ||' p_arrival_time = '||p_arrival_time
                                         ||' p_reason = '||p_reason
                                         ||' p_train_num = '||p_train_num
                                         ||' p_loco1_num = '||p_loco1_num
                                         ||' p_loco1_driver1 = '||p_loco1_driver1
                                         ||' p_loco1_driver2 = '||p_loco1_driver2
                                         ||' p_loco1_conductor = '||p_loco1_conductor
                                         ||' p_loco2_num = '||p_loco2_num
                                         ||' p_loco2_driver1 = '||p_loco2_driver1
                                         ||' p_loco2_driver2 = '||p_loco2_driver2
                                         ||' p_loco2_conductor = '||p_loco2_conductor
                                         ||' p_cars = '||p_cars); 
    
    if (p_name is null)
    then 
        return 'fail';
    end if;
    
    update send_to_station_form_save
       set sending_time = p_sending_time
          ,arrival_time = p_arrival_time
          ,reason = p_reason
          ,train_num = p_train_num
          ,loco1_num = p_loco1_num
          ,loco1_driver1 = p_loco1_driver1
          ,loco1_driver2 = p_loco1_driver2
          ,loco1_conductor = p_loco1_conductor
          ,loco2_num = p_loco2_num
          ,loco2_driver1 = p_loco2_driver1
          ,loco2_driver2 = p_loco2_driver2
          ,loco2_conductor = p_loco2_conductor
          ,cars = p_cars
          ,last_update_by = p_user_id
          ,last_update_date = sysdate
     where 1=1
       and name = p_name
    ;
    if (sql%rowcount = 0) then
        insert into send_to_station_form_save(
             name   
            ,sending_time 
            ,arrival_time 
            ,reason 
            ,train_num 
            ,loco1_num
            ,loco1_driver1
            ,loco1_driver2
            ,loco1_conductor
            ,loco2_num 
            ,loco2_driver1 
            ,loco2_driver2 
            ,loco2_conductor
            ,cars
            ,created_by
            ,created_date
            ,last_update_by
            ,last_update_date
        )
        values(
             p_name
            ,p_sending_time 
            ,p_arrival_time 
            ,p_reason 
            ,p_train_num 
            ,p_loco1_num
            ,p_loco1_driver1
            ,p_loco1_driver2
            ,p_loco1_conductor
            ,p_loco2_num 
            ,p_loco2_driver1 
            ,p_loco2_driver2 
            ,p_loco2_conductor
            ,p_cars
            ,p_user_id
            ,sysdate
            ,p_user_id
            ,sysdate
        )
        ;
    end if;    
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function get_saved_elems
return t_xx_id_name_table pipelined
as
    l_row           t_xx_id_name_row;
begin
    for l_tmp in (select *
                    from send_to_station_form_save
                 )
    loop
        l_row.name := l_tmp.name;
        pipe row (l_row);
    end loop;
end;
function load_send_to_station_form(p_name varchar2)
return t_xx_saved_elem_table pipelined
as
    l_function                  varchar2(100):='load_send_to_station_form';
    l_row                       send_to_station_form_save%rowtype;
begin
    select *
      into l_row
      from send_to_station_form_save
     where 1=1
       and name = p_name
    ;
    pipe row (l_row);  
end;
function del_send_to_station_form(
     p_user_id  number
    ,p_name     varchar2
)
return varchar2
as
begin
    delete 
      from send_to_station_form_save
     where 1=1
       and name = p_name
    ;
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function returnStations
return t_xx_station_table pipelined
as
    l_row t_xx_station_row;
begin
    for tmp in (
        select st.station_id
              ,st.name 
          from xx_disl_stations        st)
    loop
        l_row.id := tmp.station_id;
        l_row.name := tmp.name;

        pipe row (l_row);
    end loop;
end;

procedure update_cars_for_ugl(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as
    l_maxOrder          number;
    l_bandwagon_id_ugl  number;
    l_bandwagon_id_vod  number;
    l_maxOrderTmp       number;
    l_lockId            varchar2(30);
    l_lockCode          number;
    l_invoiceId         varchar2(100);
    l_rOrder            number;
    l_curTime           date;
    l_roundId           number;
    l_stationHistId     number;
    l_existsApproach    varchar2(1);
    l_notification_id   number;
    l_vod_parent_id     varchar2(100);
    l_vod_parent_type   varchar2(100);
    l_railcar_id        number;
    
    l_cont_round_id     number;
    l_cont_history_id   number;
    l_function          varchar2(100) := 'update_cars_for_ugl';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    
    
    f_out           number default apps.fnd_file.log;
begin    
    dbms_lock.allocate_unique ('xx_disl_refresh',l_lockId); --выделена блокировка    
    l_lockCode:= dbms_lock.request(l_lockId,dbms_lock.x_mode); --  запрошена блокировка в исключительном режиме
    -- если захватить не удалось, то выходим, очищая попытку блокировки
    if l_lockCode = 0 then  
        l_maxOrder := returnMaxOrder(1,'station','N');  
            
        /***beg обрабатываем вагоны, которые едут на Углеуральскую***/
        for tmp in (select listagg(ei.invoice_id, '|') within group (order by ei.invoice_id)   invoice_id/*id накладной*/
                          ,coalesce( ecar.car_number
                                   ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                   ,disl_car.car_number
                                   ,'Нет отметки'
                                   ) 
                                                                                               car_number/*номер платформы или вагона*/
                      from xx_etw.etw_invoice              ei
                          ,xx_etw.etw_inv_car              ecar
                          ,(select front_end_id
                                  ,spc_custom_text 
                              from xx_etw.etw_inv_spc 
                             where spc_transp_clause_id = 975 
                                or (    spc_transp_clause_id = 993 
                                    and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                                   )
                           ) 
                                                           eis
                          ,xx_etw.xx_disl_inv_car          disl_car
                     where  1=1
                       and ei.invoice_id not in (687152666,826468946,828099734)  
                       and ei.front_end_id not in (334416,334418) -- add 13/08/2020 Был косяк, на разных front_end_id две одинаковые накладные
                       
                       and ei.front_end_id = ecar.front_end_id(+)
                       and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                           
                       and ei.front_end_id = eis.front_end_id(+)
                       and ei.invoice_id = disl_car.invoice_id(+)
                       
                               
                       and coalesce(ecar.car_number
                                   ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                   ,disl_car.car_number
                                   ,'Нет отметки'
                                   ) != 'Нет отметки'
                       and not exists (select 1
                                         from xx_etw.xx_disl_round
                                        where 1=1
                                          and station_hist_id_out is null
                                          and railcar_id = coalesce(ecar.car_number
                                                                   ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                                                   ,disl_car.car_number
                                                                   ,'Нет отметки'
                                                                   )
                                      )
                       and not exists(select 'x'
                                        from xx_etw.xx_disl_round     r
                                            ,xx_etw.xx_disl_round_inv ri
                                       where 1=1
                                         and r.railcar_id = coalesce( ecar.car_number
                                                                     ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                                                     ,disl_car.car_number
                                                                     ,'Нет отметки'
                                                                    )
                                         and r.round_id = ri.round_id
                                         and ri.invoice_id = ei.invoice_id
                                     )
                       --------------------------------------
                       and (
                            ((ei.invoice_state in ('Груз принят к перевозке',/*'Приемосдатчиком принято','Согласование уведомления',*/'В пути','Готов комплект документов')
                             or ei.invoice_id in (select xx.INVOICE_ID from xx_etw.xx_disl_manual_upd_wagon xx where nvl(STATUS,'P') = 'P' and xx.TYPE_UPDATE = 'WAIT_UGL'))
                                
                               and lower(ei.inv_to_station_name) = 'углеуральская'
                                       
                               and ei.inv_date_create >= add_months(sysdate,-6)
                            ) 
                                --or (ei.front_end_id= 358781)
                                --or (ei.invoice_id 1155998915)
                                or ei.invoice_id in (select xx.INVOICE_ID from xx_etw.xx_disl_manual_upd_wagon xx where nvl(STATUS,'P') = 'P' and xx.TYPE_UPDATE = 'WAIT_UGL')
                            )
                     group by 
                           coalesce( ecar.car_number
                                    ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                    ,disl_car.car_number
                                    ,'Нет отметки'
                                   )
                     order by 
                           coalesce( ecar.car_number
                                    ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                    ,disl_car.car_number
                                    ,'Нет отметки'
                                   )
                   )
        loop
            log_new(l_log_id,l_function,'1) tmp.car_number = '||tmp.car_number); 
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'tmp.car_number = '||tmp.car_number);    
            l_maxOrder := l_maxOrder+1;
                
            l_roundId := xx_etw.xx_disl_round_seq.nextval();
            l_stationHistId := xx_etw.xx_disl_station_history_seq.nextval();
                
            /*заполняем таблицу оборотов*/
            insert into xx_etw.xx_disl_round(round_id,railcar_id,station_hist_id_in)
            values (l_roundId,tmp.car_number,l_stationHistId);
                
            /*заполняем таблицу накладных, по которым пришел вагон*/
            insert into xx_etw.xx_disl_round_inv 
            select l_roundId
                  ,regexp_substr(tmp.invoice_id, '[^|]+', 1, level)
                  ,null
              from dual 
           connect by level <= regexp_count(tmp.invoice_id, '[^|]+')
            ;
                
            /*заполняем таблицу таблицу историй по станциям*/
            insert into xx_etw.xx_disl_station_history(station_hist_id
                                                      ,round_id
                                                      ,station_id
                                                      ,come_date
                                                      ,come_date_fact
                                                      ,come_user_id
                                                      )
            values( l_stationHistId
                   ,l_roundId
                   ,1 -- Углеуральская
                   ,sysdate
                   ,sysdate
                   ,-1
                  )
            ;
                
            /*заполняем таблицу соотношений*/
            insert into xx_etw.xx_disl_relations
            values( tmp.car_number
                   ,'railcar'
                   ,1
                   ,'station'
                   ,l_maxOrder
                   ,'N'
                  )
            ;
            
            /*добавим работу с контейнерами*/
--            for l_cont in (
--                select ei.invoice_id
--                      ,eicont.cont_number
--                  from xx_etw.etw_invoice               ei
--                      ,xx_etw.etw_inv_car               eicar
--                      ,xx_etw.etw_inv_cont              eicont
--                 where 1=1           
--                   and ei.front_end_id = eicar.front_end_id(+)
--                   and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
--                   
--                   and nvl(eicar.car_number,tmp.car_number) = tmp.car_number
--                                       
--                   and ei.front_end_id = eicont.front_end_id
--                   and (   nvl(eicar.car_order,eicont.cont_car_order) = nvl(eicont.cont_car_order,eicar.car_order)
--                        or (eicar.car_order is null and eicont.cont_car_order is null)
--                       )
--                  
--                   and ei.invoice_id in (
--                       select regexp_substr(tmp.invoice_id, '[^|]+', 1, level)
--                         from dual 
--                      connect by level <= regexp_count(tmp.invoice_id, '[^|]+')
--                   )
--            ) loop
--                l_cont_round_id := xx_etw.xx_disl_cont_round_seq.nextval();
--                l_cont_history_id := xx_etw.xx_disl_cont_history_seq.nextval();
--                 
--                insert into xx_etw.xx_disl_cont_round
--                values(
--                    l_cont_round_id,
--                    l_cont.cont_number,
--                    l_cont_history_id,
--                    null,
--                    l_cont.invoice_id
--                );
--                
--                insert into xx_etw.xx_disl_cont_history
--                values(
--                    l_cont_history_id,
--                    l_cont_round_id,
--                    l_roundId,
--                    'railcar',
--                    sysdate,
--                    sysdate,
--                    -1,
--                    null,
--                    null,
--                    null,
--                    null  
--                );
--                
--                insert into xx_etw.xx_disl_cont_history_cur
--                values(
--                    l_cont_round_id,
--                    l_roundId,
--                    'railcar',
--                    l_cont_history_id
--                );
--            end loop;
            
            /*заполняем таблицу c дополнительной информацией*/
            begin
                fill_railcar_add_info(l_roundId,'A');
            exception when others then 
                log_new(l_log_id,l_function,'fill_railcar_add_info => l_roundId = '||l_roundId); 
            end;
            -- 21/07/2022 BekmansurovRR
            -- Обновляем статус
            for t_inv in (
                select   regexp_substr (tmp.invoice_id, '[^|]+', 1, level) inv_id
                  from   dual
            connect by   level <= regexp_count(tmp.invoice_id, '[^|]+')
            
            )
            loop
                update xx_etw.xx_disl_manual_upd_wagon x
                   set x.status = 'S'
                 where x.invoice_id = t_inv.inv_id;
            end loop;
        end loop;
        log_new(l_log_id,l_function,'end обрабатываем вагоны, которые едут на Углеуральскую');
        /***end обрабатываем вагоны, которые едут на Углеуральскую***/
        /***beg обрабатываем вагоны, которые уже прибыли на Углеуральскую***/
        log_new(l_log_id,l_function,'beg обрабатываем вагоны, которые уже прибыли на Углеуральскую'); 
        for tmp in (select to_char(max(ei.inv_date_arrive),'dd.mm.yyyy hh24:mi')                inv_date_arrive
                          ,listagg(ei.invoice_id, '|') within group (order by ei.invoice_id)    invoice_id/*id накладной*/
                          ,coalesce(ecar.car_number
                                   ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                   ,disl_car.car_number
                                   ,'Нет отметки'
                                   ) 
                                                                                                car_number/*номер платформы или вагона*/
                      from xx_etw.etw_invoice              ei
                          ,xx_etw.etw_inv_car              ecar
                          ,(select front_end_id
                                  ,spc_custom_text 
                              from xx_etw.etw_inv_spc 
                             where spc_transp_clause_id = 975 
                                or (    spc_transp_clause_id = 993 
                                    and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                                   )
                            ) 
                                                           eis
                          ,xx_etw.xx_disl_inv_car          disl_car
                     where 1=1
--                       and coalesce( ecar.car_number
--                                    ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
--                                    ,disl_car.car_number
--                                    ,'Нет отметки'
--                                   ) != '54354535'
--                       and rownum <= 15
                       and ei.front_end_id = ecar.front_end_id(+)
                       and (nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                            --or ei.invoice_id in ('1046347203')
                            or ei.invoice_id in (select xx.INVOICE_ID from xx_etw.xx_disl_manual_upd_wagon xx where nvl(STATUS,'P') = 'P' and xx.TYPE_UPDATE = 'IN_UGL')
                            
                           )
                       
                       and ei.front_end_id = eis.front_end_id(+)
                       and ei.invoice_id = disl_car.invoice_id(+)
                           
                        and (lower(ei.inv_to_station_name) = 'углеуральская'
                                or ei.invoice_id in (select xx.INVOICE_ID from xx_etw.xx_disl_manual_upd_wagon xx where nvl(STATUS,'P') = 'P' and xx.TYPE_UPDATE = 'IN_UGL')
                            )
                       --and ei.invoice_state in ('Работа с документом окончена','Груз прибыл')
                       and coalesce( ecar.car_number
                                    ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                    ,disl_car.car_number
                                    ,'Нет отметки'
                                   ) != 'Нет отметки'
                      and (ei.inv_date_arrive is not null
                               --or ei.invoice_id in ('1044152585','1044151559')
                               --or ei.invoice_id in ('1046347203')
                               or ei.invoice_id in (select xx.INVOICE_ID from xx_etw.xx_disl_manual_upd_wagon xx where nvl(STATUS,'P') = 'P' and xx.TYPE_UPDATE = 'IN_UGL')
                           )
                           
                       and (ei.inv_date_arrive >= sysdate-2
                           --or ei.invoice_id in ('1044152585','1044151559')
                           --or ei.invoice_id in ('1242967585','1207017008')
                           or ei.invoice_id in (select xx.INVOICE_ID from xx_etw.xx_disl_manual_upd_wagon xx where nvl(STATUS,'P') = 'P' and xx.TYPE_UPDATE = 'IN_UGL')
                           
                           
                           
                         ) /*все прибытия за последние сутки*/
                       /*нет прибытия на Углеуральскую*/
                       and ei.front_end_id not in (334418,334416) -- Двойные накладные
                       and not exists (select 1
                                         from xx_etw.xx_disl_round             r
                                             ,xx_etw.xx_disl_station_history   sh
                                        where 1=1
                                          and r.station_hist_id_out is null
                                          and r.railcar_id = coalesce(ecar.car_number
                                                                     ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                                                     ,disl_car.car_number
                                                                     ,'Нет отметки'
                                                                     )
                                                  
                                          and r.station_hist_id_in = sh.station_hist_id
                                          and sh.in_date is not null
                                      )
                       and (not exists(
                                  select 'x'
                                    from xx_etw.xx_disl_round               r
                                        ,xx_etw.xx_disl_round_inv           ri
                                   where 1=1
                                     and r.railcar_id = coalesce( ecar.car_number
                                                                 ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                                                 ,disl_car.car_number
                                                                 ,'Нет отметки'
                                                                )
                                     and r.round_id = ri.round_id
                                     and ri.invoice_id = ei.invoice_id
                                )
                            or
                                exists(
                                  select 'x'
                                    from xx_etw.xx_disl_round               r
                                        ,xx_etw.xx_disl_round_inv           ri
                                        ,xx_etw.xx_disl_station_history     sh
                                   where 1=1
                                     and r.railcar_id = coalesce( ecar.car_number
                                                                 ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                                                 ,disl_car.car_number
                                                                 ,'Нет отметки'
                                                                )
                                     and r.round_id = ri.round_id
                                     and ri.invoice_id = ei.invoice_id
                                     and r.round_id = sh.round_id
                                     and r.station_hist_id_in = sh.station_hist_id
                                     and sh.in_date is null
                                )
                           )
                     group by 
                           coalesce( ecar.car_number
                                    ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                    ,disl_car.car_number
                                    ,'Нет отметки'
                                   )
                     order by
                           max(ei.inv_date_arrive) 
                   )
        loop 
            log_new(l_log_id,l_function,'2) tmp.car_number = '||tmp.car_number); 
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'2; tmp.car_number = '||tmp.car_number); 
            /*ищем вагон на подходе на Углеуральскую*/
            l_existsApproach := 'N';
            begin
                select 'Y'
                  into l_existsApproach
                  from xx_etw.xx_disl_round             r
                      ,xx_etw.xx_disl_station_history   sh 
                 where 1=1
                   and r.station_hist_id_out is null
                   and r.railcar_id = tmp.car_number
                                                  
                   and r.station_hist_id_in = sh.station_hist_id
                   and sh.in_date is null
                ;
            exception
                when others then null;
            end;
                
            /*для тех случаев когда вагон пришел сразу со статусом 'Работа с документом окончена' или'Груз прибыл'*/
            /*тогда вагон на подходе на Углеуральскую не числится*/
            if (l_existsApproach='N') then                
                l_roundId := xx_etw.xx_disl_round_seq.nextval();
                l_stationHistId := xx_etw.xx_disl_station_history_seq.nextval();
                    
                /*заполняем таблицу оборотов*/
                insert into xx_etw.xx_disl_round(round_id,railcar_id,station_hist_id_in)
                values (l_roundId,tmp.car_number,l_stationHistId);
                    
                /*заполняем таблицу накладных, по которым пришел вагон*/
                insert into xx_etw.xx_disl_round_inv 
                select l_roundId
                      ,regexp_substr(tmp.invoice_id, '[^|]+', 1, level)
                      ,null
                  from dual 
               connect by level <= regexp_count(tmp.invoice_id, '[^|]+')
                ;
                    
                /*заполняем таблицу таблицу историй по станциям*/
                insert into xx_etw.xx_disl_station_history(station_hist_id
                                                          ,round_id
                                                          ,station_id
                                                          ,come_date
                                                          ,come_date_fact
                                                          ,come_user_id
                                                          )
                values( l_stationHistId
                       ,l_roundId
                       ,1 -- Углеуральская
                       ,sysdate
                       ,sysdate
                       ,-1
                      )
                ;
                    
                l_maxOrder := xx_etw.xx_dislocation.returnMaxOrder(1,'station','N');
                /*заполняем таблицу соотношений*/
                insert into xx_etw.xx_disl_relations
                values( tmp.car_number
                       ,'railcar'
                       ,1
                       ,'station'
                       ,l_maxOrder+1
                       ,'N'
                      )
                ;
                
                /*добавим работу с контейнерами*/
--                for l_cont in (
--                    select ei.invoice_id
--                          ,eicont.cont_number
--                      from xx_etw.etw_invoice               ei
--                          ,xx_etw.etw_inv_car               eicar
--                          ,xx_etw.etw_inv_cont              eicont
--                     where 1=1           
--                       and ei.front_end_id = eicar.front_end_id(+)
--                       and nvl(eicar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
--                       
--                       and nvl(eicar.car_number,tmp.car_number) = tmp.car_number
--                                           
--                       and ei.front_end_id = eicont.front_end_id
--                       and (   nvl(eicar.car_order,eicont.cont_car_order) = nvl(eicont.cont_car_order,eicar.car_order)
--                            or (eicar.car_order is null and eicont.cont_car_order is null)
--                           )
--                      
--                       and ei.invoice_id in (
--                           select regexp_substr(tmp.invoice_id, '[^|]+', 1, level)
--                             from dual 
--                          connect by level <= regexp_count(tmp.invoice_id, '[^|]+')
--                       )
--                ) loop
--                    l_cont_round_id := xx_etw.xx_disl_cont_round_seq.nextval();
--                    l_cont_history_id := xx_etw.xx_disl_cont_history_seq.nextval();
--                     
--                    insert into xx_etw.xx_disl_cont_round
--                    values(
--                        l_cont_round_id,
--                        l_cont.cont_number,
--                        l_cont_history_id,
--                        null,
--                        l_cont.invoice_id
--                    );
--                    
--                    insert into xx_etw.xx_disl_cont_history
--                    values(
--                        l_cont_history_id,
--                        l_cont_round_id,
--                        l_roundId,
--                        'railcar',
--                        sysdate,
--                        sysdate,
--                        -1,
--                        null,
--                        null,
--                        null,
--                        null  
--                    );
--                    
--                    insert into xx_etw.xx_disl_cont_history_cur
--                    values(
--                        l_cont_round_id,
--                        l_roundId,
--                        'railcar',
--                        l_cont_history_id
--                    );
--                    
--                end loop;
                
                /*заполняем таблицу с грузами*/
                fill_railcar_add_info(l_roundId,'A');
            end if;
                
            /*отмечаем дату прибытия на станцию*/
            update xx_etw.xx_disl_station_history sh
               set in_date = sysdate
                  ,in_date_fact = sysdate
                  ,in_user_id = -1
             where 1=1
               and sh.station_hist_id = (select r.station_hist_id_in
                                           from xx_etw.xx_disl_round r
                                          where 1=1
                                            and r.railcar_id = tmp.car_number
                                            and r.station_hist_id_out is null
                                        )
            ;
                    
            /*ищем гр.вагонов совпадающую с датой прибытия на Углях*/
            begin
                select max(dw.bandwagon_id)
                  into l_bandwagon_id_ugl
                  from  xx_etw.xx_disl_relations dr
                       ,xx_etw.xx_disl_bandwagon dw  
                 where 1=1
                       and dr.parent_id = 1
                       and dr.parent_type = 'station'
                       and dr.flag_come = 'Y'
                       and dr.type = 'bandwagon'
                       and dr.id = dw.bandwagon_id
                       and dw.name = tmp.inv_date_arrive
                ;
            exception
                when others then l_bandwagon_id_ugl:=null; 
            end;
            /*если такой гр. вагонов нет, то создаем и помещаем её на станцию*/
            if (l_bandwagon_id_ugl is null) then
                insert into xx_etw.xx_disl_bandwagon
                values (xx_etw.xx_disl_bandwagon_seq.nextval,tmp.inv_date_arrive)
                returning bandwagon_id into l_bandwagon_id_ugl
                ;
                    
                /*ставим группу на станцию Углеуральская*/
                l_rOrder := returnMaxOrder(1,'station','Y')+1;
                insert into xx_etw.xx_disl_relations
                values ( l_bandwagon_id_ugl
                        ,'bandwagon'
                        ,1
                        ,'station'
                        ,l_rOrder
                        ,'Y'
                       )
                ;
            end if;
                
            /*ищем гр.вагонов совпадающую с датой прибытия на Водораздальной*/
            /*проверяем есть уведомление с ПСП*/
            begin
            
                select NOTIFICATION_ID
                  into l_notification_id
                  from xx_etw.xx_disl_round
                 where 1=1
                   and round_id = xx_etw.xx_dislocation.returnLastRound(tmp.car_number)
                ; 
            exception when others then 
                null; --- l_notification_id:= null;
            end;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'1) l_notification_id = '||l_notification_id);  
            /*если нет уведомления с ПСП то помещаем под станцию с группировкой по дате, если есть, то под группу "Есть уведомление с ПСП" без группировки*/
            if (l_notification_id is null) then                
                begin
                    select max(dw.bandwagon_id)
                      into l_bandwagon_id_vod
                      from xx_etw.xx_disl_relations dr
                          ,xx_etw.xx_disl_bandwagon dw  
                     where 1=1
                       and dr.parent_id = 2 /*ст. Водораздельная*/
                       and dr.parent_type = 'station'
                       and dr.flag_come = 'N'
                       and dr.type = 'bandwagon'
                       and dr.id = dw.bandwagon_id
                       and dw.name = tmp.inv_date_arrive
                    ;
                exception
                    when others then l_bandwagon_id_vod:=null; 
                end;
                /*если такой гр. вагонов нет, то создаем и помещаем её на станцию*/
                if (l_bandwagon_id_vod is null) then
                    insert into xx_etw.xx_disl_bandwagon
                    values (xx_etw.xx_disl_bandwagon_seq.nextval,tmp.inv_date_arrive)
                    returning bandwagon_id into l_bandwagon_id_vod
                    ;
                                       
                    l_rOrder := xx_etw.xx_dislocation.returnMaxOrder(2,'station','N')+1;
                    insert into xx_etw.xx_disl_relations
                    values ( l_bandwagon_id_vod
                            ,'bandwagon'
                            ,2
                            ,'station'
                            ,l_rOrder
                            ,'N'
                           )
                    ;
                end if;
                    
                l_vod_parent_id := l_bandwagon_id_vod;   
            else
                l_vod_parent_id := '-1';/*группа "Есть уведомление с ПСП"*/
            end if;      
                
            /*ищем тек. порядок элемента в подходе на Углеуральскую*/
            select r_order
              into l_rOrder
              from xx_etw.xx_disl_relations
             where 1=1
              and id = tmp.car_number
              and type = 'railcar'
              and flag_come = 'N'
            ;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'2) l_rOrder = '||l_rOrder);  
                
            /*изменяем порядок на -1 у следующих элементов*/
            update xx_etw.xx_disl_relations
               set r_order = r_order - 1
             where 1=1
               and parent_id = 1
               and parent_type = 'station'
               and flag_come = 'N'
               and r_order > l_rOrder
            ;   
            
            /*Если есть уведомление то вагон не ставим на Углях, ставим только на подход на Водораздельную*/
            if (l_notification_id is null) then    
                /*перемещаем вагон на станцию Углеуральская*/
                l_rOrder := xx_etw.xx_dislocation.returnMaxOrder(l_bandwagon_id_ugl,'bandwagon','Y')+1;
                update xx_etw.xx_disl_relations
                   set parent_id = l_bandwagon_id_ugl
                      ,parent_type = 'bandwagon'
                      ,r_order = l_rOrder
                      ,flag_come = 'Y'
                where 1=1
                  and id = tmp.car_number
                  and type = 'railcar'
                  and flag_come = 'N'     
                ;
            else 
                delete
                  from xx_etw.xx_disl_relations
                where 1=1
                  and id = tmp.car_number
                  and type = 'railcar'
                  and flag_come = 'N'     
                ;
            end if;
            
               
            /*ставим вагон сразу на подход на Водораздельную*/
            l_rOrder := xx_etw.xx_dislocation.returnMaxOrder(l_vod_parent_id,'bandwagon','N')+1;
            insert into xx_etw.xx_disl_relations
            values (tmp.car_number
                   ,'railcar'
                   ,l_vod_parent_id
                   ,'bandwagon'
                   ,l_rOrder
                   ,'N'
                   )
            ;
            fill_railcar_date_arrive(returnLastRound(tmp.car_number));
            
            -- 21/07/2022 BekmansurovRR
            -- Обновляем статус
            for t_inv in (
                select   regexp_substr (tmp.invoice_id, '[^|]+', 1, level) inv_id
                  from   dual
            connect by   level <= regexp_count(tmp.invoice_id, '[^|]+')
            
            )
            loop
                update xx_etw.xx_disl_manual_upd_wagon x
                   set x.status = 'S'
                 where x.invoice_id = t_inv.inv_id;
            end loop;
        end loop;
        /***end обрабатываем вагоны, которые уже прибыли на Углеуральскую***/
        -- add 22/06/2022 BekmansurovRR
        -- Запрос долго выполнялся
        begin
            delete xx_etw.xx_disl_car_for_ugl_tmp;
            
            insert into xx_etw.xx_disl_car_for_ugl_tmp 
            SELECT   COALESCE (ecar.car_number,
                           REGEXP_REPLACE (eis.spc_custom_text, '[^[[:digit:]]]*'),
                           disl_car.car_number,
                           'Нет отметки')
                    AS railcar_id, ei.inv_date_ready_local AS inv_date_ready_local
          FROM   xx_etw.etw_invoice ei,
                 xx_etw.etw_inv_car ecar,
                 (SELECT   front_end_id, spc_custom_text
                    FROM   xx_etw.etw_inv_spc
                   WHERE   spc_transp_clause_id = 975
                           OR (spc_transp_clause_id = 993
                               AND UPPER (spc_custom_text) LIKE '%ПЛАТФОРМА%')) eis,
                 xx_etw.xx_disl_inv_car disl_car
         WHERE       1 = 1
                 AND ei.front_end_id = ecar.front_end_id(+)
                 AND NVL (ecar.car_sign, 0) != 1
                 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                 AND ei.front_end_id = eis.front_end_id(+)
                 AND ei.invoice_id = disl_car.invoice_id(+)
                 AND LOWER (inv_from_station_name) = 'углеуральская'
                 AND ei.inv_date_ready_local IS NOT NULL;
        exception when others then null;
        
        end;
        
        /***beg обрабатываем вагоны, которые уже уехали с Углеуральскую***/
        log_new(l_log_id,l_function,'beg обрабатываем вагоны, которые уже уехали с Углеуральскую*');
        for tmp in (select stat_hist.railcar_id
                          ,stat_hist.round_id
                      from (select r.railcar_id                             railcar_id
                                  ,r.round_id                               round_id
                                  ,max(nvl(sh.come_date_fact,sh.come_date)) come_date
                                  ,max(ri.invoice_id)                       invoice_id
                              from xx_etw.xx_disl_round                r
                                  ,xx_etw.xx_disl_round_inv            ri
                                  ,xx_etw.xx_disl_station_history      sh
                             where 1=1
                               and r.station_hist_id_out is null
                               and r.round_id = ri.round_id
                                   
                               and r.round_id = sh.round_id
                               and r.station_hist_id_in != sh.station_hist_id
                               and sh.station_id = 1
                               and in_date is null 
                             group by
                                   r.railcar_id
                                  ,r.round_id                            
                           )
                                                            stat_hist
                          ,xx_etw.etw_invoice               einv
                     where 1=1
                       and stat_hist.invoice_id = einv.invoice_id(+)
                       and (exists (select 1
                                     from xx_etw.xx_disl_car_for_ugl_tmp ei
                                    where 1=1
                                      and ei.railcar_id = stat_hist.railcar_id
                                      --and nvl(ei.inv_fact_date_accept,einv.inv_date_arrive-1) > einv.inv_date_arrive
                                      and nvl(ei.inv_date_ready_local,einv.inv_date_arrive-1) > einv.inv_date_arrive
                                  )  
                           )
                   )
        loop
            begin
            l_curTime := sysdate;
                    
            update xx_etw.xx_disl_station_history 
               set in_date = l_curTime
                  ,in_date_fact = l_curTime
                  ,in_user_id = -1
                  ,out_date = l_curTime
                  ,out_date_fact = l_curTime
                  ,out_user_id = -1
             where 1=1
               and round_id = tmp.round_id
               and station_id = 1
               and in_date is null
            returning station_hist_id into l_stationHistId
            ;
                
            update xx_etw.xx_disl_round
               set station_hist_id_out = l_stationHistId
             where 1=1
               and round_id = tmp.round_id
            ;
                
            deleteFromRelations(tmp.railcar_id,'railcar','N');
            
            /*убираем контейнера*/
            for l_cont_history_cur in (
                select *
                  from xx_etw.xx_disl_cont_history_cur
                 where 1=1
                   and place_id = tmp.round_id
                   and place_type = 'railcar'  
            ) loop
                update xx_etw.xx_disl_cont_history   
                   set out_date_sys = sysdate
                      ,out_date_fact = sysdate
                      ,out_user = -1
                 where 1=1
                   and cont_history_id = l_cont_history_cur.cont_history_id_in
                ;
                
                update xx_etw.xx_disl_cont_round
                   set cont_history_out = l_cont_history_cur.cont_history_id_in
                 where 1=1
                   and cont_round_id = l_cont_history_cur.cont_round_id
                ;
            end loop; 
            
            delete
              from xx_etw.xx_disl_cont_history_cur
             where 1=1
               and place_id = tmp.round_id
               and place_type = 'railcar' 
            ;
            exception when others then 
                null;
                log_new(l_log_id,l_function,'Ошибка '||sqlerrm||' tmp.round_id='||tmp.round_id);
            end;
        end loop;
        /***end обрабатываем вагоны, которые уже уехали с Углеуральскую***/
        log_new(l_log_id,l_function,'end обрабатываем вагоны, которые уже уехали с Углеуральскую*');
        /***beg удаляем с прихода переадресованные вагоны***/
        log_new(l_log_id,l_function,'beg удаляем с прихода переадресованные вагоны');
        for tmp in (select distinct r.round_id                round_id
                      from xx_etw.xx_disl_round                r
                          ,xx_etw.xx_disl_round_inv            ri
                          ,xx_etw.xx_disl_station_history      sh
                     where 1=1
                       and r.round_id = ri.round_id
                       and r.station_hist_id_in = sh.station_hist_id
                       and in_date is null
                       and exists (select ei.*
                                     from xx_etw.etw_invoice               ei
                                    where 1=1
                                      and ei.invoice_id = ri.invoice_id
                                      and ei.invoice_state_id in (112/*Переадресован*/,262/*Сторнирован в пути*/)
                                  )
                   )
        loop
            log_new(l_log_id,l_function,'tmp.round_id='||tmp.round_id);
            select railcar_id
              into l_railcar_id
              from xx_etw.xx_disl_round
             where 1=1
               and round_id = tmp.round_id
               and station_hist_id_out is null
            ;
            apps.fnd_file.put_line (f_out,to_char(sysdate,'dd.mm.yyyy hh24:mi:ss')||': '||'3) l_railcar_id = '||l_railcar_id);  
            xx_etw.xx_dislocation.deleteFromRelations(l_railcar_id,'railcar','N');
                
            delete 
              from xx_etw.xx_disl_round
             where 1=1
               and round_id = tmp.round_id
               and station_hist_id_out is null
            ;  
        end loop;
        log_new(l_log_id,l_function,'end удаляем с прихода переадресованные вагоны');
        /***end удаляем с прихода переадресованные вагоны***/
        
        commit;
        -- снять блокировку 
        l_lockCode := dbms_lock.release(l_lockId);
    else
        l_lockCode := dbms_lock.release(l_lockId);
        p_errbuf := 'Процедура занята'; 
        p_retcode := '2';
    end if;
exception
  when others then
    l_lockCode := dbms_lock.release(l_lockId);
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end;

procedure remove_empty_bandwagons(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as
begin
    for del_bandwagon in (select id
                                ,type
                                ,flag_come
                            from xx_etw.xx_disl_relations    rel
                           where 1=1
                             and id > 0
                             and type = 'bandwagon'
                             and flag_come = 'N'
                             and not exists (select 1 
                                               from xx_etw.xx_disl_relations rel_c
                                              where 1=1
                                                and rel_c.flag_come = rel.flag_come
                                                and rel_c.parent_id = rel.id
                                                and rel_c.parent_type = rel.type
                                            )
                          union all
                          select id
                                ,type
                                ,flag_come
                            from (select *
                                   from xx_etw.xx_disl_relations    rel
                                  where 1=1
                                    and flag_come = 'Y'
                                 )
                                    tree
                           where 1=1
                             and type = 'bandwagon'
                             and not exists (select 1 
                                               from xx_etw.xx_disl_relations rel_c
                                              where 1=1
                                                and rel_c.flag_come = tree.flag_come
                                                and rel_c.parent_id = tree.id
                                                and rel_c.parent_type = tree.type
                                            )
                          connect by prior id = parent_id
                                 and prior type = parent_type
                          start with parent_id = 1 and parent_type = 'station'
                         )
    loop
        deleteFromRelations(del_bandwagon.id,del_bandwagon.type,del_bandwagon.flag_come);
    end loop;
    commit; 
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end remove_empty_bandwagons;

function returnMaxOrder(p_id varchar2, p_type varchar2, p_flagCome varchar2)
return number
is
    l_maxOrder number;
begin
    begin
        select nvl(max(r_order),0)
          into l_maxOrder
          from xx_etw.xx_disl_relations
         where 1=1
           and parent_id = p_id
           and parent_type = p_type
           and flag_come = p_flagCome
        ;
        --log('l_maxOrder: = ' || l_maxOrder);
    exception
        when others then l_maxOrder:=0;
    end;
    return l_maxOrder;
end;

procedure deleteFromRelations(p_id varchar2, p_type varchar2, p_flag_come varchar2)
is
    l_parent_id          varchar2(100);
    l_parent_type        varchar2(100);
    l_order             number;
begin
    begin
        select parent_id
              ,parent_type
              ,r_order
          into l_parent_id
              ,l_parent_type
              ,l_order
          from xx_etw.xx_disl_relations
         where 1=1
           and id = p_id  
           and type = p_type
           and flag_come = p_flag_come
        ;

        delete 
          from xx_etw.xx_disl_relations
         where 1=1
           and id = p_id  
           and type = p_type
           and flag_come = p_flag_come
        ;
        
        update xx_etw.xx_disl_relations
           set r_order = r_order-1
         where 1=1
           and parent_id = l_parent_id
           and parent_type = l_parent_type
           and r_order > l_order
           and flag_come = p_flag_come
        ;
    exception when no_data_found then 
        null;
    end;
end;

function send_cars_from_ugl(p_user_id number,p_id_types varchar2,p_date varchar2,p_comment varchar2)
return varchar2
as
    l_done                  boolean := true;
    l_function              varchar2(100) := 'send_cars_from_ugl';
    l_log_id                number := xx_disl_log_seq.nextval();
    
    l_car_number            varchar2(100);   
    
    l_cars_table t_cars_table := t_cars_table();
    l_foreign_cars_table t_cars_table := t_cars_table();
    l_cars_table_not_request t_cars_table := t_cars_table();
    l_idx                   number;
    l_exist_request         boolean;
    l_new_req_id            number;
begin
    log_new(l_log_id,l_function,'p_user_id = '|| p_user_id
                             ||' p_id_types = ' || p_id_types 
                             ||' p_date = ' || p_date 
                             ||' p_comment = ' || p_comment);
 
    
    /*заполняем массивы вагонов из списка вагонов*/
    for tmp in (select regexp_substr(p_id_types,'[^$]+',1,level) text
                  from dual
               connect by level <= regexp_count(p_id_types,'[^$]+')
               )
    loop
        l_car_number := regexp_substr(tmp.text,'[^|]+',1,1);
        l_cars_table.extend;
        l_cars_table(l_cars_table.last) := l_car_number;
        log_new(l_log_id,l_function,'add l_cars_table. l_car_number = '||l_car_number);
        
        --if nvl(get_info_for_car_request(l_car_number,1),'_') not in ('МТФ','МД') then
            l_foreign_cars_table.extend;
            l_foreign_cars_table(l_foreign_cars_table.last) := l_car_number;
            log_new(l_log_id,l_function,'add l_foreign_cars_table. l_car_number = '||l_car_number);
        --end if;
        
          
    end loop;
    
    /*Закрываем заявки по вагонам, если нет заявки заполняем массив l_cars_table_not_request*/
    log_new(l_log_id,l_function,'Начало закрытия заявок по вагону');    
    l_idx := l_foreign_cars_table.first;
    while (l_idx is not null)
    loop
        l_car_number := l_foreign_cars_table(l_idx);
        log_new(l_log_id,l_function,'l_car_number = '||l_car_number);
        
        l_exist_request := close_request(p_user_id,l_car_number,11/*на ПСП возвр порожнего ПС (без накладных)*/,p_comment,p_date);
            
        if not l_exist_request then
            l_cars_table_not_request.extend;
            l_cars_table_not_request(l_cars_table_not_request.last) := l_car_number;
            log_new(l_log_id,l_function,'add l_cars_table_not_request. l_car_number = '||l_car_number);  
        end if;

        l_idx := l_foreign_cars_table.next(l_idx);
    end loop;
    log_new(l_log_id,l_function,'Конец закрытия заявок по вагону');
    
    /*создаем заявку по вагоном по которым их нет*/    
    if (l_cars_table_not_request.count != 0) then
        l_new_req_id := create_request(p_user_id,11,10,l_cars_table_not_request);
        log_new(l_log_id,l_function,'call create_request. l_new_req_id = '||l_new_req_id);
    end if;
    
    /*закрываем заявку*/
    l_idx := l_cars_table_not_request.first;
    while (l_idx is not null)
    loop
        l_car_number := l_cars_table_not_request(l_idx);
        l_exist_request := close_request(p_user_id,l_car_number,11/*на ПСП возвр порожнего ПС (без накладных)*/,p_comment,p_date);
        log_new(l_log_id,l_function,'call close_request. l_car_number = '||l_car_number||' result = '||boolean_to_char(l_exist_request));
        
        l_idx := l_cars_table_not_request.next(l_idx);
    end loop;
    
    /*выводим вагоны из системы*/
    l_idx := l_cars_table.first;
    while (l_idx is not null)
    loop
        l_car_number := l_cars_table(l_idx);
        if (send_from_ugl(p_user_id,l_car_number,p_date,p_comment)!='done') then
            l_done := false;
            log_new(l_log_id,l_function,'l_done = N');      
        end if;
        
        l_idx := l_cars_table.next(l_idx);
    end loop;
        
    if l_done then
        commit;
        return 'done';
    else
        rollback;
        
        /*в процедуре save_request стоит commit, и при откате заявка остается, нужно удолить в ручную*/
        if l_new_req_id is not null then      
            delete
              from xx_etw.xx_disl_requests
             where request_id = l_new_req_id;
            commit;
        end if;
        
        return 'fail';
    end if;
exception
    when others then rollback; return 'fail';
end;

function send_from_ugl(p_user_id number,p_id varchar2,p_date varchar2,p_comment varchar2)
return varchar2
is
    l_cur_time                  date;
    l_fact_time                 date;
    l_last_station_hist_id      number;
    l_last_round_id             number;
    
    l_old_parent_id             number;
    l_old_parent_type           varchar2(20);
    l_old_order                 number;
begin    
    select parent_id
          ,parent_type
          ,r_order
      into l_old_parent_id
          ,l_old_parent_type
          ,l_old_order
      from xx_disl_relations
     where 1=1
       and id = p_id
       and type = 'railcar'
       and flag_come = 'N'
    ;
    /*изменяем порядок*/
    update xx_disl_relations
       set r_order = r_order - 1
     where 1=1
       and parent_id = l_old_parent_id
       and parent_type = l_old_parent_type
       and flag_come = 'N'
       and r_order > l_old_order
    ;
        
    /*удаляем из подхода на Углеуральскую*/
    delete 
      from xx_disl_relations
     where 1=1
       and id = p_id
       and type = 'railcar'
       and flag_come = 'N'
    ;
            
    /*устанавливаем для вагонов время отправки с Углеуральской*/
    l_cur_time := sysdate;
                
    begin
        l_fact_time := to_date(p_date,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_fact_time := l_cur_time;
    end;
                
    update xx_disl_station_history
       set in_date  = l_fact_time
          ,in_user_id = p_user_id 
          ,out_date = l_cur_time
          ,out_date_fact = l_fact_time
          ,out_user_id = p_user_id 
          ,out_comment = p_comment 
     where 1=1
       and round_id = returnLastRound(p_id)
       and in_date is null
    returning round_id,station_hist_id into l_last_round_id,l_last_station_hist_id
    ;
                
    update xx_disl_round
       set station_hist_id_out = l_last_station_hist_id
     where 1=1
       and round_id = l_last_round_id
    ;
    
    /*убираем контейнера*/
    for l_cont_history_cur in (
        select *
          from xx_etw.xx_disl_cont_history_cur
         where 1=1
           and place_id = l_last_round_id
           and place_type = 'railcar'  
    ) loop
        update xx_etw.xx_disl_cont_history   
           set out_date_sys = sysdate
              ,out_date_fact = sysdate
              ,out_user = -1
         where 1=1
           and cont_history_id = l_cont_history_cur.cont_history_id_in
        ;
                
        update xx_etw.xx_disl_cont_round
           set cont_history_out = l_cont_history_cur.cont_history_id_in
         where 1=1
           and cont_round_id = l_cont_history_cur.cont_round_id
        ;
    end loop; 
            
    delete
      from xx_etw.xx_disl_cont_history_cur
     where 1=1
       and place_id = l_last_round_id
       and place_type = 'railcar' 
    ;
        
    --commit;
    return 'done';
exception
    when others then return 'fail';
end;

function output_car(
    p_user_id   number,
    p_id        varchar2,
    p_date      varchar2,
    p_comment   varchar2)
return varchar2
is
    l_cur_time                  date;
    l_user_time                 date;
    l_last_station_hist_id      number;
    l_last_round_id             number;
    
    l_old_parent_id             number;
    l_old_parent_type           varchar2(20);
    l_old_order                 number;
begin    
    select parent_id
          ,parent_type
          ,r_order
      into l_old_parent_id
          ,l_old_parent_type
          ,l_old_order
      from xx_disl_relations
     where 1=1
       and id = p_id
       and type = 'railcar';
       
    /*изменяем порядок*/
    update xx_disl_relations
       set r_order = r_order - 1
     where 1=1
       and parent_id = l_old_parent_id
       and parent_type = l_old_parent_type
       and r_order > l_old_order;
        
    /*удаляем из дерева*/
    delete 
      from xx_disl_relations
     where 1=1
       and id = p_id
       and type = 'railcar';
            
    /*устанавливаем для вагонов время отправки с Углеуральской*/
    l_cur_time := sysdate;
                
    begin
        l_user_time := to_date(p_date,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_user_time := l_cur_time;
    end;
                
    update xx_disl_station_history
       set out_date = l_cur_time
          ,out_date_fact = l_user_time
          ,out_user_id = p_user_id 
          ,out_comment = 'Вывод.Вагон разобран. ' || p_comment 
     where 1=1
       and round_id = returnLastRound(p_id)
       and out_date is null
    returning round_id,station_hist_id into l_last_round_id,l_last_station_hist_id;
                
    update xx_disl_round
       set station_hist_id_out = l_last_station_hist_id
     where 1=1
       and round_id = l_last_round_id;
    
    /*убираем контейнера*/
    for l_cont_history_cur in (
        select *
          from xx_etw.xx_disl_cont_history_cur
         where 1=1
           and place_id = l_last_round_id
           and place_type = 'railcar'  
    ) loop
        update xx_etw.xx_disl_cont_history   
           set out_date_sys = sysdate
              ,out_date_fact = sysdate
              ,out_user = -1
         where 1=1
           and cont_history_id = l_cont_history_cur.cont_history_id_in
        ;
                
        update xx_etw.xx_disl_cont_round
           set cont_history_out = l_cont_history_cur.cont_history_id_in
         where 1=1
           and cont_round_id = l_cont_history_cur.cont_round_id
        ;
    end loop; 
            
    delete
      from xx_etw.xx_disl_cont_history_cur
     where 1=1
       and place_id = l_last_round_id
       and place_type = 'railcar';
        
    return 'done';
exception
    when others then return 'fail';
end;

function output_cars(
    p_user_id       number,
    p_id_types      varchar2,
    p_date          varchar2,
    p_comment       varchar2)
return varchar2
as
    l_done                  boolean := true;
    l_function              varchar2(100) := 'output_cars';
    l_log_id                number := xx_disl_log_seq.nextval();
    
    l_car_number            varchar2(100);   
begin
    log_new(l_log_id,l_function,'p_user_id = '|| p_user_id
                             ||' p_id_types = ' || p_id_types 
                             ||' p_date = ' || p_date 
                             ||' p_comment = ' || p_comment);
 
    
    /*заполняем массивы вагонов из списка вагонов*/
    for tmp in (
        select regexp_substr(p_id_types,'[^$]+',1,level) text
          from dual
       connect by level <= regexp_count(p_id_types,'[^$]+'))
    loop
        l_car_number := regexp_substr(tmp.text,'[^|]+',1,1);
        if (output_car(p_user_id,l_car_number,p_date,p_comment) != 'done') then
            l_done := false;
            log_new(l_log_id,l_function,'l_done = N');      
        end if;
    end loop;
        
    if l_done then
        commit;
        return 'done';
    else
        rollback;        
        return 'fail';
    end if;
exception
    when others then rollback; return 'fail';
end;


function get_reasons_for_return
return t_xx_id_name_table pipelined
is
    l_row           t_xx_id_name_row;
begin
    for l_tmp in (select reason_id
                        ,descr
                    from xx_etw.xx_disl_reasons_for_return
                   where 1=1
                   order by
                         reason_id 
                 )
    loop
        l_row.id := l_tmp.reason_id;
        l_row.name := l_tmp.descr;
        
        pipe row (l_row);
    end loop;
end;

function get_last_cars_train_time(p_car_numbers varchar2,p_reason varchar2)
return varchar2
is
    l_wagon_list_id         number;
    l_send_date             varchar2(100);
    l_send_date_d           date;
begin
    if (p_reason = 'mistake') then
        begin
            select distinct sh_prev.out_wagon_list_id
              into l_wagon_list_id
              from xx_disl_station_history      sh_last
                  ,xx_disl_station_history      sh_prev
             where 1=1
               and sh_last.round_id in (
                    select returnlastround(regexp_substr(p_car_numbers,'[^|]+',1,level))
                      from dual
                   connect by level <= regexp_count(p_car_numbers,'[^|]+')   
               )
               and sh_last.in_date is null
               and sh_last.round_id = sh_prev.round_id
               and sh_last.come_date = sh_prev.out_date
            ;
        exception
            when others then l_wagon_list_id := null;
        end;
        if (l_wagon_list_id is not null) then
            select to_char(send_date+1/24/60,'dd.mm.yyyy hh24:mi')
              into l_send_date
              from xx_disl_wagon_lists
             where 1=1
               and wagon_list_id = l_wagon_list_id
            ;
        else
            l_send_date := null;
        end if;
    else 
        select max(wl.send_date)
          into l_send_date_d
          from xx_disl_station_history      sh_last
              ,xx_disl_station_history      sh_prev
              ,xx_disl_wagon_lists          wl
         where 1=1
           and sh_last.round_id in (
                select returnlastround(regexp_substr(p_car_numbers,'[^|]+',1,level))
                  from dual
               connect by level <= regexp_count(p_car_numbers,'[^|]+')   
           )
           and sh_last.in_date is null
           and sh_last.round_id = sh_prev.round_id
           and sh_last.come_date = sh_prev.out_date
           
           and sh_prev.out_wagon_list_id = wl.wagon_list_id
        ;
        
        l_send_date := to_char(l_send_date_d+1/24*2,'dd.mm.yyyy hh24:mi');
    end if;
    
    return l_send_date;
exception
    when others then return null;
end;

function return_from_psp(
    p_user_id                   number,
    p_car_numbers               varchar2,
    p_return_time               varchar2,
    p_return_reason             varchar2,
    p_return_comment            varchar2,
    p_return_correction_reason  varchar2,
    p_station_operator          varchar2
) return varchar2
is
    l_function                  varchar2(100) := 'return_from_psp';
    l_log_id                    number := xx_disl_log_seq.nextval();
    l_cur_time                  date := sysdate;
    l_return_time               date;
    l_return_id                 number;
    
    l_car_number                varchar2(100);
    l_cur_round                 number;
    l_station_hist_id_ugl       number;
    l_station_hist_id_vod       number;
    l_order                     number;
begin
    log_new(l_log_id,l_function,'p_user_id = '|| p_user_id
                             ||' p_car_numbers = ' || p_car_numbers 
                             ||' p_return_time = ' || p_return_time 
                             ||' p_return_reason = ' || p_return_reason 
                             ||' p_return_comment = ' || p_return_comment 
                             ||' p_return_correction_reason = ' || p_return_correction_reason 
                             ||' p_station_operator = ' || p_station_operator);
    
    begin
        l_return_time := to_date(p_return_time,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_return_time := l_cur_time;
    end;
    
    l_return_id := xx_disl_return_psp_info_seq.nextval();
    
    insert into xx_disl_return_from_psp_info
    values(
        l_return_id
       ,p_car_numbers
       ,l_return_time
       ,p_return_reason
       ,p_return_comment
       ,p_return_correction_reason
       ,p_station_operator
       ,p_user_id
       ,l_cur_time
    );
       
    for l_car in (
        select regexp_substr(p_car_numbers,'[^|]+',1,level) car_number
          from dual
       connect by level <= regexp_count(p_car_numbers,'[^|]+')
    ) loop
        l_car_number := l_car.car_number;
        log_new(l_log_id,l_function,'l_car_number = '||l_car_number);
        
        l_cur_round := returnLastRound(l_car_number);
        log_new(l_log_id,l_function,'l_cur_round = '||l_cur_round);
        
        select station_hist_id
          into l_station_hist_id_ugl
          from xx_disl_station_history
         where 1=1
           and round_id = l_cur_round
           and in_date is null
        ;

        update xx_disl_station_history
           set in_date = l_cur_time
              ,in_date_fact = l_return_time
              ,in_user_id = p_user_id
              ,out_date = l_cur_time
              ,out_date_fact = l_return_time
              ,out_user_id = p_user_id
              ,out_comment = p_return_comment
         where 1=1
           and round_id = l_cur_round
           and in_date is null
        returning station_hist_id into l_station_hist_id_ugl
        ;
        log_new(l_log_id,l_function,'l_station_hist_id_ugl = '||l_station_hist_id_ugl);
        
        insert into xx_disl_return_from_psp_rel 
        values(l_return_id,l_station_hist_id_ugl);
        
        l_station_hist_id_vod := xx_disl_station_history_seq.nextval();
        log_new(l_log_id,l_function,'l_station_hist_id_vod = '||l_station_hist_id_vod); 
        insert into xx_disl_station_history(
            station_hist_id
           ,round_id
           ,station_id
           ,come_date
           ,come_date_fact
           ,come_user_id)
        values (
            l_station_hist_id_vod
           ,l_cur_round
           ,2 -- Водораздельная
           ,l_cur_time
           ,l_return_time
           ,p_user_id)
        ;
        
        l_order := returnMaxOrder(-1/*Группа Есть уведомление с ПСП*/,'bandwagon','N')+1;
        update xx_disl_relations
           set parent_id = '-1'
              ,parent_type = 'bandwagon'
              ,r_order = l_order
         where 1=1
           and id = l_car_number
           and type = 'railcar'
           and flag_come = 'N'
        ;
    end loop;
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end return_from_psp;



function entry_foreign_railcar(p_user_id number,p_railcars varchar2,p_date_fact varchar2)
return varchar2
as
    l_function          varchar2(100) := 'entry_foreign_railcar';
    l_date_fact         date;
    l_cur_date          date;
    l_max_order         number;
    l_round_id          number;
    l_station_hist_id   number;
    l_station_id        number;
    l_car_number        varchar2(10);
    l_inv_number        varchar2(10);
    l_exists            varchar2(1);
    l_exists_railcars   varchar2(1000); /*список уже существующих вагонов. Разделитель |*/ 
    l_add_info_id       number;
    l_date_arrive       varchar2(50);
    l_bandwagon_id_ugl  number;
    l_bandwagon_id_vod  number;
    
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
begin
    log_new(l_log_id,l_function,'parameter: p_user_id='||p_user_id||' p_railcars='||p_railcars||' p_date_fact='||p_date_fact);
        
    l_cur_date := sysdate;
    begin
        l_date_fact := to_date(p_date_fact,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_date_fact := l_cur_date;
    end;
        
    for tmp in (select regexp_substr(p_railcars,'[^$]+',1,level) text
                  from dual
               connect by level <= regexp_count(p_railcars,'[^$]+')
               )
    loop
        l_car_number := regexp_substr(tmp.text,'[^|]+',1,1);
        log_new(l_log_id,l_function,'l_car_number=' ||l_car_number);
            
        /*проверка вагона на существование в дислокации*/
        begin
            select 'Y'
              into l_exists
              from xx_disl_round
             where 1=1
               and railcar_id = l_car_number
               and station_hist_id_out is null
            ;
        exception
            when no_data_found then l_exists:='N';
        end;
        log_new(l_log_id,l_function,'l_exists='||l_exists);
            
        if (l_exists='Y') then
            l_exists_railcars := l_exists_railcars || l_car_number || '|';    
        else
            l_inv_number := case regexp_substr(tmp.text,'[^|]+',1,9)
                              when '_'
                              then null
                              else regexp_substr(tmp.text,'[^|]+',1,9)
                            end;
            log_new(l_log_id,l_function,'l_max_order='||l_max_order||' l_inv_number='||l_inv_number);                                
            
            l_round_id := xx_disl_round_seq.nextval();
            l_station_hist_id := xx_disl_station_history_seq.nextval();
            log_new(l_log_id,l_function,'l_round_id = '||l_round_id||' l_station_hist_id = '||l_station_hist_id);
            
            /*заполняем таблицу оборотов*/
            insert into xx_disl_round(round_id,railcar_id,station_hist_id_in,foreign_car,date_arrive)
            values (l_round_id,l_car_number,l_station_hist_id,'Y',to_date(decode(regexp_substr(tmp.text,'[^|]+',1,12),'_',null,regexp_substr(tmp.text,'[^|]+',1,12)),'dd.mm.yyyy hh24:mi'))
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_round. Кол-во='||sql%rowcount);
                   
            /*заполняем таблицу накладных, по которым пришел вагон*/
            insert into xx_disl_round_inv
            values(l_round_id,null,l_inv_number)  
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_round_inv. Кол-во='||sql%rowcount); 
        
            /*заполняем таблицу таблицу историй по станциям*/
            insert into xx_disl_station_history(station_hist_id
                                               ,round_id
                                               ,station_id
                                               ,come_date
                                               ,come_date_fact
                                               ,come_user_id
                                               ,in_date
                                               ,in_date_fact
                                               ,in_user_id
                                               )
            values( l_station_hist_id
                   ,l_round_id
                   ,1
                   ,l_cur_date
                   ,l_date_fact
                   ,p_user_id
                   ,l_cur_date
                   ,l_date_fact
                   ,p_user_id
                  )
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_station_history. Кол-во='||sql%rowcount); 
                
                
            l_date_arrive := case regexp_substr(tmp.text,'[^|]+',1,12)
                              when '_'
                              then null
                              else regexp_substr(tmp.text,'[^|]+',1,12)
                            end;
                
            /*ищем гр.вагонов совпадающую с датой прибытия на Углях*/
            begin
                select max(dw.bandwagon_id)
                  into l_bandwagon_id_ugl
                  from  xx_disl_relations dr
                       ,xx_disl_bandwagon dw  
                 where 1=1
                       and dr.parent_id = 1
                       and dr.parent_type = 'station'
                       and dr.flag_come = 'Y'
                       and dr.type = 'bandwagon'
                       and dr.id = dw.bandwagon_id
                       and (   dw.name = l_date_arrive
                            or coalesce(dw.name,l_date_arrive) is null
                           )
                ;
            exception
                when others then l_bandwagon_id_ugl:=null; 
            end;
            /*если такой гр. вагонов нет, то создаем и помещаем её на станцию*/
            if (l_bandwagon_id_ugl is null) then
                insert into xx_disl_bandwagon
                values (xx_disl_bandwagon_seq.nextval,l_date_arrive)
                returning bandwagon_id into l_bandwagon_id_ugl
                ;
                    
                /*ставим группу на станцию Углеуральская*/
                l_max_order := returnMaxOrder(1,'station','Y')+1;
                insert into xx_disl_relations
                values ( l_bandwagon_id_ugl
                        ,'bandwagon'
                        ,1
                        ,'station'
                        ,l_max_order
                        ,'Y'
                       )
                ;
            end if;
                
            /*ищем гр.вагонов совпадающую с датой прибытия на Водораздельной*/
            begin
                select max(dw.bandwagon_id)
                  into l_bandwagon_id_vod
                  from xx_disl_relations dr
                      ,xx_disl_bandwagon dw  
                 where 1=1
                   and dr.parent_id = 2
                   and dr.parent_type = 'station'
                   and dr.flag_come = 'N'
                   and dr.type = 'bandwagon'
                   and dr.id = dw.bandwagon_id
                   and (   dw.name = l_date_arrive
                        or coalesce(dw.name,l_date_arrive) is null
                       )
                ;
            exception
                when others then l_bandwagon_id_vod:=null; 
            end;
            /*если такой гр. вагонов нет, то создаем и помещаем её на станцию*/
            if (l_bandwagon_id_vod is null) then
                insert into xx_disl_bandwagon
                values (xx_disl_bandwagon_seq.nextval,l_date_arrive)
                returning bandwagon_id into l_bandwagon_id_vod
                ;
                                   
                /*а тагже в подход на станцию Водораздельная*/
                l_max_order := returnMaxOrder(2,'station','N')+1;
                insert into xx_disl_relations
                values ( l_bandwagon_id_vod
                        ,'bandwagon'
                        ,2
                        ,'station'
                        ,l_max_order
                        ,'N'
                       )
                ;
            end if;
                
            /*заполняем таблицу соотношений*/
            l_max_order := returnMaxOrder(l_bandwagon_id_ugl,'bandwagon','Y')+1;
            insert into xx_disl_relations
            values( l_car_number
                   ,'railcar'
                   ,l_bandwagon_id_ugl
                   ,'bandwagon'
                   ,l_max_order
                   ,'Y'
                  )
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_relations. Кол-во='||sql%rowcount); 
            l_max_order := returnMaxOrder(l_bandwagon_id_vod,'bandwagon','N')+1;
            insert into xx_disl_relations
            values( l_car_number
                   ,'railcar'
                   ,l_bandwagon_id_vod
                   ,'bandwagon'
                   ,l_max_order
                   ,'N'
                  )
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_relations. Кол-во='||sql%rowcount);      
                
            l_add_info_id := xx_disl_railcar_add_info_seq.nextval();
            insert into xx_disl_railcar_add_info(
                 add_info_id
                ,round_id
                ,car_number
                ,status
                ,car_type
                ,freight_name
                ,weight_net
                ,weight_dep
                ,cont
                ,owner
                ,add_info_type
                ,last_record
                ,last_update_date
                ,last_update_user_id
                ,car_length
                ,need_load_car_info
                ,date_begin
            )
            values( l_add_info_id
                   ,l_round_id
                   ,l_car_number
                   ,decode(regexp_substr(tmp.text,'[^|]+',1,3),'_',null,regexp_substr(tmp.text,'[^|]+',1,3))
                   ,decode(regexp_substr(tmp.text,'[^|]+',1,2),'_',null,regexp_substr(tmp.text,'[^|]+',1,2))
                   ,decode(regexp_substr(tmp.text,'[^|]+',1,5),'_',null,regexp_substr(tmp.text,'[^|]+',1,5))
                   ,to_number(nvl(replace(decode(regexp_substr(tmp.text,'[^|]+',1,6),'_',null,regexp_substr(tmp.text,'[^|]+',1,6)),'.',','),0))/1000
                   ,to_number(nvl(replace(decode(regexp_substr(tmp.text,'[^|]+',1,7),'_',null,regexp_substr(tmp.text,'[^|]+',1,7)),'.',','),0))/1000
                   ,decode(regexp_substr(tmp.text,'[^|]+',1,10),'_',null,regexp_substr(tmp.text,'[^|]+',1,10))
                   ,decode(regexp_substr(tmp.text,'[^|]+',1,11),'_',null,regexp_substr(tmp.text,'[^|]+',1,11))
                   ,'A'
                   ,'Y'
                   ,l_cur_date
                   ,p_user_id
                   ,null
                   ,'N'
                   ,sysdate
                  )
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info. Кол-во='||sql%rowcount);
                
            insert into xx_disl_railcar_add_info_inv
            values(l_add_info_id,null,l_inv_number)
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info_inv. Кол-во='||sql%rowcount); 
        end if;
    end loop;

    commit;
        
    return 'done'||'$'||l_exists_railcars;
exception
    when others then rollback; return 'fail';
end;



function fill_railcar_attr(p_car_number varchar2,p_car_type varchar2,p_freight_name varchar2)
return varchar2
as
    l_function          varchar2(50) := 'fill_railcar_attr: ';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
begin
    log_new(l_log_id,l_function,'p_car_number='||p_car_number||' p_car_type='||p_car_type||' p_freight_name='||p_freight_name);
    
    update xx_disl_railcar_add_info
       set car_type = p_car_type
     where 1=1
       and round_id = returnLastRound(p_car_number)
       and last_record = 'Y'
       and car_type is null
    ;
    log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info(car_type). Кол-во='||sql%rowcount);
        
    update xx_disl_railcar_add_info
       set freight_name = p_freight_name
     where 1=1
       and round_id = returnLastRound(p_car_number)
       and last_record = 'Y'
       and freight_name is null
    ;
    log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info(freight_name). Кол-во='||sql%rowcount);
        
    commit;
    return 'done';  
exception
    when others then rollback; return 'fail'; 
end;

function fill_railcar_for_invoice(p_user_id number,p_invoice_id number,p_car_number varchar2)
return varchar2
as
    l_function      varchar2(100)   := 'fill_railcar_for_invoice'; 
    l_log_id        number          := xx_etw.xx_disl_log_seq.nextval();   
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id||'p_invoice_id = '||p_invoice_id||' p_car_number = '||p_car_number);
    
    if (length(nvl(p_car_number,'_')) = 8) then
        insert into xx_disl_inv_car
        values (
             p_invoice_id
            ,p_car_number
            ,p_user_id
            ,sysdate
        )
        ;
        log_new(l_log_id,l_function,'insert into xx_disl_inv_car. rowcount = '||sql%rowcount);
        commit;
        
        return 'done';
    end if;
        
    return 'fail';
exception
    when others then return 'fail';
end;

function returnBadInvoices
return t_xx_inv_table pipelined
as
    l_inv                   t_xx_inv_row;
begin
    for inv in (select ei.invoice_id    invoice_id/*id накладной*/
                      ,ei.inv_number    inv_number
                      ,listagg(eicont.cont_number, ',') 
                        within group (order by eicont.cont_number)
                                        cont_number
                      ,regexp_replace(listagg(decode(decode(lower(ei.inv_to_station_name)
                                                           ,'углеуральская',ei.inv_recip_id
                                                           ,ei.inv_sender_id
                                                           )
                                                    ,33888,'МТФ'
                                                    ,295879,'МД'
                                                    ,substr(ei.inv_recip_name,1,3)
                                                    )
                                             , ',') 
                                      within group (order by ei.inv_recip_id)
                                     ,'([^,]+)(,\1)+', '\1'
                                     )                        
                                       owner
                  from xx_etw.etw_invoice              ei
                      ,xx_etw.etw_inv_car              ecar
                      ,(select front_end_id
                              ,spc_custom_text 
                          from xx_etw.etw_inv_spc 
                         where spc_transp_clause_id = 975 
                            or (    spc_transp_clause_id = 993 
                                and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                               )
                       ) 
                                                       eis
                      ,xx_disl_inv_car                 disl_car
                      ,(select front_end_id
                              ,listagg(eicont.cont_number, ',') 
                               within group (order by eicont.cont_number)
                                                                cont_number
                          from xx_etw.etw_inv_cont              eicont
                         group by
                               front_end_id
                       )
                                                       eicont
                 where  1=1
                       and ei.front_end_id = ecar.front_end_id(+)
                       and ei.front_end_id = eis.front_end_id(+)
                       and ei.invoice_id = disl_car.invoice_id(+)
                       and ei.front_end_id = eicont.front_end_id(+)
                       
                       and coalesce(ecar.car_number
                                   ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                   ,disl_car.car_number
                                   ,'Нет отметки'
                                   ) = 'Нет отметки'
                       --------------------------------------
                       and ei.invoice_state in ('Груз принят к перевозке',/*'Приемосдатчиком принято','Готов комплект документов','Согласование уведомления',*/'В пути')
                       and lower(ei.inv_to_station_name) = 'углеуральская'
                           
                       and ei.inv_date_create >= add_months(sysdate,-6)
                 group by 
                       ei.invoice_id
                      ,ei.inv_number
               )
    loop
        l_inv.invoice_id := inv.invoice_id;
        l_inv.inv_number := inv.inv_number;
        l_inv.cont_number := inv.cont_number;
        l_inv.owner := inv.owner;
        
        pipe row (l_inv);  
    end loop;
end;

function returnCountBadInvoices
return number
as
    l_count         number;
begin
    select count(1)
      into l_count
      from xx_etw.etw_invoice              ei
          ,xx_etw.etw_inv_car              ecar
          ,(select front_end_id
                  ,spc_custom_text 
              from xx_etw.etw_inv_spc 
             where spc_transp_clause_id = 975 
                or (    spc_transp_clause_id = 993 
                    and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                   )
           ) 
                                           eis
          ,xx_disl_inv_car                 disl_car
     where  1=1
           and ei.front_end_id = ecar.front_end_id(+)
           and ei.front_end_id = eis.front_end_id(+)
           and ei.invoice_id = disl_car.invoice_id(+)
                       
           and coalesce(ecar.car_number
                       ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                       ,disl_car.car_number
                       ,'Нет отметки'
                       ) = 'Нет отметки'
           --------------------------------------
           and ei.invoice_state in ('Груз принят к перевозке',/*'Приемосдатчиком принято','Готов комплект документов','Согласование уведомления',*/'В пути')
           and lower(ei.inv_to_station_name) = 'углеуральская'
                           
           and ei.inv_date_create >= add_months(sysdate,-6)
    ;
    
    return l_count;              
end;

function add_railway(p_parent_id number,p_parent_type varchar2, p_number varchar2,p_purpose varchar2,p_pointer_from varchar2,p_pointer_to varchar2
                   ,p_length_limit varchar2,p_length_useful varchar2,p_capacity varchar2
                   ,p_add_field1 varchar2,p_add_field2 varchar2,p_add_field3 varchar2,p_disabled varchar2,p_type number)
return number
as
    l_railway_id    number;
    l_max_order     number;
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval();
    l_function                  varchar2(100):='add_railway';
begin
    begin
        log_new(l_log_id,l_function,'addRailway: p_parent_id = '||p_parent_id);
        log_new(l_log_id,l_function,'addRailway: p_parent_type = '||p_parent_type);
        log_new(l_log_id,l_function,'addRailway: p_number = '||p_number);
        log_new(l_log_id,l_function,'addRailway: p_purpose = '||p_purpose);
        log_new(l_log_id,l_function,'addRailway: p_pointer_from = '||p_pointer_from);
        log_new(l_log_id,l_function,'addRailway: p_pointer_to = '||p_pointer_to);
        log_new(l_log_id,l_function,'addRailway: p_length_limit = '||p_length_limit);
        log_new(l_log_id,l_function,'addRailway: p_length_useful = '||p_length_useful);
        log_new(l_log_id,l_function,'addRailway: p_capacity = '||p_capacity);
        log_new(l_log_id,l_function,'addRailway: p_add_field1 = '||p_add_field1);
        log_new(l_log_id,l_function,'addRailway: p_add_field2 = '||p_add_field2);
        log_new(l_log_id,l_function,'addRailway: p_add_field3 = '||p_add_field3);
        log_new(l_log_id,l_function,'addRailway: p_disabled = '||p_disabled);
        log_new(l_log_id,l_function,'addRailway: type = '||p_type);
        
        insert into xx_disl_railways
        values (xx_disl_railways_seq.nextval
               ,p_number
               ,p_purpose
               ,p_pointer_from
               ,p_pointer_to
               ,p_length_limit
               ,p_length_useful
               ,p_capacity
               ,p_add_field1
               ,p_add_field2
               ,p_add_field3
               ,p_disabled
               ,p_type
               ,null
               )
        returning railway_id into l_railway_id
        ;
        
        log_new(l_log_id,l_function,'addRailway: l_railway_id = '||l_railway_id);
        
        l_max_order := returnMaxOrder(p_parent_id,p_parent_type,'Y');
        
        log_new(l_log_id,l_function,'addRailway: l_max_order = '||l_max_order);
        
        insert into xx_disl_relations
        values(l_railway_id
              ,'railway'
              ,p_parent_id
              ,p_parent_type
              ,l_max_order+1
              ,'Y'
              )
        ;
        
        log_new(l_log_id,l_function,'addRailway: insert into xx_disl_relations. Кол-во: '||sql%rowcount);
        
        commit;
        return l_railway_id;
    exception
        when others then rollback; return 0;
    end;
end;

function change_railway_attr(p_railway_id number, p_number varchar2,p_purpose varchar2,p_pointer_from varchar2,p_pointer_to varchar2
                            ,p_length_limit varchar2,p_length_useful varchar2,p_capacity varchar2
                            ,p_add_field1 varchar2,p_add_field2 varchar2,p_add_field3 varchar2,p_disabled varchar2,p_type number)
return varchar2
as
    l_function      varchar2(100) :='change_railway_attr: ';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval(); 
begin
    begin
        log_new(l_log_id,l_function,'p_railway_id = '||p_railway_id);
        log_new(l_log_id,l_function,'p_number = '||p_number);
        log_new(l_log_id,l_function,'p_purpose = '||p_purpose);
        log_new(l_log_id,l_function,'p_pointer_from = '||p_pointer_from);
        log_new(l_log_id,l_function,'p_pointer_to = '||p_pointer_to);
        log_new(l_log_id,l_function,'p_length_limit = '||p_length_limit);
        log_new(l_log_id,l_function,'p_length_useful = '||p_length_useful);
        log_new(l_log_id,l_function,'p_capacity = '||p_capacity);
        log_new(l_log_id,l_function,'p_add_field1 = '||p_add_field1);
        log_new(l_log_id,l_function,'p_add_field2 = '||p_add_field2);
        log_new(l_log_id,l_function,'p_add_field3 = '||p_add_field3);
        log_new(l_log_id,l_function,'p_disabled = '||p_disabled);
        log_new(l_log_id,l_function,'p_type = '||p_type);
        
        update xx_disl_railways
           set railway_number = p_number
              ,purpose = p_purpose
              ,pointer_from = p_pointer_from
              ,pointer_to = p_pointer_to
              ,length_limit = p_length_limit
              ,length_useful = p_length_useful
              ,capacity = p_capacity
              ,add_field1 = p_add_field1
              ,add_field2 = p_add_field2
              ,add_field3 = p_add_field3
              ,disabled = p_disabled
              ,type = p_type
          where 1=1
            and railway_id = p_railway_id
        ;
        
        log_new(l_log_id,l_function,'update xx_disl_railways. Кол-во='||sql%rowcount);

        commit;
        return 'done';
    exception
        when others then rollback; return 'fail';
    end;
end;

function change_parent_for_railway(p_id varchar2,p_type varchar2,p_new_parent_id varchar2,p_new_parent_type varchar2)
return varchar2
as
    l_cur_parent_id         varchar2(100);
    l_cur_parent_type       varchar2(100);
    l_cur_order             number;
    l_new_max_order         number;
    --
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='delete_dev_inspection';
begin
    begin    
        log_new(l_log_id,l_function,'changeParentForRailway: p_id = '||p_id);
        log_new(l_log_id,l_function,'changeParentForRailway: p_type = '||p_type);
        log_new(l_log_id,l_function,'changeParentForRailway: p_new_parent_id = '||p_new_parent_id);
        log_new(l_log_id,l_function,'changeParentForRailway: p_new_parent_type = '||p_new_parent_type);        
        -- определим текущего родителя и порядок
        select  parent_Id
               ,parent_Type
               ,r_order
          into  l_cur_parent_id
               ,l_cur_parent_type
               ,l_cur_order
          from xx_disl_relations
         where 1=1
           and id = p_id
           and type = p_type
           and flag_come = 'Y'
        ;
        
        -- изменим порядок потомков текущего родителя
        update xx_disl_relations
           set r_order = r_order - 1
         where 1=1
               and parent_id = l_cur_parent_id
               and parent_type = l_cur_parent_type
               and r_order > l_cur_order
               and flag_come = 'Y'
        ;
        
        
        -- определим макс. порядок среди потомков нового родителя
        l_new_max_order := returnMaxOrder(p_new_parent_id,p_new_parent_type,'Y');
            
        -- поместим элемент под нового родителя в конец очереди
        update xx_disl_relations
           set parent_id = p_new_parent_id
              ,parent_type = p_new_parent_type
              ,r_order = l_new_max_order + 1
         where 1=1
           and id = p_id
           and type = p_type
           and flag_come = 'Y'
        ;    
        commit;  
        return 'done';
    exception
        when others then rollback; return 'fail';
    end;
end;


function getStations
return t_xx_station_table pipelined
as
    l_row t_xx_station_row;
begin
    for tmp in (select  st.station_id
                       ,st.name 
                  from  xx_disl_stations        st
               )
    loop
        l_row.id := tmp.station_id;
        l_row.name := tmp.name;

        pipe row (l_row);
    end loop;
end;

function getUserStations(p_login    varchar2)
return t_xx_station_table pipelined
as
    l_row t_xx_station_row;
begin
    for tmp in (select  st.station_id                   id
                       ,st.name                         name
                       ,nvl(ust.def_station,'N')        def
                  from  xx_disl_users               us
                       ,xx_disl_user_stations       ust
                       ,xx_disl_stations            st
                 where 1=1
                   and us.login = upper(p_login)
                   and us.id = ust.user_id
                   and ust.station_id = st.station_id
                 order by
                       st.station_id
               )
    loop
        l_row.id := tmp.id;
        l_row.name := tmp.name;
        l_row.def := tmp.def;

        pipe row (l_row);
    end loop;
end;

procedure nrb_stop_update_prc(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as 
begin
    delete 
      from xx_etw.xx_disl_nrb_stop
    ;
    
    insert into xx_etw.xx_disl_nrb_stop
    select cii.instance_number
          ,qr.character8
     from  apps.qa_results              qr
          ,apps.csi_item_instances      cii
          ,(select qr1.asset_instance_id
                  ,max(to_date(qr1.character3,'yyyy/mm/dd hh24:mi:ss')) mdt
              from apps.qa_results                          qr1
                  ,apps.qa_pc_results_relationship          qrel
                  ,apps.qa_results                          qr_child
             where 1=1      
               and qr1.plan_id = 1981
               and (qr1.status is null or qr1.status = 2)
               and qr1.organization_id = 305
               and qr_child.organization_id = 305
               and qr_child.occurrence = qrel.child_occurrence
               and qr_child.collection_id = qrel.child_collection_id
               and qr_child.plan_id = qrel.child_plan_id
               and (qr_child.status is null or qr_child.status = 2)
               and substr(trim(qr_child.character1),1,2) <> '0_'
               and qrel.child_plan_id = 1980
               and qr1.plan_id = qrel.parent_plan_id(+)
               and qr1.collection_id = qrel.parent_collection_id(+)
             group by  
                   qr1.asset_instance_id
          ) 
                                        ogr
    where 1=1        
      and plan_id = 1981
      and (qr.status is null or qr.status = 2)
      and qr.organization_id = 305
      and cii.instance_id = qr.asset_instance_id
      and qr.character2 like 'Огра%'
      and character8 is not null
      and cii.instance_number in (select car_number 
                                    from xx_etw.dislocation_cars 
                                   where daterequest = (select max(daterequest) 
                                                          from xx_etw.dislocation_cars
                                                       )
                                 )--для индекса 
      and to_date(qr.character3,'yyyy/mm/dd hh24:mi:ss') = ogr.mdt
      and qr.asset_instance_id = ogr.asset_instance_id(+)
    ;
    
    commit;
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end;

function get_stations_with_railways
return t_xx_tree_table pipelined
as
    l_row t_xx_tree_row;
begin
    for c_row in (select tree.*
                        ,un_n.name
                    from (select id,type,parent_id,parent_type,r_order
                            from xx_disl_relations
                           where 1=1
                             and flag_come = 'Y'
                             and type in ('railway','point','area')
                           union
                          select to_char(station_id),'station','null','null',station_id
                            from xx_disl_stations
                           where 1=1
                             and station_id != 1
                         )
                                  tree
                        ,xx_disl_union_name_v       un_n
                   where 1=1
                     and tree.id = un_n.id
                     and tree.type = un_n.type
                  connect by prior tree.id = tree.parent_id and prior tree.type = tree.parent_type
                    start with tree.type = 'station'
                    order siblings by r_order
                 )
    loop
        l_row.id := c_row.id;
        l_row.type := c_row.type;
        l_row.parent_id := c_row.parent_id;
        l_row.parent_type := c_row.parent_type;
        l_row.r_order := c_row.r_order;
        l_row.name := c_row.name;        
        pipe row (l_row);
    end loop;
end;

function get_railway_add_info(p_railway_id number)
return t_xx_railway_info_table pipelined
as
    l_row xx_disl_railways%rowtype;
begin
    select *
      into l_row
      from xx_disl_railways
     where 1=1
       and railway_id = p_railway_id
    ;
    pipe row (l_row);
end;

function change_pwd(p_login varchar2,p_new_pwd varchar2)
return varchar2
as
    l_function              varchar2(100) := 'change_pwd: ';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
begin
    log_new(l_log_id,l_function,'parameter: p_login=' || p_login || ' p_new_pwd=' || p_new_pwd);
    begin
        update xx_disl_users
           set password  = p_new_pwd
              ,flag_change_pwd = 'N'
         where 1=1
           and login = upper(p_login)
        ;
        log_new(l_log_id,l_function,'update: кол-во: ' || sql%rowcount);
        commit;
        
        return 'done';
    exception
        when others then return 'fail';
    end; 
end;

function get_freight_list 
return t_xx_freight_list_table pipelined
as
    l_row       xx_disl_freight_list_v%rowtype;
begin
    for l_tmp in (select *
                    from xx_disl_freight_list_v
                  order by freight_name
                 )
    loop
        l_row.freight_name := l_tmp.freight_name;
        pipe row (l_row);
    end loop;
    
end;

function get_org_name_list 
return t_xx_org_list_table pipelined
as
