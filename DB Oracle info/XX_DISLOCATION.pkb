        l_row.cnt_axis_2 := l_json.get_string('cnt_axis_2');
        l_row.descr := l_json.get_string('descr');
        
        l_row.created_by := p_user_id;
        l_row.creation_date := sysdate;
        l_row.last_updated_by := p_user_id;
        l_row.last_update_date := sysdate;
        l_row.deleted := 'N';

        insert into xx_etw.xx_disl_fixing_device_rule  
        values l_row;   
    end loop;
 
--    if (p_rule_id is null) then
--        l_row.rule_id := xx_etw.xx_disl_railway_part_seq.nextval();
--        l_row.railway_id := l_json.get_string('railway_id');
