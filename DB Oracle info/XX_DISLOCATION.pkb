/*возвращает вагоны на Углеуральской без уведомлений*/
function get_cars_in_ugl
return t_xx_car_numbers pipelined
as
    l_row xx_disl_round.railcar_id%type;
begin
    for l_tmp in (select r.railcar_id               id
                    from xx_disl_round              r
                        ,xx_disl_station_history    st
                   where 1=1
                     and r.station_hist_id_in = st.station_hist_id
                     
                     and st.station_id = 1
                     and st.out_date is null
                     and r.notification_id is null
                     --and st.in_date is not null
                   order by
                         r.railcar_id 
                 )
    loop
        l_row := l_tmp.id;
        pipe row (l_row);
    end loop;
end;

function register_notification(
    p_user_id                       number,
    p_cars                          varchar2,
    p_notification_time_from        varchar2,
    p_notification_person_from      varchar2,
    p_notification_railway_number   varchar2,
    p_notification_time_to  varchar2,
    p_notification_person_to    number,
    p_notification_name     varchar2
) return varchar2
as
    l_function                  varchar2(100):='register_notification';
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval(); 
    l_notification_id           number;
    l_notification_time_from    date;
    l_notification_time_to      date;
    l_car_number                xx_disl_round.railcar_id%type;
    l_round_id                  number;
    l_date_arrive               varchar2(20);
    l_bandwagon_id              number;
    l_rOrder                    number;
    l_function_result           varchar2(100);
    l_in_date                   date;
    l_exists_notification       varchar2(1);
    
    l_cars_table_v              xx_dislocation.t_cars_table := xx_dislocation.t_cars_table();
    l_new_req_id_t              number;
    l_weight_net                number;
    
    l_car_add_info              t_xx_child_row_add_info;
begin
    log_new(l_log_id,l_function,'p_user_id='||p_user_id||' p_cars='||p_cars||' p_notification_time_from='||p_notification_time_from||' p_notification_person_from='||p_notification_person_from);
    
    begin
        l_notification_time_from := to_date(p_notification_time_from,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_notification_time_from := null;
    end;
    
    begin
        l_notification_time_to := to_date(p_notification_time_to,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_notification_time_to := null;
    end;
    
    l_notification_id := xx_disl_notifications_seq.nextval();
    log_new(l_log_id,l_function,'l_notification_id = '||l_notification_id);
    
    insert into xx_disl_notifications(notification_id
                                     ,notification_time_from
                                     ,person_from
                                     ,notification_railway_number
                                     ,notification_time_to
                                     ,notification_person_to
                                     ,created_by
                                     ,created_date
                                     )
    values(l_notification_id
          ,l_notification_time_from
          ,p_notification_person_from
          ,p_notification_railway_number
          ,l_notification_time_to
          ,p_notification_person_to
          ,p_user_id
          ,sysdate
          )
    ;
    log_new(l_log_id,l_function,'insert into xx_disl_notifications. кол-во='||sql%rowcount);
    
    for tmp in (select regexp_substr(p_cars,'[^$]+',1,level) text
                  from dual
               connect by level <= regexp_count(p_cars,'[^$]+')
               )
    loop
        l_car_number := regexp_substr(tmp.text,'[^|]+',1,1);
        log_new(l_log_id,l_function,'l_car_number='||l_car_number);
        
        l_round_id := returnLastRound(l_car_number);
        log_new(l_log_id,l_function,'l_round_id='||l_round_id);
        
        select decode(notification_id
                     ,null,'N'
                     ,'Y'
                     )
          into l_exists_notification
          from xx_disl_round
         where 1=1
           and round_id = l_round_id
        ;
        log_new(l_log_id,l_function,'l_exists_notification='||l_exists_notification);
        
        if (l_exists_notification='N') then
            /*проверяем есть ли приезд на Угли*/
            select sh.in_date
              into l_in_date
              from xx_disl_round                r
                  ,xx_disl_station_history      sh
             where 1=1
               and r.round_id = l_round_id
               and r.station_hist_id_in = sh.station_hist_id
            ;
            log_new(l_log_id,l_function,'l_in_date='||l_in_date);
            
            /*если стоит на подъездных путях на Водораздельную, то перемещаем в группу "Есть уведомление с ПСП"*/
            if (l_in_date is not null) then
                /*ищем дату приезда на Углеуральскую*/
                /*select to_char(date_arrive,'dd.mm.yyyy hh24:mi')
                  into l_date_arrive
                  from xx_disl_railcar_add_info
                 where 1=1
                   and round_id = l_round_id
                   and last_record = 'Y'
                ;
                log_new(l_log_id,l_function,' l_date_arrive='||l_date_arrive);*/
                /*ищем группу вагонов с датой прибытия в группе "Есть уведомление с ПСП"(id=-1)*/
                /*begin
                    select max(dw.bandwagon_id)
                      into l_bandwagon_id
                      from xx_disl_relations dr
                          ,xx_disl_bandwagon dw  
                     where 1=1
                       and dr.parent_id = -1
                       and dr.parent_type = 'bandwagon'
                       and dr.flag_come = 'N'
                       and dr.type = 'bandwagon'
                       and dr.id = dw.bandwagon_id
                       and dw.name = l_date_arrive
                    ;
                exception
                    when others then l_bandwagon_id:=null; 
                end;*/
                /*если такой гр. вагонов нет, то создаем и помещаем её на станцию*/
                /*if (l_bandwagon_id is null) then
                    insert into xx_disl_bandwagon
                    values (xx_disl_bandwagon_seq.nextval,l_date_arrive)
                    returning bandwagon_id into l_bandwagon_id
                    ;
                            
                    l_rOrder := returnMaxOrder(-1,'bandwagon','N')+1;
                    insert into xx_disl_relations
                    values ( l_bandwagon_id
                            ,'bandwagon'
                            ,-1
                            ,'bandwagon'
                            ,l_rOrder
                            ,'N'
                           )
                    ;
                end if;
                log_new(l_log_id,l_function,' l_bandwagon_id ='||l_bandwagon_id);*/
                
                /*l_rOrder := returnMaxOrder(l_bandwagon_id,'bandwagon','N')+1;
                update xx_disl_relations
                   set parent_id = l_bandwagon_id
                      ,parent_type = 'bandwagon'
                      ,r_order = l_rOrder
                 where 1=1
                   and id = l_car_number
                   and type = 'railcar'
                   and flag_come = 'N'
                ;
                log_new(l_log_id,l_function,' update xx_disl_relations. Кол-во='||sql%rowcount);*/
                /*26.01.2016 Кулиняк Л.Я. Решили что в группу будем складывать по вагонам без группировки по дате прибытия*/
                
                l_rOrder := returnMaxOrder(-1,'bandwagon','N')+1;
                update xx_disl_relations
                   set parent_id = -1
                      ,parent_type = 'bandwagon'
                      ,r_order = l_rOrder
                 where 1=1
                   and id = l_car_number
                   and type = 'railcar'
                   and flag_come = 'N'
                ;
                log_new(l_log_id,l_function,'update xx_disl_relations. кол-во='||sql%rowcount);
                
                /*убираем вагон с Углей*/
                delete 
                  from xx_disl_relations
                 where 1=1
                   and id = l_car_number
                   and type = 'railcar'
                   and flag_come = 'Y'  
                ;
                log_new(l_log_id,l_function,'delete from xx_disl_relations. кол-во='||sql%rowcount);
            end if;
                     
            update xx_disl_round
               set notification_id = l_notification_id
             where 1=1
               and round_id = l_round_id
            ;
            log_new(l_log_id,l_function,'update xx_disl_round. Кол-во='||sql%rowcount);
            
            begin
                l_car_add_info := get_car_add_info_with_conts(l_round_id);
                l_weight_net := l_car_add_info.weight_net;
            exception
                when others then l_weight_net := 0;
            end;
            
            if l_weight_net > 0 then
                l_cars_table_v.extend;
                l_cars_table_v(l_cars_table_v.last) := l_car_number;
            end if;
        end if;
    end loop;
    
    delete 
      from xx_disl_notification_save
     where 1=1
       and notification_name = p_notification_name
    ;
    log_new(l_log_id,l_function,'delete xx_disl_notification_save: кол-во='||sql%rowcount);
    
    if l_cars_table_v.count > 0 then
        l_new_req_id_t := xx_dislocation.create_request(p_user_id,14,11,l_cars_table_v);
        log_new(l_log_id,l_function,'create_request. l_new_req_id_t = '||l_new_req_id_t);
    end if;
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function get_saved_notifications
return t_xx_id_name_table pipelined
as
    l_row           t_xx_id_name_row;
begin
    for l_tmp in (select *
                    from xx_disl_notification_save
                 )
    loop
        l_row.name := l_tmp.notification_name;
        pipe row (l_row);
    end loop;
end;

function save_notification(p_user_id number,p_notification_name varchar2,p_cars varchar2,p_notification_time_from varchar2,p_notification_person_from varchar2,p_notification_railway_number varchar2,p_notification_time_to varchar2,p_notification_person_to number)
return varchar2
as
    l_function                  varchar2(100):='save_notification:';
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval();
begin
    log_new(l_log_id,l_function,' p_user_id='||p_user_id||' p_notification_name='||p_notification_name||' p_cars='||p_cars||' p_notification_time_from='||p_notification_time_from||' p_notification_person_from='||p_notification_person_from
       ||' p_notification_railway_number='||p_notification_railway_number||' p_notification_time_to='||p_notification_time_to||' p_notification_person_to='||p_notification_person_to
       );
    
    if (p_notification_name is null or (p_cars is null and p_notification_time_from is null and p_notification_person_from is null and p_notification_railway_number is null and p_notification_time_to is null and p_notification_person_to is null))
    then 
        return 'fail';
    end if;
    
    update xx_disl_notification_save
       set cars = p_cars
          ,notification_time_from = p_notification_time_from
          ,notification_person_from = p_notification_person_from
          ,notification_railway_number = p_notification_railway_number
          ,notification_time_to = p_notification_time_to
          ,notification_person_to = p_notification_person_to
     where 1=1
       and notification_name = p_notification_name
    ;
    if (sql%rowcount = 0) then
        insert into xx_disl_notification_save
        values(p_notification_name
              ,p_cars
              ,p_notification_time_from
              ,p_notification_person_from
              ,p_notification_railway_number
              ,p_notification_time_to
              ,p_notification_person_to
              ,sysdate
              )
        ;
    end if;  
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function load_notification(p_notification_name varchar2)
return t_xx_notification_table pipelined
as
    l_function                  varchar2(100):='load_notification:';
    l_row                       xx_disl_notification_save%rowtype;
begin
    select *
      into l_row
      from xx_disl_notification_save
     where 1=1
       and notification_name = p_notification_name
    ;
    pipe row (l_row);  
end;

function del_notification(p_notification_name varchar2)
return varchar2
as
begin
    delete 
      from xx_disl_notification_save
     where 1=1
       and notification_name = p_notification_name
    ;
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

procedure del_old_notification(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as
begin
    delete 
      from xx_etw.xx_disl_notification_save
     where 1=1
       and created_date < sysdate - 10 
    ;
    commit;
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end;

function get_notifications_gu(
    p_beg_date varchar2,
    p_end_date varchar2,
    p_type_gu in varchar2 default '2b'
    )
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
    
    l_beg_date date;
    l_end_date date;
begin
    l_beg_date := trunc(sysdate - /*10*/ 30);  l_end_date := trunc(sysdate + 1);

    for tmp in (
        select xdng.notification_id
              ,xdng.not_number||' от '||to_char(xdng.not_time,'dd.mm.yyyy hh24:mi') num
              ,not_time
              ,not_number
              ,'2b' as type_gu
          from xx_etw.xx_disl_notifications_gu      xdng
         where 1=1
           and xdng.not_time between l_beg_date and l_end_date
           and p_type_gu = '2b'
         union all
         select xdng.notification_id
              ,xdng.not_number||' от '||to_char(xdng.not_time,'dd.mm.yyyy hh24:mi') num
              ,not_time
              ,not_number
              ,'2d' as type_gu
          from xx_etw.xx_disl_notifications_gu_2d      xdng
         where 1=1
           and xdng.not_time between l_beg_date and l_end_date
           and p_type_gu = '2d'
         order by
               not_time desc,
               not_number desc
         
               )
    loop
        l_row.id := tmp.notification_id;   
        l_row.name := tmp.num;
        
        pipe row (l_row);
    end loop;
end;

function get_notification_gu(
    p_not_id number, p_type_gu in varchar2
) return t_xx_notification_gu_table pipelined
as
    l_row       t_xx_notification_gu_row;
begin
    for l_not_gu in (
        select ng.notification_id
              ,ng.not_number
              ,ng.not_time
              ,ng.not_person_from
              ,ng.not_comment
              ,ng.not_time_fact
              ,ng.not_person_to
              ,ecen.cargo_end_notification_number
              ,ecen.crg_state
              ,ng.crg_pcalid -- -- add 11.11.2024 BekmansurovRR по наряду 0000068904 
          from xx_etw.xx_disl_notifications_gu      ng
              ,xx_etw.xx_disl_notification_gu_link  ngl
              ,xx_etw.etw_cargo_end_ntf             ecen
         where 1=1
           and ng.notification_id = p_not_id
           and ng.notification_id = ngl.notification_id(+)
           and ngl.front_end_id = ecen.front_end_id(+)
           and p_type_gu = '2b'
          union all
          select ng.notification_id
              ,ng.not_number
              ,ng.not_time
              ,ng.not_person_from
              ,ng.not_comment
              ,ng.not_time_fact
              ,ng.not_person_to
              ,ecen.doc_num
              ,ecen.state_name
              ,ng.crg_pcalid -- -- add 11.11.2024 BekmansurovRR по наряду 0000068904 
          from xx_etw.xx_disl_notifications_gu_2d      ng
              ,xx_etw.xx_disl_notification_gu2d_link  ngl
              ,xx_etw.etran_gu2d_data               ecen
         where 1=1
           and ng.notification_id = p_not_id
           and ng.notification_id = ngl.notification_id(+)
           and ngl.front_end_id = ecen.front_end_id(+)
           and p_type_gu = '2d'
    ) loop
        l_row.notification_id := l_not_gu.notification_id;  
        l_row.not_number := l_not_gu.not_number;
        l_row.not_time := to_char(l_not_gu.not_time,'dd.mm.yyyy hh24:mi');
        l_row.not_person_from := l_not_gu.not_person_from;
        l_row.not_comment := l_not_gu.not_comment; 
        l_row.not_time_fact := to_char(l_not_gu.not_time_fact,'dd.mm.yyyy hh24:mi');
        l_row.not_person_to := l_not_gu.not_person_to;
        l_row.not_number_etran := l_not_gu.cargo_end_notification_number;
        l_row.not_state_etran := l_not_gu.crg_state;
        l_row.crg_pcalid := l_not_gu.crg_pcalid; -- -- add 11.11.2024 BekmansurovRR по наряду 0000068904 
       
        if p_type_gu = '2b' then
            select listagg(r.railcar_id||'#'||r.round_id,'|') within group (order by cng.pk_id)
              into l_row.cars
              from xx_disl_car_notif_gu         cng
                  ,xx_disl_round                r
             where 1=1
               and cng.notification_id = l_not_gu.notification_id
               and cng.round_id = r.round_id;
        elsif p_type_gu = '2d' then
            select listagg(r.railcar_id||'#'||r.round_id,'|') within group (order by cng.pk_id)
              into l_row.cars
              from xx_disl_car_notif_gu_2d         cng
                  ,xx_disl_round                r
             where 1=1
               and cng.notification_id = l_not_gu.notification_id
               and cng.round_id = r.round_id;

        end if;
        pipe row (l_row);
    end loop;
end;

function register_notification_gu(p_data in t_regit_row)
    
return varchar2 
as
    l_function                  varchar2(100):='register_notification_gu';
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval();
    
    l_not_row                   xx_etw.xx_disl_notifications_gu%rowtype;
    l_round_row                 xx_etw.xx_disl_car_notif_gu%rowtype;
    
    --
    l_gu2d_row                   xx_etw.xx_disl_notifications_gu_2d%rowtype;
    l_gu2d_car_row               xx_etw.xx_disl_car_notif_gu_2d%rowtype;
        
    l_notification_time         date;
    l_notification_time_fact    date;
    l_round_id                  number;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_data.user_id
                             ||' p_not_id='||p_data.not_id
                             ||' p_cars='||p_data.cars
                             ||' p_notification_time = '||p_data.notification_time
                             ||' p_notification_person_from = '||p_data.notification_person_from
                             ||' p_comment = '||p_data.pcomment
                             ||' p_notification_time_fact = '||p_data.notification_time_fact
                             ||' p_notification_person_to = '||p_data.notification_person_to
                             ||' p_crg_pcalid = '||p_data.crg_pcalid
                             ||' p_gu_type = '||p_data.gu_type
                             );
    
    -- Сохраняем данные для ГУ-2б
    if upper(p_data.gu_type) = '2B' then 
        log_new(l_log_id,l_function,'Регистрируем 2Б....');
    
        begin
            l_notification_time := to_date(p_data.notification_time,'dd.mm.yyyy hh24:mi');
        exception
            when others then l_notification_time := null;
        end;
        
        begin
            l_notification_time_fact := to_date(p_data.notification_time_fact,'dd.mm.yyyy hh24:mi');
        exception
            when others then l_notification_time_fact := null;
        end;
       
        if (p_data.not_id is null) then
            l_not_row.notification_id := xx_etw.xx_disl_notifications_gu_seq.nextval();
        else
            l_not_row.notification_id := p_data.not_id;
        end if;
        
        l_not_row.not_number := p_data.not_number;
        l_not_row.not_time := l_notification_time;
        l_not_row.not_person_from := p_data.notification_person_from;
        l_not_row.not_comment := p_data.pcomment;
        l_not_row.not_time_fact := l_notification_time_fact;
        l_not_row.not_person_to := p_data.notification_person_to;
        l_not_row.created_by := p_data.user_id;
        l_not_row.created_date := sysdate;
        l_not_row.crg_pcalid := p_data.crg_pcalid;
        
        log_new(l_log_id,l_function,'l_not_row.notification_id: '||l_not_row.notification_id);
        log_new(l_log_id,l_function,'l_not_row.not_number: '||l_not_row.not_number);
        
        delete
          from xx_disl_notifications_gu
         where notification_id = l_not_row.notification_id;
         
        insert into xx_etw.xx_disl_notifications_gu
        values l_not_row;  
        
        delete 
          from xx_etw.xx_disl_car_notif_gu
         where notification_id = l_not_row.notification_id;
        
        for l_cars in (
            select regexp_substr(p_data.cars,'[^|]+',1,level) car_number
              from dual
           connect by level <= regexp_count(p_data.cars,'[^|]+'))
        loop
            l_round_row := null;
            
            log_new(l_log_id,l_function,'l_cars.car_number: '||l_cars.car_number);
            
            l_round_id := returnlastround(l_cars.car_number);
            log_new(l_log_id,l_function,'l_round_id: '||l_round_id);
            
            update xx_etw.xx_disl_car_notif_gu
               set last_record = 'N' 
             where 1=1
               and round_id = l_round_id
               and last_record = 'Y';
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_car_notif_gu: '||sql%rowcount);
            
             
            l_round_row.pk_id := xx_etw.xx_disl_car_notif_gu_seq.nextval();
            l_round_row.round_id := l_round_id;
            l_round_row.notification_id := l_not_row.notification_id;
            l_round_row.last_record := 'Y';
            
            log_new(l_log_id,l_function,'l_round_row.pk_id: '||l_round_row.pk_id);
            log_new(l_log_id,l_function,'l_round_row.round_id: '||l_round_row.round_id);
            log_new(l_log_id,l_function,'l_round_row.notification_id: '||l_round_row.notification_id);
            log_new(l_log_id,l_function,'l_round_row.last_record: '||l_round_row.last_record);
            
            insert into xx_etw.xx_disl_car_notif_gu
            values l_round_row;
        end loop;
    -- Сохраняем данные для ГУ-2д
    elsif upper(p_data.gu_type) = '2D' then 
        log_new(l_log_id,l_function,'Регистрируем 2Д....');
        begin
            l_notification_time := to_date(p_data.notification_time,'dd.mm.yyyy hh24:mi');
        exception
            when others then l_notification_time := null;
        end;
        
        begin
            l_notification_time_fact := to_date(p_data.notification_time_fact,'dd.mm.yyyy hh24:mi');
        exception
            when others then l_notification_time_fact := null;
        end;
       
        if (p_data.not_id is null) then
            l_gu2d_row.notification_id := xx_etw.xx_disl_notifications_gu2d_seq.nextval();
        else
            l_gu2d_row.notification_id := p_data.not_id;
        end if;
        
        l_gu2d_row.not_number := p_data.not_number;
        l_gu2d_row.not_time := l_notification_time;
        l_gu2d_row.not_person_from := p_data.notification_person_from;
        l_gu2d_row.not_comment := p_data.pcomment;
        l_gu2d_row.not_time_fact := l_notification_time_fact;
        l_gu2d_row.not_person_to := p_data.notification_person_to;
        l_gu2d_row.created_by := p_data.user_id;
        l_gu2d_row.created_date := sysdate;
        l_gu2d_row.crg_pcalid := p_data.crg_pcalid;
        
        log_new(l_log_id,l_function,'l_gu2d_row.notification_id: '||l_gu2d_row.notification_id);
        log_new(l_log_id,l_function,'l_gu2d_row.not_number: '||l_gu2d_row.not_number);
        
        delete
          from xx_disl_notifications_gu_2d
         where notification_id = l_gu2d_row.notification_id;
         
        insert into xx_etw.xx_disl_notifications_gu_2d
        values l_gu2d_row;  
        
        delete 
          from xx_etw.xx_disl_car_notif_gu_2d
         where notification_id = l_gu2d_row.notification_id;
        
        for l_cars in (
            select regexp_substr(p_data.cars,'[^|]+',1,level) car_number
              from dual
           connect by level <= regexp_count(p_data.cars,'[^|]+'))
        loop
            l_gu2d_car_row := null;
            
            log_new(l_log_id,l_function,'l_cars.car_number: '||l_cars.car_number);
            
            l_round_id := returnlastround(l_cars.car_number);
            log_new(l_log_id,l_function,'l_round_id: '||l_round_id);
            
            update xx_etw.xx_disl_car_notif_gu_2d
               set last_record = 'N' 
             where 1=1
               and round_id = l_round_id
               and last_record = 'Y';
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_car_notif_gu: '||sql%rowcount);
            
             
            l_gu2d_car_row.pk_id := xx_etw.xx_disl_car_notif_gu2d_seq.nextval();
            l_gu2d_car_row.round_id := l_round_id;
            l_gu2d_car_row.notification_id := l_gu2d_row.notification_id;
            l_gu2d_car_row.last_record := 'Y';
            
            log_new(l_log_id,l_function,'l_gu2d_car_row.pk_id: '||l_gu2d_car_row.pk_id);
            log_new(l_log_id,l_function,'l_gu2d_car_row.round_id: '||l_gu2d_car_row.round_id);
            log_new(l_log_id,l_function,'l_gu2d_car_row.notification_id: '||l_gu2d_car_row.notification_id);
            log_new(l_log_id,l_function,'l_gu2d_car_row.last_record: '||l_gu2d_car_row.last_record);
            
            insert into xx_etw.xx_disl_car_notif_gu_2d
            values l_gu2d_car_row;
        end loop;
    end if;
    
    commit;
    return 'done';
exception
    when others then 
        log_new(l_log_id,l_function,'Error: '||sqlerrm);
        rollback; return 'fail';
end;

-- Вывод договора на эксплуатацию путей для формы 2ГУ
function get_contract_default_for_gu return t_xx_contract_gu_table pipelined
is
    l_row       t_xx_contract_gu_row;
begin

    for cur in (
        --select id, name  from (select 1558487306 /*1523455540*/ as id, '№4/17' as name from dual)
        select x.pcal_doc_num as name, x.doc_id as id from table (xx_etw.etw_get_pcal_list_pkg.get_pcal_list_pipe) x
    )
    loop
        if cur.NAME like '%4/17' then
            l_row.selected := 'Y';
        else 
            l_row.selected := 'N';
        end if; 
        l_row.id := cur.ID;
        l_row.name := cur.NAME;
        pipe row (l_row);
        
    end loop;
end;
-- Отправка уведомления ГУ (2Б или 2Д) в Этран
function export_gu_to_etran (p_user_id   in number,
                             p_not_id    in varchar2,
                             p_pcalid    in number default null,
                             p_type_gu   in varchar2) return varchar2
is
    l_function                          varchar2(100):='export_gu_to_etran';
    l_log_id                            number := xx_etw.xx_disl_log_seq.nextval();
    ---
    l_return varchar2(4000);
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_not_id = '||p_not_id
                             ||' p_type_gu = '||p_type_gu);
    if p_type_gu = '2b' then 
        -- Отправка уведомления ГУ (2Б) в Этран
        l_return := export_notif_etran( p_user_id, p_not_id, p_pcalid);
    elsif p_type_gu = '2d' then 
        -- Отправка уведомления ГУ (2Д) в Этран
        l_return := export_gu2d_etran( p_user_id, p_not_id, p_pcalid);
    end if;
    
    return l_return;
end;      

-- Отправка уведомления ГУ (2Д) в Этран
function export_gu2d_etran (p_user_id   in number,
                            p_not_id    in varchar2,
                            p_pcalid    in number default null)
    return varchar2
is
    l_function                          varchar2(100):='export_gu2d_etran';
    l_log_id                            number := xx_etw.xx_disl_log_seq.nextval();
    ---
    l_not_row                           xx_etw.xx_disl_notifications_gu_2d%rowtype;
    ---
    l_row_d                             etran_gu2d_data%rowtype;
    l_row_wag                           etran_gu2d_data_wags%rowtype;
    ---
    x_front_end_id                      number;
    l_result                            varchar2(4000);
    x_return_status                     varchar2(10):='S';
    x_message                           varchar2(4000);
    x_list_cont                         varchar2(4000);
begin
    

    select *
      into l_not_row
      from xx_etw.xx_disl_notifications_gu_2d
     where notification_id = p_not_id;   
    
    begin   
        select front_end_id
          into l_row_d.front_end_id
          from xx_etw.xx_disl_notification_gu2d_link
         where notification_id = l_not_row.notification_id;     
    exception
        when no_data_found then l_row_d.front_end_id := null;
    end;    
    
    if l_row_d.front_end_id is not null then return 'fail$Уведомление уже создано ранее!'; end if;
    
    -- ETRAN_GU2D_DATA  - уведомление
    --  – вагоны
    l_row_d.front_end_id := etw_front_end_id_s.nextval;
    
    insert into etran_gu2d_data values l_row_d;

    insert into xx_etw.xx_disl_notification_gu2d_link
        values (p_not_id,l_row_d.front_end_id); 
    
    -- Добавляем вагоны для уведомления
    for car in (
        select rownum as rwn, 
               car.railcar_id as car_number,
                round(nvl((select cnsi.car_length 
                            from xx_etw.etw_car_nsi cnsi 
                           where 1=1 
                                  and cnsi.car_number = car.railcar_id),14)/14,2) as cond_car_length
          from xx_disl_car_notif_gu_2d x,
               xx_disl_round car
         where x.notification_id = p_not_id
               and x.round_id = car.round_id
               and x.last_record  = 'Y'
    )
    loop
        l_row_wag := null;
        
        l_row_wag.front_end_id := l_row_d.front_end_id;
        l_row_wag.car_order := car.rwn;
        l_row_wag.car_number := car.car_number;
        l_row_wag.car_length := car.cond_car_length;
        
        insert into etran_gu2d_data_wags values l_row_wag;
    end loop;
    
    -- Отправляем в этран
    /*etran_gu2d_pkg.set_gu2d_api(p_front_end_id      => l_row_d.front_end_id, 
                                px_return_status    => x_return_status, 
                                px_message          => x_message);
    */
    if (x_return_status = 'S') then
        
        l_result := 'done';
        
    else
        l_result := 'fail|'||x_message;
    end if;
    
    
    return l_result;
exception
    when others then rollback; 
    log_new(l_log_id,l_function,'EXCEPTION.OTHERS = ' || sqlerrm); 
    return 'fail|'||substr(sqlerrm,1,200);
end;                        

function export_notif_etran(
    p_user_id                   in number,
    p_not_id                    in varchar2,
    p_pcalid                    in number default null)
return varchar2 
as
    l_function                          varchar2(100):='export_notif_etran';
    l_log_id                            number := xx_etw.xx_disl_log_seq.nextval();
    
    l_not_row                           xx_etw.xx_disl_notifications_gu%rowtype;
    l_last_invoice_id                   number;
    
    l_result                            varchar2(4000);
    x_return_status                     varchar2(10);
    x_message                           varchar2(4000);
    x_list_cont                         varchar2(4000);
    r_cargo_end_ntf                     xx_etw.etw_cargo_end_ntf%rowtype;
    r_cargo_end_ntf_car                 xx_etw.etw_cargo_end_ntf_car%rowtype;
    r_cargo_end_ntf_car_cont            xx_etw.etw_cargo_end_ntf_car_cont%rowtype;
    r_cargo_end_ntf_car_csl             xx_etw.etw_cargo_end_ntf_car_csl%rowtype;
    r_cargo_end_ntf_cont_csl            xx_etw.etw_cargo_end_ntf_car_cont_csl%rowtype; -- add 04.06.2026 0000118082
    ---
    l_count_cont                        number;
    l_car_type                          varchar2(240);                     
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_not_id = '||p_not_id);
    
    log_new(l_log_id,l_function,'p_pcalid = '||p_pcalid);                         
    
    select *
      into l_not_row
      from xx_etw.xx_disl_notifications_gu
     where notification_id = p_not_id;   
    
    begin   
        select front_end_id
          into r_cargo_end_ntf.front_end_id
          from xx_etw.xx_disl_notification_gu_link
         where notification_id = l_not_row.notification_id;     
    exception
        when no_data_found then r_cargo_end_ntf.front_end_id := null;
    end;              
                             
    if (r_cargo_end_ntf.front_end_id is null) then
        xx_etw.etw_oi_pkg.get_front_end_id(r_cargo_end_ntf.front_end_id); 
        
        insert into xx_etw.xx_disl_notification_gu_link
        values (p_not_id,r_cargo_end_ntf.front_end_id);  
    else
        delete
          from xx_etw.etw_cargo_end_ntf
         where front_end_id = r_cargo_end_ntf.front_end_id;
         
        delete
          from xx_etw.etw_cargo_end_ntf_car
         where front_end_id = r_cargo_end_ntf.front_end_id;
         
        delete
          from xx_etw.etw_cargo_end_ntf_car_cont
         where front_end_id = r_cargo_end_ntf.front_end_id;
         
        delete
          from xx_etw.etw_cargo_end_ntf_car_csl
         where front_end_id = r_cargo_end_ntf.front_end_id;
        
        delete
          from xx_etw.etw_cargo_end_ntf_car_cont_csl
         where front_end_id = r_cargo_end_ntf.front_end_id;
         
    end if;
    
 
    log_new(l_log_id,l_function,'r_cargo_end_ntf.front_end_id = ' || r_cargo_end_ntf.front_end_id); 
    
    r_cargo_end_ntf.crg_date_create := l_not_row.not_time;
    r_cargo_end_ntf.crg_station_code := 76820;
    r_cargo_end_ntf.crg_station_name := 'УГЛЕУРАЛЬСКАЯ';
    r_cargo_end_ntf.crg_org_id := '33888';
    r_cargo_end_ntf.crg_org_okpo := '00203803';
    r_cargo_end_ntf.crg_org_name := 'Публичное акционерное общество "Метафракс"';
    r_cargo_end_ntf.crg_place_transfer := 'ПСП';
    r_cargo_end_ntf.crg_front_load := 'Владельца';
    r_cargo_end_ntf.crg_way := 'ОАО "РЖД"';
    r_cargo_end_ntf.crg_loc := 'ПАО "Метафракс"';
    r_cargo_end_ntf.crg_pcalid  := nvl(p_pcalid,l_not_row.crg_pcalid); -- add 11.11.2024 BekmansurovRR по наряду 0000068904
                                   -- 1523455540; -- договор "4/17" -- add 16.10.2024 BekmansurovRR из-за ошибки "Необходимо выбрать договор ЭП"
    --r_cargo_end_ntf.crg_loc := apps.xx_orgname_pkg.s_name(81,sysdate);
    
    log_new(l_log_id,l_function,'r_cargo_end_ntf.crg_pcalid = ' || r_cargo_end_ntf.crg_pcalid); 
    
    
    insert into xx_etw.etw_cargo_end_ntf
    values r_cargo_end_ntf;  
    
    /* Вагоны*/
    for l_cars in (
        select round_id
              ,row_number() over(order by pk_id) ord
          from xx_etw.xx_disl_car_notif_gu
         where notification_id = l_not_row.notification_id and round_id > 0
         order by
               pk_id)  
    loop
        l_count_cont :=0; l_car_type := null;
        r_cargo_end_ntf_car := NULL;
        r_cargo_end_ntf_car.front_end_id := r_cargo_end_ntf.front_end_id;
        
        r_cargo_end_ntf_car.car_order := l_cars.ord;
        log_new(l_log_id,l_function,'ord ='||l_cars.ord||' l_cars.round_id = ' || l_cars.round_id);
        select railcar_id
          into r_cargo_end_ntf_car.car_number
          from xx_etw.xx_disl_round
         where round_id = l_cars.round_id; 
         
        r_cargo_end_ntf_car.car_operation_id := 1;
        r_cargo_end_ntf_car.car_operation_name := 'Погрузка';   
        
        r_cargo_end_ntf_car.car_remark := 'Есть договор перевозки'; 
        
        begin 
            select enf.fr_code_etsng
                  ,enf.fr_name
                  ,ei.invoice_id
                  ,ei.inv_number
              into r_cargo_end_ntf_car.car_freight_code
                  ,r_cargo_end_ntf_car.car_freight_name
                  ,r_cargo_end_ntf_car.car_invoice_id
                  ,r_cargo_end_ntf_car.car_invoice_number
              from xx_etw.xx_disl_railcar_add_info      rai
                  ,xx_etw.xx_disl_railcar_add_info_inv  raii
                  ,xx_etw.etw_invoice                   ei
                  ,xx_etw.etw_inv_freight               eif
                  ,xx_etw.etw_nsi_freight               enf
             where 1=1
               and rai.add_info_id = (
                    select max(add_info_id)
                      from xx_etw.xx_disl_railcar_add_info    
                     where round_id = l_cars.round_id
                       and add_info_type in ('S','T'))
               and rai.add_info_id = raii.add_info_id
               
               and raii.invoice_id = ei.invoice_id 
               and ei.front_end_id = eif.front_end_id(+)
               and eif.freight_code = enf.fr_code_etsng(+)
               and rownum = 1;
        exception
            when no_data_found then null;
        end;  
        
        if (r_cargo_end_ntf_car.car_freight_code is null) then
            l_last_invoice_id := null;
            
            select max(ei.invoice_id)
              into l_last_invoice_id
              from xx_etw.etw_invoice   ei
                  ,xx_etw.etw_inv_car   ecar
             where 1=1
               and inv_from_station_code = '768207'
               and ei.front_end_id = ecar.front_end_id
               and ecar.car_number = r_cargo_end_ntf_car.car_number;
            
            begin     
                select distinct
                       enf.fr_code_etsng
                      ,enf.fr_name
                  into r_cargo_end_ntf_car.car_freight_code
                      ,r_cargo_end_ntf_car.car_freight_name
                  from xx_etw.etw_invoice                   ei
                      ,xx_etw.etw_inv_freight               eif
                      ,xx_etw.etw_nsi_freight               enf
                 where 1=1               
                   and ei.invoice_id = l_last_invoice_id
                   and ei.front_end_id = eif.front_end_id(+)
                   and eif.freight_code = enf.fr_code_etsng(+);
            exception
                when no_data_found then
                    r_cargo_end_ntf_car.car_freight_code := '421034';
                    r_cargo_end_ntf_car.car_freight_name := 'ВАГОНЫ ЖЕЛЕЗНОДОРОЖНЫЕ ВСЯКИЕ, ПЕРЕВОЗИМЫЕ НА СВОИХ ОСЯХ';     
            end;
        end if;
        
        
        -- add 01.11.2023 
        -- Если отправляют платформу без контейнеров
        log_new(l_log_id,l_function,'==> Если отправляют платформу без контейнеров: ');
        begin
            
            SELECT   CAR_TYPE into l_car_type
              FROM   xx_etw.xx_disl_railcar_add_info
             WHERE   add_info_id = (SELECT   MAX (add_info_id)
                                      FROM   xx_etw.xx_disl_railcar_add_info
                                     WHERE   round_id = l_cars.round_id);
            
            select count(*) into l_count_cont
              from xx_etw.xx_disl_cont_history_cur
             where 1=1
               and place_id = l_cars.round_id
               and place_type = 'railcar';
            
            if nvl(l_count_cont,0) = 0 and l_car_type like '%ПЛ%' then
            
                r_cargo_end_ntf_car.car_operation_id := 62;
                r_cargo_end_ntf_car.car_operation_name := 'Без операции'; 
                
                r_cargo_end_ntf_car.car_freight_code := '421195';
                r_cargo_end_ntf_car.car_freight_name := 'ВАГОНЫ ЖЕЛЕЗНОДОРОЖНЫЕ ПОРОЖНИЕ, ПЕРЕВОЗИМЫЕ НА СВОИХ ОСЯХ, ПЕРЕСЫЛАЕМЫЕ В РЕМОНТ ИЛИ ИЗ РЕМОНТА';
            end if;
            
        exception when others then null;
        end;
        
        insert into xx_etw.etw_cargo_end_ntf_car
        values r_cargo_end_ntf_car; 
        
        log_new(l_log_id,l_function,'=> for l_conts');
        
        for l_conts in (
            select cont_round_id
              from xx_etw.xx_disl_cont_history_cur
             where 1=1
               and place_id = l_cars.round_id
               and place_type = 'railcar')
        loop
            r_cargo_end_ntf_car_cont := NULL;
            r_cargo_end_ntf_car_cont.front_end_id := r_cargo_end_ntf.front_end_id;
            r_cargo_end_ntf_car_cont.car_order := r_cargo_end_ntf_car.car_order;
            
            select trim(cont_number)
              into r_cargo_end_ntf_car_cont.cont_number
              from xx_etw.xx_disl_cont_round
             where cont_round_id = l_conts.cont_round_id; 
            
            begin
                select distinct
                       --eicont.cont_tonnage -- rem 23.10.2020 BekmasnurovRR 
                                             -- При отпр.уведомления в этран возникала ошибка "В справочнике отсутствует значение contTonnage..."
                                             -- Раньше передавалось значение "грузоподьемности", поменял на cont_tonnage_id
                       eicont.cont_tonnage_id as cont_tonnage -- add 23.10.2020 BekmasnurovRR 
                      ,eicont.cont_type_big
                      ,eicont.cont_size_big
                      ,enf.fr_code_etsng
                      ,enf.fr_name
                      ,ei.invoice_id
                      ,ei.inv_number
                  into r_cargo_end_ntf_car_cont.cont_tonnage
                      ,r_cargo_end_ntf_car_cont.cont_type_big
                      ,r_cargo_end_ntf_car_cont.cont_size_big
                      ,r_cargo_end_ntf_car_cont.cont_freight_code
                      ,r_cargo_end_ntf_car_cont.cont_freight_name
                      ,r_cargo_end_ntf_car_cont.cont_invoice_id
                      ,r_cargo_end_ntf_car_cont.cont_invoice_number
                  from xx_etw.xx_disl_cont_add_info         cai
                      ,xx_etw.etw_invoice                   ei
                      ,xx_etw.etw_inv_cont                  eicont
                      ,xx_etw.etw_inv_freight               eif
                      ,xx_etw.etw_nsi_freight               enf
                 where 1=1
                   and cai.add_info_id = (
                        select max(add_info_id)
                          from xx_etw.xx_disl_cont_add_info    
                         where cont_round_id = l_conts.cont_round_id
                           and add_info_type in ('S','T'))
                   
                   and eicont.cont_number = r_cargo_end_ntf_car_cont.cont_number
                   
                   and cai.invoice_id = ei.invoice_id 
                   and ei.front_end_id = eicont.front_end_id(+)
                   and ei.front_end_id = eif.front_end_id(+)
                   and eif.freight_code = enf.fr_code_etsng(+);
            exception
                when no_data_found then 
                    begin
                        l_last_invoice_id := null;
                        
                        select max(ei.invoice_id)
                          into l_last_invoice_id
                          from xx_etw.etw_invoice                   ei
                              ,xx_etw.etw_inv_cont                  eicont
                         where 1=1
                           and inv_from_station_code = '768207'
                           and ei.front_end_id = eicont.front_end_id
                           and eicont.cont_number = r_cargo_end_ntf_car_cont.cont_number;
                           
                        select distinct
                               --eicont.cont_tonnage
                               eicont.cont_tonnage_id as cont_tonnage -- add 23.10.2020 BekmasnurovRR 
                              ,eicont.cont_type_big
                              ,eicont.cont_size_big
                              ,enf.fr_code_etsng
                              ,enf.fr_name
                          into r_cargo_end_ntf_car_cont.cont_tonnage
                              ,r_cargo_end_ntf_car_cont.cont_type_big
                              ,r_cargo_end_ntf_car_cont.cont_size_big
                              ,r_cargo_end_ntf_car_cont.cont_freight_code
                              ,r_cargo_end_ntf_car_cont.cont_freight_name
                          from xx_etw.etw_invoice                   ei
                              ,xx_etw.etw_inv_cont                  eicont
                              ,xx_etw.etw_inv_freight               eif
                              ,xx_etw.etw_nsi_freight               enf
                         where 1=1
                           and ei.invoice_id = l_last_invoice_id
                           and ei.front_end_id = eicont.front_end_id(+)
                           and ei.front_end_id = eif.front_end_id(+)
                           and eif.freight_code = enf.fr_code_etsng(+);
                    exception
                        when no_data_found then 
                            begin
                                l_last_invoice_id := null;
                                
                                select max(ei.invoice_id)
                                  into l_last_invoice_id
                                  from xx_etw.etw_invoice                   ei
                                      ,xx_etw.etw_inv_cont                  eicont
                                 where 1=1
                                   and ei.front_end_id = eicont.front_end_id
                                   and eicont.cont_number = r_cargo_end_ntf_car_cont.cont_number;
                                log_new(l_log_id,l_function,
                                                  ' l_last_invoice_id = ' || l_last_invoice_id
                                                ||' r_cargo_end_ntf_car_cont.cont_number = ' || r_cargo_end_ntf_car_cont.cont_number
                                       ); 
                                select distinct
                                       --eicont.cont_tonnage
                                       eicont.cont_tonnage_id as cont_tonnage -- add 23.10.2020 BekmasnurovRR 
                                      ,eicont.cont_type_big
                                      ,eicont.cont_size_big
                                      ,enf.fr_code_etsng
                                      ,enf.fr_name
                                  into r_cargo_end_ntf_car_cont.cont_tonnage
                                      ,r_cargo_end_ntf_car_cont.cont_type_big
                                      ,r_cargo_end_ntf_car_cont.cont_size_big
                                      ,r_cargo_end_ntf_car_cont.cont_freight_code
                                      ,r_cargo_end_ntf_car_cont.cont_freight_name
                                  from xx_etw.etw_invoice                   ei
                                      ,xx_etw.etw_inv_cont                  eicont
                                      ,xx_etw.etw_inv_freight               eif
                                      ,xx_etw.etw_nsi_freight               enf
                                 where 1=1
                                   and ei.invoice_id = l_last_invoice_id
                                   and ei.front_end_id = eicont.front_end_id(+)
                                   and ei.front_end_id = eif.front_end_id(+)
                                   and eicont.cont_number = r_cargo_end_ntf_car_cont.cont_number
                                   and eif.freight_code = enf.fr_code_etsng(+)
                                   ;
                            exception
                                when no_data_found then null;
                            end;
                    end;
            end; 
               
            r_cargo_end_ntf_car_cont.cont_remark := 'Есть договор перевозки';    
              
            insert into xx_etw.etw_cargo_end_ntf_car_cont
            values r_cargo_end_ntf_car_cont; 
            log_new(l_log_id,l_function,'=> for l_csl cont');
            for l_csl in (
                select eic.cont_number,
                       eicc.*
                  from xx_etw.etw_invoice       ei
                      ,xx_etw.etw_inv_cont      eic
                      ,xx_etw.etw_inv_cont_csl  eicc
                 where 1=1
                   and ei.invoice_id = r_cargo_end_ntf_car_cont.cont_invoice_id
                   and ei.front_end_id = eic.front_end_id
                   and eic.cont_number = r_cargo_end_ntf_car_cont.cont_number
                   and eic.front_end_id = eicc.front_end_id
                   and eic.cont_line = eicc.cont_line)
            loop
                r_cargo_end_ntf_cont_csl := NULL;
                r_cargo_end_ntf_cont_csl.front_end_id := r_cargo_end_ntf.front_end_id;
                r_cargo_end_ntf_cont_csl.car_order := r_cargo_end_ntf_car.car_order;
                
                r_cargo_end_ntf_cont_csl.seal_type_id := l_csl.seal_type_id; 
                r_cargo_end_ntf_cont_csl.seal_type_name := l_csl.seal_type_name;
                r_cargo_end_ntf_cont_csl.seal_marks := l_csl.seal_marks;
                r_cargo_end_ntf_cont_csl.seal_quantity := l_csl.seal_quantity;
                r_cargo_end_ntf_cont_csl.seal_year := l_csl.seal_year;
                r_cargo_end_ntf_cont_csl.seal_owner_type_id := l_csl.seal_owner_type_id;
                r_cargo_end_ntf_cont_csl.seal_owner_type_name := l_csl.seal_owner_type_name;
                r_cargo_end_ntf_cont_csl.seal_railway_id := l_csl.seal_railway_id;
                r_cargo_end_ntf_cont_csl.seal_railway_code := l_csl.seal_railway_code;
                r_cargo_end_ntf_cont_csl.seal_railway_name := l_csl.seal_railway_name;
                r_cargo_end_ntf_cont_csl.cont_number := l_csl.cont_number;
                
                insert into xx_etw.etw_cargo_end_ntf_car_cont_csl
                values r_cargo_end_ntf_cont_csl; 
                
                log_new(l_log_id,l_function,'insert etw_cargo_end_ntf_car_cont_csl rowcount: '||sql%rowcount);
            end loop;
        end loop;  
        
        log_new(l_log_id,l_function,'=> for l_csl car');
        for l_csl in (
            select eicc.*
              from xx_etw.etw_invoice       ei
                  ,xx_etw.etw_inv_car       ecar
                  ,xx_etw.etw_inv_car_csl   eicc
             where 1=1
               and ei.invoice_id = r_cargo_end_ntf_car.car_invoice_id
               
               and ei.front_end_id = ecar.front_end_id
               and ecar.car_number = r_cargo_end_ntf_car.car_number
               
               and ecar.front_end_id = eicc.front_end_id
               and ecar.car_order = eicc.car_order
               and nvl(l_count_cont,0) = 0 -- add 10.09.2024 BekmansurovRR по наряду 0000063282: При отправке уведомления платформы с контейнерами, данные отправляются по ЗПУ только с вкладки "Контейнеры"
               )
        loop
            r_cargo_end_ntf_car_csl := NULL;
            r_cargo_end_ntf_car_csl.front_end_id := r_cargo_end_ntf.front_end_id;
            r_cargo_end_ntf_car_csl.car_order := r_cargo_end_ntf_car.car_order;
                
            r_cargo_end_ntf_car_csl.seal_type_id := l_csl.seal_type_id; 
            r_cargo_end_ntf_car_csl.seal_type_name := l_csl.seal_type_name;
            r_cargo_end_ntf_car_csl.seal_marks := l_csl.seal_marks;
            r_cargo_end_ntf_car_csl.seal_quantity := l_csl.seal_quantity;
            r_cargo_end_ntf_car_csl.seal_year := l_csl.seal_year;
            r_cargo_end_ntf_car_csl.seal_owner_type_id := l_csl.seal_owner_type_id;
            r_cargo_end_ntf_car_csl.seal_owner_type_name := l_csl.seal_owner_type_name;
            r_cargo_end_ntf_car_csl.seal_railway_id := l_csl.seal_railway_id;
            r_cargo_end_ntf_car_csl.seal_railway_code := l_csl.seal_railway_code;
            r_cargo_end_ntf_car_csl.seal_railway_name := l_csl.seal_railway_name;
            
            insert into xx_etw.etw_cargo_end_ntf_car_csl
            values r_cargo_end_ntf_car_csl; 
            
            log_new(l_log_id,l_function,'insert etw_cargo_end_ntf_car_csl rowcount: '||sql%rowcount);
        end loop;
    end loop; 
    
    commit;
    log_new(l_log_id,l_function,'execute: xx_etw.etw_cargo_end_ntf_pkg.cargo_end_notification_api');
    xx_etw.etw_cargo_end_ntf_pkg.cargo_end_notification_api(r_cargo_end_ntf.front_end_id,x_return_status,x_message);
    log_new(l_log_id,l_function,'x_message: '||x_message);
    -- add 22.10.2020
    -- Если ЭТРАН возврщает данную ошибку, то формируем список вагонов, на которых есть данное значение
    if lower(x_message) like lower('В справочнике отсутствует%contTonnage%') then
        log_new(l_log_id,l_function,'x_message: '||x_message);
        begin
            select listagg(nc.CAR_NUMBER,',') within group (order by nc.CAR_NUMBER) into x_list_cont
                from xx_etw.etw_cargo_end_ntf_car nc
                where 1=1
                      and nc.FRONT_END_ID = r_cargo_end_ntf.front_end_id
                      and exists (select *
                                from xx_etw.etw_cargo_end_ntf_car_cont cc
                                where cc.FRONT_END_ID = nc.FRONT_END_ID
                                      and cc.CAR_ORDER = nc.CAR_ORDER
                                      and cc.CONT_TONNAGE = regexp_replace(x_message,'[^[[:digit:]]]*'));
            x_list_cont:='Для вагонов:'||x_list_cont;
        exception when others then x_list_cont:='';
        end;             
    elsif lower(x_message) like lower('Введите тип крупнотоннажного контейнера%') then
        log_new(l_log_id,l_function,'x_message: '||x_message);
        begin
            select  listagg(nc.CONT_NUMBER,',') within group (order by nc.CONT_NUMBER) into x_list_cont
              from xx_etw.etw_cargo_end_ntf_car_cont nc
             where 1=1
                   and nc.FRONT_END_ID = r_cargo_end_ntf.front_end_id 
                   and nc.CONT_TYPE_BIG is null;
            x_list_cont:='Для контейнеров:'||x_list_cont;
        exception when others then x_list_cont:='';
        end;
    end if;
    
    if (x_return_status = 'S') then
        l_result := 'done';
    else
        l_result := 'fail|'||x_message||x_list_cont;
        --log_new(l_log_id,l_function,'export_notif_etran Кол-во: '||x_message||' r_cargo_end_ntf.front_end_id='||r_cargo_end_ntf.front_end_id);
        log_new(l_log_id,l_function,'r_cargo_end_ntf.front_end_id = ' || r_cargo_end_ntf.front_end_id||' x_message='||l_result); 
    end if;
      
    return l_result;
exception
    when others then rollback; 
    log_new(l_log_id,l_function,'EXCEPTION.OTHERS = ' || sqlerrm||'r_cargo_end_ntf.front_end_id = ' || r_cargo_end_ntf.front_end_id); 
    return 'fail|'||substr(sqlerrm,1,200);
end;

function get_location_of_cars(p_find_car varchar2)
return t_xx_location_of_car_table pipelined
as
    l_row           t_xx_location_of_car_row;
    l_station_id    number;
    l_station       xx_disl_stations.name%type;
    l_railway       varchar2(1000);--xx_disl_railways.railway_number%type;
    l_weight_net    number;
    l_cont_weight_net   number;
begin
    for cars in (select id               car_number
                       ,min(flag_come)   flag_come
                   from xx_disl_relations
                  where 1=1
                    and id like p_find_car||'%'
                    and type = 'railcar'
                  group by
                        id
                )
    loop
        select tree.parent_id
          into l_station_id
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = cars.flag_come
               )
                                            tree
         where 1=1
           and tree.parent_type = 'station'
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
        
        select name
          into l_station
          from xx_disl_stations
         where 1=1
           and station_id = l_station_id
        ; 
        
        select listagg(r.railway_number,' -> ') within group(order by level desc)
          into l_railway
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = cars.flag_come
               )
                                            tree
              ,xx_disl_railways             r
         where 1=1
           and tree.type = 'railway'
           and tree.id = r.railway_id(+)
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
               
        l_row.car_number := cars.car_number;         
        l_row.station := l_station;              
        l_row.location := case
                            when cars.flag_come = 'Y'
                            then 'на станции'
                            else 'на подходе'
                          end;                           
        l_row.railway := l_railway;
        
        select status
              ,nvl(rai.weight_net,0)--decode(nvl(rai.weight_net,0)+nvl(cai.weight_net,0),0,'пор.','гр.')
              ,freight_name
              ,rai.owner
          into l_row.status
              ,l_weight_net
              ,l_row.freight_name
              ,l_row.owner
          from xx_etw.xx_disl_railcar_add_info      rai
         where 1=1
           and rai.round_id = returnLastRound(cars.car_number)
           and rai.last_record = 'Y'
        ;
        
        select sum(nvl(weight_net,0))
          into l_cont_weight_net
          from xx_etw.xx_disl_cont_history_cur      chc
              ,xx_etw.xx_disl_cont_add_info         cai
         where 1=1
           and chc.place_id = returnLastRound(cars.car_number)
           and place_type = 'railcar'
           
           and chc.cont_round_id = cai.cont_round_id(+)
           and nvl(cai.last_record,'Y') = 'Y' 
        ;
        
        l_row.state := case
                         when (nvl(l_weight_net,0)+nvl(l_cont_weight_net,0)) = 0
                           then 'пор.'
                         else 'гр.'
                       end;

        pipe row (l_row);               
    end loop;
end;

function get_report_1_data 
return t_xx_report_1_table pipelined
as
    l_row               t_xx_report_1_row;
    l_flag_come         varchar2(1);
    l_station_id        number;
    l_station           xx_disl_stations.name%type;
    l_railway           varchar2(1000);--xx_disl_railways.railway_number%type;
--    l_date_arrive       varchar2(20);
--    l_date_accept       varchar2(20); 
begin
    for cars in (select r.railcar_id                car_number
                       ,r.date_arrive               date_arrive
                       ,max(r_inv.invoice_id)       invoice_id
                   from xx_disl_round               r
                       ,xx_disl_round_inv           r_inv
                       ,xx_disl_station_history     sh
                       ,xx_etw.etw_invoice          einv        
                  where 1=1
                    and r.station_hist_id_out is null
                    
                    and r.round_id = r_inv.round_id
                    
                    and r.round_id = sh.round_id
                    
                    and r_inv.invoice_id = einv.invoice_id
                    
                    and sh.out_date is null
                    /*and (  sh.station_id != 1
                        or (sh.station_id = 1 and sh.station_hist_id = r.station_hist_id_in)
                        )*/  
                    
                    and exists (select 1
                                  from xx_etw.etw_invoice              ei
                                      ,xx_etw.etw_inv_car              ecar
                                      ,(select front_end_id
                                              ,spc_custom_text 
                                          from xx_etw.etw_inv_spc 
                                         where spc_transp_clause_id = 975 
                                            or (    spc_transp_clause_id = 993 
                                                and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                                               )
                                       ) 
                                                                       eis
                                      ,xx_disl_inv_car                 disl_car
                                 where 1=1
                                   and ei.front_end_id = ecar.front_end_id(+)
                                   and ei.front_end_id = eis.front_end_id(+)
                                   and ei.invoice_id = disl_car.invoice_id(+)
                                   
                                   and ei.invoice_state_id not in (89) /*Испорчен*/
                                    and nvl(ecar.car_sign,0)!=1 /*признак того что вагон не идет по этой накладной. Есть досылочная накладная*/
                                                           
                                   and (   lower(inv_from_station_name) = 'углеуральская'
                                        or lower(inv_to_station_name) = 'углеуральская'
                                       )
                                   and ei.inv_date_ready_local is not null
                                                           
                                   and coalesce( ecar.car_number
                                                ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                                                ,disl_car.car_number
                                                ,'Нет отметки'
                                               ) = r.railcar_id
                                   and nvl(ei.inv_date_ready_local,einv.inv_date_arrive-1) > einv.inv_date_arrive 
                               )
                  group by
                        r.railcar_id
                       ,r.date_arrive
                  order by
                        r.railcar_id
                ) 
    loop
        select min(flag_come)   flag_come
          into l_flag_come
          from xx_disl_relations
         where 1=1
           and id = cars.car_number
           and type = 'railcar'
         group by
            id
        ;
    
        select tree.parent_id
          into l_station_id
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = l_flag_come
               )
                                            tree
         where 1=1
           and tree.parent_type = 'station'
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
        
        select name
          into l_station
          from xx_disl_stations
         where 1=1
           and station_id = l_station_id
        ; 
        
        select listagg(r.railway_number,' -> ') within group(order by level desc)
          into l_railway
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = l_flag_come
               )
                                            tree
              ,xx_disl_railways             r
         where 1=1
           and tree.type = 'railway'
           and tree.id = r.railway_id(+)
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
               
        l_row.car_number := cars.car_number;         
        l_row.station := l_station;              
        l_row.location := case
                            when l_flag_come = 'Y'
                            then 'на станции'
                            else 'на подходе'
                          end;                           
        l_row.railway := l_railway;
        
        select status
              ,decode(nvl(weight_net,0),0,'пор.','гр.')
              ,freight_name
              ,owner
          into l_row.status
              ,l_row.state
              ,l_row.freight_name
              ,l_row.owner
          from xx_disl_railcar_add_info         info
         where 1=1
           and info.round_id = returnLastRound(cars.car_number)
           and info.last_record = 'Y'
        ;
        
        l_row.date_arrive := to_char(cars.date_arrive,'dd.mm.yyyy hh24:mi');
        
        select to_char(min(ei.inv_fact_date_accept),'dd.mm.yyyy hh24:mi')
          into l_row.date_accept
          from xx_etw.etw_invoice              ei
              ,xx_etw.etw_inv_car              ecar
              ,(select front_end_id
                      ,spc_custom_text 
                  from xx_etw.etw_inv_spc 
                 where spc_transp_clause_id = 975 
                    or (    spc_transp_clause_id = 993 
                        and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                       )
               ) 
                                               eis
              ,xx_disl_inv_car                 disl_car
         where 1=1
           and ei.front_end_id = ecar.front_end_id(+)
           and ei.front_end_id = eis.front_end_id(+)
           and ei.invoice_id = disl_car.invoice_id(+)
                                                           
           and lower(inv_from_station_name) = 'углеуральская'
           and ei.inv_fact_date_accept is not null
                                                           
           and coalesce( ecar.car_number
                        ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                        ,disl_car.car_number
                        ,'Нет отметки'
                       ) = cars.car_number
           and ei.invoice_id > cars.invoice_id
        ;
        
        pipe row (l_row);
    end loop;      
end;

function get_report_2_data 
return t_xx_report_2_table pipelined
as
    l_row               t_xx_report_2_row;
    l_flag_come         varchar2(1);
    l_station_id        number;
    l_station           xx_disl_stations.name%type;
    l_railway           varchar2(1000);
begin
    for cars in (select r.railcar_id                car_number
                       ,si.date_uvod                date_oper
                       ,trunc(trunc((sysdate-si.date_uvod)*86400)/3600)
                                                    downtime_hh
                       ,trunc(mod(trunc((sysdate-si.date_uvod)*86400),3600)/60)
                                                    downtime_mi
                       ,'Нет увода'                 err_type   
                   from xx_disl_round               r
                       ,xx_disl_station_history     sh
                       ,xx_disl_railway_history     rh
                       ,xx_disl_shop_info           si
                  where 1=1
--                    and r.railcar_id = '50087667'
                    and r.station_hist_id_out is null
                  
                    and r.round_id = sh.round_id
                    and sh.out_date is null
                    
                    and sh.station_hist_id = rh.station_hist_id
                    and rh.railway_hist_id = (select max(rh_1.railway_hist_id) keep (dense_rank last order by rh_1.date_oper)
                                                from xx_disl_railway_history rh_1
                                               where 1=1
                                                 and rh_1.station_hist_id = sh.station_hist_id
                                             )
                    
                    and rh.railway_id in (select r.railway_id
                                            from xx_disl_railways r
                                           where 1=1
                                             and nvl(r.type,-1) = 1
                                         )
                    
                    and r.round_id = si.round_id(+)
                    and sysdate >= nvl(si.date_uvod,sysdate) + 1/24
                 union all
                 select r.railcar_id                car_number
                       ,si.date_post                date_oper
                       ,trunc(trunc((sysdate-si.date_post)*86400)/3600)
                                                    downtime_hh
                       ,trunc(mod(trunc((sysdate-si.date_post)*86400),3600)/60)
                                                    downtime_mi   
                       ,'Нет постановки'            err_type
                   from xx_disl_round               r
                       ,xx_disl_station_history     sh
                       ,xx_disl_railway_history     rh
                       ,xx_disl_shop_info           si
                  where 1=1
--                    and r.railcar_id = '50087667'
                    and r.station_hist_id_out is null
                  
                    and r.round_id = sh.round_id
                    and sh.out_date is null
                    
                    and sh.station_hist_id = rh.station_hist_id
                    and rh.railway_hist_id = (select max(rh_1.railway_hist_id) keep (dense_rank last order by rh_1.date_oper)
                                                from xx_disl_railway_history rh_1
                                               where 1=1
                                                 and rh_1.station_hist_id = sh.station_hist_id
                                             )
                    
                    and rh.railway_id not in (select r.railway_id
                                            from xx_disl_railways r
                                           where 1=1
                                             and nvl(r.type,-1) = 1
                                         )
                    
                    and r.round_id = si.round_id
                    and si.date_post is not null
                    and date_uvod is null
                    and created_by = -1
                ) 
    loop
        select min(flag_come)   flag_come
          into l_flag_come
          from xx_disl_relations
         where 1=1
           and id = cars.car_number
           and type = 'railcar'
         group by
            id
        ;
    
        select tree.parent_id
          into l_station_id
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = l_flag_come
               )
                                            tree
         where 1=1
           and tree.parent_type = 'station'
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
        
        select name
          into l_station
          from xx_disl_stations
         where 1=1
           and station_id = l_station_id
        ; 
        
        select listagg(r.railway_number,' -> ') within group(order by level desc)
          into l_railway
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = l_flag_come
               )
                                            tree
              ,xx_disl_railways             r
         where 1=1
           and tree.type = 'railway'
           and tree.id = r.railway_id(+)
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
               
        l_row.car_number := cars.car_number;         
        l_row.station := l_station;              
        l_row.location := case
                            when l_flag_come = 'Y'
                            then 'на станции'
                            else 'на подходе'
                          end;                           
        l_row.railway := l_railway;
        
        select status
              ,decode(nvl(weight_net,0),0,'пор.','гр.')
              ,freight_name
              ,owner
          into l_row.status
              ,l_row.state
              ,l_row.freight_name
              ,l_row.owner
          from xx_disl_railcar_add_info         info
         where 1=1
           and info.round_id = returnLastRound(cars.car_number)
           and info.last_record = 'Y'
        ;
        
        l_row.downtime := cars.downtime_hh||'ч. '||cars.downtime_mi||' м.';
        l_row.err_type := cars.err_type;
        l_row.date_oper := to_char(cars.date_oper,'dd.mm.yyyy hh24:mi');
        
        pipe row (l_row);
    end loop;
end get_report_2_data;

function get_report_3_data 
return t_xx_report_3_table pipelined
as
    l_row               t_xx_report_3_row;
    l_flag_come         varchar2(1);
    l_station_id        number;
    l_station           xx_disl_stations.name%type;
    l_railway           varchar2(1000);--xx_disl_railways.railway_number%type;
--    l_date_arrive       varchar2(20);
--    l_date_accept       varchar2(20); 
begin
    for cars in (select r.railcar_id                car_number
                       ,r.date_arrive               date_arrive
                       ,max(r_inv.invoice_id)       invoice_id
                   from xx_etw.xx_disl_round               r
                       ,xx_etw.xx_disl_round_inv           r_inv
                       ,xx_etw.xx_disl_station_history     sh
                       ,xx_etw.etw_invoice          einv
                       ,xx_etw.xx_disl_railcar_add_info         info        
                  where 1=1
                    and r.station_hist_id_out is null
                    
                    and r.round_id = r_inv.round_id
                    
                    and r.round_id = sh.round_id
                    
                    and r_inv.invoice_id = einv.invoice_id
                    
                    and sh.out_date is null
                    /*and (  sh.station_id != 1
                        or (sh.station_id = 1 and sh.station_hist_id = r.station_hist_id_in)
                        )*/  
                    and r.round_id = info.ROUND_ID
                    and info.LAST_RECORD = 'Y'
                    and (info.status like '%Требует подготовки%') 
               GROUP BY   r.railcar_id, r.date_arrive
    )                
    loop
        select min(flag_come)   flag_come
          into l_flag_come
          from xx_disl_relations
         where 1=1
           and id = cars.car_number
           and type = 'railcar'
         group by
            id
        ;
    
        select tree.parent_id
          into l_station_id
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = l_flag_come
               )
                                            tree
         where 1=1
           and tree.parent_type = 'station'
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
        
        select name
          into l_station
          from xx_disl_stations
         where 1=1
           and station_id = l_station_id
        ; 
        
        select listagg(r.railway_number,' -> ') within group(order by level desc)
          into l_railway
          from (select *
                 from xx_disl_relations
                where 1=1
                  and flag_come = l_flag_come
               )
                                            tree
              ,xx_disl_railways             r
         where 1=1
           and tree.type = 'railway'
           and tree.id = r.railway_id(+)
       connect by 
               prior tree.parent_id = tree.id 
           and prior tree.parent_type = tree.type
         start with 
               tree.id = cars.car_number
           and tree.type = 'railcar'
        ;
               
        l_row.car_number := cars.car_number;         
        l_row.station := l_station;              
        l_row.location := case
                            when l_flag_come = 'Y'
                            then 'на станции'
                            else 'на подходе'
                          end;                           
        l_row.railway := l_railway;
        
        select status
              ,decode(nvl(weight_net,0),0,'пор.','гр.')
              ,freight_name
              ,owner
          into l_row.status
              ,l_row.state
              ,l_row.freight_name
              ,l_row.owner
          from xx_disl_railcar_add_info         info
         where 1=1
           and info.round_id = returnLastRound(cars.car_number)
           and info.last_record = 'Y'
        ;
        
        l_row.date_arrive := to_char(cars.date_arrive,'dd.mm.yyyy hh24:mi');
        
        select to_char(min(ei.inv_fact_date_accept),'dd.mm.yyyy hh24:mi')
          into l_row.date_accept
          from xx_etw.etw_invoice              ei
              ,xx_etw.etw_inv_car              ecar
              ,(select front_end_id
                      ,spc_custom_text 
                  from xx_etw.etw_inv_spc 
                 where spc_transp_clause_id = 975 
                    or (    spc_transp_clause_id = 993 
                        and upper(spc_custom_text) like '%ПЛАТФОРМА%'
                       )
               ) 
                                               eis
              ,xx_disl_inv_car                 disl_car
         where 1=1
           and ei.front_end_id = ecar.front_end_id(+)
           and ei.front_end_id = eis.front_end_id(+)
           and ei.invoice_id = disl_car.invoice_id(+)
                                                           
           and lower(inv_from_station_name) = 'углеуральская'
           and ei.inv_fact_date_accept is not null
                                                           
           and coalesce( ecar.car_number
                        ,regexp_replace(eis.spc_custom_text,'[^[[:digit:]]]*')
                        ,disl_car.car_number
                        ,'Нет отметки'
                       ) = cars.car_number
           and ei.invoice_id > cars.invoice_id
        ;
        
        pipe row (l_row);
    end loop;      
end;

function get_report_4_data(p_add_data in varchar2) return t_xx_report_4_table pipelined
     is
        l_json                  json;
        -----
        l_row                   t_xx_report_4_row;
        l_car_number            varchar2(250);
        l_type                  varchar2(250);
        l_freight_name          varchar2(250);
        l_car_type_name         varchar2(250);
        l_car_owner_name        varchar2(250);
        l_car_arendator_name    varchar2(250);
     begin
        
        begin
            l_json := xx_wms.json(p_add_data);
            l_car_number := nvl(l_json.get_string('car_number'),'%');
            l_type := nvl(l_json.get_string('type'),'%');
            l_freight_name := nvl(l_json.get_string('freight_name'),'%');
            l_car_type_name := nvl(l_json.get_string('car_type_name'),'%');
            l_car_owner_name := nvl(l_json.get_string('car_owner_name'),'%');
            l_car_arendator_name := nvl(l_json.get_string('car_arendator_name'),'%');
        exception 
            when others then 
                l_car_number := '%';
                l_type :='%';
                l_freight_name :='%';
                l_car_type_name := '%';
                l_car_owner_name := '%';
                l_car_arendator_name :='%';
        end;
        
        for tmp in (
            SELECT x.id     AS car_number,
                   si.STATUS,
                   si.CAR_TYPE,
                   si.FREIGHT_NAME,
                   nsi.CAR_TYPE_NAME,
                   nsi.CAR_OWNER_NAME,
                   nsi.CAR_ARENDATOR_NAME
              FROM (    SELECT ds.*
                          FROM (    SELECT *
                                      FROM xx_disl_relations
                                CONNECT BY     PRIOR id = parent_id
                                           AND PRIOR TYPE = parent_type
                                           AND PRIOR flag_come = flag_come
                                START WITH parent_id IN (1) AND parent_type = 'station') ds
                         WHERE 1 = 1 AND ds.TYPE IN ('railcar', 'cont')
                    CONNECT BY     PRIOR ds.id = ds.parent_id
                               AND PRIOR ds.TYPE = ds.parent_type
                               AND PRIOR ds.flag_come = ds.flag_come
                               AND ds.TYPE = 'railcar'
                      ORDER BY LEVEL, ds.r_order) x,
                   xx_etw.etw_car_nsi               nsi,
                   xx_etw.xx_disl_railcar_add_info  si
             WHERE     x.id = nsi.CAR_NUMBER(+)
                   AND si.round_id = xx_etw.xx_dislocation.returnLastRound (x.id)
                   AND si.LAST_RECORD (+)= 'Y'
                   AND x.PARENT_ID = 1
                    and lower(x.id) like lower('%'||l_car_number||'%')
                    and lower(si.CAR_TYPE) like lower('%'||l_type||'%')
                    and lower(si.FREIGHT_NAME) like lower('%'||l_freight_name||'%')
                    and lower(nsi.CAR_TYPE_NAME) like lower('%'||l_car_type_name||'%') 
                    and lower(regexp_replace(nsi.CAR_OWNER_NAME, '[^A-Za-zА-Яа-я0-9]')) like lower('%'||regexp_replace(l_car_owner_name, '[^A-Za-zА-Яа-я0-9]') ||'%')
                    and lower(regexp_replace(nsi.CAR_ARENDATOR_NAME, '[^A-Za-zА-Яа-я0-9]')) like lower('%'||regexp_replace(l_car_arendator_name, '[^A-Za-zА-Яа-я0-9]')||'%')
        )
        loop
            l_row.car_number            := tmp.car_number;
            l_row.status                := tmp.status;
            l_row.car_type              := tmp.car_type;
            l_row.freight_name          := tmp.freight_name;
            l_row.car_type_name         := tmp.car_type_name;
            l_row.car_owner_name        := tmp.car_owner_name;
            l_row.car_arendator_name    := tmp.car_arendator_name;
            
            pipe row (l_row);
        end loop;
        
     end;


function get_users_for_notification(p_credential_id number default null)
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for tmp in (select u.id
                      ,u.full_name
                  from xx_disl_users                u
                 where 1=1
                   and u.enterprise = 4
                       and u.open != 'N'
                 order by
                       u.full_name
               )
    loop
        l_row.id := tmp.id;   
        l_row.name := tmp.full_name;
        
        pipe row (l_row);
    end loop;
end;

function get_users_for_route(p_credential_id number default null)
return t_xx_id_name_addition_table pipelined
as
    l_row t_xx_id_name_addition_row;
    
begin
    for tmp in (select u.id
                      ,u.full_name
                  from xx_etw.xx_disl_users u
                 where 1=1
                   and u.enterprise = 4
                       and u.open != 'N'
                 order by
                       u.full_name
               )
    loop
        l_row.id := tmp.id;   
        l_row.name := tmp.full_name;
        l_row.section := get_default_id ('XX_DISL_USERS',null,tmp.id);
        pipe row (l_row);
    end loop;
end;

function add_point(p_parent_id number,p_parent_type varchar2, p_name varchar2,p_descr varchar2)
return number
as
    l_function      varchar2(100) := 'add_point:';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    l_point_id      number;
    l_max_order     number;
begin
    begin
        log_new(l_log_id,l_function,' p_parent_id = '||p_parent_id);
        log_new(l_log_id,l_function,' p_parent_type = '||p_parent_type);
        log_new(l_log_id,l_function,' p_number = '||p_name);
        log_new(l_log_id,l_function,' p_purpose = '||p_descr);
        
        insert into xx_disl_points
        values (xx_disl_points_seq.nextval
               ,p_name
               ,p_descr
               )
        returning point_id into l_point_id
        ;
        
        log_new(l_log_id,l_function,' l_railway_id = '||l_point_id);
        
        l_max_order := returnMaxOrder(p_parent_id,p_parent_type,'Y');
        
        log_new(l_log_id,l_function,' l_max_order = '||l_max_order);
        
        insert into xx_disl_relations
        values(l_point_id
              ,'point'
              ,p_parent_id
              ,p_parent_type
              ,l_max_order+1
              ,'Y'
              )
        ;
        
        log_new(l_log_id,l_function,' insert into xx_disl_relations. Кол-во: '||sql%rowcount);
        
        commit;
        return l_point_id;
    exception
        when others then rollback; return 0;
    end;
end;

function add_area(p_parent_id number,p_parent_type varchar2, p_name varchar2,p_descr varchar2)
return number
as
    l_function      varchar2(100) := 'add_area:';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    l_area_id       number;
    l_max_order     number;
begin
      
    log_new(l_log_id,l_function,'parameters: p_parent_id = '||p_parent_id||
                                           ' p_parent_type = '||p_parent_type||
                                           ' p_name = '||p_name||
                                           ' p_descr = '||p_descr
    );
        
    insert into xx_disl_areas
    values (xx_disl_areas_seq.nextval
           ,p_name
           ,p_descr
           ,null
           )
    returning area_id into l_area_id
    ;
        
    log_new(l_log_id,l_function,'l_area_id = '||l_area_id);
    
    begin    
        select nvl(max(r_order),0)
          into l_max_order
          from xx_etw.xx_disl_relations
         where 1=1
           and parent_id = p_parent_id
           and parent_type = p_parent_type
           and flag_come = 'Y'
           and type in ('station','point','area')
        ;
    exception
        when others then l_max_order:=0;
    end;
        
    log_new(l_log_id,l_function,'l_max_order = '||l_max_order);
    
    update xx_disl_relations
       set r_order = r_order+1
     where 1=1
       and parent_id = p_parent_id
       and parent_type = p_parent_type
       and flag_come = 'Y'
       and r_order > l_max_order
    ;    
    
    insert into xx_disl_relations
    values(l_area_id
          ,'area'
          ,p_parent_id
          ,p_parent_type
          ,l_max_order+1
          ,'Y'
          )
    ;
    
    log_new(l_log_id,l_function,'insert into xx_disl_relations. rowcount = '||sql%rowcount);    
        
    commit;
    return l_area_id;
exception
    when others then rollback; return 0;
end;

function toggle_like_railway(p_user_id number,p_obj_id number,p_obj_type varchar)
return varchar2
as
begin
    delete
      from xx_disl_user_like_railways
     where 1=1
       and user_id = p_user_id
       and obj_id = p_obj_id
       and obj_type = p_obj_type
    ;
    
    if (sql%rowcount=0) then
        insert into xx_disl_user_like_railways
        values (p_user_id,p_obj_id,p_obj_type)
        ;
    end if;   
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;


FUNCTION change_cars_weight_net(
         p_changes      IN t_change_cars_weight_rec
        ,p_out_load_rec IN OUT t_loading_table
) return  varchar2
as   
    l_log_id                number;
    l_function              varchar2(100):='change_cars_weight_net';
    
    l_car_number            varchar2(10);
    l_weight_net_c          varchar2(20);
    l_weight_net            number;
    l_freight               varchar2(200);
    
    l_date_post             date;
    l_date_start            date;
    l_date_end              date;
    l_date_zayavka_uvod     date;
    l_date_uvod             date;
    
    l_add_info_id_old       number;
    l_add_info_type_old     varchar2(1);
    l_weight_net_old        number;
    l_freight_old           varchar2(200);
    l_add_info_id_new       number;
    
    l_weight_net_begin      number;
    l_weight_dep_begin      number;
    
    l_refusal               varchar2(200);
    l_shop_info_id_char     varchar2(1000);
    l_shop_info_id          number;
    
    l_request_id            number;  
    
    l_scales_type_id        number;
    l_conts_count           number;
    l_cont_number           xx_etw.xx_disl_cont_round.cont_number%type;
    
    l_shop_round_id         xx_etw.xx_disl_shop_info.round_id%type;
    l_shop_round_type       xx_etw.xx_disl_shop_info.round_type%type; 
    
    l_out_scale_id          number:=0;
    l_in_scale_id           number:=0;
    
    l_scale_rec             xx_etw.xx_disl_car_scale%rowtype;
    l_scale_status          varchar2(50);
    l_scale_msg             varchar2(2400);
    l_new_weight_dep        number;
    l_new_weight_gross_td   number;
    --
    l_un_loading_id         number:=0;
    l_accepted_weight       number:=0;
    l_define_task           number:=0;
    l_define_comment        varchar2(240);
    ---
    l_check_data            varchar2(4000);
    ---
    x_loading_tbl   t_loading_table;
    x_loading_rec   t_loadnig_rec;
    x_changes_prm   t_change_cars_weight_rec;
    
    function to_date_f(p_date varchar2,p_mask varchar2)
    return date
    as
    begin
        return to_date(p_date,p_mask);
    exception
        when others then return null;
    end;
    -- add 18.11.2024 по наряду 0000069659
    -- ! Считать записи повторными если для регистрации принимается новая запись где  Дата постановки (DATE_POST ) +/-  2 часа от времени в существующей регистрации Сообщение/предупреждение для пользователя: 
    -- !Внимание:  Записи в форме Погрузка/Разгрузка для вагона (перечислить...) существуют за (указать дату и время записи по которой проводится проверка)
    FUNCTION fnc_check_data (p_data_post IN DATE, p_data IN VARCHAR2)
        RETURN VARCHAR2
    IS
        l_result              VARCHAR2 (4000);
        ---
        l_car_number          VARCHAR2 (250);
        l_round_id            NUMBER;
        ---
        l_cont_number         varchar2(240);
        l_cont_round_id       number;
        l_shop_info_id        number;
        l_shop_info_id_char   varchar2(240);
        ---
        l_count               NUMBER;
    BEGIN
        FOR l_cars IN (    SELECT REGEXP_SUBSTR (p_data,
                                                 '[^$]+',
                                                 1,
                                                 LEVEL)    text
                             FROM DUAL
                       CONNECT BY LEVEL <= REGEXP_COUNT (p_data, '[^$]+'))
        LOOP
            
            l_car_number := REGEXP_SUBSTR (l_cars.text, '[^|]+', 1, 1);
            l_cont_number := regexp_substr(l_cars.text,'[^|]+',1,2);
            if (l_cont_number != '_') then
                l_round_id := xx_etw.xx_dislocation.return_last_cont_round(l_cont_number);
                --l_shop_round_type := 'cont';
            else
                l_round_id := xx_etw.xx_dislocation.returnLastRound(l_car_number);
                --l_shop_round_type := 'railcar';
            end if;
            --l_round_id := xx_etw.xx_dislocation.returnLastRound (l_car_number);
            
            l_shop_info_id_char := regexp_substr(l_cars.text,'[^|]+',1,6);
            log_new(l_log_id,l_function,'l_shop_info_id_char = '||l_shop_info_id_char);
            log_new(l_log_id,l_function,'l_round_id = '||l_round_id);
             
            if (l_shop_info_id_char = '_') then
                l_shop_info_id := null;
            else 
                l_shop_info_id := to_number(l_shop_info_id_char);
            end if;
            
            select count (*)
              into l_count
              from xx_etw.xx_disl_shop_info x
             where round_id = l_round_id 
                   and x.date_post between p_data_post and p_data_post+2/24;

            IF l_count > 0 and l_shop_info_id is null and l_round_id > 0
            THEN
                l_result := l_result || l_car_number || ';';
            END IF;
        END LOOP;

        RETURN l_result;
    END;
begin
    x_changes_prm := p_changes;
    l_log_id := xx_etw.xx_disl_log_seq.nextval();  
    log_new(l_log_id, l_function,
            'parameters:'
            ||' p_user_id = '          ||x_changes_prm.user_id
            ||' p_cars_with_weight = ' ||x_changes_prm.cars_with_weight
            ||' p_date_post = '        ||x_changes_prm.date_post
            ||' p_date_start = '       ||x_changes_prm.date_start
            ||' p_date_end = '         ||x_changes_prm.date_end
            ||' p_date_zayavka_uvod = '||x_changes_prm.date_zayavka_uvod
            ||' p_date_uvod = '        ||x_changes_prm.date_uvod
            ||' p_who_looked_id = '    ||x_changes_prm.who_looked_id
            ||' p_who_looked = '       ||x_changes_prm.who_looked
            ||' p_who_start_id = '     ||x_changes_prm.who_start_id
            ||' p_who_start = '        ||x_changes_prm.who_start
            ||' p_who_end_id = '       ||x_changes_prm.who_end_id
            ||' p_who_end = '          ||x_changes_prm.who_end
            ||' p_who_zayavka_id = '   ||x_changes_prm.who_zayavka_id
            ||' p_who_zayavka = '      ||x_changes_prm.who_zayavka
    );

    
    l_date_post := to_date_f(x_changes_prm.date_post,'dd.mm.yyyy hh24:mi');
    log_new(l_log_id,l_function,'l_date_post = '||to_char(l_date_post,'dd.mm.yyyy hh24:mi'));
    
    x_loading_tbl := t_loading_table();
    
    if (l_date_post is null and x_changes_prm.user_id != -1) then
        return 'fail';  
    end if;

    l_date_start := to_date_f(x_changes_prm.date_start,'dd.mm.yyyy hh24:mi');
    log_new(l_log_id,l_function,'l_date_start = '||to_char(l_date_start,'dd.mm.yyyy hh24:mi'));

    l_date_end := to_date_f(x_changes_prm.date_end,'dd.mm.yyyy hh24:mi');
    log_new(l_log_id,l_function,'l_date_end = '||to_char(l_date_end,'dd.mm.yyyy hh24:mi'));
    
    l_date_zayavka_uvod := to_date_f(x_changes_prm.date_zayavka_uvod,'dd.mm.yyyy hh24:mi');
    log_new(l_log_id,l_function,'l_date_zayavka_uvod = '||to_char(l_date_zayavka_uvod,'dd.mm.yyyy hh24:mi'));
    
    l_date_uvod := to_date_f(x_changes_prm.date_uvod,'dd.mm.yyyy hh24:mi');
    log_new(l_log_id,l_function,'l_date_uvod = '||to_char(l_date_uvod,'dd.mm.yyyy hh24:mi'));
    log_new(l_log_id,l_function,'p_cars_with_weight = '||x_changes_prm.cars_with_weight);
    -- add 18.11.2024 по наряду 0000069659
    l_check_data := fnc_check_data(l_date_post,x_changes_prm.cars_with_weight);
    log_new(l_log_id,l_function,'l_check_data = '||l_check_data);
    
    if trim(l_check_data) is not null and x_changes_prm.user_id != -1 then
        log_new(l_log_id,l_function,'l_check_data = '||l_check_data);
        return 'fail$Error='||'Внимание:Записи в форме Погрузка/Разгрузка для вагона:'||l_check_data||' существуют за '||to_char(l_date_post,'DD.MM.YYYY HH24:MI:SS');
    end if;
    
    for l_cars in (select regexp_substr(x_changes_prm.cars_with_weight,'[^$]+',1,level) text
                     from dual
                  connect by level <= regexp_count(x_changes_prm.cars_with_weight,'[^$]+')
                  )
    loop
        l_car_number := regexp_substr(l_cars.text,'[^|]+',1,1);
        log_new(l_log_id,l_function,'l_car_number = '||l_car_number);

        l_cont_number := regexp_substr(l_cars.text,'[^|]+',1,2);
        log_new(l_log_id,l_function,'l_cont_number = '||l_cont_number);
        
        if (l_cont_number != '_') then
            l_shop_round_id := xx_etw.xx_dislocation.return_last_cont_round(l_cont_number);
            l_shop_round_type := 'cont';
            if l_shop_round_id = -1 then 
                return 'fail$Error='||'Не найден контейнер '||l_cont_number||' в дислокации!';
            end if;
        else
            l_shop_round_id := returnLastRound(l_car_number);
            l_shop_round_type := 'railcar';
            if l_shop_round_id = -1 then 
                return 'fail$Error='||'Не найден вагон '||l_car_number||' в дислокации!';
            end if;
        end if;
        log_new(l_log_id,l_function,'l_shop_round_id = '||l_shop_round_id||' l_shop_round_type = '||l_shop_round_type);
        
        l_weight_net_c := regexp_substr(l_cars.text,'[^|]+',1,3);
        log_new(l_log_id,l_function,'l_weight_net_c = '||l_weight_net_c);
        
        l_weight_net := to_number(nvl(l_weight_net_c,'0'),'999999999999999D999999999999999','NLS_NUMERIC_CHARACTERS = ''.,''');    
        log_new(l_log_id,l_function,'l_weight_net = '||l_weight_net);
        
        l_freight := regexp_substr(l_cars.text,'[^|]+',1,4);
        log_new(l_log_id,l_function,'l_freight = '||l_freight);
        
        l_refusal := regexp_substr(l_cars.text,'[^|]+',1,5);
        log_new(l_log_id,l_function,'l_refusal = '||l_refusal);
        l_refusal := case
                       when l_refusal = '_'
                       then null
                       else l_refusal
                     end;
        
        l_shop_info_id_char := regexp_substr(l_cars.text,'[^|]+',1,6);
        log_new(l_log_id,l_function,'l_shop_info_id_char = '||l_shop_info_id_char);
        
        if (l_shop_info_id_char = '_') then
            l_shop_info_id := null;
        else 
            l_shop_info_id := to_number(l_shop_info_id_char);
        end if;
        log_new(l_log_id,l_function,'l_shop_info_id = '||l_shop_info_id);
        -- 21.12.2022\
        -- Тип взвешивания
        l_scales_type_id := regexp_substr(l_cars.text,'[^|]+',1,7);
        log_new(l_log_id,l_function,'l_scales_type_id = '||l_scales_type_id);
        -- = 0 Данные с накладной
        -- = 1 Данные НСИ
        -- = 2 Данные с корпуса 1831 (карбамид)
        -- = 3 Данные 1С
        
        -- Тара 
        l_new_weight_dep := CASE 
                                    WHEN REGEXP_SUBSTR(l_cars.text, '[^|]+', 1, 8) = '_' THEN NULL
                                    ELSE apps.fnd_number.canonical_to_number( REGEXP_SUBSTR(l_cars.text, '[^|]+', 1, 8))
                                 END;
        log_new(l_log_id,l_function,'l_new_weight_dep = '||l_new_weight_dep);
        -- Брутто
        l_new_weight_gross_td := CASE 
                                    WHEN REGEXP_SUBSTR(l_cars.text, '[^|]+', 1, 9) = '_' THEN NULL
                                    ELSE apps.fnd_number.canonical_to_number( REGEXP_SUBSTR(l_cars.text, '[^|]+', 1, 9))
                                 END;
        log_new(l_log_id,l_function,'l_new_weight_gross_td = '||l_new_weight_gross_td);
        --
        l_un_loading_id:=xx_etw.xx_dislocation.get_un_loading_type(regexp_substr(l_cars.text,'[^|]+',1,10));
        log_new(l_log_id,l_function,'l_un_loading_id = '||l_un_loading_id);
        
        l_accepted_weight := case when regexp_substr(l_cars.text,'[^|]+',1,11) = '_' then null 
                                  else regexp_substr(l_cars.text,'[^|]+',1,11)
                             end;
        log_new(l_log_id,l_function,'l_accepted_weight = '||l_accepted_weight);
        l_define_task := case when regexp_substr(l_cars.text,'[^|]+',1,12) = '_' then null 
                              else regexp_substr(l_cars.text,'[^|]+',1,12)
                         end;
        log_new(l_log_id,l_function,'l_define_task = '||l_define_task);
        
         -- add 05.05.2026 
        x_changes_prm.otgruzka_1c_id:= nvl(case when regexp_substr(l_cars.text,'[^|]+',1,13) = '_' then null 
                                                  else regexp_substr(l_cars.text,'[^|]+',1,13)
                                             end,0);
        log_new(l_log_id,l_function,'otgruzka_1c_id = '||x_changes_prm.otgruzka_1c_id);
        
        if (nvl(l_un_loading_id,0) <> 0) then
            l_define_comment:=l_refusal;
            l_refusal:='';
        end if;
        log_new(l_log_id,l_function,'l_define_comment = '||l_define_comment);
        if (l_shop_round_type = 'railcar') then
            begin
                select max(weight_net)  keep (dense_rank last order by add_info_id)
                      ,max(weight_dep) keep (dense_rank last order by add_info_id)
                  into l_weight_net_begin, l_weight_dep_begin
                  from xx_etw.xx_disl_railcar_add_info
                 where 1=1
                   and round_id = l_shop_round_id
                   and un_loading_from_subs = l_un_loading_id -- add 27/12/2022
                   and add_info_type in ('A','M')
                ;
                
            exception
                when others then l_weight_net_begin:=null; l_weight_dep_begin:=null;
            end; 
        else
            begin
                select max(weight_net) keep (dense_rank last order by add_info_id)
                  into l_weight_net_begin
                  from xx_etw.xx_disl_cont_add_info
                 where 1=1
                   and cont_round_id = l_shop_round_id
                   and add_info_type in ('A','M')
                ;
            exception
                when others then l_weight_net_begin:=null;
            end;
        end if;
        -- add 21.12.2022 
        --     
        log_new(l_log_id,l_function,'l_weight_net_begin = '||l_weight_net_begin);       
        
         
        
        if (l_shop_info_id is not null) then  
            update xx_etw.xx_disl_shop_info
               set weight_net = case
                                  when weight_net_begin != 0 and l_date_end is not null and date_end is null/*Когда вагон разгружаем, то при введеной дате "Конец разгрузки" вес груза обнуляем (иногда пользователи забывают это делать)*/
                                    then 0
                                  else l_weight_net
                                end
                  ,date_post = l_date_post
                  ,date_start = l_date_start
                  ,date_end = l_date_end
                  ,date_zayavka_uvod = l_date_zayavka_uvod
                  ,date_uvod = l_date_uvod
                  ,who_looked_id = x_changes_prm.who_looked_id
                  ,who_looked = x_changes_prm.who_looked
                  ,who_start_id = x_changes_prm.who_start_id
                  ,who_start = x_changes_prm.who_start
                  ,who_end_id = x_changes_prm.who_end_id
                  ,who_end = x_changes_prm.who_end
                  ,who_zayavka_id = x_changes_prm.who_zayavka_id
                  ,who_zayavka = x_changes_prm.who_zayavka
                  ,last_update_date = sysdate
                  ,last_update_by = x_changes_prm.user_id
                  ,refusal = l_refusal
                  ,freight_name = l_freight
                  ,create_request = case
                                      when date_post != l_date_post
                                        then 'N'
                                      else create_request
                                    end
                  ,un_loading_from_subs = l_un_loading_id
                  ,accepted_weight = l_accepted_weight
                  ,define_task = l_define_task
                  ,define_comment = l_define_comment
                  ,otgruzka_1c_id = x_changes_prm.otgruzka_1c_id -- add 05.05.2026 
             where 1=1
               and shop_info_id = l_shop_info_id
               and un_loading_from_subs = l_un_loading_id -- add 27/12/2022
            returning weight_net into l_weight_net
            ;
            log_new(l_log_id,l_function,'l_weight_net = '||l_weight_net);
            -- 21/12/2022 BekmansurovRR
            -- Добавляем вес в таблицу взвешивания
            if nvl(l_scales_type_id,0) not in (0,1,3) and l_shop_round_type = 'railcar' and l_un_loading_id = 0 then
                begin
                    begin
                        select id as l_out_scale_id
                          into l_out_scale_id
                          from xx_disl_car_scale dcs
                         where 1=1
                               and dcs.NAPR_SYS = 'out'
                               and dcs.DESCR like '%Вес с весов корп.1831%'
                               /*and ( -- Разгрузка
                                     (dcs.WEIGHT_COR < 41 and nvl(l_new_weight_dep,0)<41 )
                                        -- Погрузка 
                                        or (dcs.WEIGHT_COR > 41 and l_new_weight_dep != l_new_weight_gross_td ) 
                                   )  */
                               and trunc(dcs.DATE_W,'MI') = trunc(l_date_end,'MI') -- add 20/01/2023  
                               and dcs.ROUND_ID = l_shop_round_id;
                    exception when others then l_out_scale_id:=0;
                    end;
                    
                    log_new(l_log_id,l_function,'l_out_scale_id = '||l_out_scale_id);
                    begin
                        select id as l_in_scale_id
                          into l_in_scale_id
                          from xx_disl_car_scale dcs
                         where 1=1
                               and dcs.NAPR_SYS = 'in' 
                               and dcs.DESCR like '%Вес с весов корп.1831%'
                               -- Разгрузка: Вес груза = 0 и тара с брутто равны
                               /*and ((dcs.WEIGHT_COR > 41 and nvl(l_weight_net,0) = 0 and l_new_weight_dep = l_new_weight_gross_td) 
                                        -- Погрузка: Вес груза != 0 
                                        or (dcs.WEIGHT_COR < 41 and nvl(l_weight_net,0) != 0 ) 
                                   )*/  
                               and trunc(dcs.DATE_W,'MI') = trunc(l_date_start,'MI') -- add 20/01/2023  
                               and dcs.ROUND_ID = l_shop_round_id;
                    exception when others then l_in_scale_id:=0;
                    end;
                end;
                log_new(l_log_id,l_function,'l_in_scale_id = '||l_in_scale_id);                
                
                
                if nvl(l_in_scale_id,0) = 0 then
                    l_in_scale_id := xx_disl_car_scale_seq.nextval;
                end if;
                
                if nvl(l_out_scale_id,0) = 0 then
                    l_out_scale_id := xx_disl_car_scale_seq.nextval;
                end if;
                
               
                
                
                l_scale_rec.SPEED := 1;
                l_scale_rec.WAG_NUMBER := '1';
                l_scale_rec.CAR_NUMBER := l_car_number;
                
                l_scale_rec.ROUND_ID := l_shop_round_id;
                l_scale_rec.CAR_NUMBER_CORR := l_car_number; 
                l_scale_rec.CHECK_CAR := 1; 
                l_scale_rec.DESCR := 'Вес с весов корп.1831 (карбамид)';
                l_scale_rec.CREATED_BY:=nvl(x_changes_prm.who_end_id,x_changes_prm.who_start_id);
                l_scale_rec.CREATED_DATE:=sysdate; 
                l_scale_rec.TYPE :='Статика';
                l_scale_rec.FOR_AKT:=0; -- Нет
                
                
                -- Вес вначеле погрузки/разгрузки
                l_scale_rec.ID := l_in_scale_id; 
                l_scale_rec.NAPR_SYS := 'in';
                l_scale_rec.DATE_W := l_date_start;                         
                l_scale_rec.PK_ID:=xx_disl_car_scale_seq.nextval;
                --Если при взвешивании пришел брутто (тара и вес), то заносим первым вес тары, а на выходе
                IF l_weight_net = l_weight_net_begin AND l_weight_net > 40
                THEN
                  l_scale_rec.WEIGHT := (l_new_weight_dep) * 1000;
                  l_scale_rec.WEIGHT_COR := (l_new_weight_dep);
                ELSE
                  if l_weight_net > 40 then
                    l_scale_rec.WEIGHT := (l_new_weight_dep) * 1000;
                    l_scale_rec.WEIGHT_COR := (l_new_weight_dep);
                  else
                    l_scale_rec.WEIGHT := (l_new_weight_gross_td) * 1000;
                    l_scale_rec.WEIGHT_COR := (l_new_weight_gross_td);
                  end if;
                END IF;
                
                
                log_new(l_log_id,l_function,'l_scale_rec.ID = '||l_scale_rec.ID);
                log_new(l_log_id,l_function,'l_scale_rec.TRAIN_ID = '||l_scale_rec.TRAIN_ID);
                log_new(l_log_id,l_function,'l_scale_rec.NAPR_SYS = '||l_scale_rec.NAPR_SYS);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT = '||l_scale_rec.WEIGHT);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT_COR = '||l_scale_rec.WEIGHT_COR);
                
                if l_scale_rec.DATE_W is not null then
                    save_merge_disl_car_scale(p_scale_rec  => l_scale_rec,
                                              p_status     => l_scale_status,
                                              p_msg        => l_scale_msg
                                             );
                    if nvl(l_scale_status,'*') = 'E' then
                        log_new(l_log_id,l_function,'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg);
                        return 'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg;
                    end if;
                end if;
                
                -- Вес после погрузки/разгрузки 
                l_scale_rec.ID := l_out_scale_id;    
                l_scale_rec.NAPR_SYS := 'out';
                l_scale_rec.DATE_W := l_date_end;                            
                l_scale_rec.PK_ID:=xx_disl_car_scale_seq.nextval;
                --l_scale_rec.WEIGHT := case when l_weight_net != 0 then l_new_weight_gross_td*1000 else l_new_weight_dep*1000 end;
                --l_scale_rec.WEIGHT_COR := case when l_weight_net != 0 then l_new_weight_gross_td else l_new_weight_dep end;
                l_scale_rec.WEIGHT := (l_new_weight_gross_td) * 1000;
                l_scale_rec.WEIGHT_COR := (l_scale_rec.WEIGHT/1000);
                log_new(l_log_id,l_function,'l_scale_rec.ID = '||l_scale_rec.ID);
                log_new(l_log_id,l_function,'l_scale_rec.TRAIN_ID = '||l_scale_rec.TRAIN_ID);
                log_new(l_log_id,l_function,'l_scale_rec.NAPR_SYS = '||l_scale_rec.NAPR_SYS);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT = '||l_scale_rec.WEIGHT);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT_COR = '||l_scale_rec.WEIGHT_COR);
                if l_scale_rec.DATE_W is not null then
                    save_merge_disl_car_scale(p_scale_rec  => l_scale_rec,
                                              p_status     => l_scale_status,
                                              p_msg        => l_scale_msg
                                             );
                    if nvl(l_scale_status,'*') = 'E' then
                           log_new(l_log_id,l_function,'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg);
                           return 'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg;
                    end if;
                end if;
            end if;
            
        else
            l_shop_info_id := xx_etw.xx_disl_shop_info_seq.nextval();
            log_new(l_log_id,l_function,'l_shop_info_id = '||l_shop_info_id);
            
            insert into xx_etw.xx_disl_shop_info 
            (ROUND_ID, WEIGHT_NET, DATE_POST, DATE_START, DATE_END, DATE_ZAYAVKA_UVOD, DATE_UVOD, WHO_LOOKED_ID, WHO_LOOKED, WHO_START_ID, WHO_START, WHO_END_ID, WHO_END, 
             WHO_ZAYAVKA_ID, WHO_ZAYAVKA, CREATION_DATE, CREATED_BY, LAST_UPDATE_DATE, LAST_UPDATE_BY, REFUSAL, CREATE_REQUEST, FREIGHT_NAME, SHOP_INFO_ID, LAST_RECORD, WEIGHT_NET_BEGIN, ROUND_TYPE, 
             BATCH_ID, BATCH_NO,un_loading_from_subs
            ,accepted_weight
            ,define_task
            ,define_comment
            ,otgruzka_1c_id -- add 05.05.2026
             )
            values(l_shop_round_id
                  ,case
                     when l_weight_net_begin != 0 and l_date_end is not null/*Когда вагон разгружаем, то при введеной дате "Конец разгрузки" вес груза обнуляем (иногда пользователи забывают это делать)*/
                       then 0
                     else l_weight_net
                   end
                  ,l_date_post             
                  ,l_date_start            
                  ,l_date_end              
                  ,l_date_zayavka_uvod     
                  ,l_date_uvod
                  ,x_changes_prm.who_looked_id
                  ,x_changes_prm.who_looked
                  ,x_changes_prm.who_start_id
                  ,x_changes_prm.who_start
                  ,x_changes_prm.who_end_id
                  ,x_changes_prm.who_end
                  ,x_changes_prm.who_zayavka_id
                  ,x_changes_prm.who_zayavka
                  ,sysdate
                  ,x_changes_prm.user_id
                  ,sysdate
                  ,x_changes_prm.user_id
                  ,l_refusal
                  ,'N'
                  ,l_freight
                  ,l_shop_info_id
                  ,'Y'    
                  ,l_weight_net_begin    
                  ,l_shop_round_type
                  ,null
                  ,null
                  ,l_un_loading_id
                  ,l_accepted_weight
                  ,l_define_task
                  ,l_define_comment
                  ,x_changes_prm.otgruzka_1c_id -- add 05.05.2026 
                  )
            returning weight_net into l_weight_net;
            log_new(l_log_id,l_function,'insert into xx_disl_shop_info. rowcount = '||sql%rowcount);
            
            update xx_etw.xx_disl_shop_info
               set last_record = 'N'
             where 1=1  
               and round_id = l_shop_round_id
               and round_type = l_shop_round_type
               and shop_info_id < l_shop_info_id
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_shop_info. rowcount = '||sql%rowcount);
            
            -- Добавляем вес в таблицу взвешивания
            if nvl(l_scales_type_id,0) not in (0,1,3) and l_shop_round_type = 'railcar' and l_un_loading_id = 0 then
                begin
                    begin
                        select id as l_out_scale_id
                          into l_out_scale_id
                          from xx_disl_car_scale dcs
                         where 1=1
                               and dcs.NAPR_SYS = 'out'
                               --and dcs.WEIGHT_COR > 41 
                               and dcs.DESCR like '%Вес с весов корп.1831%' 
                               and trunc(dcs.DATE_W,'MI') = trunc(l_date_end,'MI') -- add 20/01/2023  
                               and dcs.ROUND_ID = l_shop_round_id;
                    exception when others then l_out_scale_id:=0;
                    end;
                    
                    log_new(l_log_id,l_function,'l_out_scale_id = '||l_out_scale_id);
                    begin
                        select id as l_in_scale_id
                          into l_in_scale_id
                          from xx_disl_car_scale dcs
                         where 1=1
                               and dcs.NAPR_SYS = 'in' 
                               and dcs.DESCR like '%Вес с весов корп.1831%'
                               --and dcs.WEIGHT_COR < 41 
                               and trunc(dcs.DATE_W,'MI') = trunc(l_date_start,'MI') -- add 20/01/2023  
                               and dcs.ROUND_ID = l_shop_round_id;
                    exception when others then l_in_scale_id:=0;
                    end;
                end;
                log_new(l_log_id,l_function,'l_in_scale_id = '||l_in_scale_id);                
                
                
                if nvl(l_in_scale_id,0) = 0 then
                    l_in_scale_id := xx_disl_car_scale_seq.nextval;
                end if;
                
                if nvl(l_out_scale_id,0) = 0 then
                    l_out_scale_id := xx_disl_car_scale_seq.nextval;
                end if;
                
               
                
                log_new(l_log_id,l_function,'l_scale_rec.ID = '||l_scale_rec.ID);
                log_new(l_log_id,l_function,'l_scale_rec.TRAIN_ID = '||l_scale_rec.TRAIN_ID);
                log_new(l_log_id,l_function,'l_scale_rec.NAPR_SYS = '||l_scale_rec.NAPR_SYS);
                l_scale_rec.SPEED := 1;
                l_scale_rec.WAG_NUMBER := '1';
                l_scale_rec.CAR_NUMBER := l_car_number;
                
                l_scale_rec.ROUND_ID := l_shop_round_id;
                l_scale_rec.CAR_NUMBER_CORR := l_car_number; 
                l_scale_rec.CHECK_CAR := 1; 
                l_scale_rec.DESCR := 'Вес с весов корп.1831 (карбамид)';
                l_scale_rec.CREATED_BY:=nvl(x_changes_prm.who_end_id,x_changes_prm.who_start_id);
                l_scale_rec.CREATED_DATE:=sysdate; 
                l_scale_rec.TYPE :='Статика';
                l_scale_rec.FOR_AKT:=0; -- Нет
                
                
                -- Вес вначеле погрузки/разгрузки
                l_scale_rec.ID := l_in_scale_id; 
                l_scale_rec.NAPR_SYS := 'in';
                l_scale_rec.DATE_W := nvl(l_date_start, sysdate);                         
                l_scale_rec.PK_ID:=xx_disl_car_scale_seq.nextval;
                
                l_scale_rec.WEIGHT := case when l_weight_net != 0 then (l_new_weight_dep+l_weight_net_begin)*1000 else (l_new_weight_dep)*1000 end;
                l_scale_rec.WEIGHT_COR := case when l_weight_net != 0 then (l_new_weight_dep+l_weight_net_begin) else (l_new_weight_dep) end;
                
                log_new(l_log_id,l_function,'l_scale_rec.ID = '||l_scale_rec.ID);
                log_new(l_log_id,l_function,'l_scale_rec.TRAIN_ID = '||l_scale_rec.TRAIN_ID);
                log_new(l_log_id,l_function,'l_scale_rec.NAPR_SYS = '||l_scale_rec.NAPR_SYS);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT = '||l_scale_rec.WEIGHT);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT_COR = '||l_scale_rec.WEIGHT_COR);
                
                if l_scale_rec.DATE_W is not null then
                    save_merge_disl_car_scale(p_scale_rec  => l_scale_rec,
                                              p_status     => l_scale_status,
                                              p_msg        => l_scale_msg
                                             );
                    if nvl(l_scale_status,'*') = 'E' then
                        log_new(l_log_id,l_function,'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg);
                        return 'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg;
                    end if;
                end if;
                
                -- Вес после погрузки/разгрузки 
                l_scale_rec.ID := l_out_scale_id;    
                l_scale_rec.NAPR_SYS := 'out';
                l_scale_rec.DATE_W := nvl(l_date_end, sysdate);                            
                l_scale_rec.PK_ID:=xx_disl_car_scale_seq.nextval;
                -- add 18.03.2023 BekmansurovRR
                -- Если нет начального веса и пришел груженный вагон, то 2-я запись взешивания - с весом
                if l_weight_net != 0 and l_weight_net_begin is null then
                    l_scale_rec.WEIGHT := (l_new_weight_dep+l_weight_net)*1000;
                    l_scale_rec.WEIGHT_COR := (l_new_weight_dep+l_weight_net);
                else 
                    l_scale_rec.WEIGHT := case when l_weight_net != 0 then (l_new_weight_dep+l_weight_net_begin)*1000 else l_new_weight_dep*1000 end;
                    l_scale_rec.WEIGHT_COR := case when l_weight_net != 0 then (l_new_weight_dep+l_weight_net_begin) else l_new_weight_dep end;
                end if;
                
                log_new(l_log_id,l_function,'l_scale_rec.ID = '||l_scale_rec.ID);
                log_new(l_log_id,l_function,'l_scale_rec.TRAIN_ID = '||l_scale_rec.TRAIN_ID);
                log_new(l_log_id,l_function,'l_scale_rec.NAPR_SYS = '||l_scale_rec.NAPR_SYS);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT = '||l_scale_rec.WEIGHT);
                log_new(l_log_id,l_function,'l_scale_rec.WEIGHT_COR = '||l_scale_rec.WEIGHT_COR);
                
                if l_scale_rec.DATE_W is not null then
                    save_merge_disl_car_scale(p_scale_rec  => l_scale_rec,
                                              p_status     => l_scale_status,
                                              p_msg        => l_scale_msg
                                             );
                    if nvl(l_scale_status,'*') = 'E' then
                           log_new(l_log_id,l_function,'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg);
                           return 'fail$'||'Ошибка при добав.данных по взвешиванию! Error='||l_scale_msg;
                    end if;            
                end if;
            end if;
        end if;
            
            DECLARE
            --Проверяем, если несколько одинаковых строк с флагом LAST_RECORD, то оставляем последнюю VedyaninDA 13.05.2025
               l_count_equal       NUMBER := 0;
               l_add_info_id_max   NUMBER;
            BEGIN
               SELECT   COUNT ('X'), MAX (ADD_INFO_ID)
                 INTO   l_count_equal, l_add_info_id_max
                 FROM   xx_etw.xx_disl_railcar_add_info info
                WHERE   1 = 1 AND info.round_id = l_shop_round_id AND info.LAST_RECORD = 'Y';

               IF l_count_equal > 1
               THEN
                  UPDATE   xx_etw.xx_disl_railcar_add_info info
                     SET   LAST_RECORD = 'N'
                   WHERE       1 = 1
                           AND info.round_id = l_shop_round_id
                           AND info.LAST_RECORD = 'Y'
                           AND ADD_INFO_ID <> l_add_info_id_max;
               END IF;
               
               log_new(l_log_id,l_function,'l_shop_round_type='||l_shop_round_type||' l_shop_round_id='||l_shop_round_id||' l_add_info_id_max='||l_add_info_id_max);
            END;

        if (l_shop_round_type = 'railcar') then
        
            select add_info_id
                  ,add_info_type
                  ,weight_net
                  ,freight_name
              into l_add_info_id_old
                  ,l_add_info_type_old
                  ,l_weight_net_old
                  ,l_freight_old
              from xx_etw.xx_disl_railcar_add_info info
             where 1=1
               and info.round_id = l_shop_round_id
               and info.last_record = 'Y'
            ;
        else
            select add_info_id
                  ,add_info_type
                  ,weight_net
                  ,freight_name
              into l_add_info_id_old
                  ,l_add_info_type_old
                  ,l_weight_net_old
                  ,l_freight_old
              from xx_etw.xx_disl_cont_add_info
             where 1=1
               and cont_round_id = l_shop_round_id
               and last_record = 'Y'
            ;
        end if;
        log_new(l_log_id,l_function,'l_weight_net = '||l_weight_net||' l_freight = '||l_freight||' l_add_info_id_old = '||l_add_info_id_old||' l_add_info_type_old = '||l_add_info_type_old||' l_weight_net_old = '||l_weight_net_old||' l_freight_old = '||l_freight_old);

        if (l_weight_net_old!=l_weight_net or l_freight_old!=l_freight) then     
            if (l_shop_round_type = 'railcar') then
                if (l_add_info_type_old='A' or l_add_info_type_old='T' or l_add_info_type_old='M') then
                    l_add_info_id_new := xx_etw.xx_disl_railcar_add_info_seq.nextval();
                    
                    insert into xx_etw.xx_disl_railcar_add_info(
                         add_info_id
                        ,round_id
                        ,car_number
                        ,status
                        ,car_type
                        ,freight_name
                        ,weight_net
                        ,weight_dep
                        ,cont
                        ,owner
                        ,add_info_type
                        ,last_record
                        ,last_update_date
                        ,last_update_user_id
                        ,car_length
                        ,need_load_car_info
                        ,date_begin
                        ,SCALES_TYPE_ID
                        ,un_loading_from_subs
                        ,shop_info_id
                    )
                    select l_add_info_id_new
                          ,old_info.round_id
                          ,old_info.car_number
                          ,old_info.status
                          ,old_info.car_type
                          ,l_freight
                          ,l_weight_net
                          ,case when nvl(l_scales_type_id,0) not in (0,1,3) then l_new_weight_dep else old_info.weight_dep end as weight_dep -- add 21/12/2022
                          ,old_info.cont
                          ,old_info.owner
                          ,'M'get_car_cont_add_info
                          ,'Y'
                          ,sysdate
                          ,x_changes_prm.user_id
                          ,old_info.car_length
                          ,old_info.need_load_car_info
                          ,sysdate
                          ,nvl(l_scales_type_id,1)
                          ,l_un_loading_id
                          ,l_shop_info_id   
                      from xx_etw.xx_disl_railcar_add_info old_info
                     where 1=1
                       and add_info_id = l_add_info_id_old
                    ;
                    log_new(l_log_id,l_function,'insert into xx_disl_railcar_add_info. rowcount = '||sql%rowcount || ' l_add_info_id_new = '||l_add_info_id_new);
                                
                    update xx_etw.xx_disl_railcar_add_info 
                       set last_record = 'N'
                          ,date_end = sysdate
                     where 1=1
                       and add_info_id = l_add_info_id_old
                    ;
                    log_new(l_log_id,l_function,'update xx_disl_railcar_add_info. rowcount = '||sql%rowcount);
--                elsif (l_add_info_type_old='M') then
--                    update xx_etw.xx_disl_railcar_add_info 
--                       set weight_net = l_weight_net
--                          ,freight_name = l_freight
--                          ,last_update_date = sysdate
--                          ,last_update_user_id = p_user_id
--                     where 1=1
--                       and add_info_id = l_add_info_id_old
--                    ;
--                    log_new(l_log_id,l_function,'update xx_disl_railcar_add_info. rowcount = '||sql%rowcount);
                end if;
            else                   
                if (l_add_info_type_old='A' or l_add_info_type_old='T' or l_add_info_type_old='M') then
                    l_add_info_id_new :=  xx_etw.xx_disl_cont_add_info_seq.nextval();
                    log_new(l_log_id,l_function,'l_add_info_id_new = '||l_add_info_id_new);
                        
                    insert into xx_etw.xx_disl_cont_add_info
                    select l_add_info_id_new
                          ,cont_round_id
                          ,cont_number
                          ,status
                          ,l_freight
                          ,l_weight_net
                          ,weight_dep
                          ,owner
                          ,'M'
                          ,'Y'
                          ,sysdate
                          ,x_changes_prm.user_id
                          ,'N'
                          ,null
                          ,null
                          ,sysdate
                          ,null
                      from xx_etw.xx_disl_cont_add_info
                     where 1=1
                       and add_info_id = l_add_info_id_old  
                    ;
                    log_new(l_log_id,l_function,'update xx_disl_cont_add_info. rowcount = '||sql%rowcount);
                        
                    update xx_etw.xx_disl_cont_add_info 
                       set last_record = 'N'
                          ,date_end = sysdate
                     where 1=1
                       and add_info_id = l_add_info_id_old
                    ;
                    log_new(l_log_id,l_function,'update xx_disl_cont_add_info. rowcount = '||sql%rowcount); 
--                elsif (l_add_info_type_old='M') then
--                    update xx_etw.xx_disl_cont_add_info 
--                       set freight_name = l_freight
--                          ,weight_net = l_weight_net
--                          ,last_update_date = sysdate
--                          ,last_update_user_id = p_user_id
--                     where 1=1
--                       and add_info_id = l_add_info_id_old
--                    ;
--                    log_new(l_log_id,l_function,'update xx_disl_cont_add_info. rowcount = '||sql%rowcount);
                end if;  
            end if;   
        end if;
        
        x_loading_rec.shop_info_id := l_shop_info_id; 
        x_loading_rec.car_number := l_car_number; 
        x_loading_rec.cont_number := l_cont_number;
        x_loading_rec.otgruzka_1c_id := x_changes_prm.otgruzka_1c_id; 
        
        x_loading_tbl.extend; 
         
        x_loading_tbl(x_loading_tbl.COUNT) := x_loading_rec;
    end loop;
    
    commit;
    p_out_load_rec := x_loading_tbl;
    return 'done';    
exception
    when others then rollback; 
    log_new(l_log_id,l_function,'Error = '||sqlerrm); 
    return 'fail$Error='||sqlerrm;
end;

function get_cont_out_date(
    p_cont varchar2)
return varchar2
as
    l_date      date;
begin
    select max(in_date_fact)
      into l_date
      from xx_disl_cont_history
     where 1=1
       and place_type = 'area'
       and cont_round_id in (
            select cont_round_id
              from xx_disl_cont_round
             where 1=1
               and cont_history_out is null
               and cont_number in (
                    select regexp_substr(p_cont,'[^|]+',1,level) cont_number
                      from dual
                   connect by level <= regexp_count(p_cont,'[^|]+')
               ));
                                 
    if l_date is null then
        return '';
    else
        return(to_char(l_date,'dd.mm.yyyy hh24:mi'));
    end if;    
exception
    when others then return '';   
end;

/*возвращает дату перемещения вагона на определенные пути*/
function get_railcar_in_date(
    p_cars varchar2)
return varchar2
as
    l_date      date;
begin
    select min(date_oper_fact) + 1/24*2
      into l_date
      from xx_etw.xx_disl_railway_history
     where 1=1
       and railway_id in (53,77,79,80,81,82)
       and station_hist_id in (
        select max(station_hist_id)
          from xx_disl_station_history
         where 1=1
           and station_id = 3
           and round_id in (
            select returnLastRound(regexp_substr(p_cars,'[^|]+',1,level))
              from dual
           connect by level <= regexp_count(p_cars,'[^|]+')));
                                 
    if l_date is null then
        return '';
    else
        return(to_char(l_date,'dd.mm.yyyy hh24:mi'));
    end if;    
exception
    when others then return '';   
end;

function get_move_cont_to_pl(
    p_cars varchar2)
return varchar2
as
    l_date      date;
begin
    select max(in_date_fact)
      into l_date
      from xx_disl_cont_history_cur     chc
          ,xx_disl_cont_history         ch     
     where 1=1
       and chc.place_id in (
            select returnLastRound(regexp_substr(p_cars,'[^|]+',1,level))
              from dual
           connect by level <= regexp_count(p_cars,'[^|]+'))
       and chc.place_type = 'railcar'
       
       and chc.cont_history_id_in = ch.cont_history_id;
                                 
    if l_date is null then
        return '';
    else
        return(to_char(l_date,'dd.mm.yyyy hh24:mi'));
    end if;    
exception
    when others then return '';   
end;

function get_car_arrive_weight_net(p_round_id number) 
return number 
as
    l_weight_car            number;
    l_weight_cont           number;
begin
    select max(nvl(rai.weight_net,0)) keep (dense_rank last order by rai.add_info_id)
      into l_weight_car
      from xx_disl_railcar_add_info rai
     where 1=1
       and rai.round_id = p_round_id
       and rai.add_info_type = 'A'
    ;

    select sum(nvl(weight_net,0))
      into l_weight_cont
      from xx_etw.xx_disl_cont_history_cur  chc
          ,xx_etw.xx_disl_cont_add_info     cai
     where 1=1
       and chc.place_id = p_round_id
       and chc.place_type = 'railcar'
               
       and chc.cont_round_id = cai.cont_round_id
       and cai.add_info_type = 'A'
    ;   
    
    return nvl(l_weight_car,0)+nvl(l_weight_cont,0);  
exception
    when others then return 0;
end;

