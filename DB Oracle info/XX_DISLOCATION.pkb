function get_rail_contract_services
return t_xx_rail_contract_serv_table pipelined
as
    l_row       t_xx_rail_contract_service_row;
begin
    for l_tmp in (select rcs.id
                        ,rcs.contract_id
                        ,rc.descr  contract
                        ,rcs.service_id 
                        ,rs.code            service
                        ,rcs.ei
                        ,rcs.ei_descr
                        ,rcs.cost
                        ,rcs.cost_nds
                        ,u_cr.full_name                                         created_by
                        ,to_char(rcs.created_date,'dd.mm.yyyy')                 created_date
                        ,u_up.full_name                                         last_updated_by
                        ,to_char(rcs.last_updated_date,'dd.mm.yyyy')            last_updated_date
                    from xx_etw.xx_disl_rail_contract_services  rcs
                        ,(select id
                                ,num
                                ,beg_date
                                ,num||' от '||to_char(beg_date,'dd.mm.yyyy') ||
                                 case
                                   when sysdate between nvl(beg_date,sysdate-1) and nvl(end_date,sysdate+1)
                                     then null
                                   else ' (закрыт)'
                                 end
                                        descr
                            from xx_etw.xx_disl_rail_contracts          rc
                           union
                          select id
                                ,num
                                ,beg_date
                                ,descr
                            from xx_etw.xx_disl_rail_contract_dop_v      
                           union
                          select id
                                ,num
                                ,beg_date
                                ,descr
                            from xx_disl_rail_contract_change_v  
                         )
                                                                rc
                        ,xx_etw.xx_disl_rail_services           rs
                        ,xx_etw.xx_disl_users                   u_cr
                        ,xx_etw.xx_disl_users                   u_up 
                   where 1=1
                     and rcs.contract_id = rc.id(+)

                     and rcs.service_id = rs.id(+)
                     
                     and rcs.created_by = u_cr.id(+)
                     and rcs.last_updated_by = u_up.id(+)
                   order by
                         rc.num
                        ,rs.code
                 )
    loop
        l_row.id := l_tmp.id;
        l_row.contract_id := l_tmp.contract_id;
        l_row.contract := l_tmp.contract;
        l_row.service_id := l_tmp.service_id;
        l_row.service := l_tmp.service;
        l_row.ei := l_tmp.ei;
        l_row.ei_descr := l_tmp.ei_descr;
        l_row.cost := l_tmp.cost;
        l_row.cost_nds := l_tmp.cost_nds;
        l_row.created_by := l_tmp.created_by;
        l_row.created_date := l_tmp.created_date;
        l_row.last_updated_by := l_tmp.last_updated_by;
        l_row.last_updated_date := l_tmp.last_updated_date;
        
        pipe row (l_row);
    end loop;
end;

function get_rail_parent_contracts_add
return t_xx_parent_contracts_table pipelined
as
    l_row       t_xx_parent_contracts_row;   
begin
    for l_tmp in (
        with tmp as (
            select id
                  ,num
                  ,beg_date
                  ,-1       parent_id
                  ,num||' от '||to_char(beg_date,'dd.mm.yyyy') ||
                   case
                     when sysdate between nvl(beg_date,sysdate-1) and nvl(end_date,sysdate+1)
                       then null
                     else ' (закрыт)'
                   end
                        descr
              from xx_disl_rail_contracts
             union
            select id
                  ,num
                  ,beg_date
                  ,nvl(contract_id,-1)      parent_id
                  ,descr
              from xx_disl_rail_contract_dop_v
             union
            select id
                  ,num
                  ,beg_date
                  ,nvl(contract_id,-1)      parent_id
                  ,descr
              from xx_disl_rail_contract_change_v            
        )
        select tmp.id
              ,tmp.num
              ,to_char(tmp.beg_date,'dd.mm.yyyy')   beg_date
              ,tmp.descr
              ,level lvl
          from tmp
       connect by
               parent_id = prior id
         start with parent_id = -1
         order siblings by 
               num     
    ) loop
        l_row.id := l_tmp.id;
        l_row.num := l_tmp.num;
        l_row.beg_date := l_tmp.beg_date;
        l_row.descr := l_tmp.descr;
        l_row.lvl := l_tmp.lvl;
        
        pipe row (l_row);
    end loop;
end;

function save_rail_contract_services(  
    p_user_id           number,   
    p_id                number,
    p_contract_id       number,
    p_service_id        number,
    p_ei                  varchar2,
    p_ei_descr            varchar2,
    p_cost                number,
    p_cost_nds            number
) return varchar2
as
    l_id        number;
begin
    if (p_id is null) then
        insert into xx_etw.xx_disl_rail_contract_services(
            id,
            contract_id,
            service_id,
            ei,
            ei_descr,
            cost,
            cost_nds,
            created_by,
            created_date
        )
        values(
            xx_etw.xx_disl_rail_contract_serv_seq.nextval,
            p_contract_id,
            p_service_id,
            p_ei,
            p_ei_descr,
            p_cost,
            p_cost_nds,
            p_user_id,
            sysdate
        )
        returning id into l_id;
    else
        update xx_etw.xx_disl_rail_contract_services
           set contract_id = p_contract_id, 
               service_id = p_service_id,  
               ei = p_ei,
               ei_descr = p_ei_descr,
               cost = p_cost,
               cost_nds = p_cost_nds,
               last_updated_by = p_user_id,
               last_updated_date = sysdate
         where 1=1
           and id = p_id
        ;
    end if;
    
    commit;
    return 'done'||'$'||to_char(l_id); 

end;

function del_rail_contract_services(p_id number)
return varchar2
as
begin
    delete
      from xx_etw.xx_disl_rail_contract_services
     where 1=1
       and id = p_id 
    ;
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function get_car_containers(p_car_number varchar2)
return t_xx_cont_table pipelined
as
    l_row           t_xx_cont_row;
    
    l_round_id      number;
    
begin
    begin
        select round_id
          into l_round_id
          from xx_etw.xx_disl_round                r
         where 1=1
           and r.railcar_id = p_car_number
           and r.station_hist_id_out is null
        ;
    exception
        when no_data_found then l_round_id := null;
    end;
    
    if (l_round_id is null) then 
        select max(r.round_id) keep (dense_rank last order by sh.out_date)
          into l_round_id
          from xx_etw.xx_disl_round                 r
              ,xx_etw.xx_disl_station_history       sh
         where 1=1
           and r.railcar_id = p_car_number
           and r.station_hist_id_out = sh.station_hist_id
        ;
        
        for tmp in (
            select cr.cont_number
              from xx_etw.xx_disl_cont_history      chc
                  ,xx_etw.xx_disl_cont_round        cr
             where 1=1
               and chc.place_id = l_round_id
               and chc.place_type = 'railcar'
               
               and chc.cont_round_id = cr.cont_round_id
               and chc.cont_history_id = cr.cont_history_out
        ) loop
            l_row.cont_number := tmp.cont_number;
            pipe row (l_row);       
        end loop;
    else
        for tmp in (
            select cr.cont_number
              from xx_etw.xx_disl_cont_history_cur          chc
                  ,xx_etw.xx_disl_cont_round                cr
             where 1=1
               and place_id = l_round_id
               and place_type = 'railcar'
               
               and chc.cont_round_id = cr.cont_round_id
        ) loop
            l_row.cont_number := tmp.cont_number;
            pipe row (l_row);       
        end loop;      
    end if; 
end;

procedure mark_last_record_for_ins(p_asset_instance_number varchar2) 
as
    l_last_record_id            number; 
    
    l_cont_round_id             number;  
    l_cont_add_info_id          number;
    
    l_round_id                  number;  
    l_car_add_info_id           number;
    l_errbuf        varchar2(4000);
    l_retcode       varchar2(1);
begin
    update xx_disl_inspections
       set last_record = 'N'
     where 1=1
       and asset_instance_number = p_asset_instance_number
       and last_record = 'Y'
    ;
    
    begin
        select max(inspection_id) keep (dense_rank last order by  nvl(inspection_date,created_date))
          into l_last_record_id
          from xx_disl_inspections
         where 1=1
           and asset_instance_number = p_asset_instance_number
        ;
        
        update xx_disl_inspections
           set last_record = 'Y'
         where 1=1
           and inspection_id = l_last_record_id
        ;
    exception
        when no_data_found then null;   
    end;
 
    l_cont_round_id := return_last_cont_round(p_asset_instance_number);
                
    if l_cont_round_id != -1 then
        select add_info_id
          into l_cont_add_info_id
          from xx_etw.xx_disl_cont_add_info
         where 1=1
           and cont_round_id = l_cont_round_id
           and last_record = 'Y'
        ;
        update_cont_status(l_cont_add_info_id);
    end if;   
    
    l_round_id := returnLastRound(p_asset_instance_number);
                
    if l_round_id != -1 then
        select add_info_id
          into l_car_add_info_id
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and round_id = l_round_id
           and last_record = 'Y'
        ;
        update_railcar_status(l_errbuf,l_retcode,l_car_add_info_id);
    end if; 
end;

function enter_inspection(p_user_id                     number
                         ,p_car_number                  varchar2
                         ,p_cont                        varchar2
                         ,p_inspection_id               number
                         ,p_inspection_date             varchar2
                         ,p_inspection_place            varchar2
                         ,p_inspection_person           varchar2
                         ,p_inspection_person_appoint   varchar2
                         ,p_master                      varchar2
                         ,p_priority                    varchar2
                         ,p_result                      varchar2
                         ,p_status_kurs                 varchar2
                         ,p_comment                     varchar2
                         ,p_defects                     varchar2
                         ,p_need_commit                 varchar2 default 'Y'
                         )
return varchar2
as

    l_log_id                number;
    l_function              varchar2(100):='enter_inspection';
    
    l_inspection_date       date;
    l_instance_id           number;
    l_asset_group_id        number;
    l_asset_group           inv.mtl_system_items_b.segment1%type;
    l_asset_number          csi.csi_item_instances.serial_number%type;
    l_inspection_id         number;
    
    l_defect_id             varchar2(300);
    l_defect_code           varchar2(300);
    l_defect_descr          varchar2(300);
    l_doc_type              varchar2(300);
    l_doc_num               varchar2(300);
    l_defect_date           varchar2(30);
    
    l_errbuf                varchar2(4000);
    l_retcode               varchar2(1);
    l_add_info_id           number;
    
    l_car_owner_id          xx_etw.etw_inv_car.car_owner_id%type;
    l_car_type_code         xx_etw.etw_inv_car.car_type_code%type;
    
    l_user_name             varchar2(100);
    l_return_status         varchar2(1);
    
    l_req_result            varchar2(1);
    l_req_error_log         varchar2(200);
    
    l_asset_instance_number varchar2(30);
    
    l_old_result            varchar2(300);
    
    l_cont_round_id         number;
    l_cont_add_info_id      number;

    procedure enter_defects(p_inspection_id number,p_result varchar2,p_defects varchar2,p_log_id number)
    as
        l_function varchar2(100) := 'enter_defects';   
    begin
        delete
          from xx_disl_inspection_defects
         where 1=1
           and inspection_id = p_inspection_id
        ;
        log_new(p_log_id,l_function,'delete from xx_disl_inspection_defects. rowcount = '||sql%rowcount);
        
        if (p_result = 'Не годен' or p_result = 'Ограничение') then
            for l_defect in (select regexp_substr(p_defects,'[^$]+',1,level) text
                               from dual
                            connect by level <= regexp_count(p_defects,'[^$]+')
                            )
            loop     
                l_defect_id := regexp_substr(l_defect.text,'[^|]+',1,1);
                log_new(l_log_id,l_function,'l_defect_id = '||l_defect_id);
                        
                l_defect_code := regexp_substr(l_defect.text,'[^|]+',1,2);
                log_new(l_log_id,l_function,'l_defect_code = '||l_defect_code);
                
                l_defect_descr := regexp_substr(l_defect.text,'[^|]+',1,3);
                log_new(l_log_id,l_function,'l_defect_descr = '||l_defect_descr);
                
                l_doc_type := regexp_substr(l_defect.text,'[^|]+',1,4);
                log_new(l_log_id,l_function,'l_doc_type = '||l_doc_type);
                
                l_doc_num := regexp_substr(l_defect.text,'[^|]+',1,5);
                log_new(l_log_id,l_function,'l_doc_num = '||l_doc_num);
                
                l_defect_date := regexp_substr(l_defect.text,'[^|]+',1,6);
                log_new(l_log_id,l_function,'l_defect_date = '||l_defect_date);
                
                insert into xx_disl_inspection_defects
                values(
                    decode(l_defect_id,'_',xx_disl_inspection_defects_seq.nextval,l_defect_id)
                   ,p_inspection_id
                   ,l_defect_code
                   ,l_defect_descr
                   ,decode(l_doc_type,'_',null,l_doc_type)
                   ,decode(l_doc_num,'_',null,l_doc_num)
                   ,decode(l_defect_date,'_',null,l_defect_date)
                   ,null
                   ,null
                   ,null
                )
                ;
                log_new(l_log_id,l_function,'insert into xx_disl_inspection_defects. rowcount = '||sql%rowcount);
            end loop;                     
        end if;
    end;

begin
    /*p_cont список состоящий из номера платформы(= p_car_number) и контейнеров. Если осмотр вводится по платформе, то p_cont всегда не null(проверка на форме), если же по вагону, то p_cont=null*/    
    /*Если же p_inspection_id != null, то считаем, что старый осмотр изменяем только по одной платформе или же контейнеру, т.е. на p_cont не обращаем внимание(хотя должен быть пустой(вагон) или же иметь одно значение(платформа, контейнер))*/
    
    l_log_id := xx_disl_log_seq.nextval();
    
    log_new(l_log_id,l_function,'parameters: p_user_id = '||p_user_id
                                         ||' p_car_number= '||p_car_number
                                         ||' p_cont= '||p_cont
                                         ||' p_inspection_id= '||p_inspection_id
                                         ||' p_inspection_date= '||p_inspection_date
                                         ||' p_inspection_place= '||p_inspection_place
                                         ||' p_inspection_person = '||p_inspection_person
                                         ||' p_inspection_person_appoint= '||p_inspection_person_appoint
                                         ||' p_master= '||p_master
                                         ||' p_priority= '||p_priority
                                         ||' p_result= '||p_result
                                         ||' p_status_kurs = '||p_status_kurs
                                         ||' p_comment = '||p_comment
                                         ||' p_defects = '||p_defects
                                         ||' p_need_commit = '||p_need_commit);
    
    begin
        l_inspection_date := to_date(p_inspection_date,'dd.mm.yyyy hh24:mi');
    exception
        when others then log_new(l_log_id,l_function,'raise no_data_found'); raise no_data_found;
    end;
    log_new(l_log_id,l_function,'l_inspection_date = '||l_inspection_date);
    
    if (p_inspection_id is null) /*новый осмотр*/ then
        if (p_cont is null) /*осмотр по вагону*/ then 
            select instance_id
                  ,asset_group_id
                  ,asset_group
                  ,asset_number
              into l_instance_id
                  ,l_asset_group_id
                  ,l_asset_group
                  ,l_asset_number
              from table(xx_dislocation.get_asset_info(p_car_number))
            ;
            log_new(l_log_id,l_function,'l_instance_id = '||l_instance_id||' l_asset_group_id = '||l_asset_group_id||' l_asset_group = '||l_asset_group||' l_asset_number = '||l_asset_number);
            
            insert into xx_disl_inspections
            values(
                xx_disl_inspections_seq.nextval
               ,p_user_id
               ,sysdate
               ,p_user_id
               ,sysdate
               ,p_car_number
               ,decode(l_instance_id,-1,null,l_instance_id)
               ,l_asset_group_id
               ,l_asset_number
               ,l_inspection_date
               ,p_inspection_place
               ,p_inspection_person
               ,p_inspection_person_appoint
               ,p_master
               ,p_priority
               ,p_result
               ,p_status_kurs
               ,p_comment
               ,null
               ,null
               ,'N'
               ,null
               ,null
               ,null
            )
            returning  inspection_id into l_inspection_id
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_inspections. rowcount = '||sql%rowcount);
            log_new(l_log_id,l_function,'l_inspection_id = '||l_inspection_id);
            
            mark_last_record_for_ins(p_car_number);/*сидит обновление статуса*/
            
            enter_defects(l_inspection_id,p_result,p_defects,l_log_id);
            
            if (p_result = 'Не годен') then
                begin
                    select min(eicar.car_owner_id) keep (dense_rank last order by eicar.front_end_id)
                      into l_car_owner_id
                      from xx_etw.etw_inv_car               eicar
                     where 1=1
                       and eicar.car_number = p_car_number
                    ;
                exception
                    when no_data_found then l_car_owner_id:=-1;
                end;
                log_new(l_log_id,l_function,'l_car_owner_id = '||l_car_owner_id);
                
                if (l_car_owner_id = 33888 /*ОАО "Метафракс"*/ or l_car_owner_id = 171231/*ООО "РАЙФФАЙЗЕН-ЛИЗИНГ"*/ or l_car_owner_id = 635483/*Закрытое акционерное общество " ТихвинХимМаш"*/ or p_car_number = 'ВЕСЫ-МОД-ЖД-7260SM') then
                    create_work_request(p_user_id,l_inspection_id,l_req_result,l_req_error_log);    
                end if;
            end if;
        else /*осмотр по платформе и контейнерам*/
            for l_conts in (select regexp_substr(p_cont,'[^|]+',1,level) cont_number
                             from dual
                          connect by level <= regexp_count(p_cont,'[^|]+')
                          )
            loop
                log_new(l_log_id,l_function,'l_cont = '||l_conts.cont_number); 
                
                select instance_id
                      ,asset_group_id
                      ,asset_group
                      ,asset_number
                  into l_instance_id
                      ,l_asset_group_id
                      ,l_asset_group
                      ,l_asset_number
                  from table(xx_dislocation.get_asset_info(l_conts.cont_number))
                ;
                log_new(l_log_id,l_function,'l_instance_id = '||l_instance_id||' l_asset_group_id = '||l_asset_group_id||' l_asset_group = '||l_asset_group||' l_asset_number = '||l_asset_number);
                
                insert into xx_disl_inspections
                values(
                    xx_disl_inspections_seq.nextval
                   ,p_user_id
                   ,sysdate
                   ,p_user_id
                   ,sysdate
                   ,l_conts.cont_number
                   ,decode(l_instance_id,-1,null,l_instance_id)
                   ,l_asset_group_id
                   ,l_asset_number
                   ,l_inspection_date
                   ,p_inspection_place
                   ,p_inspection_person
                   ,p_inspection_person_appoint
                   ,p_master
                   ,p_priority
                   ,p_result
                   ,p_status_kurs
                   ,p_comment
                   ,null
                   ,null
                   ,'N'
                   ,null
                   ,null
                   ,null
                )
                returning  inspection_id into l_inspection_id
                ;
                log_new(l_log_id,l_function,'insert into xx_disl_inspections. rowcount = '||sql%rowcount);
                log_new(l_log_id,l_function,'l_inspection_id = '||l_inspection_id);
                
                mark_last_record_for_ins(l_conts.cont_number);/*сидит обновление статуса*/
                enter_defects(l_inspection_id,p_result,p_defects,l_log_id);
            end loop;
        end if;
    else /*редактируем старый осмотр*/
        begin
            select result
              into l_old_result
              from xx_disl_inspections
             where 1=1
               and inspection_id = p_inspection_id
            ;
        exception
            when others then l_old_result:=null;
        end;
        
        update xx_disl_inspections
           set last_updated_by = p_user_id
              ,last_updated_date = sysdate
              --,asset_instance_number = p_car_number
              --,asset_instance_id = decode(l_instance_id,-1,null,l_instance_id)
              --,asset_group_id = l_asset_group_id
              --,asset_number = l_asset_number
              ,inspection_date = l_inspection_date
              ,inspection_place = p_inspection_place
              ,inspection_person = p_inspection_person
              ,inspection_person_appoint = p_inspection_person_appoint
              ,master = p_master
              ,priority = p_priority
              ,result = p_result
              ,status_kurs = p_status_kurs
              ,description = p_comment
         where 1=1
           and inspection_id = p_inspection_id
         returning asset_instance_number into l_asset_instance_number 
        ;
        log_new(l_log_id,l_function,'update xx_disl_inspections. rowcount = '||sql%rowcount);
        l_inspection_id:=p_inspection_id;
        log_new(l_log_id,l_function,'l_inspection_id = '||l_inspection_id);
        
        mark_last_record_for_ins(l_asset_instance_number);/*сидит обновление статуса*/
        enter_defects(l_inspection_id,p_result,p_defects,l_log_id);
        
        if (p_result = 'Не годен' and l_old_result = 'Годен') then
            begin
                select min(eicar.car_owner_id) keep (dense_rank last order by eicar.front_end_id)
                      ,min(eicar.car_type_code) keep (dense_rank last order by eicar.front_end_id)
                  into l_car_owner_id
                      ,l_car_type_code
                  from xx_etw.etw_inv_car               eicar
                 where 1=1
                   and eicar.car_number = p_car_number
                ;
            exception
                when no_data_found then l_car_owner_id:=-1;
            end;
            log_new(l_log_id,l_function,'l_car_owner_id = '||l_car_owner_id);
                
            if (   (l_car_owner_id = 33888 /*ОАО "Метафракс"*/ or l_car_owner_id = 171231/*ООО "РАЙФФАЙЗЕН-ЛИЗИНГ"*/ or l_car_owner_id = 635483/*Закрытое акционерное общество " ТихвинХимМаш"*/)
                or (l_car_owner_id = 550333 /*Общество с ограниченной ответственностью "ВМ-Транс"*/  and l_car_type_code = 70)
               ) then
                create_work_request(p_user_id,l_inspection_id,l_req_result,l_req_error_log);    
            end if;
        end if;
    end if;
        
    if (p_need_commit='Y') then     
        commit;
    end if;
    
    return 'done';
exception
    when others then rollback; return 'fail';    
end;

function enter_inspection_for_few_cars(p_user_id                number
                                      ,p_obj_numbers            varchar2
                                      ,p_obj_type               varchar2
                                      ,p_inspection_date        varchar2
                                      ,p_inspection_place       varchar2
                                      ,p_inspection_person      varchar2
                                      ,p_inspection_person_appoint varchar2
                                      ,p_master                 varchar2
                                      ,p_priority               varchar2
                                      ,p_result                 varchar2
                                      ,p_status_kurs            varchar2
                                      ,p_comment                varchar2
                                      ,p_cars_nsi               varchar2 -- add 26/10/2022 BekmansurovRR
                                      )
return varchar2
as
    l_log_id                number;
    l_function              varchar2(100) := 'enter_inspection_for_few_cars';
    
    l_car_number            varchar2(10);
    l_result                varchar2(10);
    l_cont                  varchar2(100);
    
    l_errbuf                varchar2(4000);
    l_retcode               varchar2(1);
    l_add_info_id           number;
    --
    rec_etw_car_nsi     etw_car_nsi%rowtype;
begin
    l_log_id := xx_disl_log_seq.nextval();
    
    log_new(l_log_id,l_function,'parameters: p_user_id = '||p_user_id
                                         ||' p_obj_numbers= '||p_obj_numbers
                                         ||' p_obj_type= '||p_obj_type
                                         ||' p_inspection_date= '||p_inspection_date
                                         ||' p_inspection_place= '||p_inspection_place
                                         ||' p_inspection_person = '||p_inspection_person
                                         ||' p_inspection_person_appoint= '||p_inspection_person_appoint
                                         ||' p_master= '||p_master
                                         ||' p_priority= '||p_priority
                                         ||' p_result= '||p_result
                                         ||' p_status_kurs = '||p_status_kurs
                                         ||' p_comment = '||p_comment
                                         ||' p_cars_nsi = '||p_cars_nsi
                                         );
    
    -- add 26/10/2022 BekmansurovRR
    -- Обновлем НСИ выбранных вагонов из формы "Осмотр вагонов"
    if (p_cars_nsi is not null) then
        for v_car in (
            select regexp_substr(p_cars_nsi,'[^|]+',1,level) car_number
              from dual
           connect by level <= regexp_count(p_cars_nsi,'[^|]+') 
        )
        loop
            if (xx_etw.etw_car_nsi_pkg.car_number_validate(v_car.car_number)) then
                rec_etw_car_nsi := xx_etw.etw_car_nsi_pkg.get_car_nsi (p_car_number => v_car.car_number, p_nsi_date => sysdate/*v_car.come_date*/);
            end if;
        end loop;
    end if;
    
    if (p_obj_numbers is not null) then
        for l_obj in (select regexp_substr(p_obj_numbers,'[^|]+',1,level) obj_number
                        from dual
                     connect by level <= regexp_count(p_obj_numbers,'[^|]+') 
                     )
        loop
            
            if (p_obj_type = 'railcar') then
                l_cont:=null;
                
                l_car_number := l_obj.obj_number;
                
                select listagg(cont_number, '|') within group (order by cont_number)
                  into l_cont
                  from table(xx_dislocation.get_car_containers(l_car_number))
                ;
                
                if (l_cont is not null) then 
                    l_cont := l_car_number||'|'||l_cont;
                end if;
            else
                l_car_number := null;
                l_cont := l_obj.obj_number; 
            end if;
             
            
            l_result := enter_inspection(p_user_id
                                        ,l_car_number
                                        ,l_cont
                                        ,null
                                        ,p_inspection_date
                                        ,p_inspection_place
                                        ,p_inspection_person
                                        ,p_inspection_person_appoint
                                        ,p_master
                                        ,p_priority
                                        ,p_result
                                        ,p_status_kurs
                                        ,p_comment
                                        ,null
                                        ,'N'
                                        );
            if (l_result!='done') then
                raise no_data_found;
            end if;    
        end loop;        
    end if;
    
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;
procedure create_work_request(
     p_user_id                  number      
    ,p_inspection_id            number
    ,p_result           out     varchar2
    ,p_error_log        out     varchar2
)
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100) := 'create_work_request';
    
    l_car_number            varchar2(20);
    l_ins_result            xx_disl_inspections.result%type;
    l_asset_group           inv.mtl_system_items_b.segment1%type;
    
    l_user_name             varchar2(100);
    l_return_status         varchar2(1);
begin
    log_new(l_log_id,l_function,'p_inspection_id = '||p_inspection_id);
    
    select asset_instance_number
          ,result
      into l_car_number
          ,l_ins_result
      from xx_disl_inspections
     where 1=1
       and inspection_id = p_inspection_id
    ;
    log_new(l_log_id,l_function,'l_car_number = '||l_car_number);
    
    select asset_group
      into l_asset_group
      from table(xx_dislocation.get_asset_info(l_car_number))
    ;
    log_new(l_log_id,l_function,'l_asset_group = '||l_asset_group);
    
    if (l_asset_group is null) then
        p_result := 'E';
        p_error_log := 'Нужно добавить группу актива в OEBS!!!';   
    else
        begin
            select login
              into l_user_name
              from xx_disl_users            us
             where 1=1
               and us.id = p_user_id
            ;
        exception
            when no_data_found then null;
        end;      
        log_new(l_log_id,l_function,'l_user_name = '||l_user_name);
        
        if (g_create_work_request) then        
            apps.xxeam_programs.create_work_request_new(
                 p_asset_num   => l_car_number
                ,p_asset_grp   => l_asset_group
                ,p_org_code    => 'РПС'
                ,p_result      => l_ins_result
                ,p_crt_by      => l_user_name
                ,p_plan        => 'Дислокация'
                ,p_id          => p_inspection_id
                ,p_return_status =>l_return_status);
            log_new(l_log_id,l_function,'l_return_status = '||l_return_status);  
                   
            update xx_disl_inspections
               set created_request_status = l_return_status
             where 1=1
               and inspection_id = p_inspection_id
            ;
            log_new(l_log_id,l_function,'update xx_disl_inspections. rowcount = '||sql%rowcount);
            
            p_result := l_return_status;
            
            commit;
        end if;
    end if;
exception
    when others then 
        rollback; p_result := 'E'; p_error_log := 'Ошибка при выполение процедуры!Error='||sqlerrm;
        log_new(l_log_id,l_function,p_error_log);      
end;

procedure create_work_dev_request(
     p_user_id                  number      
    ,p_inspection_id            number
    ,p_result           out     varchar2
    ,p_error_log        out     varchar2
