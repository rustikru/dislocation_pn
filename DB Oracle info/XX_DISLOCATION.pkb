function get_info_for_car_request(p_car_number varchar2, p_info_type    number)
return varchar2
as
    l_railway_id            number;
    l_round                 number;
    l_return                varchar2(1000);
begin
    l_round := xx_etw.xx_dislocation.returnLastRound(p_car_number);
    if (p_info_type = 1) then
        select owner
          into l_return
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and round_id = l_round
           and last_record = 'Y'
        ;
    elsif (p_info_type = 2) then
        select s.short_name
          into l_return
          from xx_etw.xx_disl_station_history      sh
              ,xx_etw.xx_disl_stations             s
         where 1=1
           and sh.round_id = l_round
           and sh.out_date is null
           
           and sh.station_id = s.station_id
        ;
    elsif (p_info_type = 3) then
        select r.railway_number
          into l_return
          from xx_etw.xx_disl_station_history      sh
              ,xx_etw.xx_disl_railway_history      rh
              ,xx_etw.xx_disl_railways             r
         where 1=1
           and sh.round_id = l_round
           and sh.out_date is null
           
           and sh.station_hist_id = rh.station_hist_id
           and rh.last_record = 'Y'
           
           and rh.railway_id = r.railway_id
        ;
    elsif (p_info_type = 4) then
        select status
          into l_return
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and round_id = l_round
           and last_record = 'Y'
        ;
    elsif (p_info_type = 5) then
        l_return := case get_car_add_info_with_conts(l_round,sysdate)
                      when 0 
                        then 'пор.'
                      else 'гр.'
                    end;
    elsif (p_info_type = 6) then
        select freight_name
          into l_return
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and round_id = l_round
           and last_record = 'Y'
        ;
    elsif (p_info_type = 7) then
        select listagg(r.request_id||'('||rt.descr||')', ' ') within group (order by r.request_id)
          into l_return
          from xx_disl_requests                 r
              ,xx_disl_request_criterias        rc 
              ,xx_disl_request_criteria_cars    rcc
              ,xx_disl_request_tasks            rt
         where 1=1
           and r.status in ('O','P')
           and r.request_id = rc.request_id(+)
           and rc.criteria_id = rcc.criteria_id(+)
           and rcc.car_number = p_car_number
           
           and r.task_id = rt.task_id
        ;
    end if;     

    return l_return;
exception
    when no_data_found then return null;
end;

function create_request(
    p_user_id                   number,
    p_request_task              number,
    p_crit_task                 varchar2,
    p_cars_mas                  t_cars_table
) return number
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='create_request';

    l_idx               number;
    l_cars_char         varchar2(2000);
    l_crit_char         varchar2(2000);
    l_car_number        varchar2(200);
    
    l_result            varchar2(4000);
    l_new_request_id    number := 0;
    
    l_crit_task         varchar2(50);
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_crit_task = '||p_crit_task);

    if (p_cars_mas.count != 0) then
        l_crit_task := nvl(p_crit_task,'_');
        
        l_idx := p_cars_mas.first;
        while (l_idx is not null) 
        loop
            l_car_number := p_cars_mas(l_idx);
            log_new(l_log_id,l_function,'l_car_number = '||l_car_number);
            
            l_cars_char := l_cars_char||l_car_number||g_del_req_4_d;  -- номер вагона
            l_cars_char := l_cars_char||nvl(get_info_for_car_request(l_car_number,1),'_')||g_del_req_4_d;  
            l_cars_char := l_cars_char||nvl(get_info_for_car_request(l_car_number,2),'_')||g_del_req_4_d;
            l_cars_char := l_cars_char||nvl(get_info_for_car_request(l_car_number,3),'_')||g_del_req_4_d;
            l_cars_char := l_cars_char||nvl(get_info_for_car_request(l_car_number,4),'_')||g_del_req_4_d;
            l_cars_char := l_cars_char||nvl(get_info_for_car_request(l_car_number,5),'_')||g_del_req_4_d;
            l_cars_char := l_cars_char||nvl(get_info_for_car_request(l_car_number,6),'_')||g_del_req_4_d;
            l_cars_char := l_cars_char||'0#0#0#_'||g_del_req_3_d;
            
            l_idx := p_cars_mas.next(l_idx);
        end loop;
        log_new(l_log_id,l_function,'l_cars_char = '||l_cars_char);
        
        l_crit_char := '_@_@_@_@Годен@_@_@'||p_cars_mas.count||'@'||l_crit_task||'@_@_@'||l_cars_char||g_del_req_1_d;     
        log_new(l_log_id,l_function,'l_crit_char = '||l_crit_char);
        
        l_result := save_request(p_user_id,null,to_char(sysdate,'dd.mm.yyyy hh24:mi'),to_char(sysdate+1/24*12,'dd.mm.yyyy hh24:mi'),p_request_task,null,l_crit_char);
        log_new(l_log_id,l_function,'l_result = '||l_result);
        
        if (regexp_substr(l_result,'[^$]+',1,1)='done') then
            l_new_request_id := regexp_substr(l_result,'[^$]+',1,2);
        else
            l_new_request_id := 0;
        end if;
        log_new(l_log_id,l_function,'l_new_request_id = '||l_new_request_id);
    end if; 
    
    return l_new_request_id;
exception
    when others then return 0;
end;

function save_request(
    p_user_id           number, 
    p_request_id        number, 
    p_deadline_date_in  varchar2, 
    p_deadline_date_out varchar2, 
    p_task_id           number,
    p_criticality_id    number, 
    p_cars              varchar2
) return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='save_request';
    
    l_request_id            number;    
    l_deadline_date_in      date;
    l_deadline_date_out     date;
    
    l_criteria_id           number;
    l_railway_id            number;
    l_point_id              number;
    l_type                  varchar2(200);
    l_status                varchar2(200);
    l_state                 varchar2(200);
    l_freight               varchar2(200);
    l_count                 number;
    l_task_id               number;
    l_deadline_date         date;
    l_descr                 varchar2(1000);
    l_cars                  varchar2(4000);
    
    l_car_number            varchar2(10);
    l_car_owner             varchar2(50);
    l_car_station           varchar2(50);
    l_car_railway           varchar2(200);
    l_car_status            varchar2(100);
    l_car_state             varchar2(100);  
    l_car_freight           varchar2(100);
    l_v                     varchar2(1);   
    l_o                     varchar2(1);
    l_t                     varchar2(1);
    l_exist_car             number; 

    l_return                varchar(100);
    
    l_cars_count            number := 0;
    l_tmp                   number;
    l_need_count_cars       boolean := false;
    
    l_cars_table_v          t_cars_table := t_cars_table();
    l_cars_table_o          t_cars_table := t_cars_table();
    l_cars_table_t          t_cars_table := t_cars_table();
    l_new_req_id_v          number;
    l_new_req_id_o          number;
    l_new_req_id_t          number;
    l_new_req_id_list       varchar2(1000);
    
    l_cars_clob             clob; -- add 11/12/2019
    
    l_car_freight_dop       varchar(250);
    
    function get_substr(p_str varchar2, p_del varchar2, p_num number)
    return varchar2
    as
        l_str   varchar2(32000);
    begin
        l_str := regexp_substr(p_str,p_del,1,p_num);
        return case
                 when l_str = '_'
                   then null
                 else l_str
               end;               
    end;     
    
begin
    l_cars_clob:=to_clob(p_cars); -- add 11/12/2019
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_request_id = '||p_request_id
                             ||' p_deadline_date_in = '||p_deadline_date_in
                             ||' p_deadline_date_out = '||p_deadline_date_out
                             ||' p_criticality_id = '||p_criticality_id
                             ||' p_task_id = '||p_task_id
                             ||' p_cars = '||substr(p_cars,1,3500)
                             );
    
    if p_request_id is null then
        l_request_id := xx_etw.xx_disl_requests_seq.nextval();
    else
        l_request_id := p_request_id;
    end if;
    log_new(l_log_id,l_function,'l_request_id = '||l_request_id);
    
    begin
        l_deadline_date_in := to_date(p_deadline_date_in,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_deadline_date_in := null;
    end;
    begin
        l_deadline_date_out := to_date(p_deadline_date_out,'dd.mm.yyyy hh24:mi');
    exception
        when others then l_deadline_date_out := null;
    end;
    
    update xx_etw.xx_disl_requests
       set task_id = p_task_id
          ,deadline_date_in = l_deadline_date_in
          ,deadline_date_out = l_deadline_date_out
          ,criticality_id = p_criticality_id
          ,last_updated_by = p_user_id
          ,last_updated_date = sysdate
     where 1=1
       and request_id = l_request_id
    ;
    
    if (sql%rowcount = 0) then
        insert into xx_etw.xx_disl_requests(
             request_id
            ,task_id
            ,deadline_date_in
            ,deadline_date_out
            ,criticality_id
            ,status
            ,created_by
            ,created_date
            ,last_updated_by
            ,last_updated_date
        )
        values(
             l_request_id
            ,p_task_id
            ,l_deadline_date_in
            ,l_deadline_date_out
            ,p_criticality_id
            ,'O'
            ,p_user_id
            ,sysdate
            ,p_user_id
            ,sysdate
        );
    end if;
    log_new(l_log_id,l_function,'p_cars.length = '||length(p_cars));
    log_new(l_log_id,l_function,'g_del_req_1 = '||g_del_req_1);
    log_new(l_log_id,l_function,'g_del_req_2 = '||g_del_req_2);
    if (p_cars is not null) then
        for l_criterias in (
            select regexp_substr(
                            --p_cars,
                            l_cars_clob, -- add 11/12/2019
                            g_del_req_1,1,level) text
              from dual
           connect by level <= regexp_count(
                            --p_cars, 
                            l_cars_clob,-- add 11/12/2019
                            g_del_req_1)
        ) loop
            log_new(l_log_id,l_function,'l_criterias.text = '||substr(l_criterias.text,3700)); 
            
            l_criteria_id := to_number(get_substr(l_criterias.text,g_del_req_2,1));
            l_railway_id := to_number(get_substr(l_criterias.text,g_del_req_2,2));           
            l_point_id := to_number(get_substr(l_criterias.text,g_del_req_2,3));             
            l_type := get_substr(l_criterias.text,g_del_req_2,4);                 
            l_status := get_substr(l_criterias.text,g_del_req_2,5);               
            l_state := get_substr(l_criterias.text,g_del_req_2,6);                
            l_freight := get_substr(l_criterias.text,g_del_req_2,7);             
            l_count :=to_number(get_substr(l_criterias.text,g_del_req_2,8));                 
            l_task_id := to_number(get_substr(l_criterias.text,g_del_req_2,9));               
            l_deadline_date := to_date(get_substr(l_criterias.text,g_del_req_2,10),'dd.mm.yyyy hh24:mi');         
            l_descr := get_substr(l_criterias.text,g_del_req_2,11);      
            l_cars := get_substr(l_criterias.text,g_del_req_2,12);        
            
            log_new(l_log_id,l_function,'l_criteria_id = '||l_criteria_id);
            log_new(l_log_id,l_function,'l_railway_id = '||l_railway_id);
            log_new(l_log_id,l_function,'l_point_id = '||l_point_id);
            log_new(l_log_id,l_function,'l_type = '||l_type);
            log_new(l_log_id,l_function,'l_status = '||l_status);
            log_new(l_log_id,l_function,'l_state = '||l_state);
            log_new(l_log_id,l_function,'l_freight = '||l_freight);
            log_new(l_log_id,l_function,'l_count = '||l_count);
            log_new(l_log_id,l_function,'l_task_id = '||l_task_id);
            log_new(l_log_id,l_function,'l_deadline_date = '||l_deadline_date);
            log_new(l_log_id,l_function,'l_descr = '||l_descr);
            log_new(l_log_id,l_function,'l_cars = '||l_cars);
            
            if (l_criteria_id is null) then
                l_criteria_id := xx_etw.xx_disl_request_criterias_seq.nextval();
                log_new(l_log_id,l_function,'l_criteria_id = '||l_criteria_id);
                
                insert into xx_etw.xx_disl_request_criterias(
                     request_id
                    ,criteria_id
                    ,railway_id
                    ,point_id
                    ,car_type
                    ,car_status
                    ,car_state
                    ,car_freight
                    ,car_count
                    ,car_task_id
                    ,deadline_date
                    ,descr
                )
                values(
                    l_request_id
                   ,l_criteria_id
                   ,l_railway_id
                   ,l_point_id
                   ,l_type
                   ,l_status
                   ,l_state
                   ,l_freight
                   ,l_count
                   ,l_task_id
                   ,l_deadline_date
                   ,l_descr   
                );
                log_new(l_log_id,l_function,'insert into xx_etw.xx_disl_request_criterias. кол-во = '||sql%rowcount);
            else
                update xx_disl_request_criterias
                   set railway_id = l_railway_id
                      ,point_id = l_point_id
                      ,car_type = l_type
                      ,car_status = l_status
                      ,car_state = l_state
                      ,car_freight = l_freight
                      ,car_count = l_count
                      ,car_task_id = l_task_id
                      ,deadline_date = l_deadline_date
                      ,descr = l_descr  
                 where 1=1
                   and criteria_id = l_criteria_id
                ;
                log_new(l_log_id,l_function,'update xx_disl_request_criterias. кол-во = '||sql%rowcount);
            end if;
            
            insert into xx_etw.xx_disl_request_criterias_t
            values(l_criteria_id)
            ;
            
            if (l_cars is not null) then
                for loop_cars in (
                    select regexp_substr(l_cars,g_del_req_3,1,level) text
                      from dual
                   connect by level <= regexp_count(l_cars,g_del_req_3)
                ) loop
                    log_new(l_log_id,l_function,'loop_cars.text = '||loop_cars.text);
                    
                    l_car_number := get_substr(loop_cars.text,g_del_req_4,1);
                    l_car_owner := get_substr(loop_cars.text,g_del_req_4,2);
                    l_car_station := get_substr(loop_cars.text,g_del_req_4,3);
                    l_car_railway := get_substr(loop_cars.text,g_del_req_4,4);
                    l_car_status := get_substr(loop_cars.text,g_del_req_4,5);
                    l_car_state := get_substr(loop_cars.text,g_del_req_4,6);
                    l_car_freight := get_substr(loop_cars.text,g_del_req_4,7);
                    l_v := get_substr(loop_cars.text,g_del_req_4,8);
                    l_o := get_substr(loop_cars.text,g_del_req_4,9);
                    l_t := get_substr(loop_cars.text,g_del_req_4,10);
                    l_car_freight_dop:= get_substr(loop_cars.text,g_del_req_4,11); -- add 17.11.2020
                    
                    log_new(l_log_id,l_function,'l_car_number = '||l_car_number);
                    log_new(l_log_id,l_function,'l_car_owner = '||l_car_owner);
                    log_new(l_log_id,l_function,'l_car_station = '||l_car_station);
                    log_new(l_log_id,l_function,'l_car_railway = '||l_car_railway);
                    log_new(l_log_id,l_function,'l_car_status = '||l_car_status);
                    log_new(l_log_id,l_function,'l_car_state = '||l_car_state);
                    log_new(l_log_id,l_function,'l_car_freight = '||l_car_freight);
                    log_new(l_log_id,l_function,'l_v = '||l_v);
                    log_new(l_log_id,l_function,'l_o = '||l_o);
                    log_new(l_log_id,l_function,'l_t = '||l_t);
                    log_new(l_log_id,l_function,'l_car_freight_dop = '||l_car_freight_dop);
                    

                    select count('x')
                      into l_exist_car
                      from xx_etw.xx_disl_request_criteria_cars
                     where 1=1
                       and criteria_id = l_criteria_id
                       and car_number = l_car_number
                    ;
                    log_new(l_log_id,l_function,'l_exist_car = '||l_exist_car);
                    
                    if (l_exist_car = 0) then
                        insert into xx_etw.xx_disl_request_criteria_cars(
                            criteria_id
                           ,car_number
                           ,owner
                           ,station
                           ,railway
                           ,info_date
                           ,status
                           ,state
                           ,freight
                           ,v
                           ,o
                           ,t
                        )
                        values (
                            l_criteria_id
                           ,l_car_number
                           ,l_car_owner
                           ,l_car_station
                           ,l_car_railway
                           ,sysdate
                           ,l_car_status
                           ,l_car_state
                           ,nvl(l_car_freight_dop,l_car_freight) -- upd 17.11.2020 add l_car_freight_dop
                           ,l_v
                           ,l_o
                           ,l_t
                        );
                        log_new(l_log_id,l_function,'insert into xx_etw.xx_disl_request_criteria_cars. кол-во = '||sql%rowcount);
                    else
                        update xx_etw.xx_disl_request_criteria_cars
                           set owner = l_car_owner
                              ,station = l_car_station
                              ,railway = l_car_railway
                              ,status = l_car_status
                              ,state = l_car_state
                              ,freight = nvl(l_car_freight_dop,l_car_freight) -- upd 17.11.2020 add l_car_freight_dop
                              ,info_date = sysdate
                         where 1=1
                           and criteria_id = l_criteria_id
                           and car_number = l_car_number
                           and (   nvl(owner,'x') != nvl(l_car_owner,'x')
                                or nvl(station,'x') != nvl(l_car_station,'x')
                                or nvl(railway,'x') != nvl(l_car_railway,'x')
                                or nvl(status,'x') != nvl(l_car_status,'x')
                                or nvl(state,'x') != nvl(l_car_state,'x')
                                or nvl(freight,'x') != nvl(nvl(l_car_freight_dop,l_car_freight),'x')
                               )
                        ;
                        log_new(l_log_id,l_function,'xx_etw.xx_disl_request_criteria_cars. кол-во = '||sql%rowcount);
                    end if;
                    
                    insert into xx_etw.xx_disl_request_criteria_car_t
                    values(l_car_number)
                    ;
                    
                    if (p_task_id = 2/*Уборка*/) then
                        /*заполняем поле заявка на увод в форме погрузка разгрузка*/
                        update xx_etw.xx_disl_shop_info
                           set date_zayavka_uvod = sysdate
                         where 1=1
                           and round_id = xx_etw.xx_dislocation.returnLastRound(l_car_number)
                           and last_record = 'Y'
                           and date_zayavka_uvod is null
                        ;
                        log_new(l_log_id,l_function,'update xx_etw.xx_disl_shop_info. кол-во = '||sql%rowcount);
                    end if;
                    
                    /*Заполняем таблицы для создания дочерних заявок заявок*/
                    if (p_request_id is null and l_v = '1') then
                        l_cars_table_v.extend;
                        l_cars_table_v(l_cars_table_v.last) := l_car_number;
                    end if;
                    if (p_request_id is null and l_o = '1') then
                        l_cars_table_o.extend;
                        l_cars_table_o(l_cars_table_o.last) := l_car_number;
                    end if;
                    if (p_request_id is null and l_t = '1') then
                        l_cars_table_t.extend;
                        l_cars_table_t(l_cars_table_t.last) := l_car_number;
                    end if;   
                end loop;
            end if;
            
            delete 
              from xx_etw.xx_disl_request_criteria_cars
             where 1=1
               and criteria_id = l_criteria_id
               and car_number not in (
                   select car_number
                     from xx_etw.xx_disl_request_criteria_car_t
               )
            ;      
        end loop;
    end if;
    
    delete 
      from xx_etw.xx_disl_request_criterias
     where 1=1
       and request_id = l_request_id
       and criteria_id not in (
           select criteria_id
             from xx_etw.xx_disl_request_criterias_t
       )
    ;   
    
--    commit;
    /*создаем дочерние заявки*/
    if (l_cars_table_v.count != 0) then
        l_new_req_id_v := create_request(p_user_id,14,11,l_cars_table_v);
        log_new(l_log_id,l_function,'create_request_v. l_new_req_id_v = '||l_new_req_id_v);
    end if;
    if (l_cars_table_o.count != 0) then
        l_new_req_id_o := create_request(p_user_id,11,8,l_cars_table_o);
        log_new(l_log_id,l_function,'create_request_o. l_new_req_id_o = '||l_new_req_id_o);
    end if;
    if (l_cars_table_t.count != 0) then
        l_new_req_id_t := create_request(p_user_id,15,12,l_cars_table_t);
        log_new(l_log_id,l_function,'create_request_t. l_new_req_id_t = '||l_new_req_id_t);
    end if;
    
    l_new_req_id_list := case
                           when l_new_req_id_v is not null
                           then to_char(l_new_req_id_v)
                           else null
                         end;
    l_new_req_id_list := l_new_req_id_list|| 
                         case
                           when l_new_req_id_o is not null and l_new_req_id_list is null
                           then to_char(l_new_req_id_o)
                           when l_new_req_id_o is not null and l_new_req_id_list is not null
                           then ' '||to_char(l_new_req_id_o) 
                           else ''
                         end;
    l_new_req_id_list := l_new_req_id_list|| 
                         case
                           when l_new_req_id_t is not null and l_new_req_id_list is null
                           then to_char(l_new_req_id_t)
                           when l_new_req_id_t is not null and l_new_req_id_list is not null
                           then ' '||to_char(l_new_req_id_t) 
                           else ''
                         end;
    
    update xx_etw.xx_disl_requests
       set parent_request_id = p_request_id
     where 1=1
       and request_id in (nvl(l_new_req_id_v,-1),nvl(l_new_req_id_o,-1),nvl(l_new_req_id_t,-1))
       and p_request_id is not null
    ;
                
    if p_request_id is null then
        l_return := 'done'||'$'||to_char(l_request_id)||'$'||l_new_req_id_list;
    else
        l_return := 'done';
    end if;
    
    commit;
    return l_return;
exception
    when others then rollback; return 'fail$sqlerrm='||sqlerrm;
end;

/*закрытие заявки по вагону с определнной задачей*/
function close_request(
    p_user_id       number,
    p_car_number    varchar2,
    p_task_id       number,
    p_comment       varchar2,
    p_date          varchar2 /*формат dd.mm.yyyy hh24:mi*/
) return boolean
as
    l_function          varchar2(100):='save_request';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    
    l_exist_request     boolean :=false;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_car_number = '||p_car_number
                             ||' p_task_id = '||p_task_id
                             ||' p_comment = '||p_comment
                             ||' p_date = '||p_date);
    /*цикл на случай если заявок несколько по вагону*/
    for l_req_info in (
        select r.request_id
              ,rc.criteria_id
              ,rcc.car_number
          from xx_disl_requests                 r
              ,xx_disl_request_criterias        rc
              ,xx_disl_request_criteria_cars    rcc
         where 1=1
           and r.task_id = p_task_id /*на ПСП возвр порожнего ПС (без накладных)*/
           and r.status in ('O','P')
           and r.request_id = rc.request_id
           and rc.criteria_id = rcc.criteria_id 
           and rcc.car_number = p_car_number
    ) loop
        log_new(l_log_id,l_function,'request_id = '||l_req_info.request_id||'criteria_id = '||l_req_info.criteria_id);
                
        l_exist_request := true;
                
        update xx_disl_request_criteria_cars
           set close = 1
              ,close_date = sysdate
              ,close_by = p_user_id
              ,close_comment = p_comment||' '||p_date
         where 1=1
           and criteria_id = l_req_info.criteria_id
           and car_number = l_req_info.car_number 
           and close = 0 
        ;
        log_new(l_log_id,l_function,'update xx_disl_request_criteria_cars. кол-во = '||sql%rowcount);
                
        update xx_disl_request_criterias    rc
           set close = 1
              ,close_date = sysdate
              ,close_by = p_user_id
         where 1=1
           and criteria_id = l_req_info.criteria_id
           and close = 0
           and car_count <= (
               select count(car_number)
                 from xx_disl_request_criteria_cars
                where 1=1
                  and criteria_id = rc.criteria_id
                  and close = 1
           )
        ;
        log_new(l_log_id,l_function,'update xx_disl_request_criterias. кол-во = '||sql%rowcount);
                
        update xx_disl_requests r
           set status = 'D'
              ,closed_date = sysdate
              ,closed_by = p_user_id
         where 1=1
           and request_id = l_req_info.request_id
           and not exists (
               select 'x'
                 from xx_disl_request_criterias
                where 1=1
                  and request_id = r.request_id
                  and close = 0
           )  
        ;
        log_new(l_log_id,l_function,'update xx_disl_requests. кол-во = '||sql%rowcount);
    end loop;
        
    return l_exist_request;
end;

/*создание заявок на взвешивание для вагонов с подхода*/
/*не используется. Решили создавать заявки на взвешивания по форме "Регистрация уведомлений"*/
procedure create_req_for_in_cars(
    p_errbuf out nocopy varchar2,  
    p_retcode out nocopy varchar2
) is
    l_cars_table_v          xx_dislocation.t_cars_table := xx_dislocation.t_cars_table();
    l_new_req_id_t      number;
begin
    for l_cars in (
        select r.railcar_id car_number
          from xx_etw.xx_disl_round                 r
              ,xx_etw.xx_disl_railcar_add_info      rai
         where 1=1
           --and railcar_id in ('59273623','59272781','54574397')
           and station_hist_id_out is null
           
           and r.round_id = rai.round_id
           and rai.add_info_type = 'A'
           and rai.last_record = 'Y'   
           and rai.weight_net > 0
           
           and exists(
               select 'x'
                 from xx_etw.xx_disl_round_inv      ri
                     ,xx_etw.etw_invoice            ei
                where 1=1
                  and ri.round_id = r.round_id
                  
                  and ri.invoice_id = ei.invoice_id
                  and ei.inv_fact_date_accept is not null     
                  and ei.inv_fact_date_accept >= to_date('29.05.2017','dd.mm.yyyy')  
           )
           
           and not exists(
               select 'x'
                 from xx_etw.xx_disl_car_scale      cs
                where 1=1
                  and cs.round_id = r.round_id
           )
    ) loop
        l_cars_table_v.extend;
        l_cars_table_v(l_cars_table_v.last) := l_cars.car_number;
    end loop;
    
    l_new_req_id_t := xx_dislocation.create_request(1,14,11,l_cars_table_v);
    
    commit;
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end;

function get_requests(p_user_id number)
return t_xx_request_table pipelined
as
    l_row       t_xx_request_row;
    
    l_need_all              varchar2(1) := 'N';
    l_user_division_id      number;
begin
    /*begin
    -- add 28.11.2024 Нужно переписать
    select max(nvl(c.view_request,'N'))
      into l_need_all
      from xx_disl_user_credential uc
          ,xx_disl_credential      c
     where 1=1
       and uc.user_id = p_user_id
       and uc.credential_id = c.credential_id
    ;
    exception
        when others then null;
    end;
    */
    -- add 28.11.2024 
    l_need_all := get_user_cred_rights_val(p_user_id => p_user_id, p_rights_code => 'view_request');
    
    select division_id
      into l_user_division_id
      from xx_disl_users u1
     where 1=1
       and u1.id = p_user_id    
    ;
       
    
    for l_request in (
        -- add 04.03.2024 BekmansurovRR Добавил with
        with s_railw_check as (
            select * from xx_etw.xx_disl_requests_check_v)
            
        select r.request_id                             request_id
              ,r.status                                 status
              ,r.status_descr                           status_descr
              ,u.full_name                              created_by
              ,u.id                                     created_by_id
              ,to_char(created_date,'dd.mm.yyyy')       created_date
              ,r_crit.check_railways||d.name                                   division  -- upd 04.03.2024 BekmansurovRR
              ,(select rt.descr
                  from xx_disl_request_tasks rt
                 where 1=1
                   and rt.task_id = r.task_id 
               )
                                                        task_descr
              ,nvl(r.cars_count,0)                      cars_count
              ,nvl(rcdv.cars_count,0)                   done_cars_count
              ,r.criticality_id                         criticality_id
              ,case 
                 when r_crit.count_cr != r_crit.count_com_cr and r_crit.count_com_cr > 0 and r_crit.count_cr != 0
                 then '1'
                 else '0'
               end
                                                        part_complete
              ,case 
                 when r_crit.count_cr = r_crit.count_com_cr and count_cr != 0
                 then '1'
                 else '0'
               end
                                                        complete
              ,case 
                 when exists(
                    select 'x'
                      from xx_etw.xx_disl_request_criterias
                     where 1=1
                       and request_id = r.request_id
                       and close = '1'
                     union
                    select 'x'
                      from xx_etw.xx_disl_request_criterias         rc_1
                          ,xx_etw.xx_disl_request_criteria_cars     rcc_1
                     where 1=1
                       and rc_1.request_id = r.request_id
                       and rc_1.criteria_id = rcc_1.criteria_id
                       and rcc_1.close = '1'
                 )
                 then '1'
                 else '0'
               end part_closed
               ,case when r_crit.check_railways is null then 0 else 1 end as check_railways
          from xx_etw.xx_disl_requests             r
              ,xx_etw.xx_disl_users                u
              ,xx_etw.xx_disl_user_div_hist        ud
              ,xx_etw.xx_disl_divisions            d
              ,xx_etw.xx_disl_request_cars_done_v  rcdv
              ,(select request_id
                      ,count('x')                  count_cr
                      ,sum(decode(complete
                                 ,1,1
                                 ,0
                           )    
                       )
                                                   count_com_cr
                      ,max((select xx.field_name from s_railw_check xx where dr.RAILWAY_NUMBER like xx.field_check)) as check_railways -- add 04.03.2024 BekmansurovRR   
               from xx_etw.xx_disl_request_criterias drc
                   ,xx_etw.xx_disl_railways dr 
                 where 1=1
                        and drc.RAILWAY_ID = dr.RAILWAY_ID(+)
                 group by
                       request_id
               )
                                                   r_crit
         where 1=1
           and r.status in ('O'/*Открыт*/,'P'/*В обработке*/) 
           
           and r.created_by = u.id
           
           and u.id = ud.user_id(+)
           and r.created_date between nvl(ud.start_date,to_date('01.01.2016','dd.mm.yyyy')) and nvl(ud.end_date,to_date('31.12.2999','dd.mm.yyyy'))
           
           and ud.division_id = d.division_id(+)
           
           and r.request_id = rcdv.request_id(+)
           
           and r.request_id = r_crit.request_id(+)
           
           and (   l_need_all = 'Y'
                --or ud.division_id is null   
                or u.id = p_user_id
                or d.division_id = l_user_division_id
               )
         order by
               nvl(r.criticality_id,0)
              ,r.created_date
    ) loop
        l_row.request_id := l_request.request_id;   
        l_row.status := l_request.status;
        l_row.status_descr := l_request.status_descr;
        l_row.created_by := l_request.created_by;
        l_row.created_by_id := l_request.created_by_id;
        l_row.created_date := l_request.created_date;
        l_row.division := l_request.division;
        l_row.task_descr := l_request.task_descr;
        l_row.cars_count := l_request.cars_count;
        l_row.done_cars_count := l_request.done_cars_count;
        l_row.criticality_id := l_request.criticality_id;
        l_row.part_complete := l_request.part_complete;
        l_row.complete := l_request.complete;
        l_row.part_closed := l_request.part_closed;   
        
        l_row.check_railways := l_request.check_railways;   
          
        
        pipe row (l_row);
    end loop;

end get_requests;

function get_request(p_request_id number)
return t_xx_request_table pipelined
as
    l_row       t_xx_request_row;
begin
    for l_request in (
        select r.request_id                                         request_id
              ,r.task_id                                            task_id
              ,(select rt.descr
                  from xx_disl_request_tasks rt
                 where 1=1
                   and rt.task_id = r.task_id 
               )
                                                                    task_descr
              ,to_char(r.deadline_date_in,'dd.mm.yyyy hh24:mi')     deadline_date_in
              ,to_char(r.deadline_date_out,'dd.mm.yyyy hh24:mi')    deadline_date_out                                         
              ,r.status                                             status
              ,r.status_descr                                       status_descr
              ,u.full_name                                          created_by
              ,to_char(created_date,'dd.mm.yyyy hh24:mi')           created_date
              ,nvl(rcd.cars_count,0)                                done_cars_count
              ,r.criticality_id                                     criticality_id
          from xx_disl_requests             r
              ,xx_disl_users                u
              ,xx_disl_request_cars_done_v  rcd
         where 1=1
           and r.request_id = p_request_id
           
           and r.created_by = u.id
           
           and r.request_id = rcd.request_id(+)
         order by
               r.created_date
    ) loop
        l_row.request_id := l_request.request_id;  
        l_row.task_id := l_request.task_id;
        l_row.task_descr := l_request.task_descr;
        l_row.deadline_date_in := l_request.deadline_date_in;
        l_row.deadline_date_out := l_request.deadline_date_out; 
        l_row.status := l_request.status;
        l_row.status_descr := l_request.status_descr;
        l_row.created_by := l_request.created_by;
        l_row.created_date := l_request.created_date;
        l_row.done_cars_count := l_request.done_cars_count;
        l_row.criticality_id := l_request.criticality_id;
        
        pipe row (l_row);
    end loop;

end get_request;


function get_request_criterias(p_request_id number)
return varchar2
as    
    l_criterias varchar2(2000) := '';
begin
    
    
    for l_tmp in (
        select rc.*
              ,u_c.full_name            com_full_name
              ,u_cl.full_name           cl_full_name
          from xx_etw.xx_disl_request_criterias     rc
              ,xx_etw.xx_disl_users                 u_c
              ,xx_etw.xx_disl_users                 u_cl
         where 1=1
           and request_id = p_request_id
           
           and rc.complete_by = u_c.id(+)
           
           and rc.close_by = u_cl.id(+)
    ) loop
        l_criterias:=l_criterias||l_tmp.criteria_id||g_del_req_2_d
                                ||l_tmp.railway_id||g_del_req_2_d
                                ||l_tmp.point_id||g_del_req_2_d
                                ||l_tmp.car_type||g_del_req_2_d
                                ||l_tmp.car_status||g_del_req_2_d
                                ||l_tmp.car_state||g_del_req_2_d
                                ||l_tmp.car_freight||g_del_req_2_d
                                ||l_tmp.car_count||g_del_req_2_d
                                ||l_tmp.car_task_id||g_del_req_2_d
                                ||to_char(l_tmp.deadline_date,'dd.mm.yyyy hh24:mi')||g_del_req_2_d
                                ||l_tmp.descr||g_del_req_2_d
                                ||l_tmp.complete||g_del_req_2_d
                                ||to_char(l_tmp.complete_date,'dd.mm.yyyy')||g_del_req_2_d
                                ||l_tmp.com_full_name||g_del_req_2_d
                                ||l_tmp.close||g_del_req_2_d
                                ||to_char(l_tmp.close_date,'dd.mm.yyyy')||g_del_req_2_d
                                ||l_tmp.cl_full_name||g_del_req_2_d
                                ||l_tmp.close_comment||g_del_req_1_d;
    end loop;
    
    return l_criterias;
end get_request_criterias;

function get_request_criteria_cars(p_criteria_id number)
return varchar2
as
    l_cars          varchar2(32000) := '';
    l_exist_req     varchar2(1000);
begin
    
    
    for l_tmp in (
        select rcc.*
              ,u_c.full_name            com_full_name
              ,u_cl.full_name           cl_full_name
              ,count('x') over ()       car_count
          from xx_etw.xx_disl_request_criteria_cars     rcc
              ,xx_etw.xx_disl_users                     u_c   
              ,xx_etw.xx_disl_users                     u_cl              
         where 1=1
           and criteria_id = p_criteria_id
           
           and rcc.complete_by = u_c.id(+)
           and rcc.close_by = u_cl.id(+)
--           and rownum <= 50
    ) loop
        select listagg(r.request_id||'('||rt.descr||')', ' ') within group (order by r.request_id)
          into l_exist_req
          from xx_disl_requests                 r
              ,xx_disl_request_criterias        rc 
              ,xx_disl_request_criteria_cars    rcc
              ,xx_disl_request_tasks            rt
         where 1=1
           and r.status in ('O','P')
           and r.request_id = rc.request_id(+)
           and rc.criteria_id = rcc.criteria_id(+)
           and rc.criteria_id != p_criteria_id
           and rcc.car_number = l_tmp.car_number
           
           and r.task_id = rt.task_id
        ;
    
        l_cars:=l_cars||l_tmp.car_number||g_del_req_4_d
                      ||l_tmp.owner||g_del_req_4_d
                      ||l_tmp.station||g_del_req_4_d
                      ||case
                          when l_tmp.car_count >= 30
                            then substr(l_tmp.railway,1,12)
                          else l_tmp.railway
                        end
                            ||g_del_req_4_d
                      ||l_tmp.status||g_del_req_4_d
                      ||l_tmp.state||g_del_req_4_d
                      ||l_tmp.freight||g_del_req_4_d
                      ||to_char(l_tmp.info_date,'dd.mm.yyyy')||g_del_req_4_d
                      ||l_tmp.complete||g_del_req_4_d
                      ||to_char(l_tmp.complete_date,'dd.mm.yyyy')||g_del_req_4_d
                      ||l_tmp.com_full_name||g_del_req_4_d
                      ||l_tmp.v||g_del_req_4_d
                      ||l_tmp.o||g_del_req_4_d
                      ||l_tmp.t||g_del_req_4_d
                      ||l_tmp.close||g_del_req_4_d
                      ||to_char(l_tmp.close_date,'dd.mm.yyyy')||g_del_req_4_d
                      ||l_tmp.cl_full_name||g_del_req_4_d
                      ||l_tmp.close_comment||g_del_req_4_d
                      ||l_exist_req||g_del_req_3_d;
    end loop;
    
    return l_cars;
end get_request_criteria_cars;

function get_request_criteria_cars_new(p_criteria_id number)
return t_xx_request_car_table pipelined
as
    l_exist_req     varchar2(1000);
    l_car           t_xx_request_car;
begin
    
    
    for l_tmp in (
        select rcc.*
              ,u_c.full_name            com_full_name
              ,u_cl.full_name           cl_full_name
              ,count('x') over ()       car_count
          from xx_etw.xx_disl_request_criteria_cars     rcc
              ,xx_etw.xx_disl_users                     u_c   
              ,xx_etw.xx_disl_users                     u_cl              
         where 1=1
           and criteria_id = p_criteria_id
           
           and rcc.complete_by = u_c.id(+)
           and rcc.close_by = u_cl.id(+)
--           and rownum <= 50
    ) loop
        select listagg(r.request_id||'('||rt.descr||')', ' ') within group (order by r.request_id)
          into l_exist_req
          from xx_disl_requests                 r
              ,xx_disl_request_criterias        rc 
              ,xx_disl_request_criteria_cars    rcc
              ,xx_disl_request_tasks            rt
         where 1=1
           and r.status in ('O','P')
           and r.request_id = rc.request_id(+)
           and rc.criteria_id = rcc.criteria_id(+)
           and rc.criteria_id != p_criteria_id
           and rcc.car_number = l_tmp.car_number
           
           and r.task_id = rt.task_id
        ;

        l_car.car_number := l_tmp.car_number;
        l_car.owner := l_tmp.owner;
        l_car.station := l_tmp.station;
        l_car.railway := l_tmp.railway;
        l_car.status := l_tmp.status;
        l_car.state := l_tmp.state;
        l_car.freight := l_tmp.freight;
        l_car.info_date := to_char(l_tmp.info_date,'dd.mm.yyyy');
        l_car.complete := l_tmp.complete;
        l_car.complete_date := to_char(l_tmp.complete_date,'dd.mm.yyyy');
        l_car.com_full_name := l_tmp.com_full_name;
        l_car.v := l_tmp.v;
        l_car.o := l_tmp.o;
        l_car.t := l_tmp.t;
        l_car.close := l_tmp.close;
        l_car.close_date := to_char(l_tmp.close_date,'dd.mm.yyyy');
        l_car.cl_full_name := l_tmp.cl_full_name;
        l_car.close_comment := l_tmp.close_comment;
        l_car.exist_req := l_exist_req;
        
        pipe row(l_car);
    end loop;
end get_request_criteria_cars_new;

function save_request_status(p_user_id number,p_request_id number, p_status varchar2,p_status_descr varchar2)
return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='save_request_status';
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id|| ' p_request_id = '||p_request_id||' p_status = '||p_status||' p_status_descr = '||p_status_descr);
    
    update xx_disl_requests
       set status = p_status
          ,status_descr = p_status_descr
          ,closed_by = p_user_id
          ,closed_date = sysdate
     where 1=1
       and request_id = p_request_id
    ;
    
    if (sql%rowcount!=1) then
        rollback;
        return 'fail';
    else
        commit;
        return 'done';
    end if;
exception
    when others then rollback; return 'fail';
end;

function save_processing_status(p_user_id number,p_request_id number)
return varchar2
as
    l_function              varchar2(100):='save_processing_status';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id|| ' p_request_id = '||p_request_id);
    
    update xx_disl_requests
       set status = decode(status
                          ,'O','P'
                          ,'O'
                          )
     where 1=1
       and request_id = p_request_id
    ;
    
    if (sql%rowcount!=1) then
        rollback;
        return 'fail';
    else
        commit;
        return 'done';
    end if;
exception
    when others then rollback; return 'fail';
end;


function save_crit_complete_for_request(p_user_id number,p_criteria_id number,p_complete number)
return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='save_crit_complete_for_request';
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                              ||' p_criteria_id = '||p_criteria_id
                              ||' p_complete = '||p_complete);  

    update xx_etw.xx_disl_request_criterias
       set complete = p_complete
          ,complete_date = sysdate
          ,complete_by = p_user_id
     where 1=1
       and criteria_id = p_criteria_id
    ;
    log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criterias. кол-во = '||sql%rowcount);
    
    update xx_etw.xx_disl_request_criteria_cars
       set complete = p_complete
          ,complete_date = sysdate
          ,complete_by = p_user_id
     where 1=1
       and criteria_id = p_criteria_id
    ;
    log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criteria_cars. кол-во = '||sql%rowcount);
    
    commit;
    return 'done'; 
exception
    when others then rollback; return 'fail';
end;

function save_car_complete_for_request(p_user_id number,p_criteria_id number,p_car_number number,p_complete number)
return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='save_car_complete_for_request';
    
    l_cars_count            number;
    l_complete_cars_count   number;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                              ||' p_criteria_id = '||p_criteria_id
                              ||' p_car_number = '||p_car_number
                              ||' p_complete = '||p_complete);       
    update xx_etw.xx_disl_request_criteria_cars
       set complete = p_complete
          ,complete_date = sysdate
          ,complete_by = p_user_id
     where 1=1
       and criteria_id = p_criteria_id
       and car_number = p_car_number
    ;
    log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criteria_cars. кол-во = '||sql%rowcount);
    
    if (p_complete = 0) then
        update xx_etw.xx_disl_request_criterias
           set complete = p_complete
              ,complete_date = sysdate
              ,complete_by = p_user_id
         where 1=1
           and criteria_id = p_criteria_id
           and complete = 1
        ;
        log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criterias. кол-во = '||sql%rowcount);
    elsif (p_complete = 1) then
        select count('x')       cars_count
              ,sum(complete)    complete_cars_count
          into l_cars_count
              ,l_complete_cars_count
          from xx_disl_request_criteria_cars
         where 1=1
           and criteria_id = p_criteria_id 
        ;
        log_new(l_log_id,l_function,'l_cars_count = '||l_cars_count||' l_complete_cars_count = '||l_complete_cars_count);
        
        if (l_cars_count=l_complete_cars_count) then
            update xx_etw.xx_disl_request_criterias
               set complete = p_complete
                  ,complete_date = sysdate
                  ,complete_by = p_user_id
             where 1=1
               and criteria_id = p_criteria_id
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criterias. кол-во = '||sql%rowcount);
        end if;     
    end if;
    
    commit;
    return 'done'; 
exception
    when others then rollback; return 'fail';
end;

function save_crit_close_for_request(p_user_id number,p_criteria_id number,p_close number,p_comment varchar2)
return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='save_crit_close_for_request';
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                              ||' p_criteria_id = '||p_criteria_id
                              ||' p_close = '||p_close
                              ||' p_comment = '||p_comment);  

    update xx_etw.xx_disl_request_criterias
       set close = p_close
          ,close_date = sysdate
          ,close_by = p_user_id
          ,close_comment = p_comment
     where 1=1
       and criteria_id = p_criteria_id
    ;
    log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criterias. кол-во = '||sql%rowcount);
    
    update xx_etw.xx_disl_request_criteria_cars
       set close = p_close
          ,close_date = sysdate
          ,close_by = p_user_id
          --,close_comment = p_comment
     where 1=1
       and criteria_id = p_criteria_id
    ;
    log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criteria_cars. кол-во = '||sql%rowcount);
    
    commit;
    return 'done'; 
exception
    when others then rollback; return 'fail';
end;

function save_car_close_for_request(p_user_id number,p_criteria_id number,p_car_number number,p_close number,p_comment varchar2)
return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='save_car_close_for_request';
    
    l_cars_count            number;
    l_close_cars_count   number;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                              ||' p_criteria_id = '||p_criteria_id
                              ||' p_car_number = '||p_car_number
                              ||' p_close = '||p_close
                              ||' p_comment = '||p_comment);       
    update xx_etw.xx_disl_request_criteria_cars
       set close = p_close
          ,close_date = sysdate
          ,close_by = p_user_id
          ,close_comment = p_comment
     where 1=1
       and criteria_id = p_criteria_id
       and car_number = p_car_number
    ;
    log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criteria_cars. кол-во = '||sql%rowcount);
    
    if (p_close = 0) then
        update xx_etw.xx_disl_request_criterias
           set close = p_close
              ,close_date = sysdate
              ,close_by = p_user_id
--              ,close_comment = p_comment
         where 1=1
           and criteria_id = p_criteria_id
           and close = 1
        ;
        log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criterias. кол-во = '||sql%rowcount);
    elsif (p_close = 1) then
        select count('x')       cars_count
              ,sum(close)       close_cars_count
          into l_cars_count
              ,l_close_cars_count
          from xx_disl_request_criteria_cars
         where 1=1
           and criteria_id = p_criteria_id 
        ;
        log_new(l_log_id,l_function,'l_cars_count = '||l_cars_count||' l_close_cars_count = '||l_close_cars_count);
        
        if (l_cars_count=l_close_cars_count) then
            update xx_etw.xx_disl_request_criterias
               set close = p_close
                  ,close_date = sysdate
                  ,close_by = p_user_id
                  --,close_comment = p_comment
             where 1=1
               and criteria_id = p_criteria_id
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_request_criterias. кол-во = '||sql%rowcount);
        end if;     
    end if;
    
    commit;
    return 'done'; 
exception
    when others then rollback; return 'fail';
end;

/*формат хранения путей с вагонами в заявке путь|вагон:вагон:$*/
/*p_cars в формате вагон:вагон:*/
function get_cars_with_railways(p_cars varchar2,p_need_railway  varchar2 default 'Y')
return varchar2
as
    l_function              varchar2(100) := 'get_cars_with_railways';    
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_result                varchar2(4000);
begin
    delete 
      from xx_etw.xx_disl_cars_with_railways
    ;

    insert into xx_etw.xx_disl_cars_with_railways(car_number)
    select regexp_substr(p_cars,'[^:]+',1,level) car_id
      from dual
   connect by level <= regexp_count(p_cars,'[^:]+')
    ;
    
    if (p_need_railway = 'Y') then
        update xx_etw.xx_disl_cars_with_railways   cwr
           set cwr.railway_id = xx_etw.xx_dislocation.get_railway_for_car(cwr.car_number)
        ;
    end if;
    
    select listagg(res,'$') within group (order by res)
      into l_result
      from (select nvl(to_char(railway_id),'_')||'|'||listagg(car_number,':') within group (order by car_number)     res
              from xx_etw.xx_disl_cars_with_railways
             group by
                   nvl(to_char(railway_id),'_')
           )
    ;
    log_new(l_log_id,l_function,'l_result = '||l_result); 
    
    return l_result;
exception
    when others then return 'fail';
end;

procedure car_scale_get_data
as
begin
    null;
