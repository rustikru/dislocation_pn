function get_asset_info(p_car_number varchar2)
return t_xx_asset_info_table pipelined
as
--    l_instance_id           number;
--    l_asset_group_id        number;
--    l_asset_group           inv.mtl_system_items_b.segment1%type;
--    l_asset_number          csi.csi_item_instances.serial_number%type;
    
    l_row                   t_xx_asset_info_row;
begin
    begin
        select cii.instance_id
          into l_row.instance_id
          from csi.csi_item_instances   cii
              ,inv.mtl_system_items_b   msib
              ,inv.mtl_parameters       mp
         where 1=1      
           and msib.organization_id = mp.organization_id
           and msib.organization_id = cii.last_vld_organization_id
           and msib.inventory_item_id = cii.inventory_item_id
           and msib.eam_item_type in (1, 3)
           and msib.serial_number_control_code <> 1
           and sysdate between nvl (cii.active_start_date, sysdate - 1) and  nvl (cii.active_end_date, sysdate + 1)
           and mp.maint_organization_id = 305--:parameter.org_id
           and cii.instance_number = p_car_number
        ;
    exception
        when no_data_found then l_row.instance_id:=-1;
    end;
    
    if l_row.instance_id != -1 then
        select msi.inventory_item_id
              ,msi.segment1
          into l_row.asset_group_id
              ,l_row.asset_group
          from inv.mtl_system_items_b msi
              ,csi.csi_item_instances cii
         where 1=1
           and cii.last_vld_organization_id = 305
           and msi.inventory_item_id = cii.inventory_item_id
           and msi.organization_id = cii.last_vld_organization_id
           and cii.instance_id = l_row.instance_id
        ;
        
        select cii.serial_number
          into l_row.asset_number
          from inv.mtl_system_items_b msi
              ,csi.csi_item_instances cii
         where 1=1
           and cii.last_vld_organization_id = 305
           and msi.inventory_item_id = cii.inventory_item_id
           and msi.organization_id = cii.last_vld_organization_id
           and cii.instance_id = l_row.instance_id
        ;
    end if;
    
    pipe row(l_row);
end; 

