function getCarType(p_code_etsng varchar2,p_cont_number varchar2,p_type varchar2 default null)
return varchar2
as
begin
    return case 
             when p_code_etsng='488049' or p_code_etsng='488161'
               then 'ЦС'
             when p_code_etsng='433046'
               then 'МВ'
             when p_code_etsng='481232'
               then 'ЦС'
             when p_code_etsng='724117'
               then 'КР'
             when p_code_etsng='481321' or p_code_etsng='481482'
               then 'ПЛ с УК'
             when (p_code_etsng='723098' or p_code_etsng='723051') and p_cont_number is null
               then 'ЦС'
             when (p_code_etsng='723098' or p_code_etsng='723051') and p_cont_number is not null
               then 'ПЛ с КЦ'
             when p_code_etsng='713045' and p_cont_number is null
               then 'ЦС'  
             when p_code_etsng='713045' and p_cont_number is not null
               then 'ПЛ с КЦ'
             when p_code_etsng='482146' and p_cont_number is null
               then 'ЦС'  
             when p_code_etsng='482146' and p_cont_number is not null
               then 'ПЛ с КЦ'   
             else p_type
           end;
end;

function getCarFreight(p_code_etsng varchar2,p_cont_number varchar2,p_freight varchar2 default null)
return varchar2
as
begin
    return case 
             when p_code_etsng='488049' or p_code_etsng='488161'
               then 'Аммиак'
             when p_code_etsng='433046'
               then 'Карбамид'
             when p_code_etsng='481232'
               then 'Серн. к-та'
             when p_code_etsng='724117'
               then 'Мур. к-та'
             when p_code_etsng='481321' or p_code_etsng='481482'
               then 'Диоксид'
             when (p_code_etsng='723098' or p_code_etsng='723051') and p_cont_number is null
               then 'Ацет-д'
             when (p_code_etsng='723098' or p_code_etsng='723051') and p_cont_number is not null
               then 'Ацет-д'
             when p_code_etsng='713045' and p_cont_number is null
               then 'Капрол-м'  
             when p_code_etsng='713045' and p_cont_number is not null
               then 'Капрол-м'
             when p_code_etsng='482146' and p_cont_number is null
               then 'Едкий натр'  
             when p_code_etsng='482146' and p_cont_number is not null
               then 'Едкий натр'   
             else initcap(p_freight)
           end;
end;
/*аналогична функции md5 в php*/
function md5(input_string in varchar2) return varchar2
is
    hex_digest      varchar2(32);
    digest          varchar2(16);
begin
    digest := dbms_obfuscation_toolkit.md5(input_string => input_string);
    select lower(rawtohex(digest)) 
      into hex_digest 
      from dual
    ;
    return hex_digest;
end;


function get_credentials
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for tmp in (select credential_id
                      ,credential_name
                  from xx_disl_credential
                 where 1=1
                 order by
                       credential_name
               )
    loop
        l_row.id := tmp.credential_id;
        l_row.name := tmp.credential_name;
        
        pipe row (l_row);
    end loop;      
end;


function get_rights_list
return t_xx_rights_list_table pipelined
as
    l_row xx_etw.xx_disl_rights%rowtype;
begin
    for tmp in (select id
                      ,rights_name
                      ,rights_code
                  from xx_etw.xx_disl_rights
                 where 1=1
                 order by
                       rights_name
               )
    loop
        l_row.id := tmp.ID;
        l_row.rights_name := tmp.RIGHTS_NAME;
        l_row.rights_code := tmp.RIGHTS_CODE;
        
        pipe row (l_row);
    end loop;      
end;

function get_un_loading_type (p_type varchar2) return number
is
    l_un_loading_id     number:=0;
begin
    select  case when lower(nvl(p_type,'*')) = lower('un-loading-akm') then 1 
                 else 0
            end as l_un_loading_id
      into l_un_loading_id
    from dual;
    
    return l_un_loading_id;
end;

function get_credential_descr_new(p_credential_id number)
return t_xx_creden_descr_new_table pipelined
is
    l_row t_xx_creden_descr_new_row;
begin
    for tmp in (select c.credential_id, 
                       c.credential_name,
                       cr.rigth_id, 
                       nvl (cr.val, 'N') as rigth_val
                  from xx_etw.xx_disl_credential c, xx_etw.xx_disl_credential_rights cr
                 where     1 = 1
                       and c.credential_id = p_credential_id
                       and c.credential_id = cr.credential_id
               )
    loop
        l_row.credential_id := tmp.CREDENTIAL_ID;
        l_row.credential_name := tmp.CREDENTIAL_NAME;
        l_row.rigth_id := tmp.RIGTH_ID;
        l_row.rigth_val := tmp.RIGTH_VAL;
        pipe row (l_row);
    end loop;

end;


-- не используется с 28.11.2024 заменил на новую get_credential_descr_new
function get_credential_descr(p_credential_id number)
return t_xx_credential_descr_table pipelined
as
    l_row xx_disl_credential%rowtype;
begin
    for tmp in (select *
                  from xx_disl_credential
                 where 1=1
                   and credential_id = p_credential_id
               )
    loop
        l_row.credential_name := tmp.credential_name;
        l_row.moving_inside_railway := tmp.moving_inside_railway;
        l_row.moving_inside_shop := tmp.moving_inside_shop;
        l_row.moving_inside_station := tmp.moving_inside_station;
        l_row.moving_between_station := tmp.moving_between_station;
        l_row.change_attribute := tmp.change_attribute;
        l_row.change_weight := tmp.change_weight;
        l_row.enter_inspection := tmp.enter_inspection;
        l_row.enter_dev_inspection := tmp.enter_dev_inspection; -- Осмотры ЗУ
        l_row.fix_dev_add := tmp.fix_dev_add; -- зу.назначение 
        l_row.fix_dev_undock := tmp.fix_dev_undock; -- зу.снятие
        l_row.fix_dev_update := tmp.fix_dev_update; -- зу.корректировка 
        l_row.enter_inspection_add := tmp.enter_inspection_add;
        l_row.register_notification := tmp.register_notification;
        l_row.entry_foreign_car := tmp.entry_foreign_car;
        l_row.administrator := tmp.administrator;
        l_row.receive_to_station := tmp.receive_to_station;
        l_row.work_with_groups := tmp.work_with_groups;
        l_row.out_from_ugl := tmp.out_from_ugl;
        l_row.add_attribute := tmp.add_attribute;
        l_row.create_request := tmp.create_request;
        l_row.change_request := tmp.change_request;
        l_row.view_request := tmp.view_request;
        l_row.complete_request := tmp.complete_request;
        l_row.del_ins_doc := tmp.del_ins_doc;
        l_row.return_from_psp := tmp.return_from_psp;
        l_row.autocreate_request_v := tmp.autocreate_request_v;
        l_row.autocreate_request_o := tmp.autocreate_request_o;
        l_row.autocreate_request_t := tmp.autocreate_request_t;
        l_row.weigh_import := tmp.weigh_import;
        l_row.weigh_import_corr := tmp.weigh_import_corr;
        l_row.weigh_delete := tmp.weigh_delete;
        l_row.export_shop_info := tmp.export_shop_info;
        l_row.create_invoice_out := tmp.create_invoice_out;
        l_row.send_invoice_to_etran := tmp.send_invoice_to_etran;
        l_row.register_notification_gu := tmp.register_notification_gu;
        l_row.export_notification_gu := tmp.export_notification_gu;
        
        l_row.route_add := tmp.route_add;
        l_row.route_processing := tmp.route_processing;
        l_row.route_closing := tmp.route_closing;
        
        l_row.output_defective_cars := tmp.output_defective_cars;
        
        l_row.fix_dev_rule := tmp.fix_dev_rule;
        l_row.fix_dev_place := tmp.fix_dev_place;
        
        l_row.shift_update := tmp.shift_update; -- Приема/сдачи смены. Корректировка
        l_row.control_cars := tmp.control_cars; -- Контроль вагонов
        l_row.weighing_dispatcher := tmp.weighing_dispatcher; -- Диспетчер взвешивания
        l_row.process_of_wagons := tmp.process_of_wagons; -- Диспетчер взвешивания
        l_row.update_of_nsi := tmp.update_of_nsi; -- Обновление НСИ вагонов
        l_row.scale_type_1831_manual := tmp.scale_type_1831_manual; -- Обновление НСИ вагонов
        
        l_row.export_samples  := tmp.export_samples ; -- Создание проб в OeBS
        l_row.entry_foreign_cont  := tmp.entry_foreign_cont ; -- Ручной ввод контейнеров
        
        pipe row (l_row);
    end loop;      
end;


-- Не используется, заменил на новую save_new_credential_new
function save_new_credential(p_add_data in t_xx_user_credential_row) 
return number
as
    l_function      varchar2(100):='save_new_credential';
    l_log_id        number;
    l_credential_id             number;  
begin
    
    insert into xx_disl_credential(
         credential_id  
        ,credential_name
        ,moving_inside_railway 
        ,moving_inside_shop  
        ,moving_inside_station 
        ,moving_between_station 
        ,change_attribute 
        ,change_weight 
        ,enter_inspection 
        ,enter_inspection_add 
        ,register_notification 
        ,entry_foreign_car 
        ,administrator
        ,receive_to_station
        ,work_with_groups
        ,out_from_ugl
        ,add_attribute
        ,create_request
        ,change_request
        ,view_request
        ,complete_request
        ,del_ins_doc
        ,return_from_psp
        ,autocreate_request_v
        ,autocreate_request_o
        ,autocreate_request_t
        ,weigh_import 
        ,weigh_import_corr 
        ,weigh_delete 
        ,export_shop_info
        ,create_invoice_out
        ,send_invoice_to_etran
        ,register_notification_gu
        
        ,route_add 
        ,route_processing 
        ,route_closing 
        
        ,output_defective_cars
        ,export_notification_gu
        
        ,fix_dev_rule
        ,fix_dev_place
        ,enter_dev_inspection
        ,FIX_DEV_ADD
        ,FIX_DEV_UNDOCK
        ,FIX_DEV_UPDATE
        
        ,shift_update
        ,control_cars
        ,weighing_dispatcher
        ,process_of_wagons
        ,update_of_nsi
        ,scale_type_1831_manual
        ,export_samples
        ,entry_foreign_cont  -- Ручной ввод контейнеров
    )
    values(
         xx_disl_credential_seq.nextval
        ,p_add_data.p_credential_name
        ,p_add_data.p_moving_inside_railway 
        ,p_add_data.p_moving_inside_shop  
        ,p_add_data.p_moving_inside_station 
        ,p_add_data.p_moving_between_station 
        ,p_add_data.p_change_attribute 
        ,p_add_data.p_change_weight 
        ,p_add_data.p_enter_inspection 
        ,p_add_data.p_enter_inspection_add 
        ,p_add_data.p_register_notification 
        ,p_add_data.p_entry_foreign_car 
        ,p_add_data.p_administrator
        ,p_add_data.p_receive_to_station
        ,p_add_data.p_work_with_groups
        ,p_add_data.p_out_from_ugl
        ,p_add_data.p_add_attribute
        ,p_add_data.p_create_request
        ,p_add_data.p_change_request
        ,p_add_data.p_view_request
        ,p_add_data.p_complete_request
        ,p_add_data.p_del_ins_doc
        ,p_add_data.p_return_from_psp
        ,p_add_data.p_autocreate_request_v
        ,p_add_data.p_autocreate_request_o
        ,p_add_data.p_autocreate_request_t
        ,p_add_data.p_weigh_import 
        ,p_add_data.p_weigh_import_corr 
        ,p_add_data.p_weigh_delete 
        ,p_add_data.p_export_shop_info
        ,p_add_data.p_create_invoice_out
        ,p_add_data.p_send_invoice_to_etran
        ,p_add_data.p_register_notification_gu

        ,p_add_data.p_route_add 
        ,p_add_data.p_route_processing 
        ,p_add_data.p_route_closing 
        
        ,p_add_data.p_output_defective_cars
        ,p_add_data.p_export_notification_gu
        
        ,p_add_data.p_fix_dev_rule
        ,p_add_data.p_fix_dev_place
        ,p_add_data.p_enter_dev_inspection
        ,p_add_data.p_FIX_DEV_ADD
        ,p_add_data.p_FIX_DEV_UNDOCK
        ,p_add_data.p_FIX_DEV_UPDATE
        ,p_add_data.p_shift_update
        ,p_add_data.p_control_cars 
        ,p_add_data.p_weighing_dispatcher
        ,p_add_data.p_process_of_wagons
        ,p_add_data.p_update_of_nsi
        ,p_add_data.p_scale_type_1831_manual
        ,p_add_data.p_export_samples
        ,p_add_data.p_entry_foreign_cont    -- Ручной ввод контейнеров
    )
    returning credential_id into l_credential_id;
    commit;
    
    return l_credential_id;
    log_new(l_log_id,l_function,'l_credential_id='||l_credential_id);
exception
    when others then rollback; log_new(l_log_id,l_function,sqlerrm);   return 0;    
end;


