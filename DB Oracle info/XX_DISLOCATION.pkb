                ,p_id          => p_inspection_id
                ,p_return_status =>l_return_status);
            log_new(l_log_id,l_function,'l_return_status = '||l_return_status);  
                   
            update xx_disl_dev_inspections
               set created_request_status = l_return_status
             where 1=1
               and inspection_id = p_inspection_id
            ;
            log_new(l_log_id,l_function,'update xx_disl_dev_inspections. rowcount = '||sql%rowcount);
            
            p_result := l_return_status;
            
            commit;
        end if;
    end if;
exception
    when others then rollback; p_result := 'E'; p_error_log := 'Ошибка при выполение процедуры!';      
end;

function refusal_to_repair(
     p_user_id          number
    ,p_inspection_id    number
    ,p_person           varchar2
) 
return varchar2
as
begin
    update xx_disl_inspections
       set refusal_to_repair = p_person
          ,last_updated_by = p_user_id
          ,last_updated_date = sysdate
     where 1=1
       and inspection_id = p_inspection_id
    ;
    
    commit;
    
    return 'done';
exception
    when others then rollback; return 'fail';
end;

function get_car_inspections(p_obj_number varchar2,p_obj_type varchar2)
return t_xx_car_inspection_table pipelined
as
    l_row           t_xx_car_inspection_row;
    l_date_from     date; 
begin
    if (p_obj_type = 'railcar') then
        begin
            select sh.come_date
              into l_date_from
              from xx_etw.xx_disl_round                r
                  ,xx_etw.xx_disl_station_history      sh
             where 1=1
               and r.railcar_id = p_obj_number
               and r.station_hist_id_out is null
               
               and r.station_hist_id_in = sh.station_hist_id  
            ;
        exception
            when no_data_found then l_date_from:=null;
        end;
    elsif (p_obj_type = 'cont') then
        begin
            select ch.in_date_sys
              into l_date_from
              from xx_etw.xx_disl_cont_round        cr
                  ,xx_etw.xx_disl_cont_history      ch
             where 1=1
               and cr.cont_number = p_obj_number
               and cr.cont_history_out is null
               
               and cr.cont_history_in = ch.cont_history_id  
            ;
        exception
            when no_data_found then l_date_from:=null;
        end;   
    end if;
       
    for tmp in (select ins.inspection_id
                      ,ins.asset_instance_number
                      ,ins.asset_instance_id
                      ,ins.asset_group_id
                      ,(select msi.segment1
                          from inv.mtl_system_items_b       msi
                         where 1=1
                           and msi.inventory_item_id = ins.asset_group_id
                           and msi.organization_id = 305
                       )              
                                                                                asset_group
                      ,ins.asset_number
                      ,to_char(nvl(ins.inspection_date,ins.created_date),'dd.mm.yyyy hh24:mi')        inspection_date
                      ,ins.inspection_place
                      ,ins.inspection_person
                      ,ins.inspection_person_appoint
                      ,ins.master
                      ,ins.priority
                      ,ins.result
                      ,ins.status_kurs
                      ,ins.description
                      ,ins_d.defect_id
                      ,ins_d.defect_code
                      ,ins_d.defect_descr
                      ,ins_d.doc_type
                      ,ins_d.doc_num
                      ,ins_d.defect_date
                      ,decode(ins.created_request_status
                             ,'E','Ошибка при создании'
                             ,'S','Создан'
                             ,ins.created_request_status
                             )
                                                                                created_request_status
                      ,ins.refusal_to_repair
                      ,ins.created_by
                  from xx_disl_inspections          ins
                      ,xx_disl_inspection_defects   ins_d
                 where 1=1
                   and ins.asset_instance_number in (select p_obj_number
                                                       from dual
                                                      union
                                                     select cont_number
                                                       from table(xx_dislocation.get_car_containers(p_obj_number)) 
                                                    )
                                                    
--                   and ins.created_date >= nvl(l_date_from,ins.created_date)
                   
                   and ins.inspection_id = ins_d.inspection_id(+)
                   and ins.inspection_date is not null
                 order by
                       nvl(ins.inspection_date,ins.created_date) desc -- asdf
                      ,ins.inspection_id
                      ,ins_d.defect_id
               )
    loop
        l_row.inspection_id := tmp.inspection_id;
        l_row.asset_instance_number := tmp.asset_instance_number;
        l_row.asset_instance_id := tmp.asset_instance_id;
        l_row.asset_group_id := tmp.asset_group_id;
        l_row.asset_group := tmp.asset_group;
        l_row.asset_number := tmp.asset_number;
        l_row.inspection_date := tmp.inspection_date;
        l_row.inspection_place := tmp.inspection_place;
        l_row.inspection_person := tmp.inspection_person;
        l_row.inspection_person_appoint := tmp.inspection_person_appoint;
        l_row.master := tmp.master;
        l_row.priority := tmp.priority;
        l_row.result := tmp.result;
        l_row.status_kurs := tmp.status_kurs;
        l_row.description := tmp.description;
        l_row.defect_id := tmp.defect_id;
        l_row.defect_code := tmp.defect_code;
        l_row.defect_descr := tmp.defect_descr;
        l_row.doc_type := tmp.doc_type;
        l_row.doc_num := tmp.doc_num;
        l_row.defect_date := tmp.defect_date;
        l_row.created_request_status := tmp.created_request_status;
        l_row.refusal_to_repair := tmp.refusal_to_repair;
        l_row.created_by := tmp.created_by;
        
        pipe row (l_row);
    end loop;     
end;

function delete_inspection(p_inspection_id number) 
return varchar2
as
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval();
    l_function                  varchar2(100):='delete_inspection';

    l_delete_row_count          number;
    l_asset_instance_number     varchar2(100);
    
    l_errbuf                    varchar2(4000);
    l_retcode                   varchar2(1);
    l_add_info_id               number;
begin
    log_new(l_log_id,l_function,'p_inspection_idt = '||p_inspection_id);

    delete   
      from xx_etw.xx_disl_inspections
     where 1=1
       and inspection_id = p_inspection_id
    returning asset_instance_number into l_asset_instance_number 
    ;
    log_new(l_log_id,l_function,'l_asset_instance_number = '||l_asset_instance_number);
    
    if (l_asset_instance_number is null) then
        rollback;
        return 'fail';
    end if;
    
    delete 
      from xx_etw.xx_disl_inspection_defects
     where 1=1
       and inspection_id = p_inspection_id
    ;
    log_new(l_log_id,l_function,'delete from xx_etw.xx_disl_inspection_defects. кол-во = '||sql%rowcount);
    
    mark_last_record_for_ins(l_asset_instance_number);
    
    begin /*на случай если осмотр вводят по вагону которого нет дислокации*/
        select rai.add_info_id
          into l_add_info_id
          from xx_etw.xx_disl_round                r
              ,xx_etw.xx_disl_railcar_add_info     rai
         where 1=1
           and r.round_id = returnLastRound(l_asset_instance_number)
               
           and r.round_id = rai.round_id
           and rai.last_record = 'Y'
        ;
        log_new(l_log_id,l_function,'l_add_info_id = '||l_add_info_id);
                    
        update_railcar_status(l_errbuf,l_retcode,l_add_info_id);
    exception
        when no_data_found then null;
    end;
    
    commit;
    
    return 'done';     
exception
    when others then rollback;return 'fail';       
end;

function get_all_cars
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row; 
begin
    for l_cars in (
        select distinct railcar_id
          from xx_etw.xx_disl_round
         where 1=1
         order by
               railcar_id
    ) loop
        l_row.id := l_cars.railcar_id;
        
        pipe row (l_row);   
    end loop; 
end;

function get_suitable_cars(p_enter_text varchar2)
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row; 
begin
    for l_cars in (
        select distinct railcar_id
          from xx_etw.xx_disl_round
         where 1=1
           and railcar_id like p_enter_text||'%'
           and station_hist_id_out is null
         order by
               railcar_id
    ) loop
        l_row.id := l_cars.railcar_id;
        
        pipe row (l_row);   
    end loop; 
end;

