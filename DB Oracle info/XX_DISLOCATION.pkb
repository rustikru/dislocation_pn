    commit;
    l_result := 'done';   

    return l_result;
exception
    when others then rollback; return 'fail';
end;

function get_fixing_device(
    p_user_id       number,
    p_params        varchar2)
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row;  
    l_json      json;
    l_part_id   number;  
    
    l_seg_2     varchar2(50); 
    l_seg_4_f   varchar2(50);
    l_seg_4_l   varchar2(50);
    l_seg_5     varchar2(50);
begin
    l_json := xx_wms.json(p_params);
    
    l_seg_2 := l_json.get_string('seg2');
    l_seg_4_f := l_json.get_string('seg4f');
    l_seg_4_l := l_json.get_string('seg4l');
    l_seg_5 := upper(l_json.get_string('seg5'));

    for l_part in (
        select instance_id
              ,instance_number
          from xx_etw.xx_disl_fixing_device_v
         where 1=1
           and seg2 = nvl(l_seg_2,seg2)
           and seg4 between nvl(l_seg_4_f,seg4) and nvl(l_seg_4_l,seg4)
           and nvl(seg5,'x') = coalesce(l_seg_5,seg5,'x')
         order by
               instance_number)
    loop
        l_row := null;
        
        l_row.id := l_part.instance_id;
        l_row.name := l_part.instance_number;
        
        pipe row(l_row);
    end loop;
end;

-- Список цветов
function get_car_color_select(
    p_user_id       number,
    p_params        varchar2)
return t_xx_car_color_table pipelined
as
    l_row       t_xx_car_color_row;  
    l_json      json;
begin
    for l_part in ( 
        select *
          from xx_etw.xx_disl_color
      order by description
    )
    loop
        l_row := null;
        l_row.id := l_part.id;
        l_row.name := l_part.name;
        l_row.description := l_part.description;
        l_row.code := l_part.code;
        pipe row(l_row);
    end loop;
end;
function get_device_for_assignment(
    p_user_id       number,
    p_params        varchar2)
return t_xx_device_for_table pipelined
as
    l_row       t_xx_device_for_assignment_row;  
    l_json      json;
    l_part_id    number;
    l_railway_id number;    
    
    l_seg_2     varchar2(50); 
    l_seg_4_f   varchar2(50);
    l_seg_4_l   varchar2(50);
    l_seg_5     varchar2(50);
begin
    l_json := xx_wms.json(p_params);
    
    l_seg_2 := l_json.get_string('seg2');
    l_seg_4_f := l_json.get_string('seg4f');
    l_seg_4_l := l_json.get_string('seg4l');
    l_seg_5 := upper(l_json.get_string('seg5'));
    l_railway_id :=  l_json.get_string('railway_id');
    for l_part in (
        select instance_id
              ,instance_number
              ,nvl(xx_etw.xx_dislocation.validation_dev_trans(null,null,instance_id,'N'),'*') railway_name
        FROM   xx_etw.xx_disl_fixing_device_v fdv
       WHERE   1 = 1
               AND EXISTS
                     (SELECT   *
                        FROM   xx_etw.xx_disl_storage_place_rlw str,
                               xx_etw.xx_disl_storage_place_dvc std
                       WHERE       1 = 1
                               AND str.place_id = std.place_id
                               AND str.RAILWAY_ID = l_railway_id
                               and nvl(str.DELETED,'N') = 'N'
                               AND std.device_id = fdv.instance_id
                               AND fdv.INSTANCE_ID = std.device_id)
               and not exists (
                   select * 
                    from xx_etw.xx_disl_dev_inspections x
                   where 1=1
                         and x.asset_instance_id = fdv.instance_id
                         and x.result = 'Не годен'
                         and trunc(x.inspection_date) <= trunc(sysdate)
                    
               )   
               AND seg2 like NVL (l_seg_2, seg2)
               AND to_number(replace(ltrim(replace(seg4, '0', ' ')),' ', '0'))
                        BETWEEN NVL (l_seg_4_f, replace(ltrim(replace(seg4, '0', ' ')),' ', '0')) AND NVL (l_seg_4_l, replace(ltrim(replace(seg4, '0', ' ')),' ', '0'))
               AND NVL (seg5, 'x') = COALESCE (l_seg_5, seg5, 'x')
    ORDER BY   instance_number)
    loop
        l_row := null;
        
        l_row.id := l_part.instance_id;
        l_row.name := l_part.instance_number;
        l_row.railway_name := l_part.railway_name;
        pipe row(l_row);
    end loop;
end;

function get_device_for_update(
    p_user_id       number,
    p_params        varchar2)
return t_xx_device_update_table pipelined
as
    l_row       t_xx_device_for_update_row;  
    l_json      json;
    l_part_id    number;
    l_railway_id number;
    l_side_type  varchar2(240); 
    l_trigger    varchar2(10);
    l_seg_2     varchar2(50); 
    l_seg_4_f   varchar2(50);
    l_seg_4_l   varchar2(50);
    l_seg_5     varchar2(50);
begin
    l_json := xx_wms.json(p_params);
    
    l_seg_2 := l_json.get_string('seg2');
    l_seg_4_f := l_json.get_string('seg4f');
    l_seg_4_l := l_json.get_string('seg4l');
    l_seg_5 := upper(l_json.get_string('seg5'));
    l_railway_id :=  l_json.get_string('railway_id');
    l_part_id :=  l_json.get_string('part_id');
    l_side_type :=  l_json.get_string('side_type');
    l_trigger:=l_json.get_string('trigger');
    
    for l_part in (    
        select fdv.instance_id
              ,fdv.instance_number
              ,nvl(xx_etw.xx_dislocation.validation_dev_trans(l_railway_id,l_part_id,fdv.instance_id,'Y'),'*') railway_name
              ,case when dtl.instance_id is not null and l_trigger = 'N' then 'true' else '' end selected
              ,nvl(dtl.transactions_lines_id,0) transactions_lines_id
        FROM   xx_etw.xx_disl_fixing_device_v fdv,
              (select  dtl.*
                 from  xx_etw.xx_disl_transactions_header dth,
                       xx_etw.xx_disl_transactions_lines dtl
               WHERE   1 = 1
                       and dth.transactions_header_id = dtl.transactions_header_id
                       and dtl.transaction_type (+)= 'IN'
                       and nvl(dtl.deleted,'N') = 'N'
                       and nvl(dth.STATUS,'OPEN') = 'OPEN'
                       and nvl(dth.DELETED,'N') = 'N'
                       and dtl.transactions_out_id is null
                       and dth.railway_id = l_railway_id
                       and dth.part_id = l_part_id
                       and dtl.side_type = l_side_type) dtl
       WHERE   1 = 1
               and fdv.instance_id = dtl.instance_id (+)
               AND EXISTS
                     (SELECT   *
                        FROM   xx_etw.xx_disl_storage_place_rlw str,
                               xx_etw.xx_disl_storage_place_dvc std
                       WHERE       1 = 1
                               AND str.place_id = std.place_id
                                and nvl(str.DELETED,'N') = 'N'
                               AND str.RAILWAY_ID = l_railway_id
                               AND std.device_id = fdv.instance_id
                               AND fdv.INSTANCE_ID = std.device_id)
               AND seg2 like NVL (l_seg_2, seg2)
               AND to_number(replace(ltrim(replace(seg4, '0', ' ')),' ', '0'))
                        BETWEEN NVL (l_seg_4_f, replace(ltrim(replace(seg4, '0', ' ')),' ', '0')) AND NVL (l_seg_4_l, replace(ltrim(replace(seg4, '0', ' ')),' ', '0'))
               AND NVL (seg5, 'x') = COALESCE (l_seg_5, seg5, 'x')
    ORDER BY   selected,instance_number)
    loop
        l_row := null;
        
        l_row.id := l_part.instance_id;
        l_row.name := l_part.instance_number;
        l_row.railway_name := l_part.railway_name;
        l_row.selected := l_part.selected;
        l_row.transactions_lines_id := l_part.transactions_lines_id;
        pipe row(l_row);
    end loop;
end;
function set_header_value_fix(
    p_user_id       number,
    p_params        varchar2)
return t_xx_header_value_fix_table pipelined
as  
    l_row       t_xx_header_value_fix_row;  
    l_json      json;
    l_part_id    number;
    l_railway_id number; 
    l_side_type  varchar2(240); 
begin
    l_json := xx_wms.json(p_params);
    l_railway_id :=  l_json.get_string('railway_id');
    l_part_id :=  l_json.get_string('part_id');
    for l_part in (
       select  to_char(DATE_FIX_EVEN,'DD.MM.YYYY HH24:MI') DATE_FIX_EVEN,
               USER_FIX_EVEN, 
               USER_FIX_REP_EVEN, 
               to_char(DATE_FIX_ODD,'DD.MM.YYYY HH24:MI') DATE_FIX_ODD,
               USER_FIX_ODD, 
               USER_FIX_REP_ODD, 
               NOTE_FIX,
               CALCULATION_TYPE,
               NORMA_EVEN,
               NORMA_ODD,
               case when nvl(norma_even,0) = 0 then 'N' else 'Y' end requir_even, -- Обязательная сторона или нет 
               case when nvl(norma_odd,0) = 0 then 'N' else 'Y' end requir_odd -- Обязательная сторона или нет 
         from  xx_etw.xx_disl_transactions_header dth
        where  1 = 1
               and dth.railway_id = l_railway_id
               and dth.part_id = l_part_id
               and nvl(dth.status,'OPEN') = 'OPEN'
               and nvl(dth.deleted,'N') = 'N'
               )
    loop
        l_row := null;
        l_row.date_fix_even:=l_part.date_fix_even;
        l_row.user_fix_even:=l_part.user_fix_even;
        l_row.user_fix_rep_even:=l_part.user_fix_rep_even;
        l_row.date_fix_odd:=l_part.date_fix_odd;
        l_row.user_fix_odd:=l_part.user_fix_odd;
        l_row.user_fix_rep_odd:=l_part.user_fix_rep_odd;
        l_row.note_fix:=l_part.note_fix;
        l_row.calculation_type:=l_part.calculation_type;
        l_row.norma_even:=l_part.norma_even;
        l_row.norma_odd:=l_part.norma_odd;
        l_row.requir_even:=l_part.requir_even;
        l_row.requir_odd:=l_part.requir_odd;
        pipe row(l_row);
    end loop;
end;
function get_device_for_ondock(
    p_user_id       number,
    p_params        varchar2)
return t_xx_dev_ondock_table pipelined
as
    l_row       t_xx_dev_ondock_row;  
    l_json      json;
    l_part_id    number;
    l_railway_id number; 
    l_side_type  varchar2(240);   
    
    l_seg_2     varchar2(50); 
    l_seg_4_f   varchar2(50);
    l_seg_4_l   varchar2(50);
    l_seg_5     varchar2(50);
begin
    l_json := xx_wms.json(p_params);
    
    l_seg_2 := l_json.get_string('seg2');
    l_seg_4_f := l_json.get_string('seg4f');
    l_seg_4_l := l_json.get_string('seg4l');
    l_seg_5 := upper(l_json.get_string('seg5'));
    l_railway_id :=  l_json.get_string('railway_id');
    l_part_id :=  l_json.get_string('part_id');
    l_side_type :=  l_json.get_string('side_type');
    for l_part in (
        select fdv.instance_id
              ,fdv.instance_number
              ,dtl.transactions_lines_id
        FROM   xx_etw.xx_disl_fixing_device_v fdv,
               xx_etw.xx_disl_transactions_header dth,
               xx_etw.xx_disl_transactions_lines dtl
       WHERE   1 = 1
               and dth.railway_id = l_railway_id
               and dth.part_id = l_part_id
               and dtl.side_type = l_side_type
               and dtl.instance_id = fdv.instance_id
               and dth.transactions_header_id = dtl.transactions_header_id
               and dtl.transaction_type = 'IN'
               and nvl(dtl.deleted,'N') = 'N'
               and nvl(dth.STATUS,'OPEN') = 'OPEN'
               and nvl(dth.DELETED,'N') = 'N'
               and dtl.transactions_out_id is null
               AND seg2 like NVL (l_seg_2, seg2)
               AND to_number(replace(ltrim(replace(seg4, '0', ' ')),' ', '0'))
                        BETWEEN NVL (l_seg_4_f, replace(ltrim(replace(seg4, '0', ' ')),' ', '0')) AND NVL (l_seg_4_l, replace(ltrim(replace(seg4, '0', ' ')),' ', '0'))
               AND NVL (seg5, 'x') = COALESCE (l_seg_5, seg5, 'x')
    ORDER BY   instance_number)
    loop
        l_row := null;
        
        l_row.id := l_part.instance_id;
        l_row.name := l_part.instance_number;
        l_row.transactions_id := l_part.transactions_lines_id;
        pipe row(l_row);
    end loop;
end;

function get_parent_storage_place(
    p_user_id       number,
    p_params        varchar2)
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row;  
--    l_json      json;
begin
--    l_json := xx_wms.json(p_params);
    
--    l_seg_2 := l_json.get_string('seg2');
    for l_part in (
        select place_id
              ,place_name
          from xx_etw.xx_disl_storage_place
         where top_level = 'Y'
           and deleted = 'N'
         order by
               place_name)
    loop
        l_row := null;
        
        l_row.id := l_part.place_id;
        l_row.name := l_part.place_name;
        
        pipe row(l_row);
    end loop;
end;

function get_storage_place(
    p_user_id       number,
    p_params        varchar2)
return t_xx_storage_place_table pipelined
as
    l_row       t_xx_storage_place_row;  
    l_json      json;
    l_place_id  number;
    
    l_json_tmp  json;  
    l_json_list json_list; 
    l_exists_railway    boolean;

    cursor cur_place(p_place_id number) is
    select sp.place_id
          ,sp.place_name
          ,sp.control_count
          ,sp.top_level
          ,sp.parent_id
          ,sp_p.place_name  parent_name
          ,sp.last_update_date
          ,sp.descr
          
          ,sp.fixing_person_1
          ,con1.name                    fixing_person_1_descr
          ,sp.remove_person_1
          ,con2.name                    remove_person_1_descr
          
          ,sp.fixing_person_2
          ,us1.full_name                fixing_person_2_descr
          ,sp.remove_person_2
          ,us2.full_name                remove_person_2_descr
          ,sp.control_person_1
          ,us3.full_name                control_person_1_descr
          ,sp.control_person_2
          ,us4.full_name                control_person_2_descr
      from xx_etw.xx_disl_storage_place     sp
          ,xx_etw.xx_disl_storage_place     sp_p
          ,xx_etw.xx_disl_cond_train_dr_v   con1
          ,xx_etw.xx_disl_cond_train_dr_v   con2
          ,xx_etw.xx_disl_users             us1
          ,xx_etw.xx_disl_users             us2
          ,xx_etw.xx_disl_users             us3
          ,xx_etw.xx_disl_users             us4
     where sp.deleted = 'N'
       and sp.place_id = nvl(p_place_id,sp.place_id)
       and sp.parent_id = sp_p.place_id(+)
       and sp.place_id not in (19) -- временно
       and sp.fixing_person_1 = con1.id(+)
       and sp.remove_person_1 = con2.id(+)
       
       and sp.fixing_person_2 = us1.id(+)
       and sp.remove_person_2 = us2.id(+)
       and sp.control_person_1 = us3.id(+)
       and sp.control_person_2 = us4.id(+)
     order by
           place_id;  
    
    cursor cur_railway(p_place_id number) is
    select str.pk_id
          ,str.place_id
          ,str.railway_id
          ,r.railway_number
      from xx_etw.xx_disl_storage_place_rlw     str
          ,xx_etw.xx_disl_railways              r  
     where str.place_id = p_place_id
       and str.railway_id = r.railway_id
       and nvl(str.DELETED,'N') = 'N'
       ;  
       
    cursor cur_device(p_place_id number) is
    select std.pk_id
          ,std.place_id
          ,std.device_id
          ,fdv.instance_number
      from xx_etw.xx_disl_storage_place_dvc     std
          ,xx_etw.xx_disl_fixing_device_v       fdv  
     where std.place_id = p_place_id
       and std.device_id = fdv.instance_id;  
    
    cursor cur_device_str(p_place_id number) is    
    select listagg(seg1||'-'||seg2||'-'||seg3||'-'||seg4||'-'||seg5,', ') within group (order by seg1,seg2,seg3,seg4,seg5) device_str
      from (select seg1
                  ,seg2
                  ,seg3
                  ,seg5
                  ,listagg(seg4,', ') within group (order by seg4) seg4
              from xx_etw.xx_disl_storage_place_dvc     std
                  ,xx_etw.xx_disl_fixing_device_v       fdv  
             where 1=1
               and std.place_id = p_place_id
               and std.device_id = fdv.instance_id
             group by
                   seg1
                  ,seg2
                  ,seg3
                  ,seg5);
    
    cursor cur_con_person_str(p_place_id number) is    
    select listagg(name,',') within group (order by name) con_person_str
      from (select fpr.pk_id
                  ,fpr.place_id
                  ,fpr.person_id
                  ,cond.name
              from xx_etw.xx_disl_storage_place     stp
                  ,xx_etw.xx_disl_storage_place_prc_fc fpr
                  ,xx_etw.xx_disl_cond_train_dr_v   cond
             where stp.place_id = p_place_id
               and stp.place_id = fpr.PLACE_ID
               and nvl(fpr.DELETED,'N') = 'N'
               and fpr.person_id = cond.ID);
    
    cursor cur_rep_person_str(p_place_id number) is    
    select listagg(name,',') within group (order by name) rep_person_str
      from (select fpr.pk_id
                  ,fpr.place_id
                  ,fpr.person_id
                  ,cond.FULL_NAME name
              from xx_etw.xx_disl_storage_place     stp
                  ,xx_etw.xx_disl_storage_place_prr_fc fpr
                  ,xx_etw.xx_disl_users   cond
             where stp.place_id = p_place_id
               and stp.place_id = fpr.PLACE_ID
               and nvl(fpr.DELETED,'N') = 'N'
               and fpr.person_id = cond.ID);
    
    cursor cur_res_person_str(p_place_id number) is    
    select listagg(name,',') within group (order by name) res_person_str
      from (select fpr.pk_id
                  ,fpr.place_id
                  ,fpr.person_id
                  ,cond.FULL_NAME name
              from xx_etw.xx_disl_storage_place     stp
                  ,xx_disl_storage_place_pr_resp fpr
                  ,xx_etw.xx_disl_users   cond
             where stp.place_id = p_place_id
               and stp.place_id = fpr.PLACE_ID
               and nvl(fpr.DELETED,'N') = 'N'
               and fpr.person_id = cond.ID);
               
    cursor cur_con_person(p_place_id number) is
    select fpr.pk_id
          ,fpr.place_id
          ,fpr.person_id
          ,cond.name
      from xx_etw.xx_disl_storage_place     stp
          ,xx_etw.xx_disl_storage_place_pr_resp fpr
          ,xx_etw.xx_disl_cond_train_dr_v   cond
     where stp.place_id = p_place_id
       and stp.place_id = fpr.PLACE_ID
       and nvl(fpr.DELETED,'N') = 'N'
       and fpr.person_id = cond.ID; 
                            
begin
    l_json := xx_wms.json(p_params);

    l_place_id := to_number(l_json.get_string('place_id'));

    for l_part in cur_place(l_place_id)
    loop
        l_row := null;
        
        l_row.place_id := l_part.place_id;
        l_row.place_name := l_part.place_name;
        l_row.control_count := l_part.control_count;
        l_row.top_level := l_part.top_level;
        l_row.parent_id := l_part.parent_id;
        l_row.parent_name := l_part.parent_name;
        
        l_row.fixing_person_1 := l_part.fixing_person_1;
        l_row.fixing_person_1_descr := l_part.fixing_person_1_descr;
        l_row.fixing_person_2 := l_part.fixing_person_2;
        l_row.fixing_person_2_descr := l_part.fixing_person_2_descr;
        l_row.remove_person_1 := l_part.remove_person_1;
        l_row.remove_person_1_descr := l_part.remove_person_1_descr;
        l_row.remove_person_2 := l_part.remove_person_2;
        l_row.remove_person_2_descr := l_part.remove_person_2_descr;
        l_row.control_person_1 := l_part.control_person_1;
        l_row.control_person_1_descr := l_part.control_person_1_descr;
        l_row.control_person_2 := l_part.control_person_2;
        l_row.control_person_2_descr := l_part.control_person_2_descr;
        
        l_row.descr := l_part.descr;
        l_row.last_update_date := to_char(l_part.last_update_date,'dd.mm.yyyy hh24:mi:ss');
        
        open cur_device_str(l_row.place_id);
        fetch cur_device_str into l_row.device_str;
        close cur_device_str;
        
        l_exists_railway := false;
        l_json_list := json_list(); 
        
        for l_rwl in cur_railway(l_row.place_id)
        loop
            l_exists_railway := true;
            
            l_json_tmp := json();
            l_json_tmp.put('pk_id',l_rwl.pk_id);
            l_json_tmp.put('place_id',l_rwl.place_id);
            l_json_tmp.put('railway_id',l_rwl.railway_id);
            l_json_tmp.put('railway_number',l_rwl.railway_number);   
            
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        
        if (l_exists_railway = false) then
            l_json_tmp := json();
            l_json_tmp.put('pk_id','');
            l_json_tmp.put('place_id','');
            l_json_tmp.put('railway_id','');
            l_json_tmp.put('railway_number','');   
            
            l_json_list.append(l_json_tmp.to_json_value);
        end if;
        
        l_row.railway_mas := l_json_list.to_char(false);
        
        l_json_list := json_list(); 
        for l_dvc in cur_device(l_row.place_id)
        loop
            l_json_tmp := json();
            l_json_tmp.put('pk_id',l_dvc.pk_id);
            l_json_tmp.put('place_id',l_dvc.place_id);
            l_json_tmp.put('device_id',l_dvc.device_id);
            --l_json_tmp.put('instance_number',l_dvc.instance_number); -- пока закоментировал, т.к валится с ошибкой из-за превышения буфера, если нужно будет, прописать в РНР функцию по возврату instance_number
            
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        l_row.device_mas := l_json_list.to_char(false);
        
        open cur_con_person_str(l_row.place_id);
        fetch cur_con_person_str into l_row.con_person_str;
        close cur_con_person_str;
        
        open cur_rep_person_str(l_row.place_id);
        fetch cur_rep_person_str into l_row.rep_person_str;
        close cur_rep_person_str;
        
        open cur_res_person_str(l_row.place_id);
        fetch cur_res_person_str into l_row.res_person_str;
        close cur_res_person_str;
        
        l_json_list := json_list(); 
        for l_fpr in cur_con_person(l_row.place_id)
        loop
            l_json_tmp := json();
            l_json_tmp.put('pk_id',l_fpr.pk_id);
            l_json_tmp.put('place_id',l_fpr.place_id);
            l_json_tmp.put('person_id',l_fpr.person_id);
            l_json_tmp.put('name',l_fpr.name);
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        l_row.con_person_mas := l_json_list.to_char(false); -- Кто проводит снятие/закрепление
        
        l_row.res_person_mas := l_json_list.to_char(false); 
        l_row.rep_person_mas := l_json_list.to_char(false); 
        pipe row(l_row); 
    end loop;
end;


function get_all_fix_dev
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row; 
begin
    for l_cars in (
        select distinct instance_id,instance_number
          from xx_etw.xx_disl_fixing_device_v fdv
         where 1=1
         order by
               instance_id
    ) loop
        l_row.id := l_cars.instance_id;
        l_row.name := l_cars.instance_number;
        pipe row (l_row);   
    end loop; 
end;

function get_cond_train_dr
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for tmp in (select id
                      ,name
                  from xx_disl_cond_train_dr_v 
                 order by
                       name)
    loop
        l_row.id := tmp.id;   
        l_row.name := tmp.name;
        
        pipe row (l_row);
    end loop;
end;

function save_storage_place(
    p_user_id           number,
    p_add_data          varchar2    
) return varchar2 
as
    l_error         exception;
    l_row           xx_etw.xx_disl_storage_place%rowtype;   
    l_row_rlw       xx_etw.xx_disl_storage_place_rlw%rowtype; 
    l_row_dvc       xx_etw.xx_disl_storage_place_dvc%rowtype;
    l_row_fpr       xx_etw.xx_disl_storage_place_prc_fc%rowtype;  -- Кто проводит 
    l_row_prr       xx_etw.xx_disl_storage_place_prr_fc%rowtype;  -- Кому докладывают
    l_row_res       xx_etw.xx_disl_storage_place_pr_resp%rowtype; -- Ответственный за прием/сдачу смены
    
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_place_id   number;
    
    l_result        varchar2(4000);
begin   
    l_json_par := xx_wms.json(p_add_data);
    
    l_place_id := l_json_par.get_string('place_id');

    if (l_place_id is null) then   
        l_row.place_id := xx_etw.xx_disl_storage_places_seq.nextval();
        l_row.place_name := l_json_par.get_string('place_name');
        l_row.control_count := l_json_par.get_string('control_count');
        l_row.top_level := l_json_par.get_string('top_level');
        if (l_row.top_level = 'N') then
            l_row.parent_id := l_json_par.get_string('parent_id');
        end if;
        
        l_row.fixing_person_1 := l_json_par.get_string('fixing_person_1');
        l_row.fixing_person_2 := l_json_par.get_string('fixing_person_2');
        l_row.remove_person_1 := l_json_par.get_string('remove_person_1');
        l_row.remove_person_2 := l_json_par.get_string('remove_person_2');
        l_row.control_person_1 := l_json_par.get_string('control_person_1');
        l_row.control_person_2 := l_json_par.get_string('control_person_2');
        
        l_row.created_by := p_user_id;
        l_row.creation_date := sysdate;
        l_row.last_updated_by := p_user_id;
        l_row.last_update_date := sysdate;
        l_row.deleted := 'N';
        l_row.descr := null;
        
        insert into xx_etw.xx_disl_storage_place  
        values l_row; 
        /*Массив путей*/
        l_json_value := l_json_par.get('railway_mas');
        l_json_list := json_list(l_json_value);  
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            if (l_json.exist('station_id')) then
                l_row_rlw.station_id := l_json.get_string('station_id');
            end if;
            l_row_rlw.pk_id := xx_etw.xx_disl_storage_place_rlw_seq.nextval();
            l_row_rlw.place_id := l_row.place_id;
            l_row_rlw.railway_id := l_json.get_string('railway_id');
            
            l_row_rlw.created_by := p_user_id;
            l_row_rlw.creation_date := sysdate;
            l_row_rlw.deleted := 'N';

            insert into xx_etw.xx_disl_storage_place_rlw  
            values l_row_rlw;   
        end loop;
        /*Массив башмаков*/
        l_json_value := l_json_par.get('device_mas');
        l_json_list := json_list(l_json_value);  
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            
            l_row_dvc.pk_id := xx_etw.xx_disl_storage_place_dvc_seq.nextval();
            l_row_dvc.place_id := l_row.place_id;
            l_row_dvc.device_id := l_json.get_string('device_id');
            
            l_row_dvc.created_by := p_user_id;
            l_row_dvc.creation_date := sysdate;
            l_row_dvc.deleted := 'N';

            insert into xx_etw.xx_disl_storage_place_dvc  
            values l_row_dvc;   
        end loop;
         /*Массив кто проводит(закрепление/снятие)*/
        l_json_value := l_json_par.get('fix_person_mas');
        l_json_list := json_list(l_json_value);  
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            
            l_row_fpr.pk_id := xx_etw.xx_disl_storage_place_prc_seq.nextval();
            l_row_fpr.place_id := l_row.place_id;
            l_row_fpr.person_id := l_json.get_string('person_id');
            
            l_row_fpr.created_by := p_user_id;
            l_row_fpr.creation_date := sysdate;
            l_row_fpr.deleted := 'N';

            insert into xx_etw.xx_disl_storage_place_prc_fc  
            values l_row_fpr;
        end loop;
         /*Массив кому докладывают(закрепление/снятие)*/
        l_json_value := l_json_par.get('control_person_mas');
        l_json_list := json_list(l_json_value);  
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            
            l_row_prr.pk_id := xx_etw.xx_disl_storage_place_prc_seq.nextval();
            l_row_prr.place_id := l_row.place_id;
            l_row_prr.person_id := l_json.get_string('person_id');
            
            l_row_prr.created_by := p_user_id;
            l_row_prr.creation_date := sysdate;
            l_row_prr.deleted := 'N';

            insert into xx_etw.xx_disl_storage_place_prr_fc  
            values l_row_prr;
        end loop;
         /*Массив ответсвенный за прием/сдачу смены*/
        l_json_value := l_json_par.get('respon_person_mas');
        l_json_list := json_list(l_json_value);  
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            
            l_row_res.pk_id := xx_etw.xx_disl_storage_place_prrp_seq.nextval();
            l_row_res.place_id := l_row.place_id;
            l_row_res.person_id := l_json.get_string('person_id');
            
            l_row_res.created_by := p_user_id;
            l_row_res.creation_date := sysdate;
            l_row_res.deleted := 'N';

            insert into xx_etw.xx_disl_storage_place_pr_resp  
            values l_row_res;
        end loop;
    end if;
          
    commit;
    l_result := 'done'||'$'||l_row.place_id;   

    return l_result;
exception
    when others then rollback; return 'fail';
end;
-- Возвращем часть пути
function get_railway_parts(
    p_user_id       number,
    p_params        varchar2)
return t_xx_id_name_table pipelined
as
    l_row           t_xx_id_name_row;
    l_json          json;
    l_railway_id    number;
    l_part_id       number;
begin
    l_json := xx_wms.json(p_params);

    l_railway_id := to_number(l_json.get_string('railway_id'));
    if (l_json.exist('part_id')) then
        l_part_id := to_number(l_json.get_string('part_id'));
    end if;
    
    for tmp in (
        select part_id
              ,descr
          from xx_etw.xx_disl_railway_part 
         where railway_id = l_railway_id
           and part_id = nvl(l_part_id,part_id)
           and deleted = 'N'
         order by
               part_id)
    loop
        l_row.id := tmp.part_id;   
        l_row.name := tmp.descr;
        
        pipe row (l_row);
    end loop;
end;

function get_device_id(
    p_user_id       number,
    p_params        varchar2)
return t_xx_id_name_table pipelined
as
    l_row               t_xx_id_name_row;
    l_json              json;
    l_instance_number   varchar2(50);
begin
    l_json := xx_wms.json(p_params);

    if (l_json.exist('device_name')) then
        l_instance_number := (l_json.get_string('device_name'));
    end if;
    
    for l_cars in (
        select distinct instance_id,instance_number
          from xx_etw.xx_disl_fixing_device_v fdv
         where instance_number = l_instance_number
         order by
               instance_id
    ) loop
        l_row.id := l_cars.instance_id;
        l_row.name := l_cars.instance_number;
        pipe row (l_row);   
    end loop; 
end;

function get_railway_cars(
    p_user_id       number,
    p_params        varchar2)
return t_xx_car_info_fd_table pipelined
as
    l_json          json;
    l_railway_id    number;
    l_railcar_id    number;
    l_function      varchar2(100) := 'get_railway_cars';
    l_log_id        number:= xx_etw.xx_disl_log_seq.nextval();
    l_tbl           t_xx_car_info_fd_table;
    
    cursor l_cursor(p_railway_id number,p_railcar_id number) is
    select r.railcar_id                 railcar_id
          ,r.round_id                   round_id
          ,rai.add_info_id              add_info_id
          ,rai.weight_net               weight_net
          ,nvl(ecn.car_axles,4)         car_axles
      from xx_etw.xx_disl_relations         rel
          ,xx_etw.xx_disl_round             r
          ,xx_etw.xx_disl_railcar_add_info  rai
          ,xx_etw.etw_car_nsi               ecn 
     where rel.parent_id = nvl(p_railway_id,rel.parent_id)
       and rel.parent_type = 'railway'
       and rel.type = 'railcar'
       and rel.flag_come = 'Y'
       
       and rel.id = r.railcar_id
       and r.station_hist_id_out is null
       
       and r.round_id = rai.round_id
       and rai.date_end is null  
       and r.railcar_id = nvl(p_railcar_id,r.railcar_id)
       and r.railcar_id = ecn.car_number(+) 
     order by
           r_order;
begin
    l_json := xx_wms.json(p_params);
    if (l_json.exist('railway_id')) then
        l_railway_id := to_number(l_json.get_string('railway_id'));
    end if;
    
    if (l_json.exist('car_number')) then
        l_railcar_id := to_number(l_json.get_string('car_number'));
    end if;
    
    log_new(l_log_id,l_function,'l_railcar_id = '||l_railcar_id
                             ||' l_railway_id = '||l_railway_id);   
    
    open l_cursor(l_railway_id,l_railcar_id);
    fetch l_cursor bulk collect into l_tbl;
    close l_cursor;
        
    for i in 1 .. l_tbl.count 
    loop
        pipe row (l_tbl(i));
    end loop;
end;

function get_railway_cars_for_upd(
    p_user_id       number,
    p_params        varchar2)
return t_xx_car_info_fd_upd_table pipelined
as
    l_json          json;
    l_railway_id    number;
    l_railcar_id    number;
    l_part_id       number;
    l_function      varchar2(100) := 'get_railway_cars';
    l_log_id        number:= xx_etw.xx_disl_log_seq.nextval();
    l_tbl           t_xx_car_info_fd_upd_table;
    
    cursor l_cursor(p_railway_id number,p_railcar_id number,p_part_id number) is
    select r.railcar_id                 railcar_id
          ,r.round_id                   round_id
          ,rai.add_info_id              add_info_id
          ,rai.weight_net               weight_net
          ,nvl(ecn.car_axles,4)         car_axles
          ,nvl(dtc.transactions_cars_id,0) transactions_cars_id
      from xx_etw.xx_disl_relations         rel
          ,xx_etw.xx_disl_round             r
          ,xx_etw.xx_disl_railcar_add_info  rai
          ,xx_etw.etw_car_nsi               ecn
          ,(select dtc.*
           from  xx_etw.xx_disl_transactions_header dth,
                 xx_etw.xx_disl_transactions_cars dtc
        where  1 = 1
               and dtc.transactions_header_id = dth.transactions_header_id
               and dth.railway_id = p_railway_id
               and dth.part_id = p_part_id
               and nvl(dth.status,'OPEN') = 'OPEN'
               and nvl(dth.deleted,'N') = 'N'
               and nvl(dtc.deleted,'N') = 'N') dtc
     where rel.parent_id = nvl(p_railway_id,rel.parent_id)
       and rel.parent_type = 'railway'
       and rel.type = 'railcar'
       and rel.flag_come = 'Y'
       
       and rel.id = r.railcar_id
       and r.station_hist_id_out is null
       
       and r.round_id = rai.round_id
       and rai.date_end is null  
       and r.railcar_id = nvl(p_railcar_id,r.railcar_id)
       and r.railcar_id = ecn.car_number(+) 
       
       and r.railcar_id = dtc.car_number
     order by
           r_order;
     cursor l_cursor_cars(p_railway_id number,p_railcar_id number,p_part_id number) is
    select r.railcar_id                 railcar_id
          ,r.round_id                   round_id
          ,rai.add_info_id              add_info_id
          ,rai.weight_net               weight_net
          ,nvl(ecn.car_axles,4)         car_axles
          ,0 transactions_cars_id
      from xx_etw.xx_disl_relations         rel
          ,xx_etw.xx_disl_round             r
          ,xx_etw.xx_disl_railcar_add_info  rai
          ,xx_etw.etw_car_nsi               ecn
     where rel.parent_id = nvl(p_railway_id,rel.parent_id)
       and rel.parent_type = 'railway'
       and rel.type = 'railcar'
       and rel.flag_come = 'Y'
       
       and rel.id = r.railcar_id
       and r.station_hist_id_out is null
       
       and r.round_id = rai.round_id
       and rai.date_end is null  
       and r.railcar_id = nvl(p_railcar_id,r.railcar_id) 
       
        and r.railcar_id = ecn.car_number(+) 
     order by
           r_order;
begin
    l_json := xx_wms.json(p_params);
    if (l_json.exist('railway_id')) then
        l_railway_id := to_number(l_json.get_string('railway_id'));
    end if;
    
    if (l_json.exist('car_number')) then
        l_railcar_id := to_number(l_json.get_string('car_number'));
    end if;
    if (l_json.exist('part_id')) then
        l_part_id := to_number(l_json.get_string('part_id'));
    end if;
 
    if length(l_railcar_id) > 1 then 
        open l_cursor_cars(l_railway_id,l_railcar_id,l_part_id);
        fetch l_cursor_cars bulk collect into l_tbl;
        close l_cursor_cars;
        for i in 1 .. l_tbl.count 
        loop
            pipe row (l_tbl(i));
        end loop;
    else 
        open l_cursor(l_railway_id,l_railcar_id,l_part_id);
        fetch l_cursor bulk collect into l_tbl;
        close l_cursor;
        for i in 1 .. l_tbl.count 
        loop
            pipe row (l_tbl(i));
        end loop;
    end if;
        
    
end;

function get_suitable_device_rules(
    p_user_id       number,
    p_params        varchar2)
return varchar2
is
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_railway_id    number;
    l_part_id       number;
    l_prev_weight   number;
    l_count_axles   number := 0;
    l_same_weight   boolean;
    l_norm          number;
    l_wag_loaded    number:=0;
    l_empty_loaded  number:=0;
    l_selected      varchar2(10):='*';
    
    obj             json;
    obj_side_list   json_list;
    obj_side        json;
    obj_skid_list   json_list;
    obj_skid        json;
begin
    l_json_par := xx_wms.json(p_params);
    l_railway_id := to_number(l_json_par.get_string('railway_id'));
    l_part_id := to_number(l_json_par.get_string('part_id'));
    
    l_json_value := l_json_par.get('cars');
    l_json_list := json_list(l_json_value);  
    for i in 1..l_json_list.count loop
        l_json_value := l_json_list.get(i);
        l_json := json(l_json_value); 
            
        l_count_axles := l_count_axles + to_number(l_json.get_string('count_of_axles'));
        --DBMS_OUTPUT.put_line('l_count_axles('||i||') = '||l_count_axles);
        
        if (to_number(l_json.get_string('weight_net')) > 0) then
            l_wag_loaded := l_wag_loaded+1;
        else
            l_empty_loaded := l_empty_loaded+1;            
        end if;
       -- DBMS_OUTPUT.put_line('     l_wag_loaded('||i||') = '||l_wag_loaded);
      --  DBMS_OUTPUT.put_line('     l_empty_loaded('||i||') = '||l_empty_loaded);
    end loop;
    --DBMS_OUTPUT.put_line('l_wag_loaded = '||l_wag_loaded);
    --DBMS_OUTPUT.put_line('l_empty_loaded = '||l_empty_loaded);
    if (l_wag_loaded > 0 and l_empty_loaded > 0) then -- Если есть груженные и порожние вагоны
        l_norm := 2; -- Смешанный
    else
        l_norm := 1; -- Однородный
    end if;
    --DBMS_OUTPUT.put_line('     l_norm = '||l_norm);
    obj_side_list := json_list(); 
    for l_side in (
        select fdr.side                                 side_id
              ,fs.descr                                 side_descr
          from xx_etw.xx_disl_fixing_device_rule    fdr
              ,xx_etw.xx_disl_fixing_side           fs 
         where 1=1
           and fdr.railway_id = l_railway_id
           and fdr.part_id = l_part_id
           
           and fdr.side = fs.side_id
         group by
               fdr.side                                 
              ,fs.descr
          order by fdr.side)
    loop
        obj_side := json();
        obj_side.put('side_id',l_side.side_id);
        obj_side.put('side_descr',l_side.side_descr);
        l_selected:= '*';
        obj_skid_list := json_list();
        for l_skid in (
            select decode(l_norm,1,cnt_axis_1,cnt_axis_2)   cnt_axis
                  ,cnt_skid
                  ,fdr.rule_id
                  ,case
                     when --l_count_axles between lag(decode(l_norm,1,cnt_axis_1,cnt_axis_2),1,1) over (order by decode(l_norm,1,cnt_axis_1,cnt_axis_2) nulls last) and decode(l_norm,1,cnt_axis_1,cnt_axis_2)
                          (l_count_axles 
                                between lag(decode(l_norm,1,cnt_axis_1,cnt_axis_2),1,1) over (order by decode(l_norm,1,cnt_axis_1,cnt_axis_2) nulls last) and decode(l_norm,1,cnt_axis_1,cnt_axis_2))
                          or (fdr_max.cnt_axis_max = decode(l_norm,1,cnt_axis_1,cnt_axis_2) and l_count_axles> decode(l_norm,1,cnt_axis_1,cnt_axis_2))
                          -- если кол-во осей не попадает ни в один диапазон, то берем последний 
                     then 'Y'
                     else 'N'
                   end selected
              from xx_etw.xx_disl_fixing_device_rule    fdr
                  ,(select max(decode(l_norm,1,cnt_axis_1,cnt_axis_2)) cnt_axis_max  
                         from xx_etw.xx_disl_fixing_device_rule fdr
                        where 1=1                
                              and railway_id = l_railway_id
                              and part_id = l_part_id
                              and side = l_side.side_id) fdr_max        
             where 1=1
               and railway_id = l_railway_id
               and part_id = l_part_id
               and side = l_side.side_id
             order by
                   decode(l_norm,1,cnt_axis_1,cnt_axis_2))
        loop
            obj_skid := json();
            
            obj_skid.put('cnt_axis',l_skid.cnt_axis);
            obj_skid.put('rule_id',l_skid.rule_id);
            obj_skid.put('cnt_skid',l_skid.cnt_skid);
            --obj_skid.put('selected',l_skid.selected); 
            if (l_selected = '*' and l_skid.selected = 'Y') then -- Пока временно, если кол-во осей попадают в два диап-на, то выбираем самый первый 
                    obj_skid.put('selected',l_skid.selected);
                    l_selected := 'Y';
                else obj_skid.put('selected','N');
            end if;
            
            obj_skid_list.append(obj_skid.to_json_value);   
        end loop;
        
        obj_side.put('skid_mas',obj_skid_list);
        
        obj_side_list.append(obj_side.to_json_value);    
    end loop; 
    
    obj := json();
    obj.put('side_mas',obj_side_list);  
    
    return obj.to_char(false);                   
end;

/*Кто проводит (select)*/
function get_users_for_cond_train(
    p_user_id       number,
    p_params        varchar2)
return t_xx_id_name_table pipelined as
    l_row           t_xx_id_name_row;
    l_json          json;
    l_railway_id    number;
    l_type    varchar2(250);
begin
    l_json := xx_wms.json(p_params);
    if (l_json.exist('railway_id')) then
        l_railway_id := to_number(l_json.get_string('railway_id'));
    end if;
    l_type := l_json.get_string('type');
    for tmp in (select ID      id
                      ,NAME    name
               from xx_etw.xx_disl_cond_train_dr_v   cond
               where 1=1 
                     and l_type = 'prc_fc'
                     and exists (
                   select *
                     from xx_etw.xx_disl_storage_place_rlw    xdspr
                         ,xx_etw.xx_disl_storage_place        stp
                         ,xx_etw.xx_disl_storage_place_prc_fc fpr
                    where xdspr.railway_id = l_railway_id
                          and nvl(xdspr.deleted,'N') = 'N'
                          and nvl(fpr.DELETED,'N') = 'N'
                          and stp.place_id = xdspr.place_id
                          and stp.place_id = fpr.place_id
                          and nvl(stp.deleted,'N') = 'N'
                          
                          )
               union all
               select ID           id
                     ,FULL_NAME    name
               from xx_etw.xx_disl_users cond
               where 1=1 
                     and l_type = 'prr_fc'
                     and cond.OPEN = 'Y'
                     and exists (
                           select *
                              from xx_etw.xx_disl_storage_place     stp
                                  ,xx_etw.xx_disl_storage_place_prr_fc fpr
                                  ,xx_etw.xx_disl_storage_place_rlw    xdspr
                             where xdspr.railway_id = l_railway_id
                               and stp.place_id = fpr.PLACE_ID
                               and stp.place_id = xdspr.place_id
                               and fpr.person_id = cond.ID
                               and nvl(fpr.DELETED,'N') = 'N'
                               and nvl(stp.deleted,'N') = 'N'
                               and nvl(xdspr.deleted,'N') = 'N'                          
                     )
                order by 2    
               )
        
    loop
        l_row.id := tmp.id;
        l_row.name := tmp.name;
        
        pipe row (l_row);
    end loop;

end;



/*Кто проводит (select)*/
function set_users_for_cond_train(
    p_user_id       number,
    p_params        varchar2)
return t_xx_users_for_cond_table pipelined as
    l_row           t_xx_users_for_cond_row;
    l_json          json;
    l_railway_id    number;
    l_part_id       number;
    l_type          varchar2(250);
    l_user_id       number;
    l_user_type     varchar2(250);
begin
    l_json := xx_wms.json(p_params);
    if (l_json.exist('railway_id')) then
        l_railway_id := to_number(l_json.get_string('railway_id'));
    end if;
    if (l_json.exist('user_type')) then
        l_user_type := (l_json.get_string('user_type'));
    end if;
    if (l_json.exist('part_id')) then
        l_part_id := to_number(l_json.get_string('part_id'));
    end if;
    begin
        select case when l_user_type='USER_FIX_EVEN' then dth.USER_FIX_EVEN
                    when l_user_type='USER_FIX_REP_EVEN' then dth.USER_FIX_REP_EVEN 
                    when l_user_type='USER_FIX_ODD' then dth.USER_FIX_ODD 
                    when l_user_type='USER_FIX_REP_ODD' then dth.USER_FIX_REP_ODD 
               end into l_user_id
          from xx_etw.xx_disl_transactions_header dth
        where  1 = 1
               and dth.railway_id = l_railway_id
               and dth.part_id = l_part_id
               and nvl(dth.status,'OPEN') = 'OPEN'
               and nvl(dth.deleted,'N') = 'N';   
    exception when others then l_user_id:=0;
    end;
    l_type := l_json.get_string('type');
    for tmp in (select ID      id
                      ,NAME    name
                      ,case when id = l_user_id then 'true' else '' end selected
               from xx_etw.xx_disl_cond_train_dr_v   cond
               where 1=1 
                     and l_type = 'prc_fc'
                     and exists (
                   select *
                     from xx_etw.xx_disl_storage_place_rlw    xdspr
                         ,xx_etw.xx_disl_storage_place        stp
                         ,xx_etw.xx_disl_storage_place_prc_fc fpr
                    where xdspr.railway_id = l_railway_id
                          and nvl(xdspr.deleted,'N') = 'N'
                          and nvl(fpr.DELETED,'N') = 'N'
                          and stp.place_id = xdspr.place_id
                          and stp.place_id = fpr.place_id
                          and nvl(stp.deleted,'N') = 'N'
                          
                          )
               union all
               select ID           id
                     ,FULL_NAME    name
                     ,case when id = l_user_id then 'true' else '' end selected
               from xx_etw.xx_disl_users cond
               where 1=1 
                     and l_type = 'prr_fc'
                     and cond.OPEN = 'Y'
                     and exists (
                           select *
                              from xx_etw.xx_disl_storage_place     stp
                                  ,xx_etw.xx_disl_storage_place_prr_fc fpr
                                  ,xx_etw.xx_disl_storage_place_rlw    xdspr
                             where xdspr.railway_id = l_railway_id
                               and stp.place_id = fpr.PLACE_ID
                               and stp.place_id = xdspr.place_id
                               and fpr.person_id = cond.ID
                               and nvl(fpr.deleted,'N') = 'N'
                               and nvl(stp.deleted,'N') = 'N'
                               and nvl(xdspr.deleted,'N') = 'N'                          
                     )
                order by 2
               )
    loop
        l_row.id := tmp.id;
        l_row.name := tmp.name;
        l_row.selected := tmp.selected;
        
        pipe row (l_row);
    end loop;

end;

function get_side_for_device(
    p_user_id       number,
    p_params        varchar2)
return t_xx_side_table pipelined
as
    l_row           t_xx_side_row;
    l_json          json;
    l_railway_id    number;
    l_part_id       number;
    l_num           number;
    l_side          varchar2(10);
begin
    l_json := xx_wms.json(p_params);
    if (l_json.exist('railway_id')) then
        l_railway_id := to_number(l_json.get_string('railway_id'));
    end if;
    if (l_json.exist('part_id')) then
        l_part_id := to_number(l_json.get_string('part_id'));
    end if;
    if (l_json.exist('side')) then
        l_side := to_number(l_json.get_string('side'));
    end if;
    for tmp in (
                select   side_id id, side_descr name, rwn
                  from   (select   rownum rwn, x.*
                            from   (  select   fdr.side side_id, fs.descr side_descr
                                        from   xx_etw.xx_disl_fixing_device_rule fdr,
                                               xx_etw.xx_disl_fixing_side fs
                                       where       1 = 1
                                               and fdr.railway_id = l_railway_id
                                               and fdr.part_id = l_part_id
                                               and fdr.side = fs.side_id
                                    group by   fdr.side,
                                               fs.descr,
                                               fdr.railway_id,
                                               part_id) x)
                 where   1=1
                         --and decode(rwn,1,'even',2,'odd') = l_side
                         order by side_id
               )
    loop
        l_row.rwn := tmp.rwn;
        l_row.side_id := tmp.id;
        l_row.name := tmp.name;
        pipe row (l_row);
    end loop;
end;

/*Транзакции закрепления ЗУ*/
function save_transaction_fix_device(
    p_user_id           number,
    p_add_data          varchar2    
) return varchar2
as
    l_function      varchar2(100):='save_transaction_fix_device';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    err_msg         varchar2(4000);
    l_error         exception;
    
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_row           xx_etw.xx_disl_transactions_header%rowtype;
    l_row_l         xx_etw.xx_disl_transactions_lines%rowtype;
    l_row_c         xx_etw.xx_disl_transactions_cars%rowtype;
    
    l_station_id            number;
    l_place_id              number;
    l_tr_header_id          number;
    l_railway_id            number;
    l_part_id               number;
    l_date_fix_even         date;
    l_user_fix_even         number;
    l_user_report_even      number;
    
    l_date_fix_odd          date;
    l_user_fix_odd          number;
    l_user_report_odd       number;
    
    l_calculation_type      varchar2(50);
    l_norma_even            number;
    l_norma_odd             number;
    l_even_side_id          number;
    l_odd_side_id           number;
    l_note                  varchar2(250);
    l_transaction_type      varchar2(50);
    l_result                varchar2(4000);
begin   
    l_json_par := xx_wms.json(p_add_data);
    
    l_railway_id := l_json_par.get_string('railway_id'); -- Путь
    if (l_json_par.exist('station_id')) then
        l_station_id := l_json_par.get_string('station_id'); -- Станция
    end if;
    l_part_id := l_json_par.get_string('part_id'); -- Часть пути
    l_date_fix_even:=to_date(l_json_par.get_string('time_fixing_even'),'DD.MM.YYYY HH24:MI'); -- ЧетнаяСторона.Дата и время закрепления(Мск) 
    l_user_fix_even:=l_json_par.get_string('who_fixing_even'); -- ЧетнаяСторона.Кто проводит
    l_user_report_even:=l_json_par.get_string('who_fixing_report_even'); -- ЧетнаяСторона.Кому докладвает 
    l_date_fix_odd:=to_date(l_json_par.get_string('time_fixing_odd'),'DD.MM.YYYY HH24:MI'); -- НеЧетнаяСторона.Дата и время закрепления(Мск)
    l_user_fix_odd:=l_json_par.get_string('who_fixing_odd'); -- НеЧетнаяСторона.Кто проводит;
    l_user_report_odd:=l_json_par.get_string('who_fixing_report_odd'); -- НеЧетнаяСторона.Кому докладвает 
    l_note:=l_json_par.get_string('note'); -- ЧетнаяСторона.Кто проводит;
    l_transaction_type:=l_json_par.get_string('transaction_type');
    l_calculation_type:=l_json_par.get_string('calculation_type');
    l_norma_even:=l_json_par.get_string('norma_even');
    l_norma_odd:=l_json_par.get_string('norma_odd');
    if (l_json_par.exist('even_side_id')) then
        l_even_side_id := to_number(l_json_par.get_string('even_side_id')); -- ID Закрепления 
    end if;
    if (l_json_par.exist('odd_side_id')) then
        l_odd_side_id := to_number(l_json_par.get_string('odd_side_id'));   -- ID Закрепления 
    end if;        
    if (l_railway_id is not null and l_part_id is not null) then
        l_tr_header_id:=xx_etw.xx_disl_transactions_h_seq.nextval();
        l_row.transactions_header_id:=l_tr_header_id;
        l_row.created_by:=p_user_id;
        l_row.created_date:=sysdate;
        l_row.last_update_by:=p_user_id;
        l_row.last_update_date:=sysdate; 
        l_row.railway_id:=l_railway_id; 
        l_row.part_id:=l_part_id;
        l_row.calculation_type:=l_calculation_type; 
        l_row.norma_even:=l_norma_even;
        l_row.norma_odd:=l_norma_odd;
        l_row.status:=null;
        l_row.date_fix_even:=l_date_fix_even;
        l_row.user_fix_even:=l_user_fix_even;
        l_row.user_fix_rep_even:=l_user_report_even;
        l_row.date_fix_odd:=l_date_fix_odd;
        l_row.user_fix_odd:=l_user_fix_odd; 
        l_row.user_fix_rep_odd:=l_user_report_odd;
        l_row.note_fix:=l_note;
        l_row.even_side_id:=l_even_side_id;
        l_row.odd_side_id:=l_odd_side_id;
        l_row.station_id:=l_station_id;
        
        insert into xx_etw.xx_disl_transactions_header
            values l_row;
        
        /*Массив башмаков с четной стороны*/
        l_json_value := l_json_par.get('device_mas_even');
        l_json_list := json_list(l_json_value); 
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            
            l_row_l.transactions_header_id:=l_tr_header_id;
            l_row_l.transactions_lines_id:=xx_etw.xx_disl_transactions_l_seq.nextval();
            l_row_l.transaction_type:=l_transaction_type;
            
            l_row_l.instance_id:=l_json.get_string('device_id');
            l_row_l.side_type:=l_json.get_string('side_type');
            l_row_l.side_id:=l_json.get_string('side_id');
            l_row_l.transactions_out_id:=null;
            l_row_l.deleted:='N';
            l_row_l.deleted_by:=null; 
            l_row_l.deleted_date:=null;
            l_row_l.created_by:=p_user_id;
            l_row_l.created_date:=sysdate;
            l_row_l.last_update_by:=p_user_id;
            l_row_l.last_update_date:=sysdate; 
            insert into xx_etw.xx_disl_transactions_lines  
            values l_row_l;
        end loop; 
        
        /*Массив башмаков с нечетной стороны*/
        l_json_value := l_json_par.get('device_mas_odd');
        l_json_list := json_list(l_json_value); 
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            
            l_row_l.transactions_header_id:=l_tr_header_id;
            l_row_l.transactions_lines_id:=xx_etw.xx_disl_transactions_l_seq.nextval();
            l_row_l.transaction_type:=l_transaction_type;
            l_row_l.instance_id:=l_json.get_string('device_id');
            l_row_l.side_type:=l_json.get_string('side_type');
            l_row_l.side_id:=l_json.get_string('side_id');
            l_row_l.transactions_out_id:=null;
            l_row_l.deleted:='N';
            l_row_l.deleted_by:=null; 
            l_row_l.deleted_date:=null;
            l_row_l.created_by:=p_user_id;
            l_row_l.created_date:=sysdate;
            l_row_l.last_update_by:=p_user_id;
            l_row_l.last_update_date:=sysdate; 
            
            insert into xx_etw.xx_disl_transactions_lines  
            values l_row_l;
        end loop; 
        
        /*Массив вагонов*/
        l_json_value := l_json_par.get('cars');
        l_json_list := json_list(l_json_value); 
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            
            l_row_c.transactions_header_id:=l_tr_header_id;
            l_row_c.transactions_cars_id:=xx_etw.xx_disl_transactions_cars_seq.nextval();
            l_row_c.car_number:=l_json.get_string('car_number');
            l_row_c.round_id:=l_json.get_string('round_id');
            l_row_c.weight_net:=l_json.get_string('weight_net');
            l_row_c.count_of_axles:=l_json.get_string('count_of_axles');
            l_row_c.add_info_id:=l_json.get_string('add_info_id');
            l_row_c.transaction_type:=l_transaction_type;  
            l_row_c.deleted:='N';
            l_row_c.deleted_by:=null; 
            l_row_c.deleted_date:=null;
            l_row_c.created_by:=p_user_id;
            l_row_c.created_date:=sysdate;
            l_row_c.last_update_by:=p_user_id;
            l_row_c.last_update_date:=sysdate; 
            insert into xx_etw.xx_disl_transactions_cars  
            values l_row_c;
        end loop;
    end if;

    commit;
    l_result := 'done'||'$'||to_char(l_tr_header_id);   
    log_new(l_log_id,l_function,' insert into xx_etw.xx_disl_transactions_lines. кол-во='||sql%rowcount);
    return l_result;
exception
    when others then 
        rollback;
        err_msg := SUBSTR(SQLERRM, 1, 400);
        log_new(l_log_id,l_function,'p_user_id='||p_user_id
                                 ||' l_railway_id='||l_railway_id
                                 ||' l_part_id='||l_part_id
                                 ||' err_msg = '||err_msg);
        return 'fail'||'$'||err_msg;
end;

/*UPD Транзакций закрепления ЗУ*/
function update_transaction_fix_device(
    p_user_id           number,
    p_add_data          varchar2    
) return varchar2
as
    l_function      varchar2(100):='update_transaction_fix_device';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    err_msg         varchar2(4000);
    l_error         exception;
    
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_row           xx_etw.xx_disl_transactions_header%rowtype;
    l_row_l         xx_etw.xx_disl_transactions_lines%rowtype;
    l_row_c         xx_etw.xx_disl_transactions_cars%rowtype;
    
    l_place_id      number;
    l_tr_header_id  number;
    l_tr_line_id    number;
    l_railway_id    number;
    l_part_id       number;
    l_cars_id       number;
    l_cars_old_id   number;
    l_cars_deleted  varchar2(1);
    l_date_fix_even date;
    l_user_fix_even number;
    l_user_report_even number;
    
    l_date_fix_odd  date;
    l_user_fix_odd  number;
    l_user_report_odd number;
    
    l_calculation_type  varchar2(50);
    l_norma_even        number;
    l_norma_odd         number;
    l_note              varchar2(250);
    l_transaction_type  varchar2(50);
    l_result            varchar2(4000);
begin 
    l_json_par := xx_wms.json(p_add_data);
    
    l_railway_id := l_json_par.get_string('railway_id'); -- Путь
    l_part_id := l_json_par.get_string('part_id'); -- Часть пути
    l_date_fix_even:=to_date(l_json_par.get_string('time_fixing_even'),'DD.MM.YYYY HH24:MI'); -- ЧетнаяСторона.Дата и время закрепления(Мск) 
    l_user_fix_even:=l_json_par.get_string('who_fixing_even'); -- ЧетнаяСторона.Кто проводит
    l_user_report_even:=l_json_par.get_string('who_fixing_report_even'); -- ЧетнаяСторона.Кому докладвает 
    l_date_fix_odd:=to_date(l_json_par.get_string('time_fixing_odd'),'DD.MM.YYYY HH24:MI'); -- НеЧетнаяСторона.Дата и время закрепления(Мск)
    l_user_fix_odd:=l_json_par.get_string('who_fixing_odd'); -- НеЧетнаяСторона.Кто проводит;
    l_user_report_odd:=l_json_par.get_string('who_fixing_report_odd'); -- НеЧетнаяСторона.Кому докладвает 
    l_note:=l_json_par.get_string('note'); 
    l_transaction_type:=l_json_par.get_string('transaction_type');
    --l_calculation_type:=l_json_par.get_string('calculation_type');
    l_norma_even:=l_json_par.get_string('norma_even');
    l_norma_odd:=l_json_par.get_string('norma_odd');
    
    begin
        select transactions_header_id into l_tr_header_id
         from  xx_etw.xx_disl_transactions_header dth
        where  1 = 1
               and dth.railway_id = l_railway_id
               and dth.part_id = l_part_id
               and nvl(dth.status,'OPEN') = 'OPEN'
               and nvl(dth.deleted,'N') = 'N';
    exception when others then l_tr_header_id:=0;
        err_msg := SUBSTR(SQLERRM, 1, 400);
        log_new(l_log_id,l_function,'L_TR_HEADER_ID.EXCEPTION'
                                 ||'p_user_id='||p_user_id
                                 ||' l_railway_id='||l_railway_id
                                 ||' l_part_id='||l_part_id
                                 ||' err_msg = '||err_msg);
    end;
    
    if (nvl(l_railway_id,0) <> 0 and nvl(l_part_id,0) <> 0 and nvl(l_tr_header_id,0) <> 0) then

        l_row.date_fix_even:=l_date_fix_even;
        l_row.user_fix_even:=l_user_fix_even;
        l_row.user_fix_rep_even:=l_user_report_even;
        l_row.date_fix_odd:=l_date_fix_odd;
        l_row.user_fix_odd:=l_user_fix_odd; 
        l_row.user_fix_rep_odd:=l_user_report_odd;
        l_row.note_fix:=l_note;
        
        l_row.norma_even:=l_norma_even;
        l_row.norma_odd:=l_norma_odd;
        
        
        update xx_etw.xx_disl_transactions_header
           set last_update_by=p_user_id,
               last_update_date=sysdate,
               date_fix_even=l_row.date_fix_even,
               user_fix_even=l_row.user_fix_even,
               user_fix_rep_even=l_row.user_fix_rep_even,
               
               date_fix_odd=l_row.date_fix_odd,
               user_fix_odd=l_row.user_fix_odd, 
               user_fix_rep_odd=l_row.user_fix_rep_odd,
               note_fix=l_row.note_fix,
               
               norma_even = l_row.norma_even,
               norma_odd = l_row.norma_odd
         where transactions_header_id = l_tr_header_id;
         /*Массив башмаков с четной стороны*/
        l_json_value := l_json_par.get('device_mas_even');
        l_json_list := json_list(l_json_value); 
        
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            l_tr_line_id:=l_json.get_string('transactions_lines_id');
            if nvl(l_tr_line_id,0) = 0 then
                l_tr_line_id:=xx_etw.xx_disl_transactions_l_seq.nextval();            
            end if;
            l_row_l.transactions_header_id:=l_tr_header_id;
            l_row_l.transactions_lines_id:=l_tr_line_id;
            l_row_l.transaction_type:='IN';
            l_row_l.instance_id:=l_json.get_string('device_id');
            l_row_l.side_type:=l_json.get_string('side_type');
            l_row_l.side_id:=l_json.get_string('side_id');
            l_row_l.transactions_out_id:=null;
            l_row_l.deleted:=l_json.get_string('deleted');
            l_row_l.deleted_by:=null; 
            l_row_l.deleted_date:=null;
            l_row_l.created_by:=p_user_id;
            l_row_l.created_date:=sysdate;
            l_row_l.last_update_by:=p_user_id;
            l_row_l.last_update_date:=sysdate;
            merge into xx_etw.xx_disl_transactions_lines dtl
            using dual 
               on (dtl.transactions_lines_id = l_tr_line_id)
             when matched then 
           update set
                    LAST_UPDATE_DATE = l_row_l.last_update_date,
                    LAST_UPDATE_BY = l_row_l.last_update_by,
                    DELETED = case when l_row_l.deleted = 'Y' then 'Y' else 'N' end,
                    DELETED_BY = case when l_row_l.deleted = 'Y' then l_row_l.last_update_by end,
                    DELETED_DATE = case when l_row_l.deleted = 'Y' then sysdate end
           when not matched then 
            insert (TRANSACTIONS_HEADER_ID, 
                    TRANSACTIONS_LINES_ID, 
                    CREATED_DATE, 
                    CREATED_BY, 
                    LAST_UPDATE_DATE, 
                    LAST_UPDATE_BY, 
                    TRANSACTION_TYPE, 
                    INSTANCE_ID, 
                    SIDE_TYPE, 
                    SIDE_ID, 
                    TRANSACTIONS_OUT_ID, 
                    DELETED, 
                    DELETED_BY, 
                    DELETED_DATE)
            values (l_tr_header_id, 
                    l_tr_line_id, 
                    l_row_l.CREATED_DATE, 
                    l_row_l.CREATED_BY, 
                    l_row_l.LAST_UPDATE_DATE, 
                    l_row_l.LAST_UPDATE_BY, 
                    l_row_l.TRANSACTION_TYPE, 
                    l_row_l.INSTANCE_ID, 
                    l_row_l.SIDE_TYPE, 
                    l_row_l.SIDE_ID, 
                    l_row_l.TRANSACTIONS_OUT_ID, 
                    l_row_l.DELETED, 
                    l_row_l.DELETED_BY, 
                    l_row_l.DELETED_DATE)
           ;
            
        end loop;
         /*Массив башмаков с нечетной стороны*/
        l_json_value := l_json_par.get('device_mas_odd');
        l_json_list := json_list(l_json_value); 
        
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            l_tr_line_id:=l_json.get_string('transactions_lines_id');
            if nvl(l_tr_line_id,0) = 0 then
                l_tr_line_id:=xx_etw.xx_disl_transactions_l_seq.nextval();            
            end if;
            l_row_l.transactions_header_id:=l_tr_header_id;
            l_row_l.transactions_lines_id:=l_tr_line_id;
            l_row_l.transaction_type:='IN';
            l_row_l.instance_id:=l_json.get_string('device_id');
            l_row_l.side_type:=l_json.get_string('side_type');
            l_row_l.side_id:=l_json.get_string('side_id');
            l_row_l.transactions_out_id:=null;
            l_row_l.deleted:=l_json.get_string('deleted');
            l_row_l.deleted_by:=null; 
            l_row_l.deleted_date:=null;
            l_row_l.created_by:=p_user_id;
            l_row_l.created_date:=sysdate;
            l_row_l.last_update_by:=p_user_id;
            l_row_l.last_update_date:=sysdate;
            merge into xx_etw.xx_disl_transactions_lines dtl
            using dual 
               on (dtl.transactions_lines_id = l_tr_line_id)
             when matched then 
           update set
                    LAST_UPDATE_DATE = l_row_l.last_update_date,
                    LAST_UPDATE_BY = l_row_l.last_update_by,
                    DELETED = case when l_row_l.deleted = 'Y' then 'Y' else 'N' end,
                    DELETED_BY = case when l_row_l.deleted = 'Y' then l_row_l.last_update_by end,
                    DELETED_DATE = case when l_row_l.deleted = 'Y' then sysdate end
           when not matched then 
            insert (TRANSACTIONS_HEADER_ID, 
                    TRANSACTIONS_LINES_ID, 
                    CREATED_DATE, 
                    CREATED_BY, 
                    LAST_UPDATE_DATE, 
                    LAST_UPDATE_BY, 
                    TRANSACTION_TYPE, 
                    INSTANCE_ID, 
                    SIDE_TYPE, 
                    SIDE_ID, 
                    TRANSACTIONS_OUT_ID, 
                    DELETED, 
                    DELETED_BY, 
                    DELETED_DATE)
            values (l_tr_header_id, 
                    l_tr_line_id, 
                    l_row_l.CREATED_DATE, 
                    l_row_l.CREATED_BY, 
                    l_row_l.LAST_UPDATE_DATE, 
                    l_row_l.LAST_UPDATE_BY, 
                    l_row_l.TRANSACTION_TYPE, 
                    l_row_l.INSTANCE_ID, 
                    l_row_l.SIDE_TYPE, 
                    l_row_l.SIDE_ID, 
                    l_row_l.TRANSACTIONS_OUT_ID, 
                    l_row_l.DELETED, 
                    l_row_l.DELETED_BY, 
                    l_row_l.DELETED_DATE)
           ;
            
        end loop;
        /*Массив вагонов*/
        l_json_value := l_json_par.get('cars');
        l_json_list := json_list(l_json_value); 
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            l_cars_old_id:=l_json.get_string('transactions_cars_id');
            l_cars_id:=l_json.get_string('transactions_cars_id');
            l_cars_deleted:=l_json.get_string('deleted');
            if nvl(l_cars_old_id,0) = 0 then
                l_cars_id:=xx_etw.xx_disl_transactions_cars_seq.nextval();     
            end if;
            l_row_c.transactions_header_id:=l_tr_header_id;
            l_row_c.transactions_cars_id:= l_cars_id;
            l_row_c.car_number:=l_json.get_string('car_number');
            l_row_c.round_id:=l_json.get_string('round_id');
            l_row_c.weight_net:=l_json.get_string('weight_net');
            l_row_c.count_of_axles:=l_json.get_string('count_of_axles');
            l_row_c.add_info_id:=l_json.get_string('add_info_id');
            l_row_c.transaction_type:=l_transaction_type;  
            l_row_c.deleted:='N';
            l_row_c.deleted_by:=null; 
            l_row_c.deleted_date:=null;
            l_row_c.created_by:=p_user_id;
            l_row_c.created_date:=sysdate;
            l_row_c.last_update_by:=p_user_id;
            l_row_c.last_update_date:=sysdate; 
            if (l_cars_deleted = 'Y') then
                update xx_etw.xx_disl_transactions_cars 
                   set deleted = 'Y',
                       deleted_by = l_row_c.deleted_by,
                       deleted_date = sysdate,
                       last_update_by=p_user_id,
                       last_update_date=sysdate 
                 where transactions_cars_id = l_cars_old_id;
            end if;
            if nvl(l_cars_old_id,0) = 0 then
                insert into xx_etw.xx_disl_transactions_cars  
                values l_row_c;
            end if;
            
        end loop;
    end if;
    l_result := 'done'||'$';
    return l_result;
exception
    when others then 
        rollback;
        err_msg := SUBSTR(SQLERRM, 1, 400);
        log_new(l_log_id,l_function,'p_user_id='||p_user_id
                                 ||' l_railway_id='||l_railway_id
                                 ||' l_part_id='||l_part_id
                                 ||' err_msg = '||err_msg);
        return 'fail'||'$'||err_msg;
end;
function validation_dev_trans (p_railway_id number default null,p_part_id number default null, p_instance_id number,p_not varchar2 default 'N') 
return varchar2
as
    l_value varchar2(250);
begin
    if nvl(p_not,'N') = 'N' then
        select   distinct listagg(dr.railway_number||'('||drp.descr||')',',') within group (order by dr.railway_number||'('||drp.descr||')') into l_value
          from   xx_etw.xx_disl_transactions_header dth,
                 xx_etw.xx_disl_transactions_lines dtl,
                 xx_etw.xx_disl_railway_part drp,
                 xx_etw.xx_disl_railways dr,
                 xx_etw.xx_disl_fixing_device_v dfd
         where   1 = 1
                 and dr.RAILWAY_ID = dth.RAILWAY_ID
                 and dfd.INSTANCE_ID = dtl.INSTANCE_ID
                 and drp.RAILWAY_ID = dth.RAILWAY_ID
                 and drp.PART_ID = dth.PART_ID
                 and nvl(drp.DELETED,'N') = 'N'
                 and dth.transactions_header_id = dtl.transactions_header_id
                 and dtl.INSTANCE_ID = p_instance_id
                 and nvl(dtl.DELETED,'N') = 'N'
                 and dtl.TRANSACTION_TYPE = 'IN' -- Закрепленное ЗУ
                 and nvl(dth.STATUS,'OPEN') = 'OPEN'
                 and nvl(dth.DELETED,'N') = 'N'
                 and dtl.TRANSACTIONS_OUT_ID is null;
     end if;
    
    if nvl(p_not,'N') = 'Y' then -- Не учитывать вагоны на конкретном пути и конкретном части пути
        select   distinct listagg(dr.railway_number||'('||dr.descr||')',',') within group (order by dr.railway_number||'('||dr.descr||')') into l_value
        from (
        select   dr.railway_number,drp.descr
          from   xx_etw.xx_disl_transactions_header dth,
                 xx_etw.xx_disl_transactions_lines dtl,
                 xx_etw.xx_disl_railway_part drp,
                 xx_etw.xx_disl_railways dr,
                 xx_etw.xx_disl_fixing_device_v dfd
         where   1 = 1
                 and dr.RAILWAY_ID = dth.RAILWAY_ID
                 and dfd.INSTANCE_ID = dtl.INSTANCE_ID
                 and drp.RAILWAY_ID = dth.RAILWAY_ID
                 and drp.PART_ID = dth.PART_ID 
                 --and dth.RAILWAY_ID = p_railway_id
                 and dth.PART_ID <> p_part_id
                 and nvl(drp.DELETED,'N') = 'N'
                 and dth.transactions_header_id = dtl.transactions_header_id
                 and dtl.INSTANCE_ID = p_instance_id
                 and nvl(dtl.DELETED,'N') = 'N'
                 and dtl.TRANSACTION_TYPE = 'IN' -- Закрепленное ЗУ
                 and nvl(dth.STATUS,'OPEN') = 'OPEN'
                 and nvl(dth.DELETED,'N') = 'N'
                 and dtl.TRANSACTIONS_OUT_ID is null) dr;
     end if;
return l_value;
exception when OTHERS then return null;
end;

function get_count_fix_dev (p_railway_id number, p_side_type varchar2) 
return number
as
    l_value number:=0;
begin
    select   count(instance_id) into l_value
      from   xx_etw.xx_disl_transactions_header dth,
             xx_etw.xx_disl_transactions_lines dtl
     where   1 = 1 
             and dth.transactions_header_id = dtl.transactions_header_id
             and dth.railway_id = p_railway_id
             and dtl.SIDE_TYPE = p_side_type
             and nvl(dtl.DELETED,'N') = 'N'
             and nvl(dth.STATUS,'OPEN') = 'OPEN'
             and nvl(dth.DELETED,'N') = 'N'
             and dtl.TRANSACTION_TYPE = 'IN' -- Закрепленное ЗУ
             and dtl.TRANSACTIONS_OUT_ID is null;
    return l_value;
end;

function validation_ondock (
    p_user_id       number,
    p_params        varchar2) 
return varchar2
as
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_railway_id        number:=0;
    l_part_id           number:=0;
    l_count             number;
    l_transactions_id   number:=0;
    l_transaction_type  varchar(50);
begin
    l_json_par := xx_wms.json(p_params);
    if (l_json_par.exist('part_id')) then
         l_part_id := l_json_par.get_string('part_id'); -- Часть пути
    end if;
    if (l_json_par.exist('railway_id')) then
        l_railway_id := l_json_par.get_string('railway_id'); -- Путь
    end if;
    if (l_json_par.exist('transaction_type')) then
        l_transaction_type := l_json_par.get_string('transaction_type'); -- Путь
    end if;
    select count(dth.railway_id),
           dth.transactions_header_id into l_count,l_transactions_id
      from xx_etw.xx_disl_transactions_header dth,
           xx_etw.xx_disl_transactions_lines dtl
     where 1=1
           and dth.railway_id = l_railway_id
           and dth.part_id = l_part_id
           and dth.transactions_header_id = dtl.transactions_header_id
           and dtl.transaction_type = 'IN'
           and nvl(dtl.deleted,'N') = 'N'
           and nvl(dth.STATUS,'OPEN') = 'OPEN'
           and nvl(dth.DELETED,'N') = 'N'
           and dtl.transactions_out_id is null
    group by dth.transactions_header_id;
           
    if nvl(l_count,0) > 0 then return 'done$true$'||nvl(l_transactions_id,0); 
    else return 'done$false$0'; end if;
    
exception when no_data_found then return 'done$false$0';
          when OTHERS then return 'fail$'||SUBSTR(SQLERRM, 1, 400); 
end;

function validation_fix (
    p_user_id       number,
    p_params        varchar2) 
return varchar2
as
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_railway_id        number:=0;
    l_part_id           number:=0;
    l_count             number;
    l_transactions_id   number:=0;
    l_transaction_type  varchar(50);
    l_msg               varchar2(4000);
begin
    l_json_par := xx_wms.json(p_params);
    if (l_json_par.exist('part_id')) then
         l_part_id := l_json_par.get_string('part_id'); -- Часть пути
    end if;
    if (l_json_par.exist('railway_id')) then
        l_railway_id := l_json_par.get_string('railway_id'); -- Путь
    end if;
    if (l_json_par.exist('transaction_type')) then
        l_transaction_type := l_json_par.get_string('transaction_type'); -- Путь
    end if;
    
    SELECT   case when count_ev = 0 and count_odd = 0 then null
              else 'ЗУ назначены. Для корректировки форма "Корректировка ЗУ" Уст: '||to_char(DATE_FIX_ODD,'DD.MM.YYYY HH24:MI')
                        ||' Отв.: '||/*user_fix||'/'||*/user_rep
                        ||' ЗУ: '||inst_ev||'/'||inst_odd
                        ||' Регистр: '||created_user||' ('||to_char(CREATED_DATE,'DD.MM.YYYY HH24:MI')||').' 
         end msg into l_msg
      FROM   (SELECT   dth.CREATED_DATE,
                       du.full_name created_user,
                       CASE
                          WHEN dth.DATE_FIX_EVEN < NVL (DATE_FIX_ODD, SYSDATE)
                          THEN
                             DATE_FIX_EVEN
                          ELSE
                             dth.DATE_FIX_ODD
                       END
                          DATE_FIX_ODD,
                       CASE
                          WHEN dth.DATE_FIX_EVEN < NVL (DATE_FIX_ODD, SYSDATE)
                          THEN
                             cf_even.name
                          ELSE
                             cf_odd.name
                       END
                          user_fix,                                -- кто проводит
                       CASE
                          WHEN dth.DATE_FIX_EVEN < NVL (DATE_FIX_ODD, SYSDATE)
                          THEN
                             rep_even.full_name
                          ELSE
                             rep_odd.full_name
                       END
                          user_rep                              --кому докладывает
                                  ,
                       case when dtl_e.inst is not null then dtl_e.inst
                            else '---'
                       end inst_ev,
                       case when dtl_odd.inst is not null then dtl_odd.inst
                            else '---'
                       end inst_odd,
                       nvl(dtl_e.COUNT,0) count_ev,
                       nvl(dtl_odd.COUNT,0) count_odd
                FROM   xx_etw.xx_disl_transactions_header dth,
                       xx_etw.xx_disl_users du,
                       xx_etw.xx_disl_cond_train_dr_v cf_even,
                       xx_etw.xx_disl_cond_train_dr_v cf_odd,
                       xx_etw.xx_disl_users rep_even,
                       xx_etw.xx_disl_users rep_odd,
                       (  SELECT   dtl_e.transactions_header_id,
                                   listagg (
                                      REPLACE(LTRIM(REPLACE(fdv_e.SEG4, '0', ' ')),' ', '0') || REPLACE(LTRIM(REPLACE(fdv_e.SEG5, '0', ' ')),' ', '0'),
                                      ','
                                   )
                                      WITHIN GROUP (ORDER BY
                                                       dtl_e.transactions_header_id)
                                      inst,
                                   COUNT (dtl_e.transactions_header_id) COUNT
                            FROM   xx_etw.xx_disl_transactions_lines dtl_e,
                                   xx_etw.xx_disl_fixing_device_v fdv_e
                           WHERE       dtl_e.transaction_type = 'IN'
                                   AND dtl_e.SIDE_TYPE = 'EVEN'
                                   AND NVL (dtl_e.deleted, 'N') = 'N'
                                   AND dtl_e.transactions_out_id IS NULL
                                   AND dtl_e.INSTANCE_ID = fdv_e.INSTANCE_ID(+)
                        GROUP BY   dtl_e.transactions_header_id) dtl_e,
                       (  SELECT   dtl_e.transactions_header_id,
                                   listagg (
                                      REPLACE(LTRIM(REPLACE(fdv_e.SEG4, '0', ' ')),' ', '0') || REPLACE(LTRIM(REPLACE(fdv_e.SEG5, '0', ' ')),' ', '0'),
                                      ','
                                   )
                                      WITHIN GROUP (ORDER BY
                                                       dtl_e.transactions_header_id)
                                      inst,
                                   COUNT (dtl_e.transactions_header_id) COUNT
                            FROM   xx_etw.xx_disl_transactions_lines dtl_e,
                                   xx_etw.xx_disl_fixing_device_v fdv_e
                           WHERE       dtl_e.transaction_type = 'IN'
                                   AND dtl_e.SIDE_TYPE = 'ODD'
                                   AND NVL (dtl_e.deleted, 'N') = 'N'
                                   AND dtl_e.transactions_out_id IS NULL
                                   AND dtl_e.INSTANCE_ID = fdv_e.INSTANCE_ID(+)
                        GROUP BY   dtl_e.transactions_header_id) dtl_odd
               WHERE       1 = 1
                       AND NVL (dth.STATUS, 'OPEN') = 'OPEN'
                       AND NVL (dth.DELETED, 'N') = 'N'
                       AND dth.LAST_UPDATE_BY = du.id
                       AND dth.railway_id = l_railway_id
                       AND dth.part_id = l_part_id
                       -- Назначение ч.с ответ-е
                       AND dth.user_fix_even = cf_even.id(+)
                       AND dth.user_fix_odd = cf_odd.id(+)
                       AND dth.user_fix_rep_even = rep_even.id(+)
                       -- Назначение нч.с ответ-е
                       AND dth.user_fix_even = cf_even.id(+)
                       AND dth.user_fix_odd = cf_odd.id(+)
                       AND dth.user_fix_rep_odd = rep_odd.id(+)
                       AND dth.transactions_header_id =
                             dtl_e.transactions_header_id(+)
                       AND dth.transactions_header_id =
                             dtl_odd.transactions_header_id(+));
           
    if l_msg is not null then return 'done$false$'||l_msg; 
    else return 'done$true$0'; end if;
    
exception when no_data_found then return 'done$true$0';
          when OTHERS then return 'fail$'||SUBSTR(SQLERRM, 1, 400); 
end;
/*Транзакции открепления ЗУ*/
function save_transaction_ondock(
    p_user_id           number,
    p_add_data          varchar2    
) return varchar2
as
    l_function      varchar2(100):='save_transaction_ondock';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    err_msg         varchar2(4000);
    l_error         exception;
    
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_row           xx_etw.xx_disl_transactions_header%rowtype;
    l_row_l         xx_etw.xx_disl_transactions_lines%rowtype;
    
    l_place_id      number;
    l_tr_header_id  number;
    l_railway_id    number;
    l_part_id       number;
    l_date_fix_even date;
    l_user_fix_even number;
    l_user_report_even number;
    
    l_date_fix_odd  date;
    l_user_fix_odd  number;
    l_user_report_odd number;
    l_note          varchar2(250);
    l_transaction_type varchar2(50);
    l_result        varchar2(4000);
    l_transactions_id number;
    l_transactions_lines_id number;
    l_new_lines_id number;
begin   
    l_json_par := xx_wms.json(p_add_data);
    
    l_transactions_id := l_json_par.get_string('transactions_id'); -- id transactions_id header
    l_railway_id := l_json_par.get_string('railway_id'); -- Путь
    l_part_id := l_json_par.get_string('part_id'); -- Часть пути
    l_date_fix_even:=to_date(l_json_par.get_string('time_fixing_even'),'DD.MM.YYYY HH24:MI'); -- ЧетнаяСторона.Дата и время закрепления(Мск) 
    l_user_fix_even:=l_json_par.get_string('who_fixing_even'); -- ЧетнаяСторона.Кто проводит
    l_user_report_even:=l_json_par.get_string('who_fixing_report_even'); -- НеЧетнаяСторона.Кому докладвает 
    l_date_fix_odd:=to_date(l_json_par.get_string('time_fixing_odd'),'DD.MM.YYYY HH24:MI'); -- НеЧетнаяСторона.Дата и время закрепления(Мск)
    l_user_fix_odd:=l_json_par.get_string('who_fixing_odd'); -- НеЧетнаяСторона.Кто проводит;
    l_user_report_odd:=l_json_par.get_string('who_fixing_report_odd'); -- НеЧетнаяСторона.Кому докладвает 
    l_note:=l_json_par.get_string('note');
    l_transaction_type:=l_json_par.get_string('transaction_type');
    
    if ( nvl(l_transactions_id,0) > 0) then
        
        update xx_etw.xx_disl_transactions_header 
            set last_update_by = p_user_id,
                last_update_date = sysdate,
                
                date_undock_even=l_date_fix_even,
                user_undock_even=l_user_fix_even,
                user_undock_rep_even =l_user_report_even,
                
                date_undock_odd=l_date_fix_odd,
                user_undock_odd=l_user_fix_odd,
                user_undock_rep_odd =l_user_report_odd, 
                
                note_undock=l_note,
                STATUS = 'CLOSE'
         where transactions_header_id = l_transactions_id;
        
        /*Массив башмаков с четной стороны*/
        l_json_value := l_json_par.get('device_mas_even');
        l_json_list := json_list(l_json_value); 
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            l_new_lines_id := xx_etw.xx_disl_transactions_l_seq.nextval();
            l_row_l.transactions_header_id:=l_transactions_id;
            l_row_l.transactions_lines_id:=l_new_lines_id;
            l_row_l.transaction_type:=l_transaction_type;
            l_row_l.instance_id:=l_json.get_string('device_id');
            l_row_l.side_type:=l_json.get_string('side_type');
            l_row_l.side_id:=l_json.get_string('side_id');
            l_row_l.transactions_out_id:=null;
            l_row_l.deleted:='N';
            l_row_l.deleted_by:=null; 
            l_row_l.deleted_date:=null;
            l_row_l.created_by:=p_user_id;
            l_row_l.created_date:=sysdate;
            l_row_l.last_update_by:=p_user_id;
            l_row_l.last_update_date:=sysdate; 
            insert into xx_etw.xx_disl_transactions_lines  
            values l_row_l;
            
            l_transactions_lines_id:=l_json.get_string('transactions_lines_id');
            update xx_etw.xx_disl_transactions_lines 
               set transactions_out_id = l_new_lines_id,
                   last_update_by=p_user_id,
                   last_update_date=sysdate
             where transactions_lines_id = l_transactions_lines_id;
        end loop; 
        
        /*Массив башмаков с нечетной стороны*/
        l_json_value := l_json_par.get('device_mas_odd');
        l_json_list := json_list(l_json_value); 
        for i in 1..l_json_list.count loop
            l_json_value := l_json_list.get(i);
            l_json := json(l_json_value); 
            l_new_lines_id := xx_etw.xx_disl_transactions_l_seq.nextval();
            l_row_l.transactions_header_id:=l_transactions_id;
            l_row_l.transactions_lines_id:=l_new_lines_id;
            l_row_l.transaction_type:=l_transaction_type;
            l_row_l.instance_id:=l_json.get_string('device_id');
            l_row_l.side_type:=l_json.get_string('side_type');
            l_row_l.side_id:=l_json.get_string('side_id');
            l_row_l.transactions_out_id:=null;
            l_row_l.deleted:='N';
            l_row_l.deleted_by:=null; 
            l_row_l.deleted_date:=null;
            l_row_l.created_by:=p_user_id;
            l_row_l.created_date:=sysdate;
            l_row_l.last_update_by:=p_user_id;
            l_row_l.last_update_date:=sysdate; 
            insert into xx_etw.xx_disl_transactions_lines  
            values l_row_l;
            
            l_transactions_lines_id:=l_json.get_string('transactions_lines_id');
            update xx_etw.xx_disl_transactions_lines 
               set transactions_out_id = l_new_lines_id,
                   last_update_by=p_user_id,
                   last_update_date=sysdate
             where transactions_lines_id = l_transactions_lines_id;
        end loop; 
    end if;
    log_new(l_log_id,l_function,' insert into xx_etw.xx_disl_transactions_lines. кол-во'||sql%rowcount);
    commit;
    l_result := 'done'||'$'||to_char(l_transactions_id);   

    return l_result;
exception
    when others then 
        rollback;
        err_msg := SUBSTR(SQLERRM, 1, 400);
        log_new(l_log_id,l_function,'p_user_id='||p_user_id
                                 ||' l_railway_id='||l_railway_id
                                 ||' l_part_id='||l_part_id
                                 ||' err_msg = '||err_msg);
        return 'fail'||'$'||err_msg;
end;

/* Удаляем (помечаем) ЗУ.*/
function delete_fix(
    p_user_id           number,
    p_add_data          varchar2    
) return varchar2
as
    l_function      varchar2(100):='delete_fix';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    err_msg         varchar2(4000);
    l_error         exception;
    
    l_json_par      json;
    l_json          json;
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_place_id      number;
    l_tr_header_id  number;
    l_railway_id    number;
    l_part_id       number;
    l_deleted_note  varchar2(2400);
    l_result        varchar2(4000);
begin
    l_json_par := xx_wms.json(p_add_data);
    l_railway_id := l_json_par.get_string('railway_id'); -- Путь
    l_part_id := l_json_par.get_string('part_id'); -- Часть пути
    l_deleted_note:=l_json_par.get_string('note_delete'); 
    
    update xx_etw.xx_disl_transactions_header dth
       set 
           status = 'DELETE',
           deleted = 'Y',
           deleted_by = p_user_id,
           deleted_date = sysdate,
           deleted_note = l_deleted_note,
           LAST_UPDATE_BY = p_user_id,
           LAST_UPDATE_DATE = sysdate
     where 1=1
           and dth.railway_id = l_railway_id
           and dth.part_id = l_part_id
           and nvl(dth.status,'OPEN') = 'OPEN'
           and nvl(dth.deleted,'N') = 'N';
    log_new(l_log_id,l_function,' update xx_etw.xx_disl_transactions_header. кол-во'||sql%rowcount);
    l_result := 'done'||'$';
    return l_result;
exception
    when others then 
        rollback;
        err_msg := SUBSTR(SQLERRM, 1, 400);
        log_new(l_log_id,l_function,'p_user_id='||p_user_id
                                 ||' l_railway_id='||l_railway_id
                                 ||' l_part_id='||l_part_id
                                 ||' err_msg = '||err_msg);
        return 'fail'||'$'||err_msg;
end;

function get_device_defects
return t_xx_defect_dev_table pipelined
as
    l_row       t_xx_defect_dev_row;
begin
    for l_tmp in (select short_code         code
                        ,description        descr
                    from qa.qa_plan_char_value_lookups
                   where 1=1
                     and plan_id = 1980
                     and char_id = 2900
                     and short_code like 'ЗУ%'
                 )
    loop
        l_row.code := l_tmp.code;
        l_row.descr := l_tmp.descr;
        
        pipe row (l_row);
    end loop;
end;

function enter_dev_inspection(
                          p_user_id                   number
                         ,p_add_data                  varchar2
                         ,p_need_commit               varchar2 default 'Y'
                         )
return varchar2
as
    
    p_car_number                  varchar2(240);
    p_cont                        varchar2(240);
    p_inspection_id               number;
    p_inspection_date             varchar2(240);
    p_inspection_place            varchar2(240);
    p_inspection_person           varchar2(240);
    p_inspection_person_appoint   varchar2(240);
    p_master                      varchar2(240);
    p_priority                    varchar2(240);
    p_result                      varchar2(240);
    p_status_kurs                 varchar2(240);
    p_comment                     varchar2(240);
    p_defects                     varchar2(2400);

    l_log_id                number;
    l_function              varchar2(100):='enter_dev_inspection';
    
    l_inspection_date       date;
    l_instance_id           number;
    l_asset_group_id        number;
    l_asset_group           inv.mtl_system_items_b.segment1%type;
    l_asset_number          csi.csi_item_instances.serial_number%type;
    l_inspection_id         number;
    
    l_defect_id             varchar2(300);
    l_defect_code           varchar2(300);
    l_defect_descr          varchar2(300);
    l_doc_type              varchar2(300);
    l_doc_num               varchar2(300);
    l_defect_date           varchar2(30);
    
    l_errbuf                varchar2(4000);
    l_retcode               varchar2(1);
    l_add_info_id           number;
    
    l_car_owner_id          xx_etw.etw_inv_car.car_owner_id%type;
    l_car_type_code         xx_etw.etw_inv_car.car_type_code%type;
    
    l_user_name             varchar2(100);
    l_return_status         varchar2(1);
    
    l_req_result            varchar2(1);
    l_req_error_log         varchar2(200);
    
    l_asset_instance_number varchar2(30);
    
    l_old_result            varchar2(300);
    
    l_cont_round_id         number;
    l_cont_add_info_id      number;
    
    l_json_par              json;

    procedure enter_defects(p_inspection_id number,p_result varchar2,p_defects varchar2,p_log_id number)
    as
        l_function varchar2(100) := 'enter_dev_inspection->enter_defects';   
    begin
        delete
          from xx_disl_dev_inspection_defects
         where 1=1
           and inspection_id = p_inspection_id
        ;
        log_new(p_log_id,l_function,'delete from xx_disl_dev_inspection_defects. rowcount = '||sql%rowcount);
        
        if (p_result = 'Не годен' or p_result = 'Ограничение') then
            for l_defect in (select regexp_substr(p_defects,'[^$]+',1,level) text
                               from dual
                            connect by level <= regexp_count(p_defects,'[^$]+')
                            )
            loop     
                l_defect_id := regexp_substr(l_defect.text,'[^|]+',1,1);
                log_new(l_log_id,l_function,'l_defect_id = '||l_defect_id);
                        
                l_defect_code := regexp_substr(l_defect.text,'[^|]+',1,2);
                log_new(l_log_id,l_function,'l_defect_code = '||l_defect_code);
                
                l_defect_descr := regexp_substr(l_defect.text,'[^|]+',1,3);
                log_new(l_log_id,l_function,'l_defect_descr = '||l_defect_descr);
                
                l_doc_type := regexp_substr(l_defect.text,'[^|]+',1,4);
                log_new(l_log_id,l_function,'l_doc_type = '||l_doc_type);
                
                l_doc_num := regexp_substr(l_defect.text,'[^|]+',1,5);
                log_new(l_log_id,l_function,'l_doc_num = '||l_doc_num);
                
                l_defect_date := regexp_substr(l_defect.text,'[^|]+',1,6);
                log_new(l_log_id,l_function,'l_defect_date = '||l_defect_date);
                
                insert into xx_disl_dev_inspection_defects
                values(
                    decode(l_defect_id,'_',xx_disl_dev_inspection_def_seq.nextval,l_defect_id)
                   ,p_inspection_id
                   ,l_defect_code
                   ,l_defect_descr
                   ,decode(l_doc_type,'_',null,l_doc_type)
                   ,decode(l_doc_num,'_',null,l_doc_num)
                   ,decode(l_defect_date,'_',null,l_defect_date)
                   ,null
                   ,null
                   ,null
                )
                ;
                log_new(l_log_id,l_function,'insert into xx_disl_inspection_defects. rowcount = '||sql%rowcount);
            end loop;                     
        end if;
    end;

begin
    /*p_cont список состоящий из номера платформы(= p_car_number) и контейнеров. Если осмотр вводится по платформе, то p_cont всегда не null(проверка на форме), если же по вагону, то p_cont=null*/    
    /*Если же p_inspection_id != null, то считаем, что старый осмотр изменяем только по одной платформе или же контейнеру, т.е. на p_cont не обращаем внимание(хотя должен быть пустой(вагон) или же иметь одно значение(платформа, контейнер))*/
    l_json_par := xx_wms.json(p_add_data);
    p_car_number:=l_json_par.get_string('car_number');
    p_cont:=l_json_par.get_string('cont');
    p_inspection_id:=l_json_par.get_string('inspection_id');
    p_inspection_date:=l_json_par.get_string('inspection_date');
    p_inspection_place:=l_json_par.get_string('inspection_place');
    p_inspection_person:=l_json_par.get_string('inspection_person');
    p_inspection_person_appoint:=l_json_par.get_string('inspection_person_appoint');
    p_master:=l_json_par.get_string('master');
    p_priority:=l_json_par.get_string('priority');
    p_result:=l_json_par.get_string('result');
    p_status_kurs:=l_json_par.get_string('status_kurs');
    p_comment:=l_json_par.get_string('comment');
    p_defects:=l_json_par.get_string('defects');
    
    
    l_log_id := xx_disl_log_seq.nextval();
    
    log_new(l_log_id,l_function,'parameters: p_user_id = '||p_user_id
                                         ||' p_car_number= '||p_car_number
                                         ||' p_cont= '||p_cont
                                         ||' p_inspection_id= '||p_inspection_id
                                         ||' p_inspection_date= '||p_inspection_date
                                         ||' p_inspection_place= '||p_inspection_place
                                         ||' p_inspection_person = '||p_inspection_person
                                         ||' p_inspection_person_appoint= '||p_inspection_person_appoint
                                         ||' p_master= '||p_master
                                         ||' p_priority= '||p_priority
                                         ||' p_result= '||p_result
                                         ||' p_status_kurs = '||p_status_kurs
                                         ||' p_comment = '||p_comment
                                         ||' p_defects = '||p_defects
                                         ||' p_need_commit = '||p_need_commit);
    
    begin
        l_inspection_date := to_date(p_inspection_date,'dd.mm.yyyy hh24:mi');
    exception
        when others then log_new(l_log_id,l_function,'raise no_data_found'); raise no_data_found;
    end;
    log_new(l_log_id,l_function,'l_inspection_date = '||l_inspection_date);
    
    if (p_inspection_id is null) /*новый осмотр*/ then
        if (p_cont is null) /*осмотр по вагону*/ then 
            select instance_id
                  ,asset_group_id
                  ,asset_group
                  ,asset_number
              into l_instance_id
                  ,l_asset_group_id
                  ,l_asset_group
                  ,l_asset_number
              from table(xx_dislocation.get_asset_info(p_car_number))
            ;
            log_new(l_log_id,l_function,'l_instance_id = '||l_instance_id||' l_asset_group_id = '||l_asset_group_id||' l_asset_group = '||l_asset_group||' l_asset_number = '||l_asset_number);
            
            insert into xx_etw.xx_disl_dev_inspections
            values(
                xx_disl_dev_inspections_seq.nextval
               ,p_user_id
               ,sysdate
               ,p_user_id
               ,sysdate
               ,p_car_number
               ,decode(l_instance_id,-1,null,l_instance_id)
               ,l_asset_group_id
               ,l_asset_number
               ,l_inspection_date
               ,p_inspection_place
               ,p_inspection_person
               ,p_inspection_person_appoint
               ,p_master
               ,p_priority
               ,p_result
               ,p_status_kurs
               ,p_comment
               ,null
               ,null
               ,'N'
               ,null
               ,null
               ,null
            )
            returning  inspection_id into l_inspection_id
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_dev_inspections. rowcount = '||sql%rowcount);
            log_new(l_log_id,l_function,'l_inspection_id = '||l_inspection_id);
            
            --mark_last_record_for_ins(p_car_number);/*сидит обновление статуса*/
            
            enter_defects(l_inspection_id,p_result,p_defects,l_log_id);
            
            if (p_result = 'Не годен') then---?????
                log_new(l_log_id,l_function,'Не годен create_work_dev_request');
                create_work_dev_request(p_user_id,l_inspection_id,l_req_result,l_req_error_log);
            end if;
        end if;
    else /*редактируем старый осмотр*/
        begin
            select result
              into l_old_result
              from xx_disl_dev_inspections
             where 1=1
               and inspection_id = p_inspection_id
            ;
        exception
            when others then l_old_result:=null;
        end;
        
        update xx_disl_dev_inspections
           set last_updated_by = p_user_id
              ,last_updated_date = sysdate
              --,asset_instance_number = p_car_number
              --,asset_instance_id = decode(l_instance_id,-1,null,l_instance_id)
              --,asset_group_id = l_asset_group_id
              --,asset_number = l_asset_number
              ,inspection_date = l_inspection_date
              ,inspection_place = p_inspection_place
              ,inspection_person = p_inspection_person
              ,inspection_person_appoint = p_inspection_person_appoint
              ,master = p_master
              ,priority = p_priority
              ,result = p_result
              ,status_kurs = p_status_kurs
              ,description = p_comment
         where 1=1
           and inspection_id = p_inspection_id
         returning asset_instance_number into l_asset_instance_number 
        ;
        log_new(l_log_id,l_function,'update xx_disl_dev_inspections. rowcount = '||sql%rowcount);
        l_inspection_id:=p_inspection_id;
        log_new(l_log_id,l_function,'l_inspection_id = '||l_inspection_id);
        
        --mark_last_record_for_ins(l_asset_instance_number);/*сидит обновление статуса*/
        enter_defects(l_inspection_id,p_result,p_defects,l_log_id);
        
        if (p_result = 'Не годен' and l_old_result = 'Годен') then
            create_work_dev_request(p_user_id,l_inspection_id,l_req_result,l_req_error_log);    
        end if;
    end if;
       
    if (p_need_commit = 'Y') then 
        commit;
    end if;
    
    return 'done';
exception
    when others then 
        rollback;
        log_new(l_log_id,l_function,'Error.'||sqlerrm);   
        return 'fail';    
end;


function get_car_dev_inspections(p_obj_number varchar2,p_obj_type varchar2)
return t_xx_car_dev_inspection_table pipelined
as
    l_row           t_xx_car_dev_inspection_row;
    l_date_from     date; 
begin
   
       
    for tmp in (select ins.inspection_id
                      ,ins.asset_instance_number
                      ,ins.asset_instance_id
                      ,ins.asset_group_id
                      ,(select msi.segment1
                          from inv.mtl_system_items_b       msi
                         where 1=1
                           and msi.inventory_item_id = ins.asset_group_id
                           and msi.organization_id = 305
                       )              
                                                                                asset_group
                      ,ins.asset_number
                      ,to_char(nvl(ins.inspection_date,ins.created_date),'dd.mm.yyyy hh24:mi')        inspection_date
                      ,ins.inspection_place
                      ,ins.inspection_person
                      ,ins.inspection_person_appoint
                      ,ins.master
                      ,ins.priority
                      ,ins.result
                      ,ins.status_kurs
                      ,ins.description
                      ,ins_d.defect_id
                      ,ins_d.defect_code
                      ,ins_d.defect_descr
                      ,ins_d.doc_type
                      ,ins_d.doc_num
                      ,ins_d.defect_date
                      ,decode(ins.created_request_status
                             ,'E','Ошибка при создании'
                             ,'S','Создан'
                             ,ins.created_request_status
                             )
                                                                                created_request_status
                      ,ins.refusal_to_repair
                      ,ins.created_by
                  from xx_disl_dev_inspections          ins
                      ,xx_disl_dev_inspection_defects   ins_d
                 where 1=1
                   and ins.asset_instance_number in (select p_obj_number
                                                       from dual  
                                                    )
                                                    
--                   and ins.created_date >= nvl(l_date_from,ins.created_date)
                   
                   and ins.inspection_id = ins_d.inspection_id(+)
                   and ins.inspection_date is not null
                 order by
                       nvl(ins.inspection_date,ins.created_date) desc -- asdf
                      ,ins.inspection_id
                      ,ins_d.defect_id
               )
    loop
        l_row.inspection_id := tmp.inspection_id;
        l_row.asset_instance_number := tmp.asset_instance_number;
        l_row.asset_instance_id := tmp.asset_instance_id;
        l_row.asset_group_id := tmp.asset_group_id;
        l_row.asset_group := tmp.asset_group;
        l_row.asset_number := tmp.asset_number;
        l_row.inspection_date := tmp.inspection_date;
        l_row.inspection_place := tmp.inspection_place;
        l_row.inspection_person := tmp.inspection_person;
        l_row.inspection_person_appoint := tmp.inspection_person_appoint;
        l_row.master := tmp.master;
        l_row.priority := tmp.priority;
        l_row.result := tmp.result;
        l_row.status_kurs := tmp.status_kurs;
        l_row.description := tmp.description;
        l_row.defect_id := tmp.defect_id;
        l_row.defect_code := tmp.defect_code;
        l_row.defect_descr := tmp.defect_descr;
        l_row.doc_type := tmp.doc_type;
        l_row.doc_num := tmp.doc_num;
        l_row.defect_date := tmp.defect_date;
        l_row.created_request_status := tmp.created_request_status;
        l_row.refusal_to_repair := tmp.refusal_to_repair;
        l_row.created_by := tmp.created_by;
        
        pipe row (l_row);
    end loop;     
end;


function refusal_dev_to_repair(
     p_user_id          number
    ,p_inspection_id    number
    ,p_person           varchar2
) 
return varchar2
as
begin
    update xx_disl_dev_inspections
       set refusal_to_repair = p_person
          ,last_updated_by = p_user_id
          ,last_updated_date = sysdate
     where 1=1
       and inspection_id = p_inspection_id
    ;
    
    commit;
    
    return 'done';
exception
    when others then rollback; return 'fail';
end;


function delete_dev_inspection(p_inspection_id number) 
return varchar2
as
    l_log_id                    number := xx_etw.xx_disl_log_seq.nextval();
    l_function                  varchar2(100):='delete_dev_inspection';

    l_delete_row_count          number;
    l_asset_instance_number     varchar2(100);
    
    l_errbuf                    varchar2(4000);
    l_retcode                   varchar2(1);
    l_add_info_id               number;
begin
    log_new(l_log_id,l_function,'p_inspection_idt = '||p_inspection_id);

    delete   
      from xx_etw.xx_disl_dev_inspections
     where 1=1
       and inspection_id = p_inspection_id
    returning asset_instance_number into l_asset_instance_number 
    ;
    log_new(l_log_id,l_function,'l_asset_instance_number = '||l_asset_instance_number);
    
    
    if (l_asset_instance_number is null) then
        rollback;
        log_new(l_log_id,l_function,'Erorr.l_asset_instance_number is null');
        return 'fail';
    end if;
    
    delete 
      from xx_etw.xx_disl_dev_inspection_defects
     where 1=1
       and inspection_id = p_inspection_id
    ;
    log_new(l_log_id,l_function,'delete from xx_etw.xx_disl_dev_inspection_defects. кол-во = '||sql%rowcount);
    
    commit;
    
    return 'done';     
exception
    when others then 
        rollback;
        log_new(l_log_id,l_function,'Erorr = '||sql%rowcount);
        return 'fail';       
end;

function get_status_shift(
    p_user_id       number,
    p_params        varchar2)
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for c_row in (select u.STATUS_ID id
                        ,u.DESCR                name
                    from xx_etw.xx_disl_sh_status              u
                   where 1=1
                     
                   order by 
                         DESCR
                 )
    loop
        l_row.id := c_row.id;
        l_row.name := c_row.name;        
        pipe row (l_row);
    end loop;
end;

function get_snapshot_wagon (
    p_user_id       number,
    p_params        varchar2) 
    return t_xx_snapshot_wagon_table pipelined
as 
    l_row           t_xx_snapshot_wagon_row;  
    l_function      varchar2(100):='get_snapshot_wagon';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    err_msg         varchar2(4000);
    l_error         exception;
    
    l_json_clob     clob;
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_station_id    number;
    l_date_to     date;
    l_result        varchar2(4000);
    l_tmp_str       varchar2(32000);
    /*Сводная сводка мест нахождения ЗУ*/
    cursor cur_railway(p_station_id number,p_date_to date) is
        SELECT   1 rw, 
                 dth.railway_number,
                 nvl(l_even.COUNT,0)+nvl(l_odd.COUNT,0)-(nvl(l_even.count_fit,0)+nvl(l_odd.count_fit,0))l_count,
                 nvl(l_even.count_fit,0)+nvl(l_odd.count_fit,0) l_count_fit,
                 nvl(l_even.inst,'---')||'/'||nvl(l_odd.inst,'---') dev,
                 'Уст: '||to_char(DATE_FIX_ODD,'DD.MM.YYYY HH24:MI')
                                ||' Отв.: '||user_rep
                                ||' Регистр: '||created_user||' ('||to_char(CREATED_DATE,'DD.MM.YYYY HH24:MI')||').' note,
                 'railways' place
          FROM   (SELECT   DISTINCT transactions_header_id,
                                      dth.railway_id,
                                      dr.railway_number,
                                      ds.station_id,
                                      ds.NAME station_name,
                                      CREATED_DATE,
                                      du.FULL_NAME CREATED_USER,
                                      DATE_FIX_ODD,
                                      cf.name USER_FIX,
                                      rep.FULL_NAME USER_REP
                      FROM   xx_etw.xx_disl_transactions_zu_v dth,
                             xx_etw.xx_disl_railways dr,
                             xx_etw.xx_disl_stations ds,
                             xx_etw.xx_disl_users rep,
                             xx_etw.xx_disl_cond_train_dr_v cf,
                             xx_etw.xx_disl_users du
                     where 1=1  
                           and dth.railway_id = dr.railway_id
                           and dth.station_id = ds.station_id
                           and dth.USER_FIX_txt = cf.id(+)
                           and dth.station_id = p_station_id
                           and dth.USER_REP_txt = rep.id(+)
                           and dth.CREATED_USER = du.id) dth,
                 ( SELECT   dth.transactions_header_id,
                             listagg (
                                REPLACE (LTRIM (REPLACE (fdv_e.SEG4, '0', ' ')),
                                         ' ', '0')
                                || REPLACE (LTRIM (REPLACE (fdv_e.SEG5, '0', ' ')),
                                            ' ',  '0'), ',' )
                                WITHIN GROUP (ORDER BY dth.transactions_header_id) inst,
                             COUNT (dth.transactions_header_id) COUNT
                             ,sum(case when trunc(fit.inspection_date) is not null then 1 else 0 end) count_fit
                      FROM   xx_etw.xx_disl_transactions_zu_v dth,
                             xx_etw.xx_disl_fixing_device_v fdv_e,
                             (SELECT  (di.asset_instance_id) asset_instance_id, 
                                max(di.inspection_date) inspection_date, 
                                max(INSPECTION_ID)INSPECTION_ID
                                   FROM   xx_etw.xx_disl_dev_inspections di
                                  WHERE   NVL (di.result, 'Годен') = 'Не годен'
                                          and  di.inspection_date <= nvl(p_date_to,sysdate)
                                  group by di.asset_instance_id
                                  ) fit
                     WHERE   SIDE_TYPE = 'EVEN' 
                             AND dth.instance_id = fdv_e.instance_id
                             and dth.station_id = p_station_id
                             AND dth.instance_id = fit.asset_instance_id(+)
                  GROUP BY   dth.transactions_header_id) l_even,
                 (  SELECT   dth.transactions_header_id,
                             listagg (
                                REPLACE (LTRIM (REPLACE (fdv_e.SEG4, '0', ' ')),
                                         ' ', '0')
                                || REPLACE (LTRIM (REPLACE (fdv_e.SEG5, '0', ' ')),
                                            ' ', '0'), ',' )
                                WITHIN GROUP (ORDER BY dth.transactions_header_id)
                                inst,
                             COUNT (dth.transactions_header_id) COUNT
                             ,sum(case when trunc(fit.inspection_date) is not null then 1 else 0 end) count_fit
                      FROM   xx_etw.xx_disl_transactions_zu_v dth,
                             xx_etw.xx_disl_fixing_device_v fdv_e
                             ,(SELECT  (di.asset_instance_id) asset_instance_id, 
                                max(di.inspection_date) inspection_date, 
                                max(INSPECTION_ID)INSPECTION_ID
                                   FROM   xx_etw.xx_disl_dev_inspections di
                                  WHERE   NVL (di.result, 'Годен') = 'Не годен'
                                          and  di.inspection_date <= nvl(p_date_to,sysdate)
                                  group by di.asset_instance_id
                              ) fit
                     WHERE   SIDE_TYPE = 'ODD' 
                             AND dth.instance_id = fdv_e.instance_id
                             and dth.station_id = p_station_id
                             AND dth.instance_id = fit.asset_instance_id(+)
                  GROUP BY   dth.transactions_header_id) l_ODD
         WHERE       1 = 1
                 AND dth.transactions_header_id = l_even.transactions_header_id(+)
                 AND dth.transactions_header_id = l_odd.transactions_header_id(+)
         union all
           select 2 rw, 
                  PLACE_NAME,
                  count-nvl(l_count_fit,0) l_count,
                  l_count_fit,
                  inst,
                  null note,
                  'place' place
                from (  SELECT   sp.PLACE_NAME,
                           COUNT (sp.PLACE_NAME) COUNT,
                           SUM(CASE
                                  WHEN TRUNC (fit.inspection_date) is not null THEN 1
                                  ELSE 0
                               END)
                              l_count_fit,
                           listagg (inst, ',') WITHIN GROUP (ORDER BY sp.PLACE_NAME) inst
                    FROM   xx_etw.xx_disl_snapshot_place_v sp
                          ,(SELECT  (di.asset_instance_id) asset_instance_id, 
                                max(di.inspection_date) inspection_date, 
                                max(INSPECTION_ID)INSPECTION_ID
                                   FROM   xx_etw.xx_disl_dev_inspections di
                                  WHERE   NVL (di.result, 'Годен') = 'Не годен'
                                          and  di.inspection_date <= nvl(p_date_to,sysdate)
                                  group by di.asset_instance_id
                           ) fit
                   WHERE   1 = 1 AND sp.stations_id = p_station_id
                           and sp.device_id = fit.asset_instance_id(+)
                           AND NOT EXISTS
                                 (SELECT   *
                                    FROM   xx_etw.xx_disl_transactions_zu_v dth
                                   WHERE   dth.instance_id = sp.device_id
                                           AND dth.station_id = sp.stations_id)
                GROUP BY   sp.PLACE_NAME) 
         order by  rw, railway_number;
         /*Подробная сводка мест нахождения ЗУ*/
        cursor cur_railway_detail(p_station_id number,p_date_to date) is
            SELECT   'railways' place,
                     null place_id,
                     part_id,
                     TRANSACTIONS_HEADER_ID,
                     TRANSACTIONS_LINES_ID,
                     TRANSACTION_TYPE,
                     STATION_ID,
                     RAILWAY_ID,
                     INSTANCE_ID,
                     SIDE_TYPE,
                     SIDE_ID,
                     to_char(dth.CREATED_DATE,'DD.MM.YYYY HH24:MI:SS') as CREATED_DATE,
                     CREATED_USER,
                     USER_FIX_EVEN,
                     to_char(dth.DATE_FIX_ODD,'DD.MM.YYYY HH24:MI:SS') as DATE_FIX_ODD,
                     USER_FIX_ODD,
                     to_char(dth.DATE_FIX_EVEN,'DD.MM.YYYY HH24:MI:SS') as DATE_FIX_EVEN,
                     USER_REP_EVEN,
                     USER_REP_ODD,
                     fit.INSPECTION_ID,
                     to_char(fit.INSPECTION_DATE,'DD.MM.YYYY HH24:MI:SS') as INSPECTION_DATE,
                     to_char(dth.DATE_FIX_ODD_TXT,'DD.MM.YYYY HH24:MI:SS') as DATE_FIX_ODD_TXT,
                     USER_FIX_TXT,
                     USER_REP_TXT
                     
              FROM   xx_etw.xx_disl_transactions_zu_v dth
                     ,(SELECT  (di.asset_instance_id) asset_instance_id, 
                                max(di.inspection_date) inspection_date, 
                                max(INSPECTION_ID)INSPECTION_ID
                                   FROM   xx_etw.xx_disl_dev_inspections di
                                  WHERE   NVL (di.result, 'Годен') = 'Не годен'
                                          and  di.inspection_date <= nvl(p_date_to,sysdate)
                                  group by di.asset_instance_id
                      ) fit
             WHERE   1 = 1 
                     AND dth.STATION_ID = p_station_id
                     AND dth.instance_id = fit.asset_instance_id(+)
             union all
             SELECT  'place' place,
                     sp.PLACE_ID place_id,
                     null part_id,
                     null TRANSACTIONS_HEADER_ID,
                     null TRANSACTIONS_LINES_ID,
                     null TRANSACTION_TYPE,
                     null STATION_ID,
                     null RAILWAY_ID,
                     sp.device_id INSTANCE_ID,
                     null SIDE_TYPE,
                     null SIDE_ID,
                     null CREATED_DATE,
                     null CREATED_USER,
                     null USER_FIX_EVEN,
                     null DATE_FIX_ODD,
                     null USER_FIX_ODD,
                     null DATE_FIX_EVEN,
                     null USER_REP_EVEN,
                     null USER_REP_ODD,
                     fit.INSPECTION_ID,
                     to_char(fit.INSPECTION_DATE,'DD.MM.YYYY HH24:MI:SS') as INSPECTION_DATE,
                     null DATE_FIX_ODD_TXT,
                     null USER_FIX_TXT,
                     null USER_REP_TXT
                     
                FROM  xx_etw.xx_disl_snapshot_place_v sp
                     ,(SELECT  (di.asset_instance_id) asset_instance_id, 
                                max(di.inspection_date) inspection_date, 
                                max(INSPECTION_ID)INSPECTION_ID
                                   FROM   xx_etw.xx_disl_dev_inspections di
                                  WHERE   NVL (di.result, 'Годен') = 'Не годен'
                                          and  di.inspection_date <= nvl(p_date_to,sysdate)
                                  group by di.asset_instance_id
                      ) fit
               WHERE   1 = 1 
                       AND sp.stations_id = p_station_id
                       AND sp.device_id = fit.asset_instance_id(+)
                       AND NOT EXISTS
                             (SELECT   *
                                FROM   xx_etw.xx_disl_transactions_zu_v dth
                               WHERE   dth.instance_id = sp.device_id
                                       AND dth.station_id = sp.stations_id);
begin
        l_json_par := xx_wms.json(p_params);
        l_station_id := l_json_par.get_string('station_id'); -- Станция
        if (l_json_par.exist('date_to')) then
            if l_json_par.get_string('date_to') is not null then
                l_date_to:=to_date(l_json_par.get_string('date_to'),'DD.MM.YYYY HH24:MI')+12/24; -- конец смены
            else 
                l_date_to:=sysdate;
            end if;
        end if;
        l_row := null;
        l_json_list := json_list(); 
        /*Сводная сводка мест нахождения ЗУ*/
        for l_dvc in cur_railway(l_station_id,l_date_to)
        loop
            l_json_tmp := json();
            l_json_tmp.put('railway_number',l_dvc.railway_number);
            l_json_tmp.put('count',l_dvc.l_count);
            l_json_tmp.put('count_fit',l_dvc.l_count_fit);
            
            l_json_tmp.put('device',l_dvc.dev);
            l_json_tmp.put('note',l_dvc.note);
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        l_row.snapshot_short := l_json_list.to_char(false);
        
        /*Подробная сводка мест нахождения ЗУ*/
        l_json_list := json_list();
        dbms_lob.createtemporary(l_json_clob, true);
        for l_dvc in cur_railway_detail(l_station_id,l_date_to)
        loop
            l_json_tmp := json();
            l_json_list := json_list();
            l_json_tmp.put('transactions_header_id',l_dvc.transactions_header_id);
            l_json_tmp.put('part_id',l_dvc.part_id);
            l_json_tmp.put('transactions_lines_id',l_dvc.transactions_lines_id);
            l_json_tmp.put('transaction_type',l_dvc.transaction_type);
            l_json_tmp.put('place',l_dvc.place);
            l_json_tmp.put('place_id',l_dvc.place_id);
            l_json_tmp.put('railway_id',l_dvc.railway_id);
            l_json_tmp.put('instance_id',l_dvc.instance_id);
            l_json_tmp.put('side_type',l_dvc.side_type);
            l_json_tmp.put('side_id',l_dvc.side_id);
            l_json_tmp.put('created_date',l_dvc.created_date);
            l_json_tmp.put('created_user',l_dvc.created_user);
            l_json_tmp.put('user_fix_even',l_dvc.user_fix_even);
            l_json_tmp.put('date_fix_odd',l_dvc.date_fix_odd);
            
            l_json_tmp.put('user_fix_odd',l_dvc.user_fix_odd);
            l_json_tmp.put('date_fix_even',l_dvc.date_fix_even);
            l_json_tmp.put('user_rep_even',l_dvc.user_rep_even);
            l_json_tmp.put('user_rep_odd',l_dvc.user_rep_odd);
            l_json_tmp.put('inspection_date',l_dvc.inspection_date);
            l_json_tmp.put('inspection_id',l_dvc.inspection_id);
            l_json_tmp.put('date_fix_odd_txt',l_dvc.date_fix_odd_txt);   
            l_json_tmp.put('user_fix_txt',l_dvc.user_fix_txt);
            l_json_tmp.put('user_rep_txt',l_dvc.user_rep_txt);
            l_json_list.append(l_json_tmp.to_json_value);
            l_tmp_str := l_json_list.to_char(false);
            dbms_lob.writeappend(l_json_clob, length(l_tmp_str), l_tmp_str);
        end loop;
        --l_json_clob:=regexp_replace(replace(replace(l_json_clob,'[',''),']',','),'.','[{', 1, 1); -- убираем все [] внутри и добавлем самое начало и конец 
        l_json_clob:=replace(l_json_clob,'][',','); -- убираем все [] внутри и добавлем самое начало и конец 
        --dbms_lob.writeappend(l_json_clob, length(']'), ']');
        l_row.snapshot_detailed := l_json_clob;
        dbms_lob.freetemporary(l_json_clob);
        pipe row(l_row);  
end;


function get_smena_change(
    p_user_id       number,
    p_params        varchar2
) return t_xx_smena_change_table pipelined
as
    l_row           xx_disl_smena_change_v%rowtype;
    l_function      varchar2(100):='get_snapshot_wagon';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    err_msg         varchar2(4000);
    l_error         exception;
    
    l_json_clob     clob;
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    
    l_station_id    number;
    l_date_from     varchar2(50);
    l_date_to       varchar2(50);
    l_smena         varchar2(50);
    l_status_id     number;
    l_user_change_id number;
    l_user_reception_id number;
    l_result        varchar2(4000);
    /*Сводная сводка мест нахождения ЗУ*/
    cursor cur_railway(p_shift_change_id number, p_station_id number) is
        select nvl(l_even.railway_number,l_odd.railway_number) railway_number,
                     nvl(l_even.count_correct,0)+nvl(l_odd.count_correct,0)-(nvl(l_even.count_incorrect,0)+nvl(l_odd.count_incorrect,0))l_count,
                     nvl(l_even.count_incorrect,0)+nvl(l_odd.count_incorrect,0) l_count_fit,
                     case when h.railway_id > 0 then nvl(l_even.inst,'---')||'/'||nvl(l_odd.inst,'---') else l_even.inst end dev,
                     case when h.railway_id > 0 then  
                       'Уст: '||to_char(h.date_fix_odd_txt,'DD.MM.YYYY HH24:MI')
                                    ||' Отв.: '||h.user_rep
                                    ||' Регистр: '||h.created_user_name||' ('||to_char(h.created_date,'DD.MM.YYYY HH24:MI')||').' else null end note,
                     h.place place
        from
          (select   nvl (x.railway_number, x.place_name) railway_number,
                   listagg (
                      replace (ltrim (replace (x.seg4, '0', ' ')), ' ', '0') || replace (ltrim (replace (x.seg5, '0', ' ')), ' ', '0'),',' )
                   within group (order by x.station_id,
                                             x.shift_change_id,
                                             decode (x.place, 'place', 2, 1),
                                             nvl (x.railway_number, x.place_name))
                      inst,
                   count (x.instance_id) count_correct,
                   sum (x.inspection_count) count_incorrect,
                   nvl(x.railway_id,(-1)*x.place_id) railway_id,
                   x.shift_change_id
            from   xx_etw.xx_disl_snapshot_wagon_v x
           where   1 = 1 
                   and x.shift_change_id = p_shift_change_id
                   and x.station_id = p_station_id
                   and (nvl (x.place, '*') = 'place' or nvl (x.side_type, '*') = 'EVEN')
        group by   nvl (x.railway_number, x.place_name),
                   nvl(x.railway_id,(-1)*x.place_id),
                   x.shift_change_id) l_even,
      (select   nvl (x.railway_number, x.place_name) railway_number,
                   listagg (
                      replace (ltrim (replace (x.seg4, '0', ' ')), ' ', '0')
                      || replace (ltrim (replace (x.seg5, '0', ' ')), ' ', '0'),
                      ',' )
                   within group (order by x.station_id,
                                             x.shift_change_id,
                                             decode (x.place, 'place', 2, 1),
                                             nvl (x.railway_number, x.place_name))
                      inst,
                   count (x.instance_id) count_correct,
                   sum (x.inspection_count) count_incorrect,
                   x.shift_change_id,
                   x.railway_id
            from   xx_etw.xx_disl_snapshot_wagon_v x
           where   1 = 1 
                   and x.shift_change_id = p_shift_change_id
                   and x.station_id = p_station_id
                   and (nvl (x.place, '*') = 'railways' and nvl (x.side_type, '*') = 'ODD')
        group by   nvl (x.railway_number, x.place_name),
                   x.shift_change_id,
                   x.railway_id) l_odd,
          (select distinct 
                 x.shift_change_id,
                 nvl(x.railway_id,(-1)*x.place_id) railway_id,
                 x.user_rep,
                 x.created_user_name,
                 x.created_date,
                 x.date_fix_odd_txt,
                 x.place
            from xx_etw.xx_disl_snapshot_wagon_v x
                where 1=1
                      and x.shift_change_id = p_shift_change_id
                      and x.station_id = p_station_id
            ) h
     where 1=1
           and h.shift_change_id = l_odd.shift_change_id(+)
           and h.railway_id = l_odd.railway_id(+)
           and h.shift_change_id = l_even.shift_change_id(+)
           and h.railway_id = l_even.railway_id(+)
     order by decode(h.place, 'place',2,1),nvl(l_even.railway_number,l_odd.railway_number);
    
begin
    l_json_par := xx_wms.json(p_params);
    l_station_id := l_json_par.get_string('station_id'); -- Станция
    l_date_from := l_json_par.get_string('date_from'); 
    l_date_to := l_json_par.get_string('date_to'); 
    l_smena := l_json_par.get_string('smena'); 
    
    l_user_change_id := l_json_par.get_string('ch_user');
    l_user_reception_id := l_json_par.get_string('rep_user');
    l_status_id := l_json_par.get_string('status_id'); 
    l_row := null;
    l_json_list := json_list(); 
    for c_row in (
            select   sv.*
                     
              from   xx_etw.xx_disl_smena_change_v sv, 
                     xx_etw.xx_disl_shift_change sc
             where       1 = 1
                     and nvl(sc.DELETED,'N') = 'N'
                     and sv.shift_change_id = sc.shift_change_id
                     and sc.STATION_ID = nvl(l_station_id,sc.STATION_ID)
                     and sc.smena_change_id = nvl (l_smena, sc.smena_change_id)
                     and nvl(sc.status_id,-1) = nvl (l_status_id, nvl(sc.status_id,-1))
                     and nvl(sc.user_change_id,-1) = nvl (l_user_change_id, nvl(sc.user_change_id,-1))
                     and nvl(sc.user_reception_id,-1) = nvl (l_user_reception_id, nvl(sc.user_reception_id,-1))
                     and sc.start_date_shift between to_date(l_date_from,'dd.mm.yyyy hh24:mi') and nvl(to_date(l_date_to,'dd.mm.yyyy hh24:mi'),sc.date_change)
            order by sc.start_date_shift,sv.station_name
           
           )
    loop
        l_row := null;
        
        l_row.shift_change_id := c_row.shift_change_id;
        l_row.smena_num := c_row.smena_num; -- Номер смены
        l_row.status_name := c_row.status_name; -- Название статуса
        l_row.status_id := c_row.status_id; -- ID Статуса
        l_row.last_status_id := c_row.last_status_id; -- ID Статуса
        l_row.created_name := c_row.created_name;  
        l_row.created_date := c_row.created_date;
        l_row.last_update_date := c_row.last_update_date;
        l_row.station_short_name := c_row.station_short_name;
        
        l_row.railways_count := nvl(c_row.railways_count,0)/*+nvl(c_row.incorrect_railways,0)*/; -- Назначено
        l_row.place_count := nvl(c_row.place_count,0)/*+nvl(c_row.incorrect_place,0)*/; -- В Запасах    
        l_row.incorrect_railways := nvl(c_row.incorrect_railways,0);-- В т.ч. не годных (среди назначенных)
        l_row.incorrect_place := nvl(c_row.incorrect_place,0); -- В т.ч. не годных (в ящиках/пирамидах)
        l_row.inccorect_total :=nvl(c_row.incorrect_place,0)+nvl(c_row.incorrect_railways,0); -- Итого
        
        /*********** Сдача смены *****************/
        l_row.sign_of_change := c_row.sign_of_change;
        l_row.smena_change := c_row.smena_change;
        l_row.smena_change_id := c_row.smena_change_id;
        l_row.user_change_id := c_row.user_change_id;
        l_row.user_change := c_row.user_change; 
        l_row.date_change := c_row.date_change;
        l_row.note_change := c_row.note_change;
        l_row.start_date_shift := c_row.start_date_shift;        
        l_row.dev_change_total := c_row.dev_change_total; -- Сдача смены. Итого ЗУ (из формы)
        l_row.dev_change_correct := c_row.dev_change_correct; -- Сдача смены. Годных (из формы)
        l_row.dev_change_inccorect := c_row.dev_change_inccorect; -- Сдача смены. Исключены из использования (из формы)
        
        /*********** Прием смены *****************/
        l_row.sign_of_reception := c_row.sign_of_reception;
        l_row.user_reception := c_row.user_reception;
        l_row.date_reception := c_row.date_reception;
        l_row.smena_reception_id := c_row.smena_reception_id;
        l_row.dev_reception_total := nvl(c_row.dev_reception_total,0); -- Прием смены. Итого ЗУ (из формы)
        l_row.dev_reception_correct := nvl(c_row.dev_reception_correct,0); -- Прием смены. Годных (из формы)
        l_row.dev_reception_inccorect := nvl(c_row.dev_reception_inccorect,0); -- Прием смены. Исключены из использования (из формы)
        l_row.user_reception_id := c_row.user_reception_id;
        l_row.note_reception := c_row.note_reception;
               
        l_json_list := json_list(); 
        /*Сводная сводка мест нахождения ЗУ*/
        for l_dvc in cur_railway(c_row.shift_change_id,c_row.station_id)
        loop
            l_json_tmp := json();
            l_json_tmp.put('railway_number',l_dvc.railway_number);
            l_json_tmp.put('count',l_dvc.l_count);
            l_json_tmp.put('count_fit',l_dvc.l_count_fit);
            
            l_json_tmp.put('device',l_dvc.dev);
            l_json_tmp.put('note',l_dvc.note);
            l_json_list.append(l_json_tmp.to_json_value);
        end loop;
        l_row.l_mass_short_wag := l_json_list.to_char(false);  
        pipe row (l_row);
    end loop;
end;

-- Сохраняем данные с сдачи-приема смены
function save_shift_change(
    p_user_id           number,
    p_add_data          clob    
) return varchar2
as 
    l_function      varchar2(100):='save_shift_change';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    err_msg         varchar2(4000);
    l_error         exception;
    l_add_date      varchar2(32000);
    l_json_par      json;
    l_json          json;
    l_json_tmp      json; 
    l_json_list     json_list;
    l_json_value    json_value;
    l_json_val      json_value;
    l_station_id     number;
    l_shift_change_id   number;
    l_row_shift     xx_etw.xx_disl_shift_change%rowtype;
    l_row_wagon     xx_etw.xx_disl_snapshot_wagon%rowtype;
    l_result        varchar2(4000);
    l_button        varchar2(50);
    l_sign_of_change        varchar2(1);
    l_sign_of_reception     varchar2(1);
    l_status_id     number;
    l_count_sm      number;
    l_clob clob;
begin
    l_json_par := xx_wms.json(p_add_data);
    l_row_shift.shift_change_id := l_json_par.get_string('shift_change_id');                            -- id shift_change_id
    l_station_id:= l_json_par.get_string('station_id');                                                 -- Станция
    l_row_shift.status_id := l_json_par.get_string('status_id');                                        -- Статус
    l_row_shift.sign_of_change := l_json_par.get_string('sign_of_change');                              -- Признак сдачи смены 
    l_row_shift.smena_change_id := l_json_par.get_string('smena_change_id');                            -- Смена (Сдача)
    l_row_shift.user_change_id := l_json_par.get_string('user_change_id');                              -- Кто сдает смену 
    l_row_shift.date_change := to_date(l_json_par.get_string('date_change'),'DD.MM.YYYY HH24:MI');      -- Дата и время сдачи смены 
    l_row_shift.note_change := l_json_par.get_string('note_change');                                    -- Примечание (Сдача смены)
    l_row_shift.start_date_shift := to_date(l_json_par.get_string('start_date_shift'),'DD.MM.YYYY HH24:MI'); -- Дата и время начало смены (МСК)
    l_row_shift.dev_change_total := l_json_par.get_string('dev_change_total');                          -- Итого ЗУ(Сдача)
    l_row_shift.dev_change_correct := l_json_par.get_string('dev_change_correct');                      -- Годных ЗУ(Сдача)
    l_row_shift.dev_change_inccorect := l_json_par.get_string('dev_change_inccorect');                  -- НеГодных ЗУ(Сдача)
    l_row_shift.smena_reception_id := l_json_par.get_string('smena_reception_id');                      -- Смена (прием)
    l_row_shift.user_reception_id := l_json_par.get_string('user_reception_id');                        -- Смену принял (прием)
    l_row_shift.date_reception := to_date(l_json_par.get_string('date_reception'),'DD.MM.YYYY HH24:MI');-- Дата и время принятия смены(прием)
    l_row_shift.note_reception := l_json_par.get_string('note_reception');                              -- Примечание(прием)
    l_row_shift.dev_reception_total := l_json_par.get_string('dev_reception_total');                    -- Итого ЗУ(прием)
    l_row_shift.dev_reception_correct := l_json_par.get_string('dev_reception_correct');                -- Годных ЗУ(прием)
    l_row_shift.dev_reception_inccorect := l_json_par.get_string('dev_reception_inccorect');            -- НеГодных ЗУ(прием)
    l_row_shift.sign_of_reception := l_json_par.get_string('sign_of_reception');                        -- Признак приема смены
    l_button := l_json_par.get_string('button');
    
    l_status_id:=l_row_shift.status_id; -- Cтатус
 
    if nvl(l_row_shift.shift_change_id,0) = 0 then
        l_shift_change_id:= xx_etw.xx_disl_shift_change_seq.nextval();
        begin
          select status_id into l_status_id
            from xx_etw.xx_disl_sh_status
           where lower(DESCR) = 'сдать';
        exception when others then
             l_status_id:=1; -- Проект
        end;  
    else 
        l_shift_change_id:=l_row_shift.shift_change_id;
    end if;
    
    if (l_button = 'btn_change') then
        l_status_id:=5; -- Сдан -- xx_disl_sh_status
        l_row_shift.sign_of_change:='Y';
    end if;
    if (l_button = 'btn_reception') then
        l_status_id:=2; --Принят-- xx_disl_sh_status
        l_row_shift.sign_of_reception:='Y';
    end if;
    begin
        select count(*) into l_count_sm
          from xx_etw.xx_disl_shift_change x
         where station_id = l_station_id
               and x.smena_change_id = l_row_shift.smena_change_id
               and x.status_id = l_status_id
               and nvl(x.deleted,'N') = 'N';
    exception when others then
        l_count_sm:=0;
    end;
    log_new(l_log_id,l_function,'l_count_sm = '||nvl(l_count_sm,0)||' l_status_id='||l_status_id);
    -- Статус = Сдать и станция = Новая
    if (nvl(l_count_sm,0) >= 4 and l_status_id = 4) then
        return 'fail$'||'В системе более '||nvl(l_count_sm,0)||' незавершенных операций со статусом "Сдать"! Завершите предыдущие!';      
    end if;
    -- Статус = Сдать и станция = Новая
    if (nvl(l_count_sm,0) >= 2 and l_status_id = 3) then
        return 'fail$'||'В системе более '||nvl(l_count_sm,0)||' незавершенных операций со статусом "Обновить"! Завершите предыдущие!';      
    end if;
    log_new(l_log_id,l_function,'shift_change_id = '||l_row_shift.shift_change_id
                             ||' l_station_id = '||l_station_id
                             ||' status_id = '||l_status_id
                             ||' sign_of_change = '||l_row_shift.sign_of_change 
                             ||' smena_change_id = '||l_row_shift.smena_change_id 
                             ||' user_change_id = '||l_row_shift.user_change_id  
                             ||' note_change = '||l_row_shift.note_change
                             ||' start_date_shift = '||l_row_shift.start_date_shift
                             ||' dev_change_total = '||l_row_shift.dev_change_total
                             ||' dev_change_correct = '||l_row_shift.dev_change_correct
                             ||' dev_change_inccorect = '||l_row_shift.dev_change_inccorect
                             ||' smena_reception_id = '||l_row_shift.smena_reception_id
                             ||' user_reception_id = '||l_row_shift.user_reception_id
                             ||' date_reception = '||l_row_shift.date_reception
                             ||' note_reception = '||l_row_shift.note_reception
                             ||' dev_reception_total = '||l_row_shift.dev_reception_total
                             ||' dev_reception_correct = '||l_row_shift.dev_reception_correct
                             ||' dev_reception_inccorect = '||l_row_shift.dev_reception_inccorect
                             ||' sign_of_reception = '||l_row_shift.sign_of_reception
                             );
        if nvl(l_row_shift.shift_change_id,0) = 0 then
           insert into xx_etw.xx_disl_shift_change 
                        (SHIFT_CHANGE_ID, 
                         CREATED_BY, 
                         CREATED_DATE, 
                         LAST_UPDATE_BY, 
                         LAST_UPDATE_DATE,
                         STATION_ID, 
                         STATUS_ID,
                         last_status_id,
                         sign_of_change,
                         SMENA_CHANGE_ID,
                         USER_CHANGE_ID, 
                         DATE_CHANGE, 
                         NOTE_CHANGE, 
                         start_date_shift, 
                         DEV_CHANGE_TOTAL, 
                         DEV_CHANGE_CORRECT, 
                         DEV_CHANGE_INCCORECT)
            values (l_shift_change_id,
                    p_user_id, 
                    sysdate, 
                    p_user_id, 
                    sysdate,
                    l_station_id, 
                    l_status_id,
                    l_status_id,
                    l_row_shift.sign_of_change,
                    l_row_shift.smena_change_id,
                    l_row_shift.user_change_id, 
                    l_row_shift.date_change, 
                    l_row_shift.note_change, 
                    l_row_shift.start_date_shift, 
                    l_row_shift.dev_change_total, 
                    l_row_shift.dev_change_correct, 
                    l_row_shift.dev_change_inccorect
                    );
        else 
            update xx_etw.xx_disl_shift_change 
               set last_update_by = p_user_id,
                   last_update_date = sysdate, 
                   status_id = case when l_status_id = 3 then LAST_STATUS_ID else l_status_id end,
                   sign_of_change=l_row_shift.sign_of_change,
                   smena_change_id=l_row_shift.smena_change_id,
                   user_change_id=l_row_shift.user_change_id, 
                   date_change =l_row_shift.date_change, 
                   start_date_shift=l_row_shift.start_date_shift, 
                   dev_change_total=l_row_shift.dev_change_total, 
                   dev_change_correct=l_row_shift.dev_change_correct, 
                   dev_change_inccorect=l_row_shift.dev_change_inccorect,
                   note_change=l_row_shift.note_change,
                   
                   sign_of_reception=l_row_shift.sign_of_reception,
                   smena_reception_id=l_row_shift.smena_reception_id,
                   user_reception_id=l_row_shift.user_reception_id,
                   date_reception=l_row_shift.date_reception,
                   note_reception=l_row_shift.note_reception,
                   dev_reception_total=l_row_shift.dev_reception_total,
                   dev_reception_correct=l_row_shift.dev_reception_correct,
                   dev_reception_inccorect=l_row_shift.dev_reception_inccorect
                   
             where SHIFT_CHANGE_ID = l_shift_change_id;
        end if;
        l_json_value := l_json_par.get('mass_shift');
        l_json_list := json_list(l_json_value);
        if (l_json_list.count >0) then
            delete  xx_etw.xx_disl_snapshot_wagon where shift_change_id = l_shift_change_id;
            for i in 1..l_json_list.count loop
                l_json_val := l_json_list.get(i);
                l_json := json(l_json_val); 
                l_row_wagon.snapshot_wagon_id:=xx_etw.xx_disl_snapshot_wagon_seq.nextval();
                l_row_wagon.shift_change_id:=l_shift_change_id;
                --log_new(l_log_id,l_function,'l_json.get_string.place_id'||l_json.get_string('place_id'));
                l_row_wagon.place_id:=to_number(l_json.get_string('place_id'));
                l_row_wagon.place:=l_json.get_string('place');
                
                l_row_wagon.transactions_header_id:=l_json.get_string('transactions_header_id');
                l_row_wagon.part_id:=l_json.get_string('part_id');
                l_row_wagon.transactions_lines_id:=l_json.get_string('transactions_lines_id');
                l_row_wagon.transaction_type:=l_json.get_string('transaction_type');
                l_row_wagon.station_id:=l_station_id;
                l_row_wagon.railway_id:=l_json.get_string('railway_id');
                l_row_wagon.instance_id:=l_json.get_string('instance_id');
                
                l_row_wagon.side_type:=l_json.get_string('side_type');
                l_row_wagon.side_id:=l_json.get_string('side_id');
                l_row_wagon.fit_device:=l_json.get_string('fit_device');
                l_row_wagon.created_date:=to_date(l_json.get_string('created_date'),'DD.MM.YYYY HH24:MI:SS');
                l_row_wagon.created_user:=l_json.get_string('created_user');
                l_row_wagon.user_fix_even:=l_json.get_string('user_fix_even');
                
                l_row_wagon.date_fix_odd:=to_date(l_json.get_string('date_fix_odd'),'DD.MM.YYYY HH24:MI:SS');
                l_row_wagon.user_fix_odd:=l_json.get_string('user_fix_odd');
                l_row_wagon.date_fix_even:=to_date(l_json.get_string('date_fix_even'),'DD.MM.YYYY HH24:MI:SS');
                
                l_row_wagon.user_rep_even:=l_json.get_string('user_rep_even');
                l_row_wagon.user_rep_odd:=l_json.get_string('user_rep_odd');
                l_row_wagon.inspection_date:=to_date(l_json.get_string('inspection_date'),'DD.MM.YYYY HH24:MI:SS');
                
                l_row_wagon.date_fix_odd_txt:=to_date(l_json.get_string('date_fix_odd_txt'),'DD.MM.YYYY HH24:MI:SS');
                l_row_wagon.user_fix_txt:=l_json.get_string('user_fix_txt');
                l_row_wagon.user_rep_txt:=l_json.get_string('user_rep_txt');
                
                l_row_wagon.inspection_id:=l_json.get_string('inspection_id');
                
                
                insert into xx_etw.xx_disl_snapshot_wagon 
                values l_row_wagon;
            end loop;
        end if;
    commit;
    return 'done';     
exception
    when others then 
        rollback;
        log_new(l_log_id,l_function,'Erorr = '||sqlerrm);
        return 'fail$'||sqlerrm;       
end;

function save_shift_status(
    p_user_id           number,
    p_add_data          clob
) return varchar2
as
    l_function        varchar2(100):='save_shift_status';
    l_log_id          number := xx_etw.xx_disl_log_seq.nextval();
    err_msg           varchar2(4000);
    l_error           exception;
    l_add_date        varchar2(32000);
    l_json_par        json;
    l_json            json;
    l_json_tmp        json; 
    l_json_list       json_list;
    l_json_value      json_value;
    l_json_val        json_value;
    l_status_id       number;
    l_shift_change_id number;
    l_msg             varchar2(240);
    l_shift_ch_id     number;
    l_count_rec       number;
    l_status_descr    varchar2(2400);
begin
    l_json_par := xx_wms.json(p_add_data);
    l_shift_change_id := l_json_par.get_string('shift_change_id');
    l_status_id := l_json_par.get_string('status');
    l_status_descr := l_json_par.get_string('status_descr');
    begin
       select x1.shift_change_id into l_shift_ch_id
         from xx_etw.xx_disl_shift_change x1
        where 1=1
              and x1.shift_change_id = l_shift_change_id
              and sysdate between x1.start_date_shift and x1.start_date_shift+15/24;
    exception when others then 
        l_msg:='C момента даты и времени начала смены прошло более 15 часов. ';     
    end;
    begin
        select count(*) into l_count_rec
          from xx_etw.xx_disl_shift_change x
         where 1=1
               and nvl(x.DELETED,'N') = 'N'
               and exists(select *
                    from xx_etw.xx_disl_shift_change x1
                    where 1=1
                          and x1.shift_change_id = l_shift_change_id
                          and x.start_date_shift>x1.start_date_shift
                          and x1.station_id = x.station_id
               );
    exception when others then
        l_count_rec:=0; 
    end;
    if (nvl(l_count_rec,0)>0) then
        l_msg:=l_msg||'Существует зарегистрированные записи. Кол-во:'||l_count_rec;
    end if;   
    if (l_status_id = 3) then -- статус = Обновить
        update xx_etw.xx_disl_shift_change 
           set STATUS_ID = l_status_id,
               LAST_UPDATE_BY = p_user_id,
               LAST_UPDATE_DATE = sysdate,
               last_status_id = status_id,
               NOTE = l_status_descr
        where 1=1
              and SHIFT_CHANGE_ID = l_shift_change_id;
    elsif  (l_status_id = 6) then -- статус = удалить 
        -- - если с момента даты и времени начала смены прошло не более 15 часов;
        -- - если отсутствует сл. регистрация записей (текущей смены) прием-сдача смены по данной станции.
        if (trim(l_msg) is not null) then
            return 'fail$'||'Невозможно удалить смену.'||l_msg ; 
        end if;
        update 
            xx_etw.xx_disl_shift_change 
          set status_id = l_status_id,
              last_update_by = p_user_id,
              last_update_date = sysdate,
              deleted = 'Y',
              deleted_by = p_user_id,
              deleted_date = sysdate,
              last_status_id = status_id,
              NOTE = l_status_descr
        where 1=1
              and shift_change_id = l_shift_change_id;
    else 
        update xx_etw.xx_disl_shift_change 
           set STATUS_ID = l_status_id,
               LAST_UPDATE_BY = p_user_id,
               LAST_UPDATE_DATE = sysdate,
               last_status_id = status_id,
               NOTE = l_status_descr
        where 1=1
              and SHIFT_CHANGE_ID = l_shift_change_id;
    end if;
    commit;
    return 'done';     
exception
    when others then 
        rollback;
        log_new(l_log_id,l_function,'Erorr = '||sqlerrm);
        return 'fail$'||sqlerrm;       
end;

function get_users_for_change(p_credential_id number default null)
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for tmp in (select u.id
                      ,u.full_name
                  from xx_disl_users                u
                 where 1=1
                   and u.enterprise = 4
                 order by
                       u.full_name
               )
    loop
        l_row.id := tmp.id;   
        l_row.name := tmp.full_name;
        
        pipe row (l_row);
    end loop;
end;

function get_route_smena_change
return t_xx_route_smena_change_table pipelined
as
    l_row t_xx_route_smena_change_row;
begin
    for tmp in (
        select smena_id     id
              ,descr ||' (с '||FROM_TIME||' до '||TO_TIME||')'       name
              ,from_time
          from xx_etw.xx_disl_lr_smena
         where 1=1
               and smena_id not in (2,4)
    ) 
    loop
        l_row.id := tmp.id;
        l_row.name := tmp.name;
        l_row.from_time := tmp.from_time;
        pipe row (l_row);
    end loop;
end;

/***************** Контроль *******************************/
function get_control_standart(
    p_params        varchar2
) return t_xx_control_table pipelined
as
    l_row t_xx_control_row;
    l_function          varchar2(100):='get_control_standart';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();
    l_cause_id          number;
    l_car_number        varchar2(50);
    l_color_id          number;
    l_date_from         varchar2(50);
    l_date_to           varchar2(50);
    l_json              json;
    l_result            varchar2(4000);
begin   
    l_json := xx_wms.json(p_params);
    
    l_cause_id := l_json.get_string('cause_id');
    l_color_id := l_json.get_string('color_id');
    l_car_number := l_json.get_string('car_number');
    if (l_json.get_string('date_from') is not null) then 
        l_date_from := l_json.get_string('date_from');
    end if;
    if (l_json.get_string('date_to') is not null) then 
        l_date_to := l_json.get_string('date_to'); 
    end if;
    
    for tmp in (
        SELECT   x.CREATED_BY, 
                 to_char(x.CREATION_DATE,'DD.MM.YYYY HH24:MI:SS') CREATION_DATE,
                 x.LAST_UPDATED_BY, 
                 to_char(x.LAST_UPDATE_DATE,'DD.MM.YYYY HH24:MI:SS') LAST_UPDATE_DATE,
                 x.CAR_NUMBER, 
                 to_char(x.START_DATE,'DD.MM.YYYY') START_DATE, 
                 to_char(x.END_DATE,'DD.MM.YYYY') END_DATE, 
                 x.CODE, 
                 x.NOTE, 
                 cl.DESCRIPTION COLOR_NAME,
                 cc.CODE cause_code,
                 cc.DESCRIPTION cause_desc,
                 du.FULL_NAME CREATED_NAME,
                 cc.ID cause_id,
                 cl.id color_id,
                 x.ID_CONTROL
          FROM   XX_ETW.XX_DISL_CAR_CONTROL x,
                 xx_etw.xx_disl_color cl,
                 xx_etw.xx_disl_code_cause cc,
                 xx_etw.xx_disl_users du
         WHERE   1 = 1 
                 and x.id_color = cl.id 
                 and x.created_by = du.id
                 and x.id_cause = cc.id(+)
                 and nvl(x.deleted,'N') = 'N'
                 and nvl(x.id_cause,-1) = nvl(l_cause_id,nvl(x.id_cause,-1))
                 and x.car_number = nvl(l_car_number,x.car_number)
                 and nvl(cl.id,-1) = nvl(l_color_id,nvl(cl.id,-1))
                 --and trunc(nvl(l_date_from,sysdate)) between nvl (x.start_date, sysdate) and nvl (x.end_date, sysdate)
                 and ((to_date(l_date_from,'dd.mm.yyyy') between nvl (x.start_date, sysdate) and nvl (x.end_date, sysdate) and l_date_from is not null) or  
                        (l_date_from is null and 1=1)
                        
                     )
    ) 
    loop
        l_row.id_control := tmp.id_control;
        l_row.car_number := tmp.car_number;
        l_row.cause_code := tmp.cause_code;
        l_row.creation_date := tmp.creation_date;
        l_row.last_update_date := tmp.last_update_date;
        l_row.start_date := tmp.start_date;
        l_row.end_date := tmp.end_date;
        l_row.created_name := tmp.created_name;
        l_row.cause_desc := tmp.cause_desc;
        l_row.cause_id := tmp.cause_id;
        l_row.color_id := tmp.color_id;
        l_row.note := tmp.note;
        l_row.color_name := tmp.color_name;
        
        pipe row (l_row);
    end loop;
end;

function xx_is_date (p_value in varchar2,p_date_format in varchar2) return boolean
is
    l_val date;
begin
    l_val := to_date(trim(p_value),p_date_format);
    
    return true;
    exception 
        when others then return false;
end;

function xx_is_number (p_number varchar) return boolean
is
    l_val number;
begin
    l_val := to_number(p_number);
    return true;
    exception when others then return false;
end;

function get_sum (p_car_number number) return number
is
    l_sum number;
    l_car_num number;
begin
   l_car_num := p_car_number;
   l_sum := 0;
   while (l_car_num > 0)
   loop
     l_sum := mod(l_car_num,10)+l_sum;
     l_car_num := floor(l_car_num/10);
   end loop;
   return l_sum;
end;
function check_car_number (p_car_number varchar) return number
is
    l_val number;
    l_sum number;
    i number;
    i2 number;
    num number;
    
begin
    if (p_car_number ='00009138' or p_car_number='00009874') then
        return 0;
    end if;
    if (length(p_car_number) != 8) then
        return 0;
    end if;
    /*Проверяем что строка состоит из цифр*/
    if (xx_is_number(p_car_number) = false) then
        return 0;
    end if;
    
    l_sum:= 0;
    i:=0;
    
    while (i<7)
    loop
        num := substr (p_car_number,i+1,1);
        --DBMS_OUTPUT.put_line('i = '||i||' num='||num);
        if mod(i,2)=0 then i2:=2;
           else i2:=1;
        end if;
        --DBMS_OUTPUT.put_line('i = ('||i||') l_sum='||l_sum||'+('||num||'*'||i2||' ='||num*(i2)||' :'||get_sum(num*(i2))||');');
        l_sum :=l_sum+get_sum(num*(i2)); 
        i:=i+1;
    end loop;
    --DBMS_OUTPUT.put_line('Full: l_sum='||l_sum);    
    if ((ceil(l_sum/10)*10-l_sum) = substr (p_car_number,8,1)) then
        return 1;
     else 
        return 0;
    end if;
    
    return l_val;
end;

function get_control_code_cause(
    p_params        varchar2
) return t_xx_control_code_cause_table pipelined
as
    l_row t_xx_control_code_cause_row;
begin
    for tmp in (
        SELECT   *
          FROM   xx_etw.xx_disl_code_cause
    ) 
    loop
        l_row.id := tmp.id;
        l_row.code := tmp.code;
        l_row.description := tmp.description;
        pipe row (l_row);
    end loop;
end;

-- Сохранение
function save_control_car(
    p_user_id           number,
    p_row_id            number,
    p_add_data          varchar2    
) return varchar2 
as
    l_row           XX_ETW.XX_DISL_CAR_CONTROL%rowtype;   
    l_json          json;
    l_date_from     date;
    l_date_to       date;
    l_car_number    varchar2(240);
    l_id_control    number;
    l_count         number;
    l_msg           varchar2(240);
    l_result        varchar2(4000);
begin   
    l_json := xx_wms.json(p_add_data);
    l_id_control := l_json.get_string('id_control');
    l_car_number :=l_json.get_string('car_number');    
    l_date_from :=to_date(l_json.get_string('start_date'),'dd.mm.yyyy');
    l_date_to :=to_date(l_json.get_string('end_date'),'dd.mm.yyyy');
    
    -- Проверка номера вагона
    if xx_dislocation.check_car_number(l_car_number) = 0 then 
       return 'fail$'||'.Неверный номер вагона.';
    end if;
        
    begin
    select count(*) into l_count
        from XX_ETW.XX_DISL_CAR_CONTROL x
        where 1=1
              and CAR_NUMBER = l_car_number
              and nvl(x.deleted,'N') = 'N'
              and ((START_DATE between l_date_from and trunc(nvl(l_date_to,sysdate))) or (trunc(nvl(END_DATE,sysdate)) between l_date_from and trunc(nvl(l_date_to,sysdate))))
              and id_control <> nvl(l_id_control,0);
    exception when others then l_count :=0;
    end;

    if (l_count > 0) then
        return 'fail$'||'.Вагон уже зарегистрирован в данном периоде';
    end if;
    
    if (nvl(l_id_control,0) = 0) then
        l_row.id_control := xx_etw.xx_disl_car_control_seq.nextval();
        l_row.created_by := p_user_id;
        l_row.creation_date := sysdate;
        l_row.last_updated_by := p_user_id;
        l_row.last_update_date := sysdate;
        l_row.car_number :=l_json.get_string('car_number');
        l_row.id_color:=l_json.get_string('color_id');
        l_row.id_cause :=l_json.get_string('cause_id');
        l_row.start_date :=to_date(l_json.get_string('start_date'),'dd.mm.yyyy');
        l_row.end_date :=to_date(l_json.get_string('end_date'),'dd.mm.yyyy');         
        l_row.note :=l_json.get_string('note');

        insert into XX_ETW.XX_DISL_CAR_CONTROL  
        values l_row;
    else
        update XX_ETW.XX_DISL_CAR_CONTROL 
           set last_updated_by = p_user_id
              ,last_update_date = sysdate
              ,id_color=l_json.get_string('color_id')
              ,id_cause =l_json.get_string('cause_id')
              ,start_date =to_date(l_json.get_string('start_date'),'dd.mm.yyyy')
              ,end_date =to_date(l_json.get_string('end_date'),'dd.mm.yyyy')      
              ,note =l_json.get_string('note')
         where id_control = l_id_control;
    end if;
          
    commit;
    l_result := 'done';   
    return l_result;
exception
    when others then rollback; return 'fail$'||sqlerrm;
end;
function delete_control_car(
    p_user_id           number,
    p_row_id            number,
    p_add_data          varchar2    
) return varchar2 
as
    l_row           XX_ETW.XX_DISL_CAR_CONTROL%rowtype;   
    l_json          json;
    l_date_from     date;
    l_date_to       date;
    l_car_number    varchar2(240);
    l_id_control    number;
    l_count         number;
    l_msg           varchar2(240);
    l_result        varchar2(4000);
begin   
    l_json := xx_wms.json(p_add_data);
    l_id_control := l_json.get_string('id_control');
    update XX_ETW.XX_DISL_CAR_CONTROL 
                set deleted = 'Y', 
                    deleted_by = p_user_id, 
                    deleted_date = sysdate
     where id_control = l_id_control;
    commit;
    l_result := 'done';   
    return l_result;
exception
    when others then rollback; return 'fail$'||sqlerrm;
end;
/*********************************************************/
procedure update_shop_info(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2)
as
    l_function              varchar2(100) := 'update_shop_info';    
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    
    l_shop_info_row         xx_disl_shop_info%rowtype;
    l_freight_name          varchar2(200);
    l_result                varchar2(4000); 
    l_shop_info_id          number;
    
    l_cars                  varchar2(2000);
    l_cars_count            number;
    l_cars_with_railways    varchar2(4000);
    l_cars_item_uborka      varchar2(32000);
    l_cars_item_poda4a      varchar2(32000);
    
    l_ip_server             varchar2(20) :='123';
    x_out_loading_tbl       t_loading_table;
    x_out_load_rec          t_loadnig_rec;
begin    
    apps.xxmssql_pkg.get_xx_bi_naliv_hist_tmp();
    apps.xxmssql_pkg.get_xx_bi_naliv_tmp();
    
    select utl_inaddr.get_host_address
      into l_ip_server 
      from dual
    ;    

    for l_source_si in (
        select rr.round_id
              ,shop_info.*
          from (select shop_info.car_number
                      ,d_post       date_post
                      ,d_nach       date_start
                      ,d_end        date_end
                      ,d_zaj        date_zayavka_uvod
                      ,d_uw         date_uvod
                      ,p_osm        who_looked
                      ,p_otgr       who_start
                      ,p_otgr       who_end
                      ,p_zaj        who_zayavka
                      ,decode(wes
                             ,0,sk
                             ,wes -- change 18.10.2018 KuchukbaevRF
                             )
                                    weight_net
                      ,freight
                      ,gr
                      ,row_number() over(partition by shop_info.car_number order by d_post desc,wes desc) rn 
                  from (select num              car_number
                              ,d_post 
                              ,d_nach
                              ,d_end
                              ,d_zaj
                              ,d_uw
                              ,p_nach
                              ,p_osm
                              ,p_otgr
                              ,p_zaj
                              ,to_number(replace(nvl(sk,'0'),',','.'),'999999999D99999999','NLS_NUMERIC_CHARACTERS = ''. ''')        sk
                              ,to_number(replace(nvl(wes,'0'),',','.'),'999999999D99999999','NLS_NUMERIC_CHARACTERS = ''. ''')       wes
                              ,freight
                              ,null gr
                          from xx_bi.xx_bi_naliv_hist_tmp
                         where 1=1
                         union
                        select num
                              ,post 
                              ,nach
                              ,end_
                              ,zaj
                              ,uw
                              ,p_nach
                              ,p_osm
                              ,p_otgr
                              ,p_zaj
                              ,to_number(replace(nvl(sk,'0'),',','.'),'999999999D99999999','NLS_NUMERIC_CHARACTERS = ''. ''')        sk
                              ,to_number(replace(nvl(wes,'0'),',','.'),'999999999D99999999','NLS_NUMERIC_CHARACTERS = ''. ''')       wes
                              ,freight
                              ,gr
                          from xx_bi.xx_bi_naliv_tmp
                         where 1=1
                           and num != '0'
                       )
                                        shop_info
                 where 1=1 
--                 group by
--                       shop_info.car_number
--                      ,d_post
--                      ,d_nach
--                      ,d_end
--                      ,d_zaj
--                      ,d_uw
--                      ,p_osm
--                      ,p_otgr
--                      ,p_otgr
--                      ,p_zaj
--                      ,decode(wes
--                             ,0,sk
--                             ,sk
--                             )
--                      ,freight
                       )
                           
                                                shop_info
              ,(select r.railcar_id               car_number
                      ,r.round_id               round_id
                      ,coalesce(r.date_arrive
                               ,sh.come_date
                               ,sysdate
                               )
                                                date_arrive
                  from xx_etw.xx_disl_round             r
                      ,xx_etw.xx_disl_station_history   sh
                 where 1=1
                   and r.station_hist_id_out is null
                   and r.station_hist_id_in = sh.station_hist_id
                   and sh.in_date is not null
               )
                                                rr
         where 1=1
           and shop_info.car_number = rr.car_number
               
           and shop_info.date_post >= rr.date_arrive
               
           and shop_info.rn = 1
               
           and not exists(
               select 'x'
                 from xx_etw.xx_disl_shop_info si
                where 1=1
                  and si.round_id = rr.round_id
                  and si.date_post = shop_info.date_post
                  and si.date_start = shop_info.date_start
                  and si.date_end = shop_info.date_end
                  and si.date_zayavka_uvod = shop_info.date_zayavka_uvod
                  and si.date_uvod = shop_info.date_uvod
                  and si.weight_net = shop_info.weight_net
           )
    ) loop
            begin
                --dbms_output.put_line(l_source_si.round_id);
                select si.shop_info_id
                  into l_shop_info_id
                  from xx_etw.xx_disl_shop_info     si
                 where 1=1
                   and si.round_id = l_source_si.round_id
                   and si.date_post = l_source_si.date_post
                   and si.last_record = 'Y'
                ;
            exception
                when no_data_found then l_shop_info_id := null;
                log_new(l_log_id,l_function,'1.Error:l_shop_info_id! l_source_si.round_id='||l_source_si.round_id||' l_source_si.date_post='||to_char(l_source_si.date_post,'DD.MM.YYYY HH24:MI:SS')||' l_source_si.gr ='||l_source_si.gr);
                --when others then dbms_output.put_line('l_source_si.round_id = '||l_source_si.round_id);
            end;     
        if (l_shop_info_id is null) then
            begin
                select si.shop_info_id
                  into l_shop_info_id
                  from xx_etw.xx_disl_shop_info     si
                 where 1=1
                   and si.round_id = l_source_si.round_id
                   and (  si.date_post is null
                       or si.date_start is null
                       or si.date_end is null
                       or si.date_zayavka_uvod is null
                       or si.date_uvod is null
                       )
                ;
            exception
                when no_data_found then l_shop_info_id := null;
                log_new(l_log_id,l_function,'2.Error:l_shop_info_id! l_source_si.round_id='||l_source_si.round_id||' l_source_si.gr ='||l_source_si.gr);
                --when others then dbms_output.put_line('l_source_si.round_id = '||l_source_si.round_id);
            end;     
        end if;  
        -- возникают ситуации, когда дата приходит без времени => создается новая запись => происходит разгрузка цистерны, хотя был налив
        -- ошибка на стороне MSSQL (Добрынин А.)
        log_new(l_log_id,l_function,'Before change_cars_weight_net: l_source_si.round_id='||l_source_si.round_id
                                                                ||' l_source_si.car_number ='||l_source_si.car_number
                                                                ||' l_source_si.gr ='||l_source_si.gr
                                                                ||' l_source_si.date_post = '||to_char(l_source_si.date_post,'dd.mm.yyyy hh24:mi')
                                                                ||' l_source_si.date_start = '||to_char(l_source_si.date_start,'dd.mm.yyyy hh24:mi')
                                                                ||' l_source_si.date_end = '||to_char(l_source_si.date_start,'dd.mm.yyyy hh24:mi')
                                                                ||' l_source_si.date_zayavka_uvod = '||to_char(l_source_si.date_start,'dd.mm.yyyy hh24:mi')
                                                                ||' l_source_si.weight_net = '||replace(to_char(l_source_si.weight_net),',','.')
                                                                );
            declare
                l_prm xx_dislocation.t_change_cars_weight_rec;
            begin
                                                                                               
                l_prm.user_id           := -1;
                l_prm.cars_with_weight  := l_source_si.car_number||'|_|'
                                         ||REPLACE(TO_CHAR(l_source_si.weight_net),',','.')||'|'
                                         ||l_source_si.freight||'|'||'_'||'|'
                                         ||CASE WHEN TO_CHAR(l_shop_info_id) IS NULL
                                                THEN '_'
                                                ELSE TO_CHAR(l_shop_info_id)
                                           END||'$';
                l_prm.date_post         := TO_CHAR(l_source_si.date_post,        'dd.mm.yyyy hh24:mi');
                l_prm.date_start        := TO_CHAR(l_source_si.date_start,       'dd.mm.yyyy hh24:mi');
                l_prm.date_end          := TO_CHAR(l_source_si.date_end,         'dd.mm.yyyy hh24:mi');
                l_prm.date_zayavka_uvod := TO_CHAR(l_source_si.date_zayavka_uvod,'dd.mm.yyyy hh24:mi');
                l_prm.date_uvod         := TO_CHAR(l_source_si.date_uvod,        'dd.mm.yyyy hh24:mi');
                l_prm.who_looked_id     := NULL;
                l_prm.who_looked        := l_source_si.who_looked;
                l_prm.who_start_id      := NULL;
                l_prm.who_start         := l_source_si.who_start;
                l_prm.who_end_id        := NULL;
                l_prm.who_end           := l_source_si.who_end;
                l_prm.who_zayavka_id    := NULL;
                l_prm.who_zayavka       := l_source_si.who_zayavka;
                
                l_result := xx_dislocation.change_cars_weight_net(l_prm, x_out_loading_tbl);
            end;
        
            log_new(l_log_id,l_function,'l_result='||l_result||' car_number = '||l_source_si.car_number||' parameter1 = '||l_source_si.car_number||'|'||replace(to_char(l_source_si.weight_net),',','.')||'|'||l_source_si.freight||'$');
            if (l_result != 'done') then
                log_new(l_log_id,l_function,'car_number = '||l_source_si.car_number||' parameter1 = '||l_source_si.car_number||'|'||replace(to_char(l_source_si.weight_net),',','.')||'|'||l_source_si.freight||'$');
                raise_application_error(-20006,'Ошибка в процедуре change_cars_weight_net');
            end if; 
        --dbms_output.put_line('car_number = '||l_source_si.car_number||' l_shop_info_id = '||l_shop_info_id);
    end loop;
    
    commit;
    
    /*** обработка информации из цеха для создания заявок на уборку и подачу ***/
    begin
        select listagg(r.railcar_id,':') within group (order by r.railcar_id)||':'
              ,count('x')
          into l_cars
              ,l_cars_count
          from xx_etw.xx_disl_shop_info si
              ,xx_etw.xx_disl_round     r
         where 1=1
           and si.create_request = 'N'
           and si.date_end is not null
           and lower(si.freight_name) = 'метанол'
           and si.created_by = -1 /*заявки которые были созданы с помощью интерфейса*/
           
           and si.round_id = r.round_id
           
           and si.last_record = 'Y'
           
           and r.station_hist_id_out is null
        ;
    exception
        when others then l_cars := null; l_cars_count := 0;
    end;
    log_new(l_log_id,l_function,'l_cars = '||l_cars);
    
    begin
        if (l_cars_count != 0) then
            l_cars_with_railways := xx_etw.xx_dislocation.get_cars_with_railways(l_cars);
            log_new(l_log_id,l_function,'l_cars_with_railways = '||l_cars_with_railways);
            /*
            select listagg('_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||railway_id||xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'Метанол'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||cars_count||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||cars
                         ,xx_etw.xx_dislocation.g_del_req_1_d) within group (order by railway_id)
                   ||xx_etw.xx_dislocation.g_del_req_1_d
                                cars_item_uborka
                  ,listagg('_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||railway_id||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'ЦС'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'Годен'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'пор.'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'Метанол'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||cars_count||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'
                         ,xx_etw.xx_dislocation.g_del_req_1_d) within group (order by railway_id)
                   ||xx_etw.xx_dislocation.g_del_req_1_d
                                cars_item_poda4a
              into l_cars_item_uborka
                  ,l_cars_item_poda4a
              from (select nvl(to_char(railway_id),'_')         railway_id
                          ,count('x')   cars_count
                          ,listagg(car_number||xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,1),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,1))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,2),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,2))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||case
                                     when railway_id in (30,32) --если вагон не стоит на путях метанола для налива, то по умолчанию берем путь 18
                                       then decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,3),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,3))
                                       else '18_Наливная эстакада'
                                   end
                                        ||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,4),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,4))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,5),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,5))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,6),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,6))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||'0'||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||'0'||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||'0'
                                  ,xx_etw.xx_dislocation.g_del_req_3_d) within group (order by car_number)
                           ||xx_etw.xx_dislocation.g_del_req_3_d
                            cars
                      from xx_etw.xx_disl_cars_with_railways
                     group by
                           nvl(to_char(railway_id),'_')
                   );
             */ --- Ввалится с ошибкой ORA-01489: результат строковой конкатенации слишком велик
            
             for c_cur in (select listagg('_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||railway_id||xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'Метанол'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||cars_count||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ---||cars -- из-за нее и ввлится 
                         ||'<cars>'
                         ,xx_etw.xx_dislocation.g_del_req_1_d) within group (order by railway_id)
                   ||xx_etw.xx_dislocation.g_del_req_1_d cars_item_uborka
                  ,cars
                  ,listagg('_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||railway_id||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'ЦС'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'Годен'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'пор.'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'Метанол'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||cars_count||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'||xx_etw.xx_dislocation.g_del_req_2_d
                         ||'_'
                         ,xx_etw.xx_dislocation.g_del_req_1_d) within group (order by railway_id)
                   ||xx_etw.xx_dislocation.g_del_req_1_d
                                cars_item_poda4a
              --into l_cars_item_uborka ,l_cars_item_poda4a
              from (select nvl(to_char(railway_id),'_')         railway_id
                          ,count('x')   cars_count
                          ,listagg(car_number||xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,1),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,1))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,2),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,2))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||case
                                     when railway_id in (30,32) --если вагон не стоит на путях метанола для налива, то по умолчанию берем путь 18
                                       then decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,3),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,3))
                                       else '18_Наливная эстакада'
                                   end
                                        ||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,4),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,4))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,5),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,5))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||decode(xx_etw.xx_dislocation.get_info_for_car_request(car_number,6),null,'_',xx_etw.xx_dislocation.get_info_for_car_request(car_number,6))||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||'0'||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||'0'||xx_etw.xx_dislocation.g_del_req_4_d
                                 ||'0'
                                  ,xx_etw.xx_dislocation.g_del_req_3_d) within group (order by car_number)
                           ||xx_etw.xx_dislocation.g_del_req_3_d
                            cars
                      from xx_etw.xx_disl_cars_with_railways
                     group by
                           nvl(to_char(railway_id),'_')
                   )
               group by cars)
            loop
                l_cars_item_uborka:=l_cars_item_uborka||replace(c_cur.cars_item_uborka,'<cars>',c_cur.cars);
                l_cars_item_poda4a:=l_cars_item_poda4a||c_cur.cars_item_poda4a;
            end loop;
            
            --fnd_file.put_line(fnd_file.output, 'l_cars_item_uborka = '||l_cars_item_uborka);
            --fnd_file.put_line(fnd_file.output, 'l_cars_item_poda4a = '||l_cars_item_poda4a);
            
            log_new(l_log_id,l_function,'l_cars_item_uborka = '||substr(l_cars_item_uborka,1,3900));
            log_new(l_log_id,l_function,'l_cars_item_poda4a = '||substr(l_cars_item_poda4a,1,3900));
            
            l_result := xx_etw.xx_dislocation.save_request(186/*Метанол*/, null, to_char(sysdate,'dd.mm.yyyy hh24:mi'),to_char(sysdate + 4/24,'dd.mm.yyyy hh24:mi'), 2/*уборка*/, null ,l_cars_item_uborka);
            log_new(l_log_id,l_function,'save_request уборка. l_result = '||l_result);
            
            if (substr(l_result,1,4) = 'done') then
                l_result := xx_etw.xx_dislocation.save_request(186/*Метанол*/, null, to_char(sysdate,'dd.mm.yyyy hh24:mi'),to_char(sysdate + 4/24,'dd.mm.yyyy hh24:mi'), 1/*уборка*/, null ,l_cars_item_poda4a);
                log_new(l_log_id,l_function,'save_request подача. l_result = '||l_result);
            end if;
            
            if (substr(l_result,1,4) = 'done') then
                update xx_etw.xx_disl_shop_info
                   set create_request = 'Y'
                 where 1=1
                   and last_record = 'Y'
                   and round_id in (
                       select xx_etw.xx_dislocation.returnLastRound(regexp_substr(l_cars,'[^:]+',1,level))
                         from dual
                      connect by level <= regexp_count(l_cars,'[^:]+')
                   )
                ;
                log_new(l_log_id,l_function,'update xx_etw.xx_disl_shop_info. кол-во = '||sql%rowcount);   
            end if;
        end if;
    exception
        when others 
        then log_new(l_log_id,l_function,'ошибка создания заявки. sqlerrm = '||sqlerrm);
             if (l_ip_server='10.0.0.40'/*m5000*/) then
                 send_mail_general('Ошибка создания заявки в процедуре update_shop_info.',' sqlerrm = '||sqlerrm);
             end if;
    end;
     
    commit; 
exception
  when others then
    rollback;
    p_errbuf := sqlerrm; 
    p_retcode := '2';
end;


-- убрал 25.10.2018 
--procedure update_car_nsi(p_errbuf out nocopy varchar2,  p_retcode out nocopy varchar2) 
--is
--    cnst_lockname constant          varchar2(30) := 'LOCK_CAR_NSI_UPDATE';
--    cnst_expiration_secs constant   integer := 3600;
--    cnst_timeout constant           integer := 10;
--    
