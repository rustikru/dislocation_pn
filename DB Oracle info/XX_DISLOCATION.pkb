function get_rail_contract_change
return t_xx_rail_contract_dop_table pipelined
as
    l_row       t_xx_rail_contract_dop_row;
begin
    for l_tmp in (select rcc.id
                        ,rcc.num
                        ,rcc.descr
                        ,nvl(rcd.id,rc.id)                                      contract_id
                        ,case
                           when rcd.num is not null
                             then rcd_rc.num||' от '||to_char(rcd_rc.beg_date,'dd.mm.yyyy') ||' -> ' ||rcd.num||' от '||to_char(rcd.beg_date,'dd.mm.yyyy') 
                           when rc.num is not null 
                             then rc.num||' от '||to_char(rc.beg_date,'dd.mm.yyyy')    
                           else
                             ''
                         end
                                                                                contract_num
                        ,to_char(rcc.beg_date,'dd.mm.yyyy')                     beg_date
                        ,to_char(rcc.end_date,'dd.mm.yyyy')                     end_date
                        ,u_cr.full_name                                         created_by
                        ,to_char(rcc.created_date,'dd.mm.yyyy')                 created_date
                        ,u_up.full_name                                         last_updated_by
                        ,to_char(rcc.last_updated_date,'dd.mm.yyyy')            last_updated_date
                    from xx_etw.xx_disl_rail_contract_change    rcc
                        ,xx_etw.xx_disl_rail_contract_dop       rcd
                        ,xx_etw.xx_disl_rail_contracts          rcd_rc
                        ,xx_etw.xx_disl_rail_contracts          rc
                        ,xx_etw.xx_disl_users                   u_cr
                        ,xx_etw.xx_disl_users                   u_up 
                   where 1=1
                     and rcc.contract_id = rc.id(+)
                     and rcc.contract_id = rcd.id(+)
                     and rcd.contract_id = rcd_rc.id(+)
                     and rcc.created_by = u_cr.id(+)
                     and rcc.last_updated_by = u_up.id(+)
                   order by
                         nvl(rcd.num,rc.num)
                        ,rcc.num
                 )
    loop
        l_row.id := l_tmp.id;
        l_row.num := l_tmp.num;
        l_row.descr := l_tmp.descr;
        l_row.contract_id := l_tmp.contract_id;
        l_row.contract_num := l_tmp.contract_num;
        l_row.beg_date := l_tmp.beg_date;
        l_row.end_date := l_tmp.end_date;
        l_row.created_by := l_tmp.created_by;
        l_row.created_date := l_tmp.created_date;
        l_row.last_updated_by := l_tmp.last_updated_by;
        l_row.last_updated_date := l_tmp.last_updated_date;
        
        pipe row (l_row);
    end loop;
end;

function get_rail_parent_contracts
return t_xx_parent_contracts_table pipelined
as
    l_row       t_xx_parent_contracts_row;   
begin
    for l_tmp in (
        with tmp as (
            select id
                  ,num
                  ,beg_date
                  ,-1       parent_id
                  ,num||' от '||to_char(beg_date,'dd.mm.yyyy') descr
              from xx_disl_rail_contracts
             union
            select rcd.id
                  ,rcd.num
                  ,rcd.beg_date
                  ,nvl(rcd.contract_id,-1)      parent_id
                  ,rc.num||' от '||to_char(rc.beg_date,'dd.mm.yyyy') ||' -> ' ||rcd.num||' от '||to_char(rcd.beg_date,'dd.mm.yyyy') descr
              from xx_disl_rail_contract_dop        rcd
                  ,xx_disl_rail_contracts           rc
             where 1=1
               and rcd.contract_id = rc.id(+)
        )
        select tmp.id
              ,tmp.num
              ,to_char(tmp.beg_date,'dd.mm.yyyy')   beg_date
              ,tmp.descr
              ,level lvl
          from tmp
       connect by
               parent_id = prior id
         start with parent_id = -1
         order siblings by 
               num     
    ) loop
        l_row.id := l_tmp.id;
        l_row.num := l_tmp.num;
        l_row.beg_date := l_tmp.beg_date;
        l_row.descr := l_tmp.descr;
        l_row.lvl := l_tmp.lvl;
        
        pipe row (l_row);
    end loop;
end;

