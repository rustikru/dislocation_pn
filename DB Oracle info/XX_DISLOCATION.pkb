end; 

function get_car_scale_weights
return t_xx_car_scale_weight_table pipelined
as
    l_row           t_xx_car_scale_weight_row;
begin
    for l_scale_weights in (
        select train_id
              ,to_char(max(date_w) over (partition by train_id),'dd.mm.yyyy hh24:mi:ss')      
                                                            train_date
              ,id                                              
              ,car_number
              ,wag_number
              ,to_char(date_w,'dd.mm.yyyy hh24:mi:ss')      date_w
              ,weight
              ,speed
              ,napr_sys 
          --from apps.xx_car_scale  sc -- rem 30.10.2025
          from xx_etw.xx_car_scale_v  sc -- add 30.10.2025
         where 1=1
           and sc.train_id not in (10960,14341,14370) -- ошибочные
           and sc.date_w >= to_date('09.05.2017','dd.mm.yyyy')
           and not exists (
               select 'x'
                 from xx_disl_car_scale dsc
                where 1=1
                  and dsc.id = sc.id
                  and dsc.train_id = sc.train_id
           )
         order by 
               train_id
              ,wag_number      
    ) loop
        l_row.train_id := l_scale_weights.train_id;   
        l_row.train_date := l_scale_weights.train_date;
        l_row.id := l_scale_weights.id;
        l_row.car_number := l_scale_weights.car_number;
        l_row.wag_number := l_scale_weights.wag_number;
        l_row.date_w := l_scale_weights.date_w;
        l_row.weight := l_scale_weights.weight/1000;
        l_row.speed := l_scale_weights.speed;
        l_row.napr_sys := l_scale_weights.napr_sys; 
      
        pipe row(l_row);
    end loop;

end;

function load_car_scale_weights(
    p_user_id               number,
    p_train_id              number,
    p_general_com           varchar2,
    p_cars                  varchar2
) return varchar2
as
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    l_function              varchar2(100):='load_car_scale_weights';

    l_train_id              number;
    l_weight_id             number;
    l_check                 number;
    l_car_number            varchar2(20);
    l_weight                number;
    l_date                  varchar2(50);
    l_speed                 number;
    l_comment               varchar2(1000);
    l_weight_type           varchar2(50);
    l_round_id              number;
    l_exist_request         boolean;
    l_for_akt               number; -- add 14.01.2021
    l_karbamid              varchar2(100);
    l_msg                   varchar2(1000);
    l_freight_name          varchar2(100);                
begin
    DBMS_SESSION.set_nls ('NLS_NUMERIC_CHARACTERS', '''. ''');
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_train_id = '||p_train_id
                             ||' p_general_com = '||p_general_com
                             ||' p_cars = '||p_cars); 
    
    if (p_train_id is null) then
        l_train_id := xx_disl_car_scale_train_seq.nextval()*(-1);
    else
        l_train_id := p_train_id;
    end if;
    log_new(l_log_id,l_function,'l_train_id = '||l_train_id);
                              
    insert into xx_disl_car_scale_train
    values(l_train_id,p_general_com)
    ;
    log_new(l_log_id,l_function,'insert into xx_disl_car_scale_train. кол-во='||sql%rowcount);
                               
    for l_car_info in (
        select regexp_substr(p_cars,'[^$]+',1,level)        text
              ,level                                        lvl
          from dual
       connect by level <= regexp_count(p_cars,'[^$]+')
    ) loop
        log_new(l_log_id,l_function,'l_car_info = '||l_car_info.text);     
        
        l_weight_id := get_substr(l_car_info.text,'|',1);
        l_check := to_number(get_substr(l_car_info.text,'|',2));
        l_car_number := get_substr(l_car_info.text,'|',3);
        l_weight := to_number(replace(get_substr(l_car_info.text,'|',4),',','.'));
        l_comment := get_substr(l_car_info.text,'|',5);
        l_date := get_substr(l_car_info.text,'|',6);
        l_speed := get_substr(l_car_info.text,'|',7);
        l_weight_type := get_substr(l_car_info.text,'|',8);
        l_for_akt := to_number(get_substr(l_car_info.text,'|',9));
        
        l_round_id := returnLastRound(l_car_number);
        
        log_new(l_log_id,l_function,'l_weight_id = '||l_weight_id
                                || ' l_check = '||l_check
                                || ' l_car_number = '||l_car_number
                                || ' l_weight = '||l_weight
                                || ' l_comment = '||l_comment
                                || ' l_date = '||l_date
                                || ' l_speed = '||l_speed
                                || ' l_for_akt = '||l_for_akt
                                || ' l_round_id = '||l_round_id);     
        
        if (p_train_id is null) then
            insert into xx_disl_car_scale
            select null
                  ,null
                  ,l_car_info.lvl
                  ,to_date(l_date,'dd.mm.yyyy hh24:mi')
                  ,null
                  ,l_train_id
                  ,l_speed
                  ,null
                  ,l_round_id
                  ,l_weight
                  ,l_car_number
                  ,l_check
                  ,l_comment
                  ,p_user_id
                  ,sysdate
                  ,l_weight_type
                  ,xx_disl_car_scale_seq.nextval
                  ,l_for_akt
              from dual
             where 1=1  
            ;
            log_new(l_log_id,l_function,'insert into xx_disl_car_scale. кол-во='||sql%rowcount); 
        else
            insert into xx_disl_car_scale
            select id
                  ,car_number
                  ,wag_number
                  ,date_w
                  ,weight
                  ,train_id
                  ,speed
                  ,napr_sys
                  ,l_round_id
                  ,l_weight
                  ,l_car_number
                  ,l_check
                  ,l_comment
                  ,p_user_id
                  ,sysdate
                  ,'Динамика'
                  ,xx_disl_car_scale_seq.nextval
                  ,l_for_akt
              --from apps.xx_car_scale  sc -- rem 30.10.2025
                from xx_etw.xx_car_scale_v  sc -- add 30.10.2025
             where 1=1
               and train_id = l_train_id
               and id = l_weight_id    
            ;
            
            begin
              begin
                 SELECT  cai.freight_name as freight_name
                  into   l_freight_name
                  FROM   xx_etw.xx_disl_cont_history_cur chc,
                         xx_etw.xx_disl_cont_round cr,
                         xx_etw.xx_disl_cont_add_info cai,
                         xx_etw.xx_disl_nrb_stop_add_v d_nrb_stop
                 WHERE       1 = 1
                         AND chc.place_id = l_round_id
                         AND chc.place_type = 'railcar'
                         AND chc.cont_round_id = cr.cont_round_id
                         AND cr.cont_round_id = cai.cont_round_id
                         AND cai.LAST_RECORD = 'Y'
                         and cai.OWNER = 'МТФ'
                         and rownum = 1
                         AND cr.cont_number = d_nrb_stop.obj_number(+);
              exception 
                when others then l_freight_name:='*';
              end;
              
              log_new(l_log_id,l_function,'l_freight_name='||l_freight_name); 
              
              if lower(l_freight_name) like '%карбамид%' then
                 l_karbamid := 'Y';
                 
              elsif l_freight_name = '*' then
                  select 'Y' 
                    into l_karbamid
                    from dual
                    where 1=1
                          and exists (
                                select *
                                  from xx_etw.xx_disl_railcar_add_info drai
                                 where lower(drai.freight_name) like '%карбамид%'
                                       and drai.last_record = 'Y'
                                       and drai.OWNER = 'МТФ'
                                       and drai.round_id = l_round_id
                             );
              else 
                l_karbamid := 'N';
              end if;
              
            exception when others then 
                null;
                l_karbamid:='N'; l_freight_name:='';
                log_new(l_log_id,l_function,'Error='||sqlerrm||' l_karbamid='||l_karbamid); 
                
            end;
            
            if (l_karbamid = 'Y') then
                    l_msg:=l_msg||l_car_number||' - '||l_weight||'<br>';
            end if;                     
            
            log_new(l_log_id,l_function,'insert into xx_disl_car_scale. кол-во='||sql%rowcount); 
        end if;  
        
        l_exist_request := close_request(p_user_id,l_car_number,14/*Взвешивание*/,'автоматическое закрытие при загрузке  с весов',to_char(sysdate,'dd.mm.yyyy hh24:mi'));  
        log_new(l_log_id,l_function,'close_request. result = '||boolean_to_char(l_exist_request)); 
        
             
    end loop;
    if l_msg is not null then
        begin
            for mail in (
            select 'Rustam.Bekmansurov@metafrax.ru'to_email from dual union
            select 'Oleg.Starkov@metafrax.ru' from dual union
            select 'Aleksandr.Toktarov@metafrax.ru' from dual union
            select 'mikhail.vlasovskikh@metafrax.ru' from dual union
            select 'Aleksandr.Krasnykh@metafrax.ru' from dual union
            select 'Dmitriy.Polezhaev@metafrax.ru' from dual union
            select 'Sergey.Pyatiletov@metafrax.ru' from dual union
            select 'Maksim.Fedyaev@metafrax.ru' from dual union
            select 'larisa.Kulinyak@metafrax.ru' from dual
            )    
            loop
                apps.xx_requests.send_mail(p_to=>mail.to_email,
                                          p_subject=>'АКМ. Карбамид. Результаты Взвешиваний ст Новая',
                                          p_html_msg=>l_msg,
                                          p_text_encode=>'utf-8');
            end loop;
        exception 
            when others then null;
            log_new(l_log_id,l_function,'Error_mail='||sqlerrm); 
        end;
    end if;
    commit;
    return 'done';
exception
    when others then rollback; 
    log_new(l_log_id,l_function,'Error='||sqlerrm); 
    return 'fail';                                
end;

function get_car_scale_weights_add(p_car_number varchar2)
return t_xx_car_scale_weight_tbl_add pipelined
as
    l_row               t_xx_car_scale_weight_row_add;
    l_prev_round        number;
    l_prev_max_date_w   date;
begin
    begin
    select max(round_id)
      into l_prev_round  
      from xx_etw.xx_disl_round 
     where 1=1
       and railcar_id = p_car_number
       and round_id < returnLastRound(p_car_number)
    ;
    exception
        when others then l_prev_round := null;
    end;
    
    if (l_prev_round is not null) then
        select max(date_w)
          into l_prev_max_date_w
          from xx_disl_car_scale 
         where 1=1
           and car_number_corr =p_car_number
           and round_id = l_prev_round
        ;
    end if;

    for l_scale_weights in (
        select id
              ,train_id
              ,to_char(date_w,'dd.mm.yyyy hh24:mi:ss') date_char
              ,speed
              ,weight
              ,weight_cor
              ,descr
              ,decode(date_w
                     ,l_prev_max_date_w,'Y'
                     ,'N'
                     )
                            prev_max_date_w
              ,decode(nvl(for_akt,0),1,'Да','Нет') for_akt
              ,nvl(pk_id,0) as pk_id
              ,case when lower(descr) like lower('%корп.1831%') then 'КОРП_1831' else 'НОВАЯ' end as scale_type
              ,type as weighing_type
          from xx_disl_car_scale 
         where 1=1
           and car_number_corr =p_car_number
         order by
               date_w desc    
    ) loop
        l_row.id := l_scale_weights.id;   
        l_row.train_id := l_scale_weights.train_id;
        l_row.date_w := l_scale_weights.date_char;
        l_row.speed := l_scale_weights.speed;
        l_row.weight := l_scale_weights.weight/1000;
        l_row.weight_cor := l_scale_weights.weight_cor;
        l_row.descr := l_scale_weights.descr;
        l_row.prev_max_date_w := l_scale_weights.prev_max_date_w;
        l_row.for_akt := l_scale_weights.for_akt;
        l_row.pk_id := l_scale_weights.pk_id;
        l_row.scale_type := l_scale_weights.scale_type;
        l_row.weighing_type := l_scale_weights.weighing_type; -- 14.02.2023
        
        pipe row(l_row);
    end loop;

end;

procedure save_merge_disl_car_scale (p_scale_rec    in xx_etw.xx_disl_car_scale%rowtype, 
                                     p_status       out varchar2,
                                     p_msg          out varchar2
                                     )
is
    l_function              varchar2(100):='save_merge_disl_car_scale';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_train_id              number;
    l_scale_rec             xx_etw.xx_disl_car_scale%rowtype;
begin
    
    l_scale_rec:=p_scale_rec;
    
    if (nvl(l_scale_rec.train_id,0) = 0) then
        l_scale_rec.train_id := xx_disl_car_scale_train_seq.nextval()*(-1);
        insert into xx_disl_car_scale_train values(l_scale_rec.train_id,null);
    else
        l_scale_rec.train_id := p_scale_rec.train_id;
    end if;
    
    log_new(l_log_id,l_function,'p_scale_rec.train_id = '||l_scale_rec.train_id);
    
    merge into xx_etw.xx_disl_car_scale  rci
        using dual 
           on (rci.ID = l_scale_rec.id)
         when matched then 
       update set
              weight =  l_scale_rec.weight,
              weight_cor =  l_scale_rec.weight_cor,
              CAR_NUMBER_CORR=  l_scale_rec.CAR_NUMBER_CORR,
              created_date =  l_scale_rec.created_date,
              created_by =  nvl(l_scale_rec.created_by,rci.created_by),
              type =  l_scale_rec.type,
              descr =  l_scale_rec.descr
         when not matched then 
       insert(ID, CAR_NUMBER, WAG_NUMBER, DATE_W, WEIGHT, TRAIN_ID, SPEED, NAPR_SYS, ROUND_ID, WEIGHT_COR, CAR_NUMBER_CORR, CHECK_CAR, DESCR, CREATED_BY, CREATED_DATE, TYPE, PK_ID, FOR_AKT) 
       values(l_scale_rec.ID, 
              l_scale_rec.CAR_NUMBER, 
              l_scale_rec.WAG_NUMBER, 
              l_scale_rec.DATE_W, 
              l_scale_rec.WEIGHT, 
              l_scale_rec.TRAIN_ID, 
              l_scale_rec.SPEED, 
              l_scale_rec.NAPR_SYS, 
              l_scale_rec.ROUND_ID, 
              l_scale_rec.WEIGHT_COR, 
              l_scale_rec.CAR_NUMBER_CORR, 
              l_scale_rec.CHECK_CAR, 
              l_scale_rec.DESCR, 
              l_scale_rec.CREATED_BY, 
              l_scale_rec.CREATED_DATE, 
              l_scale_rec.TYPE, 
              l_scale_rec.PK_ID, 
              l_scale_rec.FOR_AKT
             );
    commit;
    p_status:='S'; p_msg:='';
exception when others then 
    p_status := 'E';
    p_msg:=sqlerrm;
    log_new(l_log_id,l_function,'p_status = '||p_status||' p_msg ='||p_msg);
end;
-- Сохранение "Результаты взвешивания"
function save_change_weight_car(
    p_user_id           number,
    p_add_data          varchar2     
) return varchar2
is
    l_function              varchar2(100):='save_change_weight_car';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    --
    l_row           xx_etw.xx_disl_car_scale%rowtype;   
    l_json          json;
    l_date_from     date;
    l_date_to       date;
    l_scale_id      xx_etw.xx_disl_car_scale.id%type;
    l_train_id      xx_etw.xx_disl_car_scale.train_id%type;
    l_for_akt       xx_etw.xx_disl_car_scale.for_akt%type;
    l_descr         xx_etw.xx_disl_car_scale.descr%type; 
    l_pk_id         xx_etw.xx_disl_car_scale.pk_id%type; 
    l_msg           varchar2(240);
    l_result        varchar2(4000);
begin
    l_json := xx_wms.json(p_add_data);
    
    l_scale_id := l_json.get_string('id');
    l_train_id := l_json.get_string('train_id');
    l_for_akt :=l_json.get_string('for_akt');
    l_descr :=l_json.get_string('comment');
    l_pk_id :=l_json.get_string('p_pk_id');
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' l_scale_id = '||l_scale_id
                             ||' l_train_id = '||l_train_id
                             ||' l_for_akt = '||l_for_akt
                             ||' l_descr = '||l_descr
                             ||' l_pk_id = '||l_pk_id
                             );
    update xx_etw.xx_disl_car_scale x
           set x.for_akt = l_for_akt,
               x.descr = l_descr
         where 1=1
               --and x.id = l_scale_id and x.train_id = l_train_id
               and x.pk_id = l_pk_id;
    commit;
    l_result := 'done';   
    return l_result;
exception
    when others then rollback; return 'fail$'||sqlerrm;
end;


function get_places_for_cont(p_station_id number,p_area_type varchar2)
return t_xx_tree_table pipelined
as
    l_row                       t_xx_tree_row;
begin
    for l_elem in (
        with tree as (
            select *
              from xx_etw.xx_disl_relations
             where 1=1
               and flag_come = 'Y'
        )
        select  tree.id
               ,tree.type
               ,nm_v.name
          from  tree
               ,xx_etw.xx_disl_union_name_v        nm_v
         where     1=1
               and tree.id = nm_v.id
               and tree.type = nm_v.type  
               and tree.type = p_area_type
               
               and p_area_type = 'area'

       connect by  
               tree.parent_id = prior tree.id
           and tree.parent_type = prior tree.type
         start with 
               tree.parent_id = p_station_id
           and tree.parent_type = 'station'
         union all
        select r.railcar_id
              ,'railcar'
              ,r.railcar_id
          from xx_etw.xx_disl_round              r
         where 1=1
           and p_area_type = 'railcar'
           and r.station_hist_id_out is null
           and xx_etw.xx_dislocation.get_railcar_type(r.round_id) = 1
        order by 1
        ) 
        
    loop
        l_row.id := l_elem.id;
        l_row.name := l_elem.name;
        l_row.type := l_elem.type;    
        
        pipe row (l_row);
    end loop;    
end;

procedure add_conts_for_add_info_tbl(p_cont_numbers varchar2)
as
begin
    for l_conts in (select regexp_substr(p_cont_numbers,'[^|]+',1,level) text
                     from dual
                  connect by level <= regexp_count(p_cont_numbers,'[^|]+')
                  )
    loop
        insert into xx_etw.xx_disl_obj_add_info_tmp(obj_number,obj_type)
        values (l_conts.text,'cont')
        ;
    end loop;               
end;

function move_conts(p_user_id number,p_conts varchar2, p_place_id number, p_place_type varchar2, p_oper_date varchar2, p_comment varchar2)
return varchar2
as
    l_function              varchar2(100):='move_conts';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    
    l_oper_date             date;
    l_cont_move_list_id     number := xx_disl_cont_move_list_seq.nextval();
    
    l_oper_result           varchar2(100);
    l_result                varchar2(100) := 'done'; 
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_conts = '||p_conts
                             ||' p_place_type = '||p_place_type
                             ||' p_place_id = '||p_place_id
                             ||' p_oper_date = '||p_oper_date
                             ||' p_comment = '||p_comment);
    begin
        l_oper_date := to_date(p_oper_date,'dd.mm.yyyy hh24:mi'); 
    exception
        when others then l_oper_date := null;
    end;

    insert into xx_etw.xx_disl_cont_move_list
    values(
        l_cont_move_list_id,
        p_conts,
        p_place_id,
        p_place_type,
        l_oper_date,
        p_comment,
        p_user_id,
        sysdate
    );
    log_new(l_log_id,l_function,'insert into xx_etw.xx_disl_cont_move_list. rowcount = '||sql%rowcount);       
     
    for l_cont in (
        select regexp_substr(p_conts,'[^|]+',1,level) cont_number
          from dual
       connect by level <= regexp_count(p_conts,'[^|]+')
    ) loop
        l_oper_result := move_cont(p_user_id,l_cont.cont_number, p_place_id,p_place_type, l_oper_date, l_cont_move_list_id);
        log_new(l_log_id,l_function,'l_cont.cont_number = '||l_cont.cont_number||' l_oper_result = '||l_oper_result);  
        if (l_oper_result != 'done') then
            l_result := 'fail';
            
        end if;
    end loop;
    
    if (l_result = 'done') then
        commit;
    end if;
    
    return l_result;   
exception
    when others then return 'fail';
end;

function move_cont(p_user_id number,p_cont_number varchar2, p_place_id number,p_place_type varchar2, p_oper_date date, p_cont_move_list_id number)
return varchar2
as
    l_function              varchar2(100):='move_cont';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    
    l_cont_round_id         number;
    l_cont_history_id_old   number;
    l_cont_history_id_new   number := xx_etw.xx_disl_cont_history_seq.nextval();
    
    l_place_id              number;
    
    l_place_id_old          number;
    l_place_type_old        xx_etw.xx_disl_cont_history.place_type%type;
    l_order                 number;
    l_max_order             number;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_cont_number = '||p_cont_number
                             ||' p_place_id = '||p_place_id
                             ||' p_place_type = '||p_place_type
                             ||' p_oper_date = '||to_char(p_oper_date,'dd.mm.yyyy hh24:mi')
                             ||' p_cont_move_list_id = '||p_cont_move_list_id);
    select cont_round_id
      into l_cont_round_id
      from xx_etw.xx_disl_cont_round
     where 1=1
       and cont_number = p_cont_number
       and cont_history_out is null
    ;
    log_new(l_log_id,l_function,'l_cont_round_id = '||l_cont_round_id);
        
    select cont_history_id
          ,place_id
          ,place_type
      into l_cont_history_id_old
          ,l_place_id_old
          ,l_place_type_old
      from xx_etw.xx_disl_cont_history
     where 1=1
       and cont_round_id = l_cont_round_id
       and out_date_sys is null
    ;
    log_new(l_log_id,l_function,'l_cont_history_id_old = '||l_cont_history_id_old||' l_place_id_old = '||l_place_id_old||' l_place_type_old = '||l_place_type_old);
    
    update xx_etw.xx_disl_cont_history
       set out_date_sys = sysdate
          ,out_date_fact = p_oper_date
          ,out_user = p_user_id
          ,cont_move_list_id = p_cont_move_list_id
     where 1=1
       and cont_history_id = l_cont_history_id_old
    ;
    log_new(l_log_id,l_function,'update xx_etw.xx_disl_cont_history. rowcount = '||sql%rowcount);
    
    l_place_id := p_place_id;
    if (p_place_type = 'railcar') then
        l_place_id := returnLastRound(p_place_id);
    end if;  
    
    insert into xx_etw.xx_disl_cont_history
    values(
        l_cont_history_id_new,
        l_cont_round_id,
        l_place_id,
        p_place_type,
        sysdate,
        p_oper_date,
        p_user_id,
        null,
        null,
        null,
        null  
    );
    log_new(l_log_id,l_function,'insert into xx_etw.xx_disl_cont_history. rowcount = '||sql%rowcount);
    
    if (p_place_type = 'area')then
        l_max_order := returnMaxOrder(p_place_id,p_place_type,'Y');
        if (l_place_type_old = 'railcar') then
            insert into xx_etw.xx_disl_relations
            values(
                p_cont_number,
                'cont',
                p_place_id,
                p_place_type,
                l_max_order+1,
                'Y'    
            );
            log_new(l_log_id,l_function,'insert into xx_etw.xx_disl_relations. rowcount = '||sql%rowcount);  
        else
            select r_order
              into l_order
              from xx_etw.xx_disl_relations
             where 1=1
               and id = p_cont_number
               and type = 'cont' 
               and flag_come = 'Y'
            ;
            log_new(l_log_id,l_function,'l_order = '||l_order);
                        
            update xx_etw.xx_disl_relations
               set r_order = r_order - 1
             where 1=1
               and parent_id = l_place_id_old
               and parent_type = l_place_type_old 
               and flag_come = 'Y'
               and r_order > l_order
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_relations. rowcount = '||sql%rowcount);  
            
            update xx_etw.xx_disl_relations
               set parent_id = p_place_id
                  ,parent_type = p_place_type
                  ,r_order = l_max_order+1
             where 1=1
               and id = p_cont_number
               and type = 'cont' 
               and flag_come = 'Y'
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_relations. rowcount = '||sql%rowcount);  
        end if;
    else
        if (l_place_type_old = 'area') then
            select r_order
              into l_order
              from xx_etw.xx_disl_relations
             where 1=1
               and id = p_cont_number
               and type = 'cont' 
               and flag_come = 'Y'
            ;
            log_new(l_log_id,l_function,'l_order = '||l_order);
            
            update xx_etw.xx_disl_relations
               set r_order = r_order - 1
             where 1=1
               and parent_id = l_place_id_old
               and parent_type = l_place_type_old 
               and flag_come = 'Y'
               and r_order > l_order
            ;
            log_new(l_log_id,l_function,'update xx_etw.xx_disl_relations. rowcount = '||sql%rowcount);
            
            delete xx_etw.xx_disl_relations
             where 1=1
               and id = p_cont_number
               and type = 'cont' 
               and flag_come = 'Y'
            ;
            log_new(l_log_id,l_function,'delete xx_etw.xx_disl_relations. rowcount = '||sql%rowcount);
        end if;
    end if;
    
    update xx_etw.xx_disl_cont_history_cur 
       set place_id = l_place_id
          ,place_type = p_place_type
          ,cont_history_id_in = l_cont_history_id_new
     where 1=1
       and cont_round_id = l_cont_round_id;    
    
    /*add KuchukbaevRF 16.01.2019 для контейнеров заполняем дату увода в форме погрузки/разгрузки*/ 
    if (l_place_type_old = 'area' and p_place_type = 'railcar') then
        update xx_disl_shop_info si
           set si.date_zayavka_uvod = nvl(si.date_zayavka_uvod,p_oper_date)
              ,si.date_uvod = nvl(si.date_uvod,p_oper_date)
         where 1=1
           and round_id = l_cont_round_id
           and round_type = 'cont'
           and (date_zayavka_uvod  is null or date_uvod is null)
           and refusal is null;    
    end if;      
    
    return 'done';
exception
    when others then return 'fail';
end;

function create_return_invoice_adapter(p_user_id number,p_car_number varchar2,p_otpr_nom number,p_graph varchar2,p_recip_address_id number,p_recip_telefon varchar2,p_depl_person number,p_cont_csl varchar2)
return varchar2
as
    l_function              varchar2(100):='create_return_invoice_adapter';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();

    l_round_id      number;
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_car_number = '||p_car_number
                             ||' p_otpr_nom = '||p_otpr_nom
                             ||' p_graph = '||p_graph
                             ||' p_recip_address_id = '||p_recip_address_id
                             ||' p_recip_telefon = '||p_recip_telefon
                             ||' p_depl_person = '||p_depl_person
                             ||' p_cont_csl = '||p_cont_csl);

    select round_id
      into l_round_id
      from xx_etw.xx_disl_round
     where 1=1
       and railcar_id = p_car_number
       and station_hist_id_out is null
    ;
    
    return create_return_invoice(p_user_id,l_round_id,p_otpr_nom,p_graph,p_recip_address_id,p_recip_telefon,p_depl_person,p_cont_csl);
end;

function close_return_invoice(p_user_id number,p_car_number varchar2)
return varchar2
as
    l_function              varchar2(100):='close_return_invoice';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();

    l_round_id      number;
    l_result        varchar2(100);
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_car_number = '||p_car_number);

    select round_id
      into l_round_id
      from xx_etw.xx_disl_round
     where 1=1
       and railcar_id = p_car_number
       and station_hist_id_out is null
    ;
    
    update xx_disl_round_invoice_out
       set closed_date = sysdate
          ,closed_by = p_user_id
     where 1=1
       and round_id = l_round_id
       and closed_date is null
    ;
    
    if (sql%rowcount = 1) then
        l_result := 'done';
    else
        l_result := 'fail'; 
    end if;
    
    return l_result;
end;

function create_return_invoice(p_user_id number,p_round_id number,p_otpr_nom number,p_graph varchar2,p_recip_address_id number,p_recip_telefon varchar2,p_depl_person number,p_cont_csl varchar2)
return varchar2
as
    l_function              varchar2(100):='create_return_invoice';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();
    
    l_car_number            xx_etw.xx_disl_round.railcar_id%type;
    l_front_end_id          number;
    l_count_cont            number;
    l_cont_number           etw_inv_cont.cont_number%type;
    l_otpr_graph_pod        varchar2(500);
    
    l_cont_weight           number := 0;

    r_invoice               xx_etw.etw_invoice%rowtype; 
    l_inv_recip_name        xx_etw.etw_invoice.inv_recip_name%type;
    
    x_tbl_inv_spc           xx_etw.etw_invoice_pkg.tbl_inv_spc;
    indx                    binary_integer;
    
    -- add 29.08.2023
    x_tbl_inv_paragraphs    etw_invoice_pkg.tbl_inv_paragraphs;
    x_tbl_inv_pattern       etw_invoice_pkg.tbl_inv_pattern;

       
    
    r_inv_doc               xx_etw.etw_inv_doc%rowtype;
    
    r_inv_car               etw_inv_car%rowtype;
    
    r_inv_cont              etw_inv_cont%rowtype;
    
    r_inv_cont_csl          etw_inv_cont_csl%rowtype;
    
    r_inv_freight           etw_inv_freight%rowtype;
    
    l_export_invoice        boolean := false;
    
    l_round_for_freight     number;
    
    l_inv_depl_person       apps.fnd_flex_values_vl.description%type:=''; 
begin
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                             ||' p_round_id = '||p_round_id
                             ||' p_otpr_nom = '||p_otpr_nom
                             ||' p_graph = '||p_graph
                             ||' p_recip_address_id = '||p_recip_address_id
                             ||' p_recip_telefon = '||p_recip_telefon
                             ||' p_depl_person = '||p_depl_person
                             ||' p_cont_csl = '||p_cont_csl);
       
    merge into xx_etw.xx_disl_round_claim_info  rci
    using dual 
       on (rci.round_id = p_round_id)
     when matched then 
   update set
          last_update_date = sysdate,
          last_update_by = p_user_id,
          graph = p_graph,
          recip_address_id = p_recip_address_id,
          recip_telefon = p_recip_telefon,
          depl_person = p_depl_person,
          otpr_nom = p_otpr_nom
     when not matched then 
   insert(creation_date,
          created_by,
          round_id,
          graph,
          recip_address_id,
          recip_telefon,
          depl_person,
          otpr_nom) 
   values(sysdate,
          p_user_id,
          p_round_id,
          p_graph,
          p_recip_address_id,
          p_recip_telefon,
          p_depl_person,
          p_otpr_nom
         ) 
    ;
    
    select railcar_id
      into l_car_number
      from xx_etw.xx_disl_round
     where 1=1
       and round_id = p_round_id
    ;
    
    select count('x')
      into l_count_cont
      from xx_etw.xx_disl_cont_history_cur
     where 1=1
       and place_type = 'railcar'
       and place_id = to_char(p_round_id)
    ;
    
    begin
        select front_end_id
          into l_front_end_id
          from xx_etw.xx_disl_round_invoice_out
         where 1=1
           and round_id = p_round_id
           and closed_date is null
    ;
    exception
        when no_data_found then l_front_end_id := null;
    end;
      
    if (l_front_end_id is not null) then
        r_invoice.front_end_id := l_front_end_id; 
        
        delete
          from xx_etw.etw_invoice
         where 1=1
           and front_end_id = r_invoice.front_end_id
        ;
        delete
          from xx_etw.etw_inv_spc
         where 1=1
           and front_end_id = r_invoice.front_end_id
        ;
        delete
          from xx_etw.etw_inv_doc
         where 1=1
           and front_end_id = r_invoice.front_end_id
        ; 
        delete
          from etw_inv_car
         where 1=1
           and front_end_id = r_invoice.front_end_id
        ;   
        delete
          from etw_inv_freight
         where 1=1
           and front_end_id = r_invoice.front_end_id
        ;   
        delete
          from etw_inv_cont
         where 1=1
           and front_end_id = r_invoice.front_end_id
        ;  
        delete
          from etw_inv_cont_csl
         where 1=1
           and front_end_id = r_invoice.front_end_id
        ;  
        
        delete from etw_inv_pattern where 1=1 and front_end_id = r_invoice.front_end_id;  
        delete from etw_inv_paragraphs where 1=1 and front_end_id = r_invoice.front_end_id;
        
    else 
        etw_oi_pkg.get_front_end_id (r_invoice.front_end_id);   
    end if;

    log_new(l_log_id,l_function,'r_invoice.front_end_id=' || r_invoice.front_end_id);
    
    -- Тип накладной
    r_invoice.inv_type_id := 1; -- (1 - Накладная на погрузку)
    etw_oi_pkg.get_nsi_common (147, r_invoice.inv_type_id, r_invoice.inv_type_name);
    
    -- Тип бланка
    r_invoice.inv_blank_type_id := case
                                     when l_count_cont = 0 
                                     then 112
                                     --else 94
                                     else 182
                                   end;
    etw_oi_pkg.get_nsi_blank_type (r_invoice.inv_blank_type_id, r_invoice.inv_blank_type, r_invoice.inv_blank_type_name);
    
    -- Вид отправки
    r_invoice.inv_send_kind_id := case
                                    when l_count_cont = 0 
                                    then 1 -- (1 - Повагонная)
                                    else 8 -- (8 - Контейнерная комплектом на вагон)
                                  end;
    etw_oi_pkg.get_nsi_inv_send_type (r_invoice.inv_send_kind_id, r_invoice.inv_send_kind_name);
       
    -- Грузоотправитель/адрес
    etw_oi_pkg.set_sender (r_invoice.inv_sender_id,
                           r_invoice.inv_sender_okpo,
                           r_invoice.inv_sender_name,
                           r_invoice.inv_sender_address_id,
                           r_invoice.inv_sender_address,
                           r_invoice.inv_sender_tgnl); 
                           
    -- Заявка    
    begin
        select claim_id
              ,claim_number
             ||decode(claim_version
                     ,null,''
                     ,'-ИЗМ/'||claim_version
                     )
              ,(select kind_disp
                  from etw_nsi_inv_disp_kind
                 where 1=1
                   and trim(upper(name)) = trim(upper(ec.clm_msg_kind_name))
               )
          into r_invoice.inv_claim_id
              ,r_invoice.inv_claim_number
              ,r_invoice.inv_disp_kind_id
          from xx_etw.etw_clm   ec
         where 1=1
           and claim_number = (
                select claim_number
                  from xx_etw.xx_disl_round_claim_link
                 where 1=1
                   and round_id = p_round_id
                   and date_end is null
           ) 
           and claim_id in (
                select max(ec3.claim_id) --ищем последнюю версию заявки
                  from xx_etw.etw_clm ec3
                 where 1=1 
                   and ec3.claim_number = ec.claim_number
                   and ec3.claim_state_id in (70,71,72) --статусы только согласование
           )
        ;  
    exception
        when no_data_found then null;
    end;
    
    if (r_invoice.inv_claim_id is not null) then 
        begin
            select otpr_nom
                  ,gp_pod_num
                  --,gp_pod_date
                  -- add 14/09/2020
                  ,trunc(nvl((select xx.inv_date_create from xx_etw.etw_invoice xx where xx.front_end_id = r_invoice.front_end_id),sysdate))
                  ,otpr_nom||'-'||gp_pod_num||'-'||to_char(gp_pod_date,'dd.mm.yyyy')
             into r_invoice.inv_otpr_num,
                  r_invoice.inv_pod_num,
                  r_invoice.inv_date_load,
                  l_otpr_graph_pod
             from etw_clm_otpr_graph_pod
            where 1=1
              and claim_id = r_invoice.inv_claim_id
              and rowid = chartorowid(p_graph)
            ;
            
            update xx_etw.xx_disl_round_claim_info  rci
               set graph_add = l_otpr_graph_pod
             where 1=1
               and rci.round_id = p_round_id
            ;
        exception
            when no_data_found then null;
        end;
    end if;
    
    log_new(l_log_id,l_function,'Заявки');
    
    -- Грузополучатель 
    select otpr_recip_id
          ,otpr_recip_okpo
          ,otpr_recip_name
          ,otpr_to_country_code
          ,otpr_to_station_code
          ,otpr_to_station_name
      into r_invoice.inv_recip_id
          ,r_invoice.inv_recip_okpo
          ,r_invoice.inv_recip_name
--          ,r_invoice.inv_recip_address_id
--          ,r_invoice.inv_recip_address
--          ,r_invoice.inv_recip_tgnl
          ,r_invoice.inv_to_country_code -- Страна назначеия
          ,r_invoice.inv_to_station_code -- Станция назначения
          ,r_invoice.inv_to_station_name
      from etw_clm_otpr
     where 1=1
       and claim_id = r_invoice.inv_claim_id 
       and otpr_nom = p_otpr_nom
    ;
    etw_oi_pkg.get_nsi_country (r_invoice.inv_to_country_code, r_invoice.inv_to_country_name);
    
    if (r_invoice.inv_to_country_code != '643'/*Россия*/) then
        l_export_invoice := true;
    end if;
    
    if l_export_invoice then
        select otpr_to_port_name
          into r_invoice.inv_to_port_name /*Порт*/
          from etw_clm_otpr
         where 1=1
           and claim_id = r_invoice.inv_claim_id 
           and otpr_nom = p_otpr_nom
        ;
    end if;
    
    log_new(l_log_id,l_function,'Грузополучатель');
    
    if (p_recip_address_id is not null) then
        r_invoice.inv_recip_address_id := p_recip_address_id;
        
        /*Использую l_inv_recip_name потому что в справочники хранятся не актуальнрые данные*/
        etw_oi_pkg.get_org_passport_address_all(r_invoice.inv_recip_id, r_invoice.inv_recip_okpo, l_inv_recip_name/*r_invoice.inv_recip_name*/, r_invoice.inv_recip_address_id, r_invoice.inv_recip_address, r_invoice.inv_recip_tgnl); 
        
        if (p_recip_telefon is not null) then
            r_invoice.inv_recip_address := trim(r_invoice.inv_recip_address)||', тел: '||p_recip_telefon;
        end if;
    end if;  
    log_new(l_log_id,l_function,'Грузополучатель с телефоном');
    
    -- Подъездной путь
    r_invoice.inv_to_load_way := 'п/п Грузополучателя';
    if l_export_invoice and r_invoice.inv_to_port_name is not null then
        r_invoice.inv_to_load_way := 'п/п '||r_invoice.inv_to_port_name;
    elsif l_export_invoice and r_invoice.inv_to_port_name is null then
        return 'fail|Определить Порт/Пункт перевалки';
    end if;    
    
    --etw_oi_pkg.get_nsi_station (r_invoice.inv_to_station_code, r_invoice.inv_to_station_name);
    
    -- Плательщик
    select payer_id
          ,payer_code
          ,payer_name
      into r_invoice.inv_payer_id
          ,r_invoice.inv_payer_code
          ,r_invoice.inv_payer_name
      from etw_clm_payer
     where 1=1
       and claim_id = r_invoice.inv_claim_id 
    ;
     
     
    -- Вид грузовых работ (ID по НСИ - COMMON, тип 122)
    r_invoice.inv_load_type_id := case
                                    when l_count_cont = 0 
                                    then 11 -- (11 - БЕЗ ЗАЧЕТА В ПОГРУЗКУ)
                                    else 1 -- (1 - СОБСТВЕННАЯ ПОГРУЗКА, ВЫГРУЗКА СТАНЦИИ)
                                  end;
    etw_oi_pkg.get_nsi_common (122, r_invoice.inv_load_type_id, r_invoice.inv_load_type_name);
    
    -- Страна отправления
    r_invoice.inv_from_country_code := etw_oi_pkg.f_from_country_code;
    etw_oi_pkg.get_nsi_country (r_invoice.inv_from_country_code, r_invoice.inv_from_country_name);
    
    -- Станция отправления/выход из СНГ (код ЕСР по НСИ - STATION) -->
    r_invoice.inv_from_station_code := etw_oi_pkg.f_from_station_code;
    etw_oi_pkg.get_nsi_station (r_invoice.inv_from_station_code, r_invoice.inv_from_station_name);
    
    -- Подъездной путь отправления
    r_invoice.inv_from_load_way := 'ПАО "Метафракс"';
    --r_invoice.inv_from_load_way := apps.xx_orgname_pkg.s_name(81,sysdate);
    
    -- Скорость отправки (ID по INV_SPEED_KIND)
    r_invoice.inv_send_speed_id := 2; -- (2 - Грузовая)
    etw_oi_pkg.get_nsi_inv_speed_kind (r_invoice.inv_send_speed_id, r_invoice.inv_send_speed_name);
    
    -- Место оплаты (ID по INV_PAY_PLACE)
    r_invoice.inv_pay_place_id := 3;
    etw_oi_pkg.get_nsi_inv_pay_place (r_invoice.inv_pay_place_id, r_invoice.inv_pay_place_name);

    -- Форма оплаты (PAY_FORM по INV_PAY_FORM)
    r_invoice.inv_pay_form_id := 99;
    etw_oi_pkg.get_nsi_inv_pay_form (r_invoice.inv_pay_form_id, r_invoice.inv_pay_form_name);
    
    -- Планируемый род вагонов (ID по НСИ - WAG_TYPE)
    /*r_invoice.inv_plan_car_type_id := case
                                        when l_count_cont = 0 
                                        then 70 -- (70 - цистерны)
                                        else 253 -- (253 - ПЛ для КТК длиной  19,62)
                                      end;
    etw_oi_pkg.get_nsi_wag_type (r_invoice.inv_plan_car_type_id, r_invoice.inv_plan_car_type_code, r_invoice.inv_plan_car_type_name);*/

    -- Тип собственности вагона (ID по НСИ - COMMON, тип 7) -->
    r_invoice.inv_plan_car_owner_type_id := 1; -- "1"="Собственный"(временно с 21.11.2014)
    etw_oi_pkg.get_nsi_common (7, r_invoice.inv_plan_car_owner_type_id, r_invoice.inv_plan_car_owner_type_name);

    -- Планируемое количество вагонов
    r_invoice.inv_plan_car_count := 1;
    
    -- Погрузка на вагон средствами
    r_invoice.inv_load_assets_id := 1;
    r_invoice.inv_load_assets_name := 'Отпр';
    
    -- Ответсвенный за внесений данных
    begin
        select distinct 'Инженер ТУ '||clm_sender_agent_name
          into r_invoice.inv_resp_person
          from etw_clm
         where 1=1
           and claim_number = (
                select claim_number
                  from xx_etw.xx_disl_round_claim_link
                 where 1=1
                   and round_id = p_round_id
                   and date_end is null
           )
           and clm_sender_agent_name is not null
        ;
    exception
        when others then null;
    end;
    
    -- Объявленная ценность (руб)
    r_invoice.inv_announce_value := 0;
    
    if l_export_invoice then
        /*соответствие двух справочников ETW_NSI_INV_DISP_KIND и ETW_NSI_COMMON(paramid = 120)*/
        select decode(clm_msg_kind_id
                     ,15,7
                     ,null
                     )
          into r_invoice.inv_disp_kind_id
          from etw_clm
         where 1=1
           and claim_id = r_invoice.inv_claim_id
        ;
    end if;
    
    -- Способ определения массы
    r_invoice.inv_scale_type_id := 3; --'По трафарету';
    r_invoice.inv_scale_type_name := 'По трафарету';
    
    -- Кем проводилось
    r_invoice.inv_scale_person_id := 2;
    r_invoice.inv_scale_person_name := 'Отправителем';
    
    -- Ответсвенный за размещение груза
    if (p_depl_person is not null) then
        begin
            select description
              into --r_invoice.inv_depl_person -- rem 27.12.2021 BekmansurovRR
                   l_inv_depl_person -- add 27.12.2021 BekmansurovRR
              from apps.fnd_flex_values_vl
             where 1=1
               and flex_value_id = p_depl_person
               and flex_value_set_id = 1006217 /*Ответственный за прав/погрузки*/
            ;
            r_invoice.inv_depl_person := l_inv_depl_person;-- add 27.12.2021 BekmansurovRR Если длина значения не превышает размер поля (inv_depl_person), то храним данные в поле inv_depl_person, иначе в переменной l_inv_depl_person
            l_inv_depl_person:=null;
        exception when others then null;
        end;
    end if;
    
    -- Груз размещен и закреплен согласно
    r_invoice.inv_dep_norm_doc_id := 2;
    r_invoice.inv_dep_norm_doc_name := 'Техническим условиям';
    
    -- Фактические дата и время погрузки 
    if (l_count_cont = 0) then
        select to_char(max(date_end)-2*1/24,'dd.mm.yyyy hh24:mi:ss')
              ,to_char(max(date_end),'dd.mm.yyyy hh24:mi:ss')
          into r_invoice.inv_fact_date_to_load
              ,r_invoice.inv_fact_date_to_load_local
          from xx_disl_shop_info
         where 1=1
           and round_id = p_round_id
           and round_type = 'railcar'  
           and last_record = 'Y' 
        ;
    else
        select to_char(max(date_end)-2*1/24,'dd.mm.yyyy hh24:mi:ss')
              ,to_char(max(date_end),'dd.mm.yyyy hh24:mi:ss')
          into r_invoice.inv_fact_date_to_load
              ,r_invoice.inv_fact_date_to_load_local
          from xx_disl_shop_info
         where 1=1
           and round_id in (
                select chc.cont_round_id
                  from xx_etw.xx_disl_cont_history_cur  chc
                 where 1=1
                   and place_type = 'railcar'
                   and place_id = p_round_id
               )
           and round_type = 'cont'  
           and last_record = 'Y' 
        ;
    end if;
    log_new(l_log_id,l_function,'r_invoice.inv_fact_date_to_load = '||r_invoice.inv_fact_date_to_load);
    
    /* Груз */
    r_inv_freight := NULL;

    r_inv_freight.front_end_id := r_invoice.front_end_id; --r_invoice.front_end_id;
    r_inv_freight.freight_line := 1; -- один груз

    if l_count_cont != 0 then  
        /*на случай когда платформа пришла без контейнеров*/
        begin         
            select min(ch.place_id) keep (dense_rank first order by in_date_sys)
              into l_round_for_freight
              from xx_etw.xx_disl_cont_history_cur  chc
                  ,xx_etw.xx_disl_cont_history      ch
                  ,xx_etw.xx_disl_round             dr -- add 26.02.2024 BekmansurovRR
             where 1=1
               and chc.place_type = 'railcar'
               and chc.place_id = p_round_id
               
               and dr.round_id = ch.place_id -- add 26.02.2024 BekmansurovRR добавил доп.связь, из-за того, чтоб была ситуация, что не было записи по round_id = 200362
               and chc.cont_round_id = ch.cont_round_id
               and ch.place_type = 'railcar';
        exception
            when others then l_round_for_freight := p_round_id;  
        end;
    else
        l_round_for_freight := p_round_id;
    end if;   
    
    select 
           case
             when freight_danger_sign_id = 2 and /*l_count_cont*/2 = 0 /*Опасный груз*/
             then 4 -- (4 - Тара на условиях опасного груза)
             when freight_danger_sign_id = 2 /*Опасный груз*/
             then 3 -- (3 - На условиях опасного груза)
             else 1 -- (1 -- Неопасный груз)
           end
          ,case 
             when freight_code = 723098 -- АЦЕТАЛЬДЕГИД (ЭТАНАЛЬ, АЛЬДЕГИД УКСУСНЫЙ)
             then -- 3408 -- rem 08.08.2024 BekmansurovRR
                  43 -- add 08.08.2024 BekmansurovRR
             when freight_code = 713045 -- КАПРОЛАКТАМ
             then 1521 
             when freight_code = 482146 -- НАТРИЯ ГИДРОКСИДА РАСТВОР едкий натр
             then 2050
             when freight_code = 391498-- КИСЛОТА МУРАВЬИНАЯ
             then 4806 -- add 18/10/2021
             when freight_code = 486166 -- САЖА БЕЛАЯ, АМОРФНЫЙ КРЕМНЕЗЕМ И ПРОЧИЕ КРЕМНЕКИСЛОТНЫЕ НАПОЛНИТЕЛИ
             then 486166 -- add 16/02/2022
           end 
           --- p.s freight_danger_id из таблицы etw_nsi_df_danger
          ,freight_accident_card_id
          
      into r_inv_freight.freight_danger_sign_id -- Аварийность груза (ID по НСИ - COMMON, тип 151)
          ,r_inv_freight.freight_danger_id -- Опасный груз
          ,r_inv_freight.freight_accident_card_id -- Аварийная карта (указывается номер или ID карты)
      from (
            select distinct
                   eif.freight_danger_sign_id
                  ,eif.freight_code
                  ,eif.freight_accident_card_id
              from etw_invoice      ei
                  ,etw_inv_freight  eif
             where 1=1
               and ei.front_end_id != 289558
               and ei.invoice_id in (
                    select invoice_id
                      from xx_disl_round_inv
                     where 1=1
                       and round_id = l_round_for_freight
               )
               and ei.front_end_id = eif.front_end_id   
           )
     where 1=1
    ;
    log_new(l_log_id,l_function,'r_inv_freight.freight_danger_id='||r_inv_freight.freight_danger_id);
    r_invoice.inv_dep_norm_doc_name :=  case when r_inv_freight.freight_danger_id = 
                                                        -- 3408/*Ацетальдегид*/  
                                                        43 /*Ацетальдегид*/   -- add 08.08.2024 BekmansurovRR
                                                    --then 'Техническим условиям размещения и крепления грузов в вагонах и контейнерах от 27.05.2003 № ЦМ ? 943'
                                                    then 'Техническим условиям размещения и крепления грузов в вагонах и контейнерах от 27.05.2003 № ЦМ - 943'
                                             when r_inv_freight.freight_danger_id = 2050/*НАТРИЯ ГИДРОКСИДА РАСТВОР едкий натр*/
                                                    --then 'Техническим условиям размещения и крепления грузов в вагонах и контейнерах от 27.05.2003 № ЦМ ? 943'
                                                    then 'Техническим условиям размещения и крепления грузов в вагонах и контейнерах от 27.05.2003 № ЦМ - 943'
                                             when r_inv_freight.freight_danger_id = 4806/*КИСЛОТА МУРАВЬИНАЯ*/  
                                                  then 'Техническим условиям размещения и крепления грузов в вагонах и контейнерах от 27.05.2003 № ЦМ - 943'      
                                             -- add 16.02.2022
                                             when r_inv_freight.freight_danger_id = 486166/*САЖА БЕЛАЯ*/  
                                                  then 'Техническим условиям размещения и крепления грузов в вагонах и контейнерах от 27.05.2003 № ЦМ - 943'      
                                             
                                             else 'Техническим условиям'
                                                  --'Местным техническим условиям'
                                       end;
    log_new(l_log_id,l_function,'r_invoice.inv_dep_norm_doc_name='||r_invoice.inv_dep_norm_doc_name);
    begin
        select id into r_invoice.inv_dep_norm_doc_id
          from xx_etw.etw_nsi_common
         where 1=1
               and paramid = 108
               and sysdate between nvl(recdatebegin,sysdate-1) and nvl(recdateend,sysdate+1)
               and name = r_invoice.inv_dep_norm_doc_name;
    exception when others then
        r_invoice.inv_dep_norm_doc_id:=2;
    end;
    etw_oi_pkg.get_nsi_common (151, r_inv_freight.freight_danger_sign_id, r_inv_freight.freight_danger_sign_name);    
    
    if r_inv_freight.freight_danger_id not in (486166) then
        etw_oi_pkg.get_nsi_df(r_inv_freight.freight_danger_id,
                              r_inv_freight.freight_danger_name,
                              r_inv_freight.freight_accident_card_id,
                              r_inv_freight.freight_accident_card);
    
    end if;
    
    log_new(l_log_id,l_function,'Груз №1');
 
    -- Точное наименование груза.
    select eco.otpr_freight_code
      into r_inv_freight.freight_code
      from etw_clm_otpr                 eco
     where 1=1
       and claim_id = r_invoice.inv_claim_id
       and otpr_nom = p_otpr_nom
    ;
    etw_oi_pkg.get_nsi_freight (r_inv_freight.freight_code, r_inv_freight.freight_name);
    r_inv_freight.freight_exact_name := r_inv_freight.freight_name;
    
    log_new(l_log_id,l_function,'Груз №2');
    
    r_inv_freight.freight_gng_code := case
                                        when l_count_cont = 0 
                                        then 99220000
                                        else null
                                      end;
    etw_oi_pkg.get_nsi_gng_freight_2001 (r_inv_freight.freight_gng_id, r_inv_freight.freight_gng_code, r_inv_freight.freight_gng_name);
    
    log_new(l_log_id,l_function,'Груз №3');
    
--    r_inv_freight.freight_additional := case
--                                          when l_count_cont = 0 
--                                          then 'Порожний вагон- цистерна.Цистерна полностью слита.Остаточное давление в котле 2.8 МПа.Информация о состоянии цистерны указана грузополучятелем в памятке приёмосдатчика.'
--                                          else 'Информация о состоянии контейнер-цистерне указана грузополучателем в памятке приёмосдатчика.Кантейнер-цистерна слита полностью.'
--                                        end;
    r_inv_freight.freight_additional := case
                                          
                                          when r_inv_freight.freight_danger_id = 
                                                    --3408/*Ацетальдегид*/ 
                                                    43 /*Ацетальдегид*/   -- add 08.08.2024 BekmansurovRR
                                                and l_count_cont = 0
                                          then 'Порожний вагон- цистерна.Цистерна полностью слита.Остаточное давление в котле 2.8 МПа.Информация о состоянии цистерны указана грузополучятелем в памятке приёмосдатчика.'
                                          -- rem 06/11/2019 Bekmansurovrr
                                          --when r_inv_freight.freight_danger_id = 3408 and l_count_cont != 0 /*Ацетальдегид*/ 
                                          --then 'Порожние контейнер-цистерны.Информация о состоянии контейнер-цистерн, указана грузополучателем в памятке приемосдатчика.Контейнер-цистерны слиты полностью, остаточное давление в котле 2,8МПа.'
                                          -- add 06/11/2019 Bekmansurovrr
                                          when r_inv_freight.freight_danger_id = --3408 
                                                                                 43 /*Ацетальдегид*/   -- add 08.08.2024 BekmansurovRR
                                                and l_count_cont != 0 /*Ацетальдегид*/ 
                                          then 'Порожние контейнер-цистерны. Контейнер-цистерны слиты полностью, остаточное давление в котле 2,8МПа.'
                                          when r_inv_freight.freight_danger_id = 1521/*Капролактам*/ then 'Порожние контейнер-цистерны. Информация о состоянии контейнер-цистерн (КЦ) указана грузополучателем в памятке приемосдатчика. Контейнер-цистерны слиты полностью.'
                                          -- rem 06/11/2019 Bekmansurovrr
                                          --when r_inv_freight.freight_danger_id = 2050/*НАТРИЯ ГИДРОКСИДА РАСТВОР едкий натр*/ 
                                          --then 'Порожние контейнер-цистерны. Информация о состоянии контейнер-цистерн (КЦ) указана грузополучателем в памятке приемосдатчика. Контейнер-цистерны слиты полностью.'
                                          -- add 06/11/2019 Bekmansurovrr
                                          when r_inv_freight.freight_danger_id = 2050/*НАТРИЯ ГИДРОКСИДА РАСТВОР едкий натр*/ 
                                          then 'Порожние контейнер-цистерны. Контейнер-цистерны слиты полностью.'
                                          -- add 16.02.2022 Bekmansurovrr
                                          when r_inv_freight.freight_danger_id = 486166  -- САЖА БЕЛАЯ
                                          then ''
                                          else 'МТУ №2776р, п.22, рис.18 от 29.12.2016г.' -- add KuchukbaevRF 21.01.2019 для продукта "Диоксид"
                                        end;
    
                                                    
    log_new(l_log_id,l_function,'Груз №3');
    -- Масса груза
    r_inv_freight.freight_weight := 0;

    insert into etw_inv_freight
    values r_inv_freight;  
    
    log_new(l_log_id,l_function,'r_inv_freight.freight_additional='||r_inv_freight.freight_additional);
    log_new(l_log_id,l_function,'r_inv_freight.freight_danger_id='||r_inv_freight.freight_danger_id);
    log_new(l_log_id,l_function,'l_count_cont='||l_count_cont);
    r_invoice.inv_dep_cond := case
--                                when r_inv_freight.freight_danger_id = 3408/*Ацетальдегид*/ and l_count_cont = 0
--                                then 'Порожний вагон- цистерна.Цистерна полностью слита.Остаточное давление в котле 2.8 МПа.Информация о состоянии цистерны указана грузополучятелем в памятке приёмосдатчика.'
--                                when r_inv_freight.freight_danger_id = 3408 and l_count_cont != 0
--                                then 'Порожние контейнер-цистерны.Информация о состоянии контейнер-цистерн, указана грузополучателем в памятке приемосдатчика.Контейнер-цистерны слиты полностью, остаточное давление в котле 2,8МПа.'
                                when (r_inv_freight.freight_danger_id = 43 /*Ацетальдегид*/   -- 3408/*Ацетальдегид*/  
                                        or r_inv_freight.freight_danger_id = 1521/*Капролактам*/ or r_inv_freight.freight_danger_id = 2050/*НАТРИЯ ГИДРОКСИДА РАСТВОР едкий натр*/ ) and l_count_cont = 2
                                then --'Гл.9, р.3, п.3.1., рис. 11 ТУ ЦМ 943 от 2003г. правильно.'
                                     'Гл.9, р.3, п.3.1., рис. 11 ТУ ЦМ 943 от 2003г. правильно.'
                                when (r_inv_freight.freight_danger_id = 43/*Ацетальдегид*/   -- 3408/*Ацетальдегид*/  
                                            or r_inv_freight.freight_danger_id = 1521/*Капролактам*/ or r_inv_freight.freight_danger_id = 2050/*НАТРИЯ ГИДРОКСИДА РАСТВОР едкий натр*/ ) and l_count_cont = 3
                                then 
                                      --'Гл.9, р.3, п.3.2., рис. 12 ТУ ЦМ 943 от 2003г. правильно.'
                                      'Глава 9, раздел 3, п. 3.2, рис.12 ТУ ЦМ 943 от 2003г. правильно.'
                                when r_inv_freight.freight_danger_id = 4806/*КИСЛОТА МУРАВЬИНАЯ*/ 
                                     then 'Гл.1 ТУ правильно, гл.12 п. 6, рис.8.: п.2.6 рис.1.'
                                -- add 16.02.2022 Bekmansurovrr
                                when r_inv_freight.freight_danger_id = 486166  -- САЖА БЕЛАЯ
                                then 'МТУ распоряжение ОАО "РЖД" от 24.12.2019 №184/р, пункт 4,2,1 рис 2'
                                
                                else ''
                              end;
    log_new(l_log_id,l_function,'r_invoice.inv_dep_cond='||r_invoice.inv_dep_cond);
    r_invoice.inv_additional_cond := r_invoice.inv_dep_cond;
    log_new(l_log_id,l_function,'Параграф');
    
    x_tbl_inv_paragraphs.delete; x_tbl_inv_pattern.delete;
    
    if r_invoice.inv_dep_cond = 'Гл.9, р.3, п.3.1., рис. 11 ТУ ЦМ 943 от 2003г. правильно.' then
       indx := x_tbl_inv_paragraphs.COUNT + 1;
       x_tbl_inv_paragraphs (indx).front_end_id := r_invoice.front_end_id;
       x_tbl_inv_paragraphs (indx).paragr_id := 6723; -- ГЛАВА 9/ПУНКТ 3.1;
       --
       indx := x_tbl_inv_pattern.COUNT + 1;
       x_tbl_inv_pattern (indx).front_end_id := r_invoice.front_end_id;
       x_tbl_inv_pattern (indx).pattern_type_id := 1; -- "1"=>"Рисунок";
       x_tbl_inv_pattern (indx).pattern_num := '11'; -- Рисунок № 11
       x_tbl_inv_pattern (indx).pattern_date := NULL;
       x_tbl_inv_pattern (indx).scetch_id := NULL;
    elsif r_invoice.inv_dep_cond = 'Глава 9, раздел 3, п. 3.2, рис.12 ТУ ЦМ 943 от 2003г. правильно.' then
       indx := x_tbl_inv_paragraphs.COUNT + 1;
       x_tbl_inv_paragraphs (indx).front_end_id := r_invoice.front_end_id;
       x_tbl_inv_paragraphs (indx).paragr_id := 6725; -- ГЛАВА 9/ПУНКТ 3.2;
       --
       indx := x_tbl_inv_pattern.COUNT + 1;
       x_tbl_inv_pattern (indx).front_end_id := r_invoice.front_end_id;
       x_tbl_inv_pattern (indx).pattern_type_id := 1; -- "1"=>"Рисунок";
       x_tbl_inv_pattern (indx).pattern_num := '12'; -- Рисунок № 12
       x_tbl_inv_pattern (indx).pattern_date := NULL;
       x_tbl_inv_pattern (indx).scetch_id := NULL;
    end if;
    
    -- НАКЛАДНАЯ: Параграфы/Пункты  (0..1)
    forall indx in x_tbl_inv_paragraphs.first .. x_tbl_inv_paragraphs.last
    insert into etw_inv_paragraphs
    values x_tbl_inv_paragraphs (indx);
    
    -- НАКЛАДНАЯ: Сведения о Рисунке/Эскизе  (0..1)
    forall indx in x_tbl_inv_pattern.first .. x_tbl_inv_pattern.last
    insert into etw_inv_pattern
    values x_tbl_inv_pattern (indx);
    
    
    
    -- add 27.12.2021 BekmasnurovRR
    if l_inv_depl_person is not null then
        r_invoice.inv_dep_cond:= r_invoice.inv_dep_cond || /*chr(10)*/ '  ' || 'Грузоотправитель: '||l_inv_depl_person;
    end if;
    
    /* Специальные отметки */
    x_tbl_inv_spc.delete;
    
    if (r_inv_freight.freight_danger_id = 43 --3408/*Ацетальдегид*/
        ) then
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 198; -- ["198"="Не спускать с горки"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
--        --
--        indx := x_tbl_inv_spc.COUNT + 1;
--        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
--        x_tbl_inv_spc (indx).spc_transp_clause_id := 228; -- ["228"="Прикрытие 3/1-1*-1-1"]
--        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
--        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
        -- заменил 19.03.2019
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 1328; -- ["1328"="Прикрытие 1-1-1"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
        --
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 9; -- ["9"="Легко воспламеняется"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
    end if;
    
    if (r_inv_freight.freight_danger_id = 1521/*Капролактам*/) then
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 249; -- ["249"="Прикрытие 3/0-0-1-0"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
        --
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 9; -- ["9"="Легко воспламеняется"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
    end if;
    
    if (r_inv_freight.freight_danger_id = 2050/*НАТРИЯ ГИДРОКСИДА РАСТВОР едкий натр*/) then
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 835; -- ["835"="Едкое"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
    end if;
    
    if (r_inv_freight.freight_danger_id = 4806/*КИСЛОТА МУРАВЬИНАЯ*/ ) then
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 835; -- ["835"="Едкое"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
        --
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 1326; -- ["9"="Прикрытие 0-0-1"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
    end if;
    
    if (r_invoice.inv_to_country_code != 643/*Россия*/) then
        indx := x_tbl_inv_spc.COUNT + 1;
        x_tbl_inv_spc (indx).front_end_id := r_invoice.front_end_id;
        x_tbl_inv_spc (indx).spc_transp_clause_id := 838; -- ["838"="Экспорт"]
        x_tbl_inv_spc (indx).spc_transp_clause_desc := etw_oi_pkg.fn_get_t_inv_transp_clause (x_tbl_inv_spc(indx).spc_transp_clause_id);
        x_tbl_inv_spc (indx).spc_custom_text := TO_CHAR (NULL);
    end if;
    
    -- Add 07.09.2023: контроль об обязательном указании отметок
    BEGIN             
       -- "Организатор погрузки", "Организатор выгрузки" на перевозку контейнеров
       IF r_invoice.inv_send_kind_id = 8               -- *!* "2"="Контейнерное"
       THEN
          etw_oi_pkg.spc_resp (row_invoice      => r_invoice,
                               xx_tbl_inv_spc   => x_tbl_inv_spc);
           null;
       END IF;
    END;
    -- EndAdd 07.09.2023 -----------------------------------------
    
    
    forall indx in x_tbl_inv_spc.first .. x_tbl_inv_spc.last
    insert into etw_inv_spc
    values x_tbl_inv_spc (indx);
    
    log_new(l_log_id,l_function,'Специальные отметки');
    
    /* ПИП документы */
    for v_inv_doc in (
        select 962                  doc_type_id -- [962 -> Другие прилагаемые документы]
              ,case
                 when l_count_cont = 0 
                 then 'дополнительная дорожная ведомость - 2 экземпляра' 
                 else 'Опись контейнеров.'
               end
                                    doc_number
          from dual)
    loop
        r_inv_doc := null;
        r_inv_doc.front_end_id := r_invoice.front_end_id;
        r_inv_doc.doc_type_id := v_inv_doc.doc_type_id;
        r_inv_doc.doc_number := v_inv_doc.doc_number;

        insert into etw_inv_doc
        values r_inv_doc;
    end loop;
    
    log_new(l_log_id,l_function,'ПИП документы');
    
    /* Контейнеры */
    for l_cont in (
        select cr.cont_round_id
              ,cr.cont_number
              ,rownum               rn   
          from xx_etw.xx_disl_cont_history_cur  chc
              ,xx_etw.xx_disl_cont_round        cr
         where 1=1
           and place_type = 'railcar'
           and place_id = p_round_id
           and chc.cont_round_id = cr.cont_round_id)
    loop
        r_inv_cont := null;
        r_inv_cont.front_end_id := r_invoice.front_end_id;
        
        r_inv_cont.cont_line := l_cont.rn;
        r_inv_cont.cont_number := l_cont.cont_number;
        
        begin 
            select cont_tonnage_id
                  ,cont_tonnage
                  ,cont_type_big
                  ,cont_type_big_name
                  ,cont_size_big
                  ,cont_width_foot
                  ,cont_weight_dep
                  ,cont_places_count
                  ,cont_weight_dep -- CONT_WEIGHT_GROSS
                  ,0 -- CONT_WEIGHT_NET
                  ,cont_owner_country_code
                  ,cont_owner_country_name
                  ,cont_owner_type_id
                  ,cont_owner_type_name
                  ,cont_owner_id
                  ,cont_owner_okpo
                  ,cont_owner_name
                  ,cont_tonnage
                  ,cont_size_big
                  ,cont_owner_type_id
                  ,cont_owner_type_name
                  ,l_count_cont
              into r_inv_cont.cont_tonnage_id
                  ,r_inv_cont.cont_tonnage
                  ,r_inv_cont.cont_type_big
                  ,r_inv_cont.cont_type_big_name
                  ,r_inv_cont.cont_size_big
                  ,r_inv_cont.cont_width_foot
                  ,r_inv_cont.cont_weight_dep
                  ,r_inv_cont.cont_places_count
                  ,r_inv_cont.cont_weight_gross
                  ,r_inv_cont.cont_weight_net
                  ,r_inv_cont.cont_owner_country_code
                  ,r_inv_cont.cont_owner_country_name
                  ,r_inv_cont.cont_owner_type_id
                  ,r_inv_cont.cont_owner_type_name
                  ,r_inv_cont.cont_owner_id
                  ,r_inv_cont.cont_owner_okpo
                  ,r_inv_cont.cont_owner_name
                  ,r_invoice.inv_plan_cont_tonnage
                  ,r_invoice.inv_cont_plan_size_big
                  ,r_invoice.inv_plan_cont_owner_type_id
                  ,r_invoice.inv_plan_cont_owner_type_name
                  ,r_invoice.inv_plan_cont_count
              from etw_inv_cont
             where 1=1
               and cont_number = r_inv_cont.cont_number
               and front_end_id = (
                    select max(ei.front_end_id)
                      from etw_inv_cont eic
                          ,etw_invoice  ei
                     where 1=1
                       and eic.cont_number = r_inv_cont.cont_number
                       and eic.front_end_id = ei.front_end_id
                       and ei.inv_from_station_code = '768207' -- Углеуральская
               )
            ;
        exception
            when no_data_found then 
                select cont_tonnage_id
                      ,cont_tonnage
                      ,cont_type_big
                      ,cont_type_big_name
                      ,cont_size_big
                      ,cont_width_foot
                      ,cont_weight_dep
                      ,cont_places_count
                      ,cont_weight_dep -- CONT_WEIGHT_GROSS
                      ,0 -- CONT_WEIGHT_NET
                      ,cont_owner_country_code
                      ,cont_owner_country_name
                      ,cont_owner_type_id
                      ,cont_owner_type_name
                      ,cont_owner_id
                      ,cont_owner_okpo
                      ,cont_owner_name
                      ,cont_tonnage
                      ,cont_size_big
                      ,cont_owner_type_id
                      ,cont_owner_type_name
                      ,l_count_cont
                  into r_inv_cont.cont_tonnage_id
                      ,r_inv_cont.cont_tonnage
                      ,r_inv_cont.cont_type_big
                      ,r_inv_cont.cont_type_big_name
                      ,r_inv_cont.cont_size_big
                      ,r_inv_cont.cont_width_foot
                      ,r_inv_cont.cont_weight_dep
                      ,r_inv_cont.cont_places_count
                      ,r_inv_cont.cont_weight_gross
                      ,r_inv_cont.cont_weight_net
                      ,r_inv_cont.cont_owner_country_code
                      ,r_inv_cont.cont_owner_country_name
                      ,r_inv_cont.cont_owner_type_id
                      ,r_inv_cont.cont_owner_type_name
                      ,r_inv_cont.cont_owner_id
                      ,r_inv_cont.cont_owner_okpo
                      ,r_inv_cont.cont_owner_name
                      ,r_invoice.inv_plan_cont_tonnage
                      ,r_invoice.inv_cont_plan_size_big
                      ,r_invoice.inv_plan_cont_owner_type_id
                      ,r_invoice.inv_plan_cont_owner_type_name
                      ,r_invoice.inv_plan_cont_count
                  from etw_inv_cont
                 where 1=1
                   and cont_number = r_inv_cont.cont_number
                   and front_end_id = (
                        select max(ei.front_end_id)
                          from etw_inv_cont eic
                              ,etw_invoice  ei
                         where 1=1
                           and eic.cont_number = r_inv_cont.cont_number
                           and eic.front_end_id = ei.front_end_id
                           and ei.inv_to_station_code = '768207' -- Углеуральская
                   )
                ;
        end;
        
        begin
            select cont_tonnage
              into r_invoice.inv_plan_cont_tonnage
              from etw_inv_cont
             where 1=1
               and cont_number = r_inv_cont.cont_number
               and front_end_id = (
                    select max(ei.front_end_id)
                      from etw_inv_cont eic
                          ,etw_invoice  ei
                     where 1=1
                       and eic.cont_number = r_inv_cont.cont_number
                       and eic.front_end_id = ei.front_end_id
                       and ei.inv_from_station_code = '768207' -- Углеуральская
                       and ei.front_end_id != r_invoice.front_end_id
               )
            ;
        exception
            when no_data_found then
                select cont_tonnage
                  into r_invoice.inv_plan_cont_tonnage
                  from etw_inv_cont
                 where 1=1
                   and cont_number = r_inv_cont.cont_number
                   and front_end_id = (
                        select max(ei.front_end_id)
                          from etw_inv_cont eic
                              ,etw_invoice  ei
                         where 1=1
                           and eic.cont_number = r_inv_cont.cont_number
                           and eic.front_end_id = ei.front_end_id
                           and ei.inv_to_station_code = '768207' -- Углеуральская
                   )
                ;
        end;
        
        l_cont_weight := l_cont_weight + r_inv_cont.cont_weight_gross;
        
        insert into etw_inv_cont
        values r_inv_cont;
    end loop;
    
    log_new(l_log_id,l_function,'Контейнеры');
    
    /* Вагоны*/
    r_inv_car := NULL;
    r_inv_car.front_end_id := r_invoice.front_end_id;

    r_inv_car.car_number := l_car_number;

    r_inv_car.car_order := 1;

      -- 20.05.2013 Ищем в нашем справочнике
    BEGIN
        select car_type_id,
               car_type_code,
               car_type_name,
               car_axles,
               car_owner_country_code,
               car_owner_country_name,
               car_owner_type_id,
               car_owner_type_name,
               car_owner_id,
               car_owner_okpo,
               car_owner_name,
               car_tonnage,
               car_weight_dep,
               car_tank_type,
               car_volume,
               
               car_tenant_id,
               car_tenant_okpo,
               car_tenant_name,
               
               car_type_id
          INTO r_inv_car.car_type_id,
               r_inv_car.car_type_code,
               r_inv_car.car_type_name,
               r_inv_car.car_axles,
               r_inv_car.car_owner_country_code,
               r_inv_car.car_owner_country_name,
               r_inv_car.car_owner_type_id,
               r_inv_car.car_owner_type_name,
               r_inv_car.car_owner_id,
               r_inv_car.car_owner_okpo,
               r_inv_car.car_owner_name,
               r_inv_car.car_tonnage,
               r_inv_car.car_weight_dep,
               r_inv_car.car_tank_type,
               --r_inv_car.car_volume
               r_inv_car.car_liquid_volume,
               
               r_inv_car.car_tenant_id,
               r_inv_car.car_tenant_okpo,
               r_inv_car.car_tenant_name,

               r_invoice.inv_plan_car_type_id
          from xx_etw.etw_invoice   ei
              ,xx_etw.etw_inv_car   ecar
         where 1=1
           and ei.invoice_id in (
               select invoice_id
                 from xx_etw.xx_disl_round_inv
                where 1=1
                  and round_id = p_round_id
           )
           and ei.front_end_id = ecar.front_end_id
           and ecar.car_number = r_inv_car.car_number
        ;
        log_new(l_log_id,l_function,'Данные НСИ вагонов из ETW_INV_CAR');     
    
    EXCEPTION
        WHEN OTHERS
        THEN
            begin
             SELECT   car_type_id,
                      car_type_code,
                      car_type_name,
                      car_axles,
                      car_owner_country_code,
                      car_owner_country_name,
                      car_owner_type_id,
                      car_owner_type_name,
                      car_owner_id,
                      car_owner_okpo,
                      car_owner_name,
                      car_tonnage,
                      car_weight_dep,
                      car_tank_type,
                      car_volume,
                      car_type_id
               INTO   r_inv_car.car_type_id,
                      r_inv_car.car_type_code,
                      r_inv_car.car_type_name,
                      r_inv_car.car_axles,
                      r_inv_car.car_owner_country_code,
                      r_inv_car.car_owner_country_name,
                      r_inv_car.car_owner_type_id,
                      r_inv_car.car_owner_type_name,
                      r_inv_car.car_owner_id,
                      r_inv_car.car_owner_okpo,
                      r_inv_car.car_owner_name,
                      r_inv_car.car_tonnage,
                      r_inv_car.car_weight_dep,
                      r_inv_car.car_tank_type,
                      --r_inv_car.car_volume
                      r_inv_car.car_liquid_volume,
                      r_invoice.inv_plan_car_type_id
               FROM   xx_etw.etw_car_nsi
              WHERE   car_number = r_inv_car.car_number
                      and (trunc(car_next_repair) - trunc(sysdate)) < 40; -- change KuchukbaevRF 30.11.2018
                      --AND TRUNC (CURRENT_DATE) - TRUNC (xx_last_update_date) <= 3;
            
            log_new(l_log_id,l_function,'Данные НСИ вагонов из ETW_CAR_NSI');   
            exception
                when others
                then
                    log_new(l_log_id,l_function,'Данные НСИ: ' || sqlerrm);
                    
                    declare
                        rec_etw_car_nsi     etw_car_nsi%rowtype;
                    begin
                        rec_etw_car_nsi := xx_etw.etw_car_nsi_pkg.get_car_nsi (p_car_number => r_inv_car.car_number, p_nsi_date => sysdate/*v_car.come_date*/);
                        
                        if (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'S') then
                            r_inv_car.car_type_id := rec_etw_car_nsi.car_type_id;
                            r_inv_car.car_type_code := rec_etw_car_nsi.car_type_code;
                            r_inv_car.car_type_name := rec_etw_car_nsi.car_type_name;
                            r_inv_car.car_axles := rec_etw_car_nsi.car_axles;
                            r_inv_car.car_owner_country_code := rec_etw_car_nsi.car_owner_country_code;
                            r_inv_car.car_owner_country_name := rec_etw_car_nsi.car_owner_country_name;
                            r_inv_car.car_owner_type_id := rec_etw_car_nsi.car_owner_type_id;
                            r_inv_car.car_owner_type_name := rec_etw_car_nsi.car_owner_type_name;
                            r_inv_car.car_owner_id := rec_etw_car_nsi.car_owner_id;
                            r_inv_car.car_owner_okpo := rec_etw_car_nsi.car_owner_okpo;
                            r_inv_car.car_owner_name := rec_etw_car_nsi.car_owner_name;
                            r_inv_car.car_tonnage := rec_etw_car_nsi.car_tonnage;
                            r_inv_car.car_weight_dep := rec_etw_car_nsi.car_weight_dep;
                            r_inv_car.car_tank_type := rec_etw_car_nsi.car_tank_type;
                            r_inv_car.car_liquid_volume := rec_etw_car_nsi.car_volume;
                            r_invoice.inv_plan_car_type_id := rec_etw_car_nsi.car_type_id;
                             
                            log_new(l_log_id,l_function,'Данные НСИ вагонов из ЭТРАН');
                        elsif (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'E') then
                            log_new(l_log_id,l_function,'Данные НСИ вагонов EXCEPTION'|| ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10));
                            --l_error := l_error || ' ' || v_car.car_number || ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10);  
                        elsif (xx_etw.etw_car_nsi_pkg.get_car_nsi_status = 'U') then
                            log_new(l_log_id,l_function,'Данные НСИ вагонов EXCEPTION'|| ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10));
                            --l_error := l_error || ' ' || v_car.car_number || ': ' ||xx_etw.etw_car_nsi_pkg.get_car_nsi_message||chr(10);
                        end if; 
                    end;
--                    BEGIN
--                       SELECT   car_type_id,
--                                car_type_code,
--                                car_type_name,
--                                car_axles,
--                                car_owner_country_code,
--                                car_owner_country_name,
--                                car_owner_type_id,
--                                car_owner_type_name,
--                                car_owner_id,
--                                car_owner_okpo,
--                                car_owner_name,
--                                car_tonnage,
--                                car_weight_dep,
--                                car_tank_type,
--                                car_volume,
--                                car_type_id
--                         -- *!* car_arendator_id,
--                         -- *!* car_arendator_okpo,
--                         -- *!* car_arendator_name
--                         -- *!* car_tonnage_nsi,
--                         -- *!* car_weight_dep_nsi
--                         INTO -- ETW_INV_CAR
--                             r_inv_car.car_type_id,
--                                r_inv_car.car_type_code,
--                                r_inv_car.car_type_name,
--                                r_inv_car.car_axles,
--                                r_inv_car.car_owner_country_code,
--                                r_inv_car.car_owner_country_name,
--                                r_inv_car.car_owner_type_id,
--                                r_inv_car.car_owner_type_name,
--                                r_inv_car.car_owner_id,
--                                r_inv_car.car_owner_okpo,
--                                r_inv_car.car_owner_name,
--                                r_inv_car.car_tonnage,
--                                r_inv_car.car_weight_dep,
--                                r_inv_car.car_tank_type,
--                                --r_inv_car.car_volume
--                                r_inv_car.car_liquid_volume,
--                                r_invoice.inv_plan_car_type_id
--                         FROM   table (xx_etw.etw_car_nsi_pkg.get_car_nsi_pipe (r_inv_car.car_number,
--                                                                                'N',
--                                                                                'N',
--                                                                                'Y'));

--                        log_new(l_log_id,l_function,'Данные НСИ вагонов из ЭТРАН');  
--                        apps.fnd_file.put_line (apps.fnd_file.LOG, 'Данные НСИ вагонов из ЭТРАН');
--                    EXCEPTION
--                       WHEN OTHERS
--                       THEN
--                          log_new(l_log_id,l_function,'Данные НСИ вагонов EXCEPTION'); 
--                    END;
           end;
    END;
    
    etw_oi_pkg.get_nsi_wag_type (r_invoice.inv_plan_car_type_id, r_invoice.inv_plan_car_type_code, r_invoice.inv_plan_car_type_name);
    
    r_inv_car.car_weight_net := l_cont_weight;
    r_inv_car.car_weight_gross := r_inv_car.car_weight_dep*100 + r_inv_car.car_weight_net;
    
    insert into etw_inv_car
    values r_inv_car;  
    
    log_new(l_log_id,l_function,'Вагоны');    
    
    /* ЗПУ */
    if (p_cont_csl is not null) then
        for l_csl in (
            select regexp_substr(p_cont_csl,'[^$]+',1,level) txt
              from dual
           connect by level <= regexp_count(p_cont_csl,'[^$]+')    
        )
        loop
            r_inv_cont_csl := null;
            r_inv_cont_csl.front_end_id := r_invoice.front_end_id;
            
            l_cont_number := get_substr(l_csl.txt,'|',1);
            
            select cont_line
              into r_inv_cont_csl.cont_line
              from etw_inv_cont
             where 1=1
               and front_end_id = r_inv_cont_csl.front_end_id
               and cont_number = l_cont_number
            ;
            
            r_inv_cont_csl.seal_type_id := get_substr(l_csl.txt,'|',2);
            if (r_inv_cont_csl.seal_type_id is not null) then
                select name
                  into r_inv_cont_csl.seal_type_name
                  from xx_etw.etw_nsi_inv_seal_type
                 where 1=1
                   and seal_type = r_inv_cont_csl.seal_type_id
                   and sysdate between nvl(recdatebegin,sysdate-1) and nvl(recdateend,sysdate+1)   
                ;
            end if;
            
            r_inv_cont_csl.seal_marks := get_substr(l_csl.txt,'|',3);
            
            r_inv_cont_csl.seal_quantity := get_substr(l_csl.txt,'|',4);
            
            r_inv_cont_csl.seal_year := get_substr(l_csl.txt,'|',5);
            
            r_inv_cont_csl.seal_owner_type_id := get_substr(l_csl.txt,'|',6);
            if (r_inv_cont_csl.seal_owner_type_id is not null) then
                select name
                  into r_inv_cont_csl.seal_owner_type_name
                  from xx_etw.etw_nsi_common
                 where 1=1
                   and id = r_inv_cont_csl.seal_owner_type_id
                   and paramid = 150
                   and sysdate between nvl(recdatebegin,sysdate-1) and nvl(recdateend,sysdate+1)
                ;
            end if;
            
            insert into etw_inv_cont_csl
            values r_inv_cont_csl;
        end loop;
    end if;

    log_new(l_log_id,l_function,'ЗПУ');
        
    insert into xx_etw.etw_invoice
    values r_invoice;
    
    if (l_front_end_id is null) then
        insert into xx_etw.xx_disl_round_invoice_out
        values(
            p_round_id,
            r_invoice.front_end_id,
            sysdate,
            p_user_id,
            null,
            null   
        );
    end if;

    commit;
    log_new(l_log_id,l_function,'r_invoice.front_end_id='||r_invoice.front_end_id);
    return 'done'||'|'||to_char(r_invoice.front_end_id);
exception
    when others then rollback; log_new(l_log_id,l_function,'ERROR ='||sqlerrm); return 'fail';
end;

function send_invoice_to_etran(p_user_id number, p_car_number varchar2)
return varchar2
as
    l_function          varchar2(100):='send_invoice_to_etran';
    l_log_id            number := xx_etw.xx_disl_log_seq.nextval();

    l_rec_error         etw_common_pkg.rec_error_type;
    l_front_end_id      number;
    
    r_invoice           xx_etw.etw_invoice%rowtype; 
    
    l_res               varchar2(1000);
--    x_use_calc_graph_pod   CHAR (1);
    
    e_no_communication  exception;
begin
    EXECUTE IMMEDIATE 'alter session set nls_date_format = ''dd.mm.yyyy hh24:mi:ss''';
    
    log_new(l_log_id,l_function,'p_user_id = '||p_user_id
                              ||'p_car_number = '||p_car_number);

    l_front_end_id := get_front_end_id(p_car_number);
    log_new(l_log_id,l_function,'l_front_end_id = '||l_front_end_id);
    
    if (l_front_end_id is not null) then
--        x_use_calc_graph_pod := TO_CHAR (NULL);
        etw_invoice_pkg.invoice_direct_load (p_front_end_id          => l_front_end_id,
                                             p_use_mod11             => true,
                                             --p_use_car_nsi           => null,
                                             --p_use_cont_nsi          => false,
                                             --p_use_primary_car_nsi   => false,
                                             --p_not_state             => false,
                                             --p_use_valid             => false,
                                             p_use_warning           => true,
                                             p_use_calc_graph_pod    => 'noError',
                                             rec_error               => l_rec_error);
--        etw_invoice_pkg.invoice_direct_load (p_front_end_id          => l_front_end_id,
--                                             p_use_mod11             => TRUE,
--                                             p_use_car_nsi           => 1,
--                                             p_use_cont_nsi          => FALSE,
--                                             p_use_primary_car_nsi   => FALSE,
--                                             p_not_state             => FALSE,
--                                             p_use_valid             => FALSE,
--                                             p_use_warning           => TRUE,
--                                             p_use_calc_graph_pod    => x_use_calc_graph_pod,
--                                             rec_error               => l_rec_error);
    else
        return 'fail|Нет накладной в OEBS';   
    end if;   
    
    if etw_common_pkg.test_connection is null then
        raise e_no_communication;
    end if;
    
    begin
        select   invoice_id,
                 inv_number,
                 invoice_state,
                 inv_claim_number,
                 inv_otpr_num,
                 inv_pod_num,
                 warning
          into   r_invoice.invoice_id,
                 r_invoice.inv_number,
                 r_invoice.invoice_state,
                 r_invoice.inv_claim_number,
                 r_invoice.inv_otpr_num,
                 r_invoice.inv_pod_num,
                 r_invoice.warning
          from   etw_invoice
         where   front_end_id = l_front_end_id;
    exception
        when no_data_found then r_invoice.invoice_id := null;
    end;
                                                   
    if l_rec_error.error_flag = 'Y' then
        l_res := 'fail|'||substr ('[' || l_rec_error.error_place || '] ' || l_rec_error.error_message, 1, 200);
        
        rollback;
    
        return l_res;
    else
        l_res := 'done|';
        if r_invoice.warning is not null then
            l_res:= l_res || substr (r_invoice.warning, 1, 200);
        end if;
        
        commit;
    
        return l_res;
    end if;
exception
    when e_no_communication
    then
        rollback;
        return 'fail|Нет связи с АСУ ЭТРАН';
    when others 
    then 
        rollback; 
        return 'fail';    
end;

function get_claim(p_car_number varchar2)
return varchar2
as
    l_round_id      number;
    l_claim_number  xx_etw.xx_disl_round_claim_link.claim_number%type;    
begin
    select round_id
      into l_round_id
      from xx_etw.xx_disl_round
     where 1=1
       and railcar_id = p_car_number 
       and station_hist_id_out is null
    ;
    
    select claim_number
      into l_claim_number
      from xx_etw.xx_disl_round_claim_link
     where 1=1
       and round_id = l_round_id 
       and date_end is null
    ; 
    
    return l_claim_number;   
exception
    when others then return null;
end;

function get_claim_info(p_car_number varchar2)
return t_xx_claim_info_table pipelined
as
    l_round_id  number;
    l_claim_num xx_etw.etw_clm.claim_number%type;
    l_row       t_xx_claim_info_row;   
begin
    select round_id
      into l_round_id
      from xx_etw.xx_disl_round
     where 1=1
       and railcar_id = p_car_number 
       and station_hist_id_out is null
    ;
    dbms_output.put_line('l_round_id = '||l_round_id);
    
    l_claim_num := xx_dislocation.get_claim(p_car_number);
    dbms_output.put_line('l_claim_num = '||l_claim_num);
     
    begin
        if (l_claim_num is not null) then
            dbms_output.put_line('enter loop');
            select graph
                  ,recip_address_id
                  ,recip_telefon
                  ,depl_person
                  ,otpr_nom
                  ,graph_add
              into l_row.graph
                  ,l_row.recip_address_id
                  ,l_row.recip_telefon
                  ,l_row.depl_person
                  ,l_row.otpr_nom
                  ,l_row.graph_add
              from xx_etw.xx_disl_round_claim_info
             where 1=1
               and round_id = l_round_id
            ;
            pipe row (l_row); 
        end if;
    exception
        when no_data_found then null;
    end;  
exception
    when others then null;
end;

function get_inv_cont_csl(p_front_end_id varchar2)
return t_xx_cont_csl_table pipelined
as
    l_round_id  number;
    l_row       t_xx_cont_csl_row;   
begin
    for l_loop in (    
        select cont_number     
              ,seal_type_id     
              ,seal_marks         
              ,seal_quantity    
              ,seal_year          
              ,seal_owner_type_id  
          from xx_etw.etw_inv_cont_csl  eicc
              ,xx_etw.etw_inv_cont      eic
         where 1=1
           and eicc.front_end_id = p_front_end_id
           
           and eicc.front_end_id = eic.front_end_id
           and eicc.cont_line = eic.cont_line
    )
    loop
        l_row.cont_number := l_loop.cont_number;    
        l_row.seal_type_id := l_loop.seal_type_id;   
        l_row.seal_marks := l_loop.seal_marks;         
        l_row.seal_quantity := l_loop.seal_quantity;    
        l_row.seal_year := l_loop.seal_year;          
        l_row.seal_owner_type_id := l_loop.seal_owner_type_id;   
    
        pipe row (l_row);
    end loop;     
end;

function get_front_end_id(p_car_number varchar2)
return number
as
    l_round_id          number;
    l_front_end_id      number; 
begin
    select round_id
      into l_round_id
      from xx_etw.xx_disl_round
     where 1=1
       and railcar_id = p_car_number 
       and station_hist_id_out is null
    ;
    
    begin
        select front_end_id
          into l_front_end_id
          from xx_disl_round_invoice_out
         where 1=1
           and round_id = l_round_id
           and closed_date is null
        ;
    exception
        when no_data_found then l_front_end_id := null;
    end;
    
    return l_front_end_id;   
exception
    when others then return '';
end;

function get_send_inv_number(p_car_number varchar2)
return number
as
    l_inv_number    xx_etw.etw_invoice.inv_number%type; 
begin
    select ei.inv_number
      into l_inv_number
      from xx_etw.xx_disl_round     r
          ,xx_etw.etw_invoice       ei
     where 1=1
       and railcar_id = p_car_number 
       and station_hist_id_out is null
       
       and r.front_end_id_out = ei.front_end_id(+)
    ;
    
    return l_inv_number;   
exception
    when others then return '';
end;

function get_depl_person
return t_xx_id_name_table pipelined
as
    l_row   t_xx_id_name_row;  
begin    
    for l_lp in (    
        select flex_value_id
              ,description
          from apps.fnd_flex_values_vl
         where 1=1
           and flex_value_set_id = 1006217 /*Ответственный за прав/погрузки*/
           and enabled_flag = 'Y'
           and sysdate between nvl(start_date_active,sysdate-1) and nvl(end_date_active,sysdate+1)
         order by
               --description
               substr(description,instr(description,' ',-2,3))
    )
    loop
        l_row.id := l_lp.flex_value_id;
        l_row.name := l_lp.description;   
        
        pipe row (l_row);
    end loop;   
end;

function get_seal_types
return t_xx_id_name_table pipelined
as
    l_row   t_xx_id_name_row;  
begin    
    for l_lp in (    
        select seal_type
              ,name
          from xx_etw.etw_nsi_inv_seal_type
         where 1=1
           and sysdate between nvl(recdatebegin,sysdate-1) and nvl(recdateend,sysdate+1)
        order by name
    ) 
    loop
        l_row.id := l_lp.seal_type;
        l_row.name := l_lp.name;   
        
        pipe row (l_row);
    end loop;   
end;

function get_seal_owner_types
return t_xx_id_name_table pipelined
as
    l_row   t_xx_id_name_row;  
begin    
    for l_lp in (    
        select id
              ,name
          from xx_etw.etw_nsi_common
         where 1=1
           and paramid = 150
           and sysdate between nvl(recdatebegin,sysdate-1) and nvl(recdateend,sysdate+1)
    ) 
    loop
        l_row.id := l_lp.id;
        l_row.name := l_lp.name;   
        
        pipe row (l_row);
    end loop;   
end;

function get_graph_pod(p_claim_number varchar2)
return t_xx_graph_pod_table pipelined
as
    l_claim_id      number;  
    l_row           t_xx_graph_pod_row;  
begin
    select claim_id
      into l_claim_id
      from xx_etw.etw_clm   ec
     where 1=1
       and claim_number = p_claim_number
       and claim_id in (
            select max(ec3.claim_id) --ищем последнюю версию заявки
              from xx_etw.etw_clm ec3
             where 1=1 
               and ec3.claim_number = ec.claim_number
               and ec3.claim_state_id in (70,71,72) --статусы только согласование
       )
    ;  
    
    for l_lp in (    
        select rowidtochar(rowid)                                                       row_id
              ,to_char(gp_pod_date,'dd.mm.yyyy')||'-'||gp_weight||'-'||gp_car_count     descr
              ,otpr_nom||'-'||gp_pod_num||'-'||to_char(gp_pod_date,'dd.mm.yyyy')        add_descr
          from etw_clm_otpr_graph_pod
         where 1=1
           and claim_id = l_claim_id
         order by
               gp_pod_date) 
    loop
        l_row.row_id := l_lp.row_id;
        l_row.descr := l_lp.descr;   
        l_row.add_descr := l_lp.add_descr;
        
        pipe row (l_row);
    end loop;   
end;

function get_claim_otpr(p_claim_number varchar2)
return t_xx_claim_otpr_table pipelined
as
    l_claim_id      number;  
    l_row           t_xx_claim_otpr_row;  
begin
    select claim_id
      into l_claim_id
      from xx_etw.etw_clm   ec
     where 1=1
       and claim_number = p_claim_number
       and claim_id in (
            select max(ec3.claim_id) --ищем последнюю версию заявки
              from xx_etw.etw_clm ec3
             where 1=1 
               and ec3.claim_number = ec.claim_number
               and ec3.claim_state_id in (70,71,72) --статусы только согласование
       )
    ;  
    dbms_output.put_line('l_claim_id = '||l_claim_id);
    
    for l_lp in (    
        select otpr_nom                                  otpr_nom
              ,otpr_nom||' - '||otpr_to_station_name     descr
              ,eco.otpr_car_count
              -(
                select count (ei1.invoice_id) car_cnt         --кол-во вагонов
                  from etw_clm_inv      eci1
                      ,etw_invoice      ei1
                 where 1=1
                   and eci1.claim_id = eco.claim_id
                   and eci1.inv_otpr_nom = eco.otpr_nom 
                 
                   and eci1.inv_id = ei1.invoice_id
                   and eci1.inv_state_id in (4, --'груз принят к перевозке',
                                             35,--'в пути',
                                             36,--'груз прибыл',
                                             44,--'работа с документом окончена',
                                             42,--'раскредитован'
                                             38,--'получатель извещен'
                                             31 --'Оформлено грузоотправителем'
                                            )
               )
                                free_car_count
          from etw_clm_otpr     eco
         where 1=1
           and eco.claim_id = l_claim_id) 
    loop
        l_row.otpr_nom := l_lp.otpr_nom;
        l_row.descr := l_lp.descr;   
        l_row.telefon := get_recip_telefon(l_claim_id,l_lp.otpr_nom);
        l_row.free_car_count := l_lp.free_car_count;   
        
        pipe row (l_row);
    end loop;   
end;

function get_recip_telefon(p_claim_id number,p_otpr_nom number)
return varchar2
as
    l_recip_telefon     varchar2(100);  
begin    
    select case
             when instr(inv_recip_address,'тел') != 0
             then regexp_replace(substr(inv_recip_address,instr(inv_recip_address,'тел')+3),'[:. ]','') 
             else ''
           end
      into l_recip_telefon
      from etw_invoice
     where 1=1
       and front_end_id = (
            select max(front_end_id)
              from etw_invoice
             where 1=1
               and invoice_id is not null
               and inv_recip_id = (
                    select otpr_recip_id
                      from etw_clm_otpr
                     where 1=1
                       and claim_id = p_claim_id
                       and otpr_nom = p_otpr_nom
               )
       ) 
    ;
    return l_recip_telefon;
exception
    when no_data_found then return '';    
end;

function get_recip_address(p_claim_number varchar2)
return t_xx_recip_address_table pipelined
as
    l_claim_id      number;  
    l_row           t_xx_recip_address_row;  
begin
    select claim_id
      into l_claim_id
      from xx_etw.etw_clm   ec
     where 1=1
       and claim_number = p_claim_number
       and claim_id in (
            select max(ec3.claim_id) --ищем последнюю версию заявки
              from xx_etw.etw_clm ec3
             where 1=1 
               and ec3.claim_number = ec.claim_number
               and ec3.claim_state_id in (70,71,72) --статусы только согласование
       )
    ;  
    
    for l_row in (    
        select ord_ad.address_id                    address_id
              ,address_tgnl||' - '||address_puzht   address
          from etw_clm_otpr                 eco
              ,etw_org_passport_address_v   ord_ad
         where 1=1
           and claim_id = l_claim_id
           and eco.otpr_recip_id = ord_ad.org_id) 
    loop
        l_row.address_id := l_row.address_id;
        l_row.address := l_row.address;   
        
        pipe row (l_row);
    end loop;   
end;

function get_suitable_claims(p_enter_text varchar2)
return t_xx_id_name_table pipelined
as
    l_row       t_xx_id_name_row; 
begin
    for l_cars in (
        select distinct claim_number
          from xx_etw.etw_clm
         where 1=1
           and claim_state_id in (70,71,72)
           and claim_number like p_enter_text||'%'
         order by
               claim_number
    ) loop
        l_row.name := l_cars.claim_number;
        
        pipe row (l_row);   
    end loop; 
end;

function enter_claim(p_user_id number, p_car_number varchar2,p_claim_number varchar2)
return varchar2
as
    l_function      varchar2(100):='enter_claim';
    l_log_id        number := xx_etw.xx_disl_log_seq.nextval();
    l_claim_count   number;
    l_round_id      number;   
    l_link_id_prev  number;
    l_link_id       number;
    l_clean_num     varchar2(20) := '0000000000'; /*вводим для очистки заявки. Если вводят данный номер то закрываем привязку предыдущей заявки, а новую не привязываем*/
begin
    log_new(l_log_id,l_function,'p_user_id = ' ||p_user_id||' p_car_number = ' ||p_car_number||' p_claim_number = ' ||p_claim_number);
     
    select count('x')
      into l_claim_count
      from xx_etw.etw_clm
     where 1=1
       and claim_number = p_claim_number
    ;
       
    if (l_claim_count = 0 and p_claim_number != l_clean_num) then
        return 'fail|Не существует заявки с таким номером в OEBS!';
    end if;
    
    select round_id
      into l_round_id
      from xx_etw.xx_disl_round
     where 1=1
       and railcar_id = p_car_number 
       and station_hist_id_out is null
    ;
    log_new(l_log_id,l_function,'l_round_id = ' ||l_round_id);
    
    begin
        select link_id
          into l_link_id_prev
          from xx_etw.xx_disl_round_claim_link   
         where 1=1
           and round_id = l_round_id
           and date_end is null
        ;  
    exception
        when no_data_found then l_link_id_prev:=null;
    end;
    log_new(l_log_id,l_function,'l_link_id_prev = ' ||l_link_id_prev);
    
    if (l_link_id_prev is not null) then
        update xx_etw.xx_disl_round_claim_link
           set date_end = sysdate
         where 1=1
           and link_id = l_link_id_prev
        ;
    end if;  
    
    if (p_claim_number != l_clean_num) then
        l_link_id := xx_etw.xx_disl_round_claim_link_seq.nextval();
        log_new(l_log_id,l_function,'l_link_id = ' ||l_link_id);
            
        insert into xx_etw.xx_disl_round_claim_link
        values(
            l_link_id,
            l_round_id,
            p_claim_number,
            sysdate,
            null,
            p_user_id        
        );
    end if; 
 
    commit;
    
    return 'done';
exception
    when others then rollback; 
    log_new(l_log_id,l_function,'Ошибка = ' ||sqlerrm);
    return 'fail|Ошибка:'||sqlerrm;
end;

