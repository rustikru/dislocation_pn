function get_rail_services
return t_xx_rail_services_table pipelined
as
    l_row       t_xx_rail_services_row;
begin
    for l_tmp in (select rs.id
                        ,rs.code
                        ,rs.descr
                        ,rs.descr_full
                        ,rs.service_rgd_id
                        ,rs_rgd.code    service_rgd
                        ,(select listagg(task_id, ',') within group (order by task_id)
                            from xx_etw.xx_disl_rail_services_tasks
                           where 1=1
                             and service_id = rs.id
                         )
                                    request_tasks_id
                        ,(select listagg(rt.descr, ', ') within group (order by rt.task_id)
                            from xx_etw.xx_disl_rail_services_tasks    rst
                                ,xx_etw.xx_disl_request_tasks          rt
                           where 1=1
                             and rst.service_id = rs.id
                             and rst.task_id = rt.task_id 
                         )
                                    request_tasks
                        ,to_char(rs.beg_date,'dd.mm.yyyy')              beg_date
                        ,to_char(rs.end_date,'dd.mm.yyyy')              end_date
                        ,u_cr.full_name                                 created_by
                        ,to_char(rs.created_date,'dd.mm.yyyy')          created_date
                        ,u_up.full_name                                 last_updated_by
                        ,to_char(rs.last_updated_date,'dd.mm.yyyy')     last_updated_date
                        ,case
                           when sysdate between nvl(rs.beg_date,sysdate-1) and nvl(rs.end_date,sysdate+1)
                           then 'Y'
                           else 'N'
                         end
                                                                        opened
                    from xx_etw.xx_disl_rail_services       rs
                        ,xx_etw.xx_disl_rail_services_rgd   rs_rgd
                        ,xx_etw.xx_disl_users               u_cr
                        ,xx_etw.xx_disl_users               u_up         
                   where 1=1
                     and rs.service_rgd_id = rs_rgd.id(+)
                     and rs.created_by = u_cr.id(+)
                     and rs.last_updated_by = u_up.id(+)
                 )
    loop
        l_row.id := l_tmp.id;
        l_row.code := l_tmp.code;
        l_row.descr := l_tmp.descr;
        l_row.descr_full := l_tmp.descr_full;
        l_row.service_rgd_id := l_tmp.service_rgd_id;
        l_row.service_rgd := l_tmp.service_rgd;
        l_row.request_tasks_id := l_tmp.request_tasks_id;
        l_row.request_tasks := l_tmp.request_tasks;
        l_row.beg_date := l_tmp.beg_date;
        l_row.end_date := l_tmp.end_date;
        l_row.created_by := l_tmp.created_by;
        l_row.created_date := l_tmp.created_date;
        l_row.last_updated_by := l_tmp.last_updated_by;
        l_row.last_updated_date := l_tmp.last_updated_date;
        l_row.opened := l_tmp.opened;
        
        pipe row (l_row);
    end loop;
end;

function save_rail_service(
    p_user_id           number,    
    p_id                number,
    p_code              varchar2,
    p_descr             varchar2,
    p_descr_full        varchar2,
    p_beg_date          date,
    p_end_date          date,
    p_service_rgd_id    number,
    p_request_tasks     varchar2
) return varchar2
as
    l_function              varchar2(50) := 'save_rail_service';
    l_log_id                number := xx_etw.xx_disl_log_seq.nextval();

    l_id        number;
    l_id_res    number;
begin
    log_new(l_log_id,l_function,'p_id = '||p_id||' p_code'||p_code||' p_descr = '||p_descr||' p_descr_full = '||p_descr_full||' p_service_rgd_id = '||p_service_rgd_id||' p_request_tasks = '||p_request_tasks);

    if (p_id is null) then
        insert into xx_etw.xx_disl_rail_services(
            id,
            code,
            descr,
            descr_full,
            beg_date,
            end_date,
            service_rgd_id,
            created_by,
            created_date
        )
        values(
            xx_etw.xx_disl_rail_services_seq.nextval,
            p_code,p_descr,
            p_descr_full,
            p_beg_date,
            p_end_date,
            p_service_rgd_id,
            p_user_id,
            sysdate
        )
        returning id into l_id_res;
        l_id := l_id_res;
    else
        update xx_etw.xx_disl_rail_services
           set code = p_code, 
               descr = p_descr,
               descr_full = p_descr_full,
               beg_date = p_beg_date,
               end_date = p_end_date,
               service_rgd_id = p_service_rgd_id,
               last_updated_by = p_user_id,
               last_updated_date = sysdate
         where 1=1
           and id = p_id
        ;
        l_id := p_id;
    end if;
    
    delete
      from xx_etw.xx_disl_rail_services_tasks
     where 1=1
       and service_id = l_id
    ;
    
    if (p_request_tasks is not null) then
        insert into xx_etw.xx_disl_rail_services_tasks
        select l_id
              ,regexp_substr(p_request_tasks,'[^,]+',1,level)
          from dual
       connect by
               level <= regexp_count(p_request_tasks,'[^,]+')
        ;
    end if;
    
    commit;
    return 'done'||'$'||to_char(l_id_res);   
exception
    when others then rollback; return 'fail';
end;

function del_rail_service(p_id number)
return varchar2
as
begin
    delete
      from xx_etw.xx_disl_rail_services
     where 1=1
       and id = p_id 
    ;
    commit;
    return 'done';
exception
    when others then rollback; return 'fail';
end;

