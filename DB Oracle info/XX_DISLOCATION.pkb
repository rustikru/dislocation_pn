function get_current_time 
return varchar2
as
begin
    return to_char(sysdate,'dd.mm.yyyy hh24:mi');
end;

function boolean_to_char(status in boolean)
return varchar2 
    is
begin
    return case status
             when true then 'true'
             when false then 'false'
           end;
end;

function get_railcar_type(p_round_id number)
return number /*0-вагон, 1-платформа*/
as
    l_tmp  number;
begin
    select count('x')
      into l_tmp
      from xx_etw.xx_disl_cont_history       ch
     where 1=1
       and ch.place_id = p_round_id   
       and ch.place_type = 'railcar'; 
    
    if (l_tmp != 0) then
        return 1;    
    else
        select max(1)
          into l_tmp 
          from xx_etw.xx_disl_railcar_add_info
         where 1=1
           and round_id = p_round_id
           and last_record = 'Y'
           and upper(car_type) like 'ПЛ%';
        if (l_tmp != 0) then
            return 1;
        else
            return 0;
        end if;
    end if;
exception
    when others then return 0;    
end;

function return_last_cont_round(p_cont_number   varchar2)
return number
as
    l_cont_round_id             number;
begin
    select cont_round_id
      into l_cont_round_id
      from xx_etw.xx_disl_cont_round
     where 1=1
       and cont_number = p_cont_number
       and cont_history_out is null
    ;
    return l_cont_round_id;
exception
    when others then return -1;
end;

function returnLastRound(p_railcar_id varchar2)
return number
is
    l_round number;
begin
    select round_id 
      into l_round
      from xx_etw.xx_disl_round 
     where railcar_id = p_railcar_id
       and station_hist_id_out is null
    ;
    return l_round;
exception
    when others then return -1;
end;

function returnDate_arrive (p_round_id number)
return date
is
    l_date_arrive date;
begin
    select date_arrive 
      into l_date_arrive
      from xx_etw.xx_disl_round 
     where round_id = p_round_id
    ;
    return l_date_arrive;
exception
    when others then return null;
end;


function get_railways_name (p_railway_id number) return varchar2
is
    l_return                xx_etw.xx_disl_railways.railway_number%type;
begin
     
  select railway_number
    into l_return
    from xx_etw.xx_disl_railways
   where 1=1
         and railway_id = p_railway_id;
    return l_return;
exception
    when no_data_found then return '';
end;


/*возвращает по номеру вагона текущий путь на котором стоит вагон*/
function get_railway_for_car(p_car_number varchar2, p_name number default 0)
return varchar2
as
    l_railway_id            number;
    l_return                xx_etw.xx_disl_railways.railway_number%type;
begin
      with in_station as (select *
                            from xx_etw.xx_disl_relations
                           where 1=1
                                 and flag_come = 'Y'                     
                         )
    select min(id) keep (dense_rank first order by level)
      into l_railway_id
      from in_station
     where 1=1
       and type = 'railway'
   connect by prior parent_id = id and prior parent_type = type
     start with id = p_car_number and type = 'railcar'
    ;
    
    if (p_name = 1) then
        select railway_number
          into l_return
          from xx_etw.xx_disl_railways
         where 1=1
           and railway_id = l_railway_id
        ;
    else
        l_return := to_char(l_railway_id);
    end if;

    return l_return;
exception
    when no_data_found then return '0';
end;


function get_stations_for_railway(p_railway varchar2, p_name number default 0)
return varchar2
as
    l_railway_id            varchar2(250);
    l_return                xx_disl_railways.railway_number%type;
begin
      with in_station as (select *
                            from xx_etw.xx_disl_relations
                           where 1=1
                                 and flag_come = 'Y'                     
                         )
    select min(parent_id) keep (dense_rank first order by level)
      into l_railway_id
      from in_station
     where 1=1
       and parent_type = 'station'
   connect by prior parent_id = id and prior parent_type = type
     start with id = p_railway and type = 'railway'
    ;
    if (p_name = 1) then
        select short_name
          into l_return
          from xx_etw.XX_DISL_STATIONS
         where 1=1
           and station_id = l_railway_id
        ;
    else
        l_return := to_char(l_railway_id);
    end if;
    

    return l_return;
exception
    when no_data_found then return '0';
end;

function get_train_drivers
return t_xx_train_drivers pipelined
as
    l_row xx_disl_train_drivers%rowtype;
begin
    for c_row in (select *
                    from xx_disl_train_drivers
                   where sysdate between beg_date and nvl(end_date,sysdate)
                   order by 
                         name
                 )
    loop
        l_row.id := c_row.id;
        l_row.name := c_row.name;        
        pipe row (l_row);
    end loop;
end;

function get_users_for_naliv
return t_xx_id_name_table pipelined
as
    l_row t_xx_id_name_row;
begin
    for c_row in (select u.id
                        ,u.full_name                name
                    from xx_etw.xx_disl_users              u
                   where 1=1
                     and u.enterprise in (2/*Метафракс*/,3/*Метадинея*/)
                     and nvl(u.OPEN,'Y') = 'Y' 
                   order by 
                         name
                 )
    loop
