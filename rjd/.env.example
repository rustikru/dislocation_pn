APP_ENV=development
# Логировать SQL-запросы в /tmp/sql_debug.log (true/false)
APP_DEBUG=false
APP_NAME=ПАО «Метафракс»

# Database driver: 'postgres' or 'oracle'
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=disl_rzd
# DB_USER=postgres
# DB_PASS=

DB_DRIVER=oracle
DB_HOST=127.0.0.1
DB_PORT=1521
DB_NAME=
DB_USER=
DB_PASS=

# Active Directory (LDAP)
# AD_ENABLED=true  → пробуем AD, при неудаче — локальный пароль
AD_ENABLED=false
AD_HOST=ldap://ad.company.local
AD_DOMAIN=company.local
AD_BASE_DN=DC=company,DC=local

SESSION_NAME=disl_session

# Базовый путь если приложение в подпапке (пример: /rjd/public)
# Оставьте пустым при использовании виртуального хоста
APP_BASE_PATH=
