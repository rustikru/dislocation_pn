APP_ENV=development
# Логировать SQL-запросы в /tmp/sql_debug.log (true/false)
APP_DEBUG=false
APP_NAME=АО Метафракс-Кемикалс

DB_DRIVER=oracle
DB_HOST=10.0.0.173
DB_PORT=51521
DB_NAME=PROD
DB_USER=xx_etw
DB_PASS=xx_etw

# Active Directory (LDAP)
# AD_ENABLED=true  → пробуем AD, при неудаче — локальный пароль
AD_ENABLED=false
AD_HOST=ldap://ad.company.local
AD_DOMAIN=company.local
AD_BASE_DN=DC=company,DC=local

SESSION_NAME=disl_session

# Базовый путь если приложение в подпапке (пример: /rjd/public)
APP_BASE_PATH=/rjd/public
