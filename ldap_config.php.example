<?php
/**
 * Скопировать в ldap_config.php и заполнить параметры AD/LDAP.
 * Без ldap_config.php или при enabled=false авторизация работает как раньше.
 */
return array(
    'enabled' => false,
    'debug' => false,
    'auth_log_file' => '/tmp/auth_debug.log',
    'log_file' => '/tmp/ldap_debug.log',

    // Можно указать один host или несколько hosts для резервирования.
    'host' => 'ldap://172.16.0.192:389',
    'hosts' => array(
        // 'ldap://172.16.0.192:389',
    ),
    'port' => 389,
    'use_ssl' => false,
    'start_tls' => false,
    'network_timeout' => 3,

    // Вариант 1: сервисный bind + поиск пользователя, затем bind найденного DN.
    'domain' => 'mf.metafrax.ru',
    'base_dn' => 'DC=mf,DC=metafrax,DC=ru',
    'bind_dn' => '',
    'bind_password' => '',
    'user_filter' => '(sAMAccountName={login})',

    // Вариант 2: прямой bind без сервисной учетной записи.
    // Используется только если bind_dn/bind_password пустые.
    'bind_formats' => array(
        '{login}@mf.metafrax.ru',
    ),
);
